@model MobileShopSystem.Models.User

@{
    ViewData["Title"] = "تعديل المستخدم";
    var username = Context.Session.GetString("Username");
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: #f4f6f9;
            margin: 0;
            padding: 20px;
            color: #333;
        }

        .page-wrapper {
            max-width: 600px;
            margin: 0 auto;
        }

        /* بطاقة العنوان */
        .header-card {
            background: white;
            border-radius: 16px;
            padding: 20px 25px;
            margin-bottom: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .header-title h1 {
            margin: 0;
            font-size: 26px;
            font-weight: 600;
            color: #3498db;
        }

        .header-title p {
            margin: 5px 0 0;
            color: #6c757d;
            font-size: 14px;
        }

        .user-info {
            background: #f8f9fa;
            color: #3498db;
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 500;
            border: 1px solid #e9ecef;
        }

            .user-info i {
                margin-left: 8px;
            }

        /* بطاقة التعديل */
        .edit-card {
            background: white;
            border-radius: 16px;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
        }

        .section-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
            color: #3498db;
            font-weight: 600;
            font-size: 18px;
            padding-bottom: 10px;
            border-bottom: 2px solid #f0f0f0;
        }

            .section-title i {
                font-size: 20px;
            }

        /* صورة المستخدم */
        .user-avatar {
            display: flex;
            align-items: center;
            gap: 15px;
            background: #f8f9fa;
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 20px;
        }

        .avatar-icon {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #3498db, #2980b9);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 30px;
        }

        .avatar-info h3 {
            margin: 0;
            color: #333;
            font-size: 18px;
        }

        .avatar-info p {
            margin: 5px 0 0;
            color: #6c757d;
            font-size: 13px;
        }

        /* حقول النموذج */
        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 8px;
            color: #3498db;
            font-weight: 500;
            font-size: 14px;
        }

            .form-label i {
                width: 20px;
            }

        .form-control {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e9ecef;
            border-radius: 10px;
            font-size: 14px;
            transition: all 0.3s;
            background: #f8f9fa;
            box-sizing: border-box;
        }

            .form-control:focus {
                outline: none;
                border-color: #3498db;
                background: white;
                box-shadow: 0 5px 20px rgba(52, 152, 219, 0.1);
            }

        /* بطاقة الحالة */
        .status-card {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 15px;
            margin: 20px 0;
            border-right: 3px solid #3498db;
        }

        .status-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px dashed #dee2e6;
        }

            .status-row:last-child {
                border-bottom: none;
            }

        .status-label {
            color: #6c757d;
            font-size: 13px;
        }

        .status-value {
            font-weight: 600;
            color: #333;
            font-size: 14px;
        }

        .online {
            color: #27ae60;
        }

        .offline {
            color: #95a5a6;
        }

        /* الأزرار */
        .btn {
            padding: 10px 20px;
            border-radius: 8px;
            color: #fff;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
            border: none;
            cursor: pointer;
            margin: 3px;
        }

            .btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            }

        .btn-save {
            background: linear-gradient(135deg, #2ecc71, #27ae60);
        }

        .btn-delete {
            background: linear-gradient(135deg, #e74c3c, #c0392b);
        }

        .btn-block {
            background: linear-gradient(135deg, #e67e22, #d35400);
        }

        .btn-unblock {
            background: linear-gradient(135deg, #27ae60, #2ecc71);
        }

        .btn-promote {
            background: linear-gradient(135deg, #3498db, #2980b9);
        }

        .btn-demote {
            background: linear-gradient(135deg, #9b59b6, #8e44ad);
        }

        .btn-back {
            background: linear-gradient(135deg, #7f8c8d, #6c757d);
        }

        .actions-group {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 25px;
            padding-top: 20px;
            border-top: 2px solid #f0f0f0;
        }

        /* رسالة تحذير */
        .warning-note {
            background: #fff3cd;
            color: #856404;
            padding: 12px;
            border-radius: 8px;
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
            border-right: 3px solid #ffc107;
        }

            .warning-note i {
                font-size: 16px;
            }

        /* شريط التبويب */
        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            border-bottom: 2px solid #f0f0f0;
            padding-bottom: 10px;
        }

        .tab {
            padding: 8px 20px;
            border-radius: 8px;
            color: #6c757d;
            cursor: pointer;
            transition: all 0.3s;
        }

            .tab.active {
                background: #3498db;
                color: white;
            }
    </style>
</head>
<body>
    <div class="page-wrapper">
        <!-- بطاقة العنوان -->
        <div class="header-card">
            <div class="header-title">
                <h1>
                    <i class="fas fa-user-edit"></i> تعديل بيانات المستخدم
                </h1>
                <p>تحديث معلومات وحساب المستخدم</p>
            </div>
            <div class="user-info">
                <i class="fas fa-user-circle"></i>
                @username
            </div>
        </div>

        <!-- بطاقة التعديل -->
        <div class="edit-card">
            <!-- صورة المستخدم -->
            <div class="user-avatar">
                <div class="avatar-icon">
                    <i class="fas fa-user"></i>
                </div>
                <div class="avatar-info">
                    <h3>@Model.Username</h3>
                    <p>@(Model.IsAdmin ? "مدير النظام" : "مستخدم عادي")</p>
                </div>
            </div>

            <!-- شريط التبويب -->
            <div class="tabs">
                <span class="tab active">المعلومات الأساسية</span>
                <span class="tab">الصلاحيات</span>
                <span class="tab">النشاط</span>
            </div>

            <!-- نموذج التعديل -->
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="IsAdmin" />
                <input type="hidden" asp-for="IsOnline" />
                <input type="hidden" asp-for="LastLogin" />
                <input type="hidden" asp-for="LastLogout" />

                <!-- تحذير عند تعديل بيانات مهمة -->
                <div class="warning-note">
                    <i class="fas fa-exclamation-triangle"></i>
                    <span>تغيير بيانات المستخدم قد يؤثر على صلاحياته في النظام</span>
                </div>

                <!-- اسم المستخدم -->
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-user-tag"></i>
                        اسم المستخدم
                    </label>
                    <input type="text" asp-for="Username" class="form-control" required placeholder="أدخل اسم المستخدم" />
                </div>

                <!-- رقم الهاتف -->
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-phone"></i>
                        رقم الهاتف
                    </label>
                    <input type="tel" asp-for="Phone" class="form-control" pattern="01[0-9]{9}" required placeholder="01xxxxxxxxx" />
                </div>

                <!-- كلمة السر -->
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-lock"></i>
                        كلمة السر
                    </label>
                    <input type="text" asp-for="Password" class="form-control" required placeholder="كلمة المرور" />
                </div>

                <!-- بطاقة الحالة -->
                <div class="status-card">
                    <div class="status-row">
                        <span class="status-label">الصلاحية الحالية</span>
                        <span class="status-value">@(Model.IsAdmin ? "أدمن" : "مستخدم")</span>
                    </div>
                    <div class="status-row">
                        <span class="status-label">حالة الاتصال</span>
                        <span class="status-value @(Model.IsOnline ? "online" : "offline")">
                            <i class="fas fa-circle"></i> @(Model.IsOnline ? "متصل" : "غير متصل")
                        </span>
                    </div>
                    <div class="status-row">
                        <span class="status-label">آخر دخول</span>
                        <span class="status-value">@Model.LastLogin?.ToString("yyyy-MM-dd HH:mm")</span>
                    </div>
                    <div class="status-row">
                        <span class="status-label">آخر خروج</span>
                        <span class="status-value">@Model.LastLogout?.ToString("yyyy-MM-dd HH:mm")</span>
                    </div>
                </div>

                <!-- مجموعة الأزرار -->
                <div class="actions-group">
                    <button type="submit" class="btn btn-save">
                        <i class="fas fa-save"></i> حفظ التغييرات
                    </button>

                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-delete" onclick="return confirm('هل أنت متأكد من حذف هذا المستخدم؟')">
                        <i class="fas fa-trash"></i> حذف
                    </a>

                    @if (!Model.IsBlocked)
                    {
                        <a asp-action="Block" asp-route-id="@Model.Id" class="btn btn-block" onclick="return confirm('هل أنت متأكد من حظر هذا المستخدم؟')">
                            <i class="fas fa-ban"></i> حظر
                        </a>
                    }
                    else
                    {
                        <a asp-action="Unblock" asp-route-id="@Model.Id" class="btn btn-unblock" onclick="return confirm('هل أنت متأكد من فك الحظر عن هذا المستخدم؟')">
                            <i class="fas fa-check-circle"></i> فك الحظر
                        </a>
                    }

                    @if (!Model.IsAdmin)
                    {
                        <a asp-action="Promote" asp-route-id="@Model.Id" class="btn btn-promote" onclick="return confirm('هل أنت متأكد من ترقية هذا المستخدم إلى أدمن؟')">
                            <i class="fas fa-arrow-up"></i> ترقية لأدمن
                        </a>
                    }
                    else
                    {
                        <a asp-action="Demote" asp-route-id="@Model.Id" class="btn btn-demote" onclick="return confirm('هل أنت متأكد من تنزيل صلاحية هذا المستخدم؟')">
                            <i class="fas fa-arrow-down"></i> تنزيل صلاحية
                        </a>
                    }

                    <a asp-action="Index" class="btn btn-back">
                        <i class="fas fa-arrow-right"></i> رجوع
                    </a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>