                // إرسال للمستخدمين المختارين
                function sendToSelectedUsers() {
                    if (selectedUsers.length === 0) {
                        alert('❌ الرجاء اختيار مستخدم واحد على الأقل');
                        return;
                    }

                    const message = document.getElementById('bulkMessageText').value;
                    if (!message.trim()) {
                        alert('❌ الرجاء كتابة الرسالة');
                        return;
                    }

                    const resultDiv = document.getElementById('bulkSendResult');
                    resultDiv.style.display = 'block';
                    resultDiv.className = 'alert alert-info';
                    resultDiv.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري فتح واتساب...';

                    let successCount = 0;
                    let failCount = 0;

                    selectedUsers.forEach((user, index) => {
                        setTimeout(() => {
                            try {
                                let personalizedMessage = message
                                    .replace(/{اسم المستخدم}/g, user.username)
                                    .replace(/{كلمة المرور}/g, user.password || '******')
                                    .replace(/{رقم الهاتف}/g, user.phone)
                                    .replace(/{الصلاحية}/g, user.role)
                                    .replace(/{الحالة}/g, user.isBlocked ? 'محظور' : (user.isOnline ? 'متصل' : 'غير متصل'))
                                    .replace(/{آخر دخول}/g, user.lastLogin || 'لم يسجل')
                                    .replace(/{آخر خروج}/g, user.lastLogout || 'لم يسجل')
                                    .replace(/{رابط الموقع}/g, siteUrl);

                                let phone = user.phone.replace(/[^0-9]/g, '');
                                if (phone.startsWith('0')) {
                                    phone = '20' + phone.substring(1);
                                }

                                const url = `https://wa.me/${phone}?text=${encodeURIComponent(personalizedMessage)}`;
                                window.open(url, '_blank');
                                successCount++;
                            } catch (err) {
                                console.error('خطأ في فتح واتساب:', err);
                                failCount++;
                            }
                        }, index * 1000);
                    });

                    resultDiv.className = 'alert alert-success';
                    resultDiv.innerHTML = `
                        <i class="fas fa-check-circle"></i>
                        تم فتح ${successCount} محادثة واتساب بنجاح
                        ${failCount > 0 ? `، فشل فتح ${failCount} محادثة` : ''}
                    `;
                }

