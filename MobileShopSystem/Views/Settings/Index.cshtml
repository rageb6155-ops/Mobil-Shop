@model List<MobileShopSystem.Models.User>

@{
    ViewData["Title"] = "الإعدادات";
    var username = Context.Session.GetString("Username");
    var approved = Model.Where(x => x.IsApproved).ToList();
    var pending = Model.Where(x => !x.IsApproved).ToList();
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <!-- إضافة مكتبات PDF والواتساب -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: #ffffff;
            margin: 0;
            padding: 20px;
            color: #333;
        }

        .page-wrapper {
            max-width: 1200px;
            margin: 0 auto;
        }

        /* بطاقة العنوان */
        .header-card {
            background: white;
            border-radius: 16px;
            padding: 20px 25px;
            margin-bottom: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .header-title h1 {
            margin: 0;
            font-size: 26px;
            font-weight: 600;
            color: #f39c12;
        }

        .header-title p {
            margin: 5px 0 0;
            color: #6c757d;
            font-size: 14px;
        }

        .user-info {
            background: #f8f9fa;
            color: #f39c12;
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 500;
            border: 1px solid #e9ecef;
        }

            .user-info i {
                margin-left: 8px;
            }

        /* بطاقة المحتوى */
        .content-card {
            background: white;
            border-radius: 16px;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
            margin-bottom: 30px;
        }

        .card-header-custom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid #f0f0f0;
        }

            .card-header-custom h2 {
                margin: 0;
                color: #f39c12;
                font-weight: 600;
                font-size: 22px;
            }

        .badge-count {
            background: #f39c12;
            color: white;
            padding: 5px 15px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 500;
        }

        /* أزرار */
        .btn {
            padding: 6px 12px;
            border-radius: 6px;
            color: #fff;
            text-decoration: none;
            font-size: 12px;
            margin: 2px;
            display: inline-block;
            transition: all 0.3s;
            border: none;
            cursor: pointer;
        }

            .btn:hover {
                transform: translateY(-2px);
            }

        .btn-edit {
            background: #3498db;
        }

        .btn-approve {
            background: #2ecc71;
        }

        .btn-block {
            background: #e67e22;
        }

        .btn-unblock {
            background: #27ae60;
        }

        .btn-delete {
            background: #e74c3c;
        }

        .btn-details {
            background: #9b59b6;
        }

        .btn-whatsapp {
            background: #25D366;
            color: white;
        }

        .btn-whatsapp-bulk {
            background: #128C7E;
            color: white;
            padding: 8px 20px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-pdf {
            background: #f39c12;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .btn-pdf:hover {
                background: #e67e22;
                transform: translateY(-2px);
            }

            .btn-pdf:disabled {
                opacity: 0.5;
                cursor: not-allowed;
                transform: none;
            }

        /* الجدول */
        .table-responsive {
            overflow-x: auto;
            border-radius: 12px;
        }

        .user-table {
            width: 100%;
            border-collapse: collapse;
            background: white;
        }

            .user-table th {
                background: #f8f9fa;
                color: #f39c12;
                padding: 12px;
                font-weight: 600;
                font-size: 14px;
                text-align: center;
                border: 1px solid #e9ecef;
            }

            .user-table td {
                padding: 12px;
                text-align: center;
                border-bottom: 1px solid #e9ecef;
                color: #333;
            }

            .user-table tbody tr {
                transition: all 0.3s;
                cursor: pointer;
            }

                .user-table tbody tr:hover {
                    background: #f8f9fa;
                }

                .user-table tbody tr.selected {
                    background: #fff3e0;
                    border: 2px solid #f39c12;
                }

        .online {
            color: #27ae60;
            font-weight: bold;
        }

        .offline {
            color: #95a5a6;
        }

        .status-badge {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: bold;
        }

        .status-admin {
            background: #f39c12;
            color: white;
        }

        .status-user {
            background: #3498db;
            color: white;
        }

        .status-blocked {
            background: #e74c3c;
            color: white;
        }

        .empty-state {
            text-align: center;
            padding: 40px;
            background: #f8f9fa;
            border-radius: 12px;
            color: #6c757d;
        }

            .empty-state i {
                font-size: 48px;
                margin-bottom: 15px;
                color: #dee2e6;
            }

        .selection-message {
            background: #fff3cd;
            color: #856404;
            padding: 8px 15px;
            border-radius: 8px;
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* ===== تنسيق مودال الواتساب ===== */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 9999;
            overflow-y: auto;
        }

        .modal-content {
            background: white;
            width: 90%;
            max-width: 900px;
            margin: 50px auto;
            border-radius: 20px;
            padding: 25px;
            max-height: 85vh;
            overflow-y: auto;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid #f0f0f0;
        }

            .modal-header h3 {
                margin: 0;
                color: #f39c12;
                font-weight: 600;
            }

        .close-btn {
            background: #6c757d;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.3s;
        }

            .close-btn:hover {
                background: #5a6268;
            }

        /* ===== تنسيق اختيار المستخدمين ===== */
        .users-selection {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin: 20px 0;
            max-height: 500px;
        }

        .users-list {
            border: 1px solid #e9ecef;
            border-radius: 12px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .list-header {
            background: #f39c12;
            color: white;
            padding: 12px 15px;
            font-weight: 500;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .list-header i {
                cursor: pointer;
                opacity: 0.8;
                transition: opacity 0.3s;
            }

                .list-header i:hover {
                    opacity: 1;
                }

        .list-search {
            padding: 10px;
            border-bottom: 1px solid #e9ecef;
            position: relative;
        }

            .list-search input {
                width: 100%;
                padding: 8px 35px 8px 10px;
                border: 1px solid #e9ecef;
                border-radius: 20px;
                font-size: 13px;
            }

            .list-search i {
                position: absolute;
                right: 20px;
                top: 18px;
                color: #adb5bd;
                font-size: 14px;
            }

        .list-items {
            overflow-y: auto;
            flex: 1;
            max-height: 350px;
        }

        .user-item {
            padding: 10px 15px;
            border-bottom: 1px solid #f0f0f0;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            transition: all 0.2s;
        }

            .user-item:hover {
                background: #fff3e0;
            }

            .user-item.selected {
                background: #ffe6cc;
                border-right: 3px solid #f39c12;
            }

        .user-checkbox {
            width: 18px;
            height: 18px;
            cursor: pointer;
        }

        .user-info {
            flex: 1;
        }

        .user-name {
            font-weight: 600;
            color: #333;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 5px;
            flex-wrap: wrap;
        }

        .user-details {
            font-size: 11px;
            color: #666;
            margin-top: 2px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .user-phone {
            color: #27ae60;
        }

        .user-role {
            padding: 2px 6px;
            border-radius: 10px;
            font-size: 9px;
            font-weight: bold;
        }

        .role-admin {
            background: #f39c12;
            color: white;
        }

        .role-user {
            background: #3498db;
            color: white;
        }

        .status-online {
            color: #27ae60;
        }

        .status-offline {
            color: #95a5a6;
        }

        .status-blocked {
            color: #e74c3c;
        }

        .selected-count {
            background: white;
            color: #f39c12;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
        }

        .selection-actions {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
            flex-wrap: wrap;
        }

        .message-preview {
            background: #fff3e0;
            border-radius: 12px;
            padding: 15px;
            margin: 20px 0;
            border-right: 4px solid #25D366;
        }

            .message-preview h5 {
                margin: 0 0 10px 0;
                color: #f39c12;
                font-size: 14px;
            }

        .preview-content {
            background: white;
            padding: 12px;
            border-radius: 8px;
            font-size: 13px;
            line-height: 1.5;
            white-space: pre-wrap;
            max-height: 200px;
            overflow-y: auto;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            color: #495057;
            font-size: 14px;
            font-weight: 500;
        }

        .form-control, .form-select {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e9ecef;
            border-radius: 10px;
            font-size: 14px;
            transition: all 0.3s;
        }

            .form-control:focus, .form-select:focus {
                outline: none;
                border-color: #f39c12;
                box-shadow: 0 0 0 3px rgba(243, 156, 18, 0.1);
            }

        .alert {
            padding: 12px 15px;
            border-radius: 8px;
            margin-bottom: 15px;
        }

        .alert-success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .alert-info {
            background: #d1ecf1;
            color: #0c5460;
            border: 1px solid #bee5eb;
        }

        .alert-warning {
            background: #fff3cd;
            color: #856404;
            border: 1px solid #ffeeba;
        }

        /* ===== تنسيق 80mm للطباعة ===== */
        .print-80mm {
            width: 80mm;
            padding: 2mm;
            margin: 0 auto;
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: white;
            direction: rtl;
            font-size: 9px;
            line-height: 1.2;
            box-sizing: border-box;
        }

            .print-80mm .header {
                text-align: center;
                border-bottom: 1px dashed #f39c12;
                padding-bottom: 2mm;
                margin-bottom: 2mm;
            }

            .print-80mm .title {
                font-size: 14px;
                font-weight: bold;
                color: #f39c12;
            }

            .print-80mm .info-row {
                display: flex;
                justify-content: space-between;
                padding: 1mm 0;
                border-bottom: 1px dotted #eee;
            }

            .print-80mm .footer {
                margin-top: 2mm;
                text-align: center;
                font-size: 7px;
                color: #999;
                border-top: 1px solid #eee;
                padding-top: 1mm;
            }
    </style>
</head>
<body>
    <div class="page-wrapper">
        <!-- بطاقة العنوان -->
        <div class="header-card">
            <div class="header-title">
                <h1>
                    <i class="fas fa-cog"></i> الإعدادات
                </h1>
                <p>إدارة المستخدمين والصلاحيات</p>
            </div>
            <div class="user-info">
                <i class="fas fa-user-circle"></i>
                @username
            </div>
        </div>

        @* المستخدمين قيد الموافقة *@
        @if (pending.Any())
        {
            <div class="content-card">
                <div class="card-header-custom">
                    <h2>
                        <i class="fas fa-hourglass-half"></i> مستخدمين قيد الموافقة
                    </h2>
                    <div style="display: flex; gap: 15px; align-items: center;">
                        <span class="badge-count">@pending.Count()</span>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="user-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>اسم المستخدم</th>
                                <th>الهاتف</th>
                                <th>الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int pendingCounter = 1;
                                foreach (var u in pending)
                                {
                                    <tr>
                                        <td>@pendingCounter</td>
                                        <td><i class="fas fa-user"></i> @u.Username</td>
                                        <td><i class="fas fa-phone"></i> @u.Phone</td>
                                        <td>
                                            <a asp-controller="Settings" asp-action="Approve" asp-route-id="@u.Id" class="btn btn-approve">
                                                <i class="fas fa-check"></i> موافقة
                                            </a>
                                            <a asp-controller="Settings" asp-action="Delete" asp-route-id="@u.Id" class="btn btn-delete">
                                                <i class="fas fa-trash"></i> حذف
                                            </a>
                                            <a asp-controller="Settings" asp-action="Details" asp-route-id="@u.Id" class="btn btn-details">
                                                <i class="fas fa-info"></i> عرض التفاصيل
                                            </a>
                                            <button class="btn btn-whatsapp" onclick="showUserWhatsAppModal(@u.Id, '@u.Username', '@u.Phone')">
                                                <i class="fab fa-whatsapp"></i> واتساب
                                            </button>
                                        </td>
                                    </tr>
                                    pendingCounter++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* المستخدمين الحاليين *@
        <div class="content-card">
            <div class="card-header-custom">
                <h2>
                    <i class="fas fa-users"></i> المستخدمين الحاليين
                </h2>
                <div style="display: flex; gap: 15px; align-items: center;">
                    <button class="btn-whatsapp-bulk" onclick="showBulkWhatsAppModal()">
                        <i class="fab fa-whatsapp"></i> رسائل جماعية
                    </button>
                    <div id="selectionMessage" class="selection-message" style="display: none;">
                        <i class="fas fa-check-circle"></i>
                        <span id="selectedUserName"></span>
                    </div>
                    <button class="btn-pdf" id="printPdfBtn" onclick="printSelectedUser()" disabled>
                        <i class="fas fa-file-pdf"></i> تصدير PDF
                    </button>
                    <span class="badge-count">@approved.Count()</span>
                </div>
            </div>

            <div class="table-responsive">
                <table class="user-table" id="usersTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>الاسم</th>
                            <th>الهاتف</th>
                            <th>الصلاحية</th>
                            <th>الحالة</th>
                            <th>آخر دخول</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int approvedCounter = 1;
                            foreach (var u in approved)
                            {
                                <tr onclick="selectUser(@approvedCounter - 1, '@u.Username', '@u.Phone', '@(u.IsAdmin ? "أدمن" : "مستخدم")', '@(u.IsOnline ? "متصل" : "غير متصل")', '@u.LastLogin?.ToString("yyyy-MM-dd HH:mm")', '@u.Id', '@u.Password', '@u.IsBlocked', '@u.IsApproved')">
                                    <td>@approvedCounter</td>
                                    <td><i class="fas fa-user"></i> @u.Username</td>
                                    <td><i class="fas fa-phone"></i> @u.Phone</td>
                                    <td>
                                        @if (u.IsAdmin)
                                        {
                                            <span class="status-badge status-admin">أدمن</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-user">مستخدم</span>
                                        }
                                        @if (u.IsBlocked)
                                        {
                                            <span class="status-badge status-blocked" style="margin-right: 5px;">محظور</span>
                                        }
                                    </td>
                                    <td class="@(u.IsOnline ? "online" : "offline")">
                                        <i class="fas fa-circle"></i> @((u.IsOnline) ? "متصل" : "غير متصل")
                                    </td>
                                    <td><i class="far fa-clock"></i> @u.LastLogin?.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        <a asp-controller="Settings" asp-action="Edit" asp-route-id="@u.Id" class="btn btn-edit">
                                            <i class="fas fa-edit"></i> تعديل
                                        </a>
                                        @if (!u.IsBlocked)
                                        {
                                            <a asp-controller="Settings" asp-action="Block" asp-route-id="@u.Id" class="btn btn-block">
                                                <i class="fas fa-ban"></i> حظر
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-controller="Settings" asp-action="Unblock" asp-route-id="@u.Id" class="btn btn-unblock">
                                                <i class="fas fa-check-circle"></i> فك الحظر
                                            </a>
                                        }
                                        <a asp-controller="Settings" asp-action="Delete" asp-route-id="@u.Id" class="btn btn-delete">
                                            <i class="fas fa-trash"></i> حذف
                                        </a>
                                        <a asp-controller="Settings" asp-action="Details" asp-route-id="@u.Id" class="btn btn-details">
                                            <i class="fas fa-info"></i> عرض التفاصيل
                                        </a>
                                        <button class="btn btn-whatsapp" onclick="showUserWhatsAppModal(@u.Id, '@u.Username', '@u.Phone')">
                                            <i class="fab fa-whatsapp"></i> واتساب
                                        </button>
                                    </td>
                                </tr>
                                approvedCounter++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ===== مودال الرسائل الجماعية المتقدم ===== -->
    <div id="bulkWhatsAppModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fab fa-whatsapp text-success"></i> إرسال رسائل واتساب للمستخدمين</h3>
                <button class="close-btn" onclick="closeBulkWhatsAppModal()">✕ إغلاق</button>
            </div>
            <div class="modal-body">
                <!-- أزرار الإجراءات السريعة -->
                <div class="selection-actions">
                    <button class="btn btn-sm btn-primary" onclick="selectAllUsers()">
                        <i class="fas fa-check-double"></i> تحديد الكل
                    </button>
                    <button class="btn btn-sm btn-secondary" onclick="deselectAllUsers()">
                        <i class="fas fa-times"></i> إلغاء التحديد
                    </button>
                    <button class="btn btn-sm btn-info" onclick="refreshUsersList()">
                        <i class="fas fa-sync-alt"></i> تحديث القائمة
                    </button>
                </div>

                <!-- قسم اختيار المستخدمين -->
                <div class="users-selection">
                    <!-- قائمة المستخدمين المتاحين -->
                    <div class="users-list">
                        <div class="list-header">
                            <span><i class="fas fa-users"></i> قائمة المستخدمين</span>
                            <span class="selected-count" id="availableCount">0</span>
                        </div>
                        <div class="list-search">
                            <i class="fas fa-search"></i>
                            <input type="text" id="availableSearch" placeholder="بحث في القائمة..." oninput="filterAvailableUsers()">
                        </div>
                        <div class="list-items" id="availableUsersList">
                            <div class="text-center p-3 text-muted">
                                <i class="fas fa-spinner fa-spin"></i> جاري التحميل...
                            </div>
                        </div>
                    </div>

                    <!-- قائمة المستخدمين المختارين -->
                    <div class="users-list">
                        <div class="list-header" style="background: #27ae60;">
                            <span><i class="fas fa-check-circle"></i> المستخدمين المختارين</span>
                            <span class="selected-count" id="selectedCount">0</span>
                        </div>
                        <div class="list-search">
                            <i class="fas fa-search"></i>
                            <input type="text" id="selectedSearch" placeholder="بحث في القائمة..." oninput="filterSelectedUsers()">
                        </div>
                        <div class="list-items" id="selectedUsersList">
                            <div class="text-center p-3 text-muted">
