                        <div style="margin: 2mm 0; font-size: 9px;">
                            <div style="display: flex; justify-content: space-between; padding: 1mm 0;">
                                <span>نوع المعاملة:</span>
                                <span style="color: ${titleColor};">${invoiceData.transactionType}</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; padding: 1mm 0; border-top: 1px dashed #eee;">
                                <span>المبلغ:</span>
                                <span>${invoiceData.amount.toLocaleString()} ج.م</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; padding: 1mm 0; border-top: 1px dashed #eee;">
                                <span>المدفوع:</span>
                                <span style="color: #28a745;">${invoiceData.paidAmount.toLocaleString()} ج.م</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; padding: 1mm 0; border-top: 1px dashed #eee;">
                                <span>المتبقي:</span>
