                    <div class="stat-card">
                        <div class="stat-value">${totalPaid.toLocaleString()} ج.م</div>
                        <div class="stat-label">إجمالي المدفوعات</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">${avgDebt.toLocaleString()} ج.م</div>
                        <div class="stat-label">متوسط الدين</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">${paidPercentage.toFixed(1)}%</div>
                        <div class="stat-label">نسبة السداد</div>
                    </div>
