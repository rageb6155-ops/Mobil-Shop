            const totalPaid = customer.totalPaid || 0;
            const currentDebt = customer.currentDebt || 0;
            const avgDebt = customer.averageDebt || 0;
            const paidPercentage = customer.paidPercentage || 0;

            const analysisHtml = `
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-value">${totalDebts.toLocaleString()} ج.م</div>
                        <div class="stat-label">إجمالي الديون</div>
