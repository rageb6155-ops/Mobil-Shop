        function switchDetailsTab(tab, isActive) {
            document.querySelectorAll('#customerDetailsModal .tab').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');

            document.querySelectorAll('#customerDetailsModal .tab-content').forEach(content => content.classList.remove('active'));
            document.getElementById(tab + 'Tab').classList.add('active');
        }

        // إغلاق مودال التفاصيل
        function closeDetailsModal() {
            document.getElementById('customerDetailsModal').style.display = 'none';
        }

        // تعديل العميل الحالي
        function editCurrentCustomer() {
            closeDetailsModal();
            editCustomer(currentCustomerId);
        }

        // حذف العميل الحالي (ناعم)
        function deleteCurrentCustomer() {
            closeDetailsModal();
            deleteCustomer(currentCustomerId);
        }

        // إظهار مودال إضافة معاملة
        function showAddTransactionModal() {
            document.getElementById('transactionCustomerId').value = currentCustomerId;
            document.getElementById('transactionType').value = 'دين';
            document.getElementById('transactionAmount').value = '';
            document.getElementById('paidAmount').value = '0';
            document.getElementById('paymentMethod').value = 'نقدي';
            document.getElementById('dueDate').value = '';
            document.getElementById('isInstallment').checked = false;
            document.getElementById('installmentFields').style.display = 'none';
            document.getElementById('transactionNotes').value = '';
            toggleInstallmentFields();
            document.getElementById('transactionModal').style.display = 'block';
        }

        // إغلاق مودال المعاملة
        function closeTransactionModal() {
            document.getElementById('transactionModal').style.display = 'none';
        }

        // تبديل حقول التقسيط
        function toggleInstallmentFields() {
            const type = document.getElementById('transactionType').value;
            const isInstallment = document.getElementById('isInstallment').checked;

            document.getElementById('paidAmountGroup').style.display = type === 'دين' && !isInstallment ? 'block' : 'none';
            document.getElementById('installmentFields').style.display = isInstallment ? 'block' : 'none';

            if (type !== 'دين') {
                document.getElementById('isInstallment').checked = false;
                document.getElementById('installmentFields').style.display = 'none';
            }
        }

        // حفظ المعاملة
        function saveTransaction() {
            const data = {
                customerId: parseInt(document.getElementById('transactionCustomerId').value),
                transactionType: document.getElementById('transactionType').value,
                amount: parseFloat(document.getElementById('transactionAmount').value),
                paidAmount: parseFloat(document.getElementById('paidAmount').value),
                dueDate: document.getElementById('dueDate').value || null,
                notes: document.getElementById('transactionNotes').value || null,
                isInstallment: document.getElementById('isInstallment').checked,
                installmentCount: document.getElementById('installmentCount') ? parseInt(document.getElementById('installmentCount').value) : null,
                installmentPeriod: document.getElementById('installmentPeriod') ? parseInt(document.getElementById('installmentPeriod').value) : null
            };

            if (!data.amount || data.amount <= 0) {
                alert('❌ الرجاء إدخال مبلغ صحيح');
                return;
            }

            fetch('/Customers/AddTransaction', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    if (data.limitExceeded) {
                        const userResponse = confirm(
                            `⚠️ تحذير: تم تجاوز حد الدين الأقصى!\n\n` +
                            `الحد الأقصى: ${data.maxDebtLimit.toLocaleString()} ج.م\n` +
                            `النسبة: ${data.limitPercentage.toFixed(1)}%\n\n` +
                            `هل تريد تعديل حد الدين الأقصى للعميل؟`
                        );

                        if (userResponse) {
                            editCustomer(data.customerId);
                            setTimeout(() => {
                                const limitField = document.getElementById('maxDebtLimit');
                                if (limitField) {
                                    limitField.focus();
                                    limitField.style.borderColor = '#ffc107';
                                }
                            }, 500);
                        }
                    }

                    alert(data.message);
                    closeTransactionModal();
                    showCustomerDetails(currentCustomerId);
                    loadDashboardStats();
                    loadRiskyCustomers();

                    if (data.invoice) {
                        setTimeout(() => printCustomerInvoice(data.invoice), 500);
                    }
                } else {
                    alert('❌ ' + data.message);
                }
            })
            .catch(error => {
                alert('❌ حدث خطأ في الاتصال بالخادم');
            });
        }

        // إظهار مودال التقارير
        function showReportsModal() {
            document.getElementById('reportsModal').style.display = 'block';
            loadReports();
        }

        // إغلاق مودال التقارير
        function closeReportsModal() {
            document.getElementById('reportsModal').style.display = 'none';
        }

        // تحميل التقارير
        function loadReports() {
            const fromDate = document.getElementById('reportFromDate').value;
            const toDate = document.getElementById('reportToDate').value;
            const customerId = document.getElementById('reportCustomerId').value;

            fetch(`/Customers/DebtReports?fromDate=${fromDate}&toDate=${toDate}&customerId=${customerId}`)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        displayReports(data.transactions, data.summary);
                    }
                });
        }

        // عرض التقارير
        function displayReports(transactions, summary) {
            document.getElementById('reportsSummary').innerHTML = `
                <div class="stat-card">
                    <div class="stat-value">${summary.totalDebts.toLocaleString()} ج.م</div>
                    <div class="stat-label">إجمالي الديون</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">${summary.totalPaid.toLocaleString()} ج.م</div>
                    <div class="stat-label">إجمالي المدفوع</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">${summary.totalRemaining.toLocaleString()} ج.م</div>
                    <div class="stat-label">المتبقي</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">${summary.averagePaidPercentage.toFixed(1)}%</div>
                    <div class="stat-label">متوسط السداد</div>
                </div>
            `;

            let html = '<h5>المعاملات</h5>';
            if (transactions.length === 0) {
                html += '<p class="text-center text-muted">لا توجد معاملات</p>';
            } else {
                html += '<div class="table-responsive"><table class="table table-bordered"><thead><tr><th>#</th><th>العميل</th><th>النوع</th><th>المبلغ</th><th>المدفوع</th><th>المتبقي</th><th>التاريخ</th><th>الحالة</th></tr></thead><tbody>';
                transactions.forEach((t, index) => {
                    html += `
                        <tr>
                            <td>${index + 1}</td>
                            <td>${t.customerName}</td>
                            <td>${t.transactionType}</td>
                            <td>${t.amount.toLocaleString()} ج.م</td>
                            <td>${t.paidAmount.toLocaleString()} ج.م</td>
                            <td class="${t.remainingAmount > 0 ? 'text-danger' : 'text-success'}">${t.remainingAmount.toLocaleString()} ج.م</td>
                            <td>${new Date(t.transactionDate).toLocaleDateString('ar-EG')}</td>
                            <td><span class="badge ${t.status === 'مكتمل' ? 'bg-success' : (t.status === 'متأخر' ? 'bg-danger' : 'bg-warning')}">${t.status}</span></td>
                        </tr>
                    `;
                });
                html += '</tbody></table></div>';
            }
            document.getElementById('reportsList').innerHTML = html;
        }
    </script>
</body>
</html>