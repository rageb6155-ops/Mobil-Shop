        function generateComprehensiveReport(customers) {
            // تجميع إحصائيات
            const totalCustomers = customers.length;
            const totalDebts = customers.reduce((sum, c) => sum + c.currentDebt, 0);
            const customersWithDebt = customers.filter(c => c.currentDebt > 0).length;
            const averageDebt = customersWithDebt > 0 ? totalDebts / customersWithDebt : 0;

            const reportHtml = `
                <h3>تقرير شامل - ${new Date().toLocaleDateString('ar-EG')}</h3>
                <p>إجمالي العملاء: ${totalCustomers}</p>
                <p>عملاء عليهم ديون: ${customersWithDebt}</p>
                <p>إجمالي الديون: ${totalDebts.toLocaleString()} ج.م</p>
                <p>متوسط الدين: ${averageDebt.toLocaleString()} ج.م</p>
                <table border="1">
                    <thead>
                        <tr>
                            <th>الاسم</th>
                            <th>الهاتف</th>
                            <th>الدين</th>
                            <th>النوع</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${customers.map(c => `
                            <tr>
                                <td>${c.fullName}</td>
                                <td>${c.phoneNumber}</td>
                                <td>${c.currentDebt.toLocaleString()} ج.م</td>
                                <td>${c.customerType}</td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table>
            `;

            const newWindow = window.open();
            newWindow.document.write(reportHtml);
        }

        // تصدير Excel
        function exportToExcel() {
            fetch('/Customers/GetAllCustomers?showDeleted=false')
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        let csv = 'الاسم,رقم الهاتف,الدين الحالي,نوع العميل,عدد المعاملات\n';
                        data.customers.forEach(c => {
                            csv += `${c.fullName},${c.phoneNumber},${c.currentDebt},${c.customerType},${c.transactionsCount}\n`;
                        });

                        const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
                        const link = document.createElement('a');
                        const url = URL.createObjectURL(blob);
                        link.setAttribute('href', url);
                        link.setAttribute('download', 'العملاء.csv');
                        link.style.visibility = 'hidden';
                        document.body.appendChild(link);
                        link.click();
                        document.body.removeChild(link);
                    }
                });
        }

