@{
    ViewData["Title"] = "إدارة العملاء";
    var username = Context.Session.GetString("Username");
    var today = DateTime.Now;
    var dayName = today.ToString("dddd", new System.Globalization.CultureInfo("ar-EG"));
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <!-- إضافة مكتبات PDF -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: #f4f6f9;
            margin: 0;
            padding: 20px;
        }

        .page-wrapper {
            max-width: 1400px;
            margin: 0 auto;
        }

        .header-card {
            background: white;
            border-radius: 16px;
            padding: 20px 25px;
            margin-bottom: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .header-title h1 {
            margin: 0;
            font-size: 26px;
            font-weight: 600;
            color: #4361ee;
        }

        .header-title p {
            margin: 5px 0 0;
            color: #6c757d;
            font-size: 14px;
        }

        .user-info {
            background: #f8f9fa;
            color: #4361ee;
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 500;
            border: 1px solid #e9ecef;
        }

        .customers-card {
            background: white;
            border-radius: 16px;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid #f0f0f0;
            flex-wrap: wrap;
            gap: 15px;
        }

            .card-header h2 {
                margin: 0;
                color: #4361ee;
                font-weight: 600;
                font-size: 22px;
            }

        .search-section {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 20px;
            position: relative;
        }

        .search-input {
            flex: 1;
            min-width: 250px;
            padding: 10px 15px;
            border: 2px solid #e9ecef;
            border-radius: 8px;
            font-size: 14px;
            transition: all 0.3s;
        }

            .search-input:focus {
                outline: none;
                border-color: #4361ee;
                box-shadow: 0 0 0 3px rgba(67, 97, 238, 0.1);
            }

        .search-results {
            position: absolute;
            top: 100%;
            right: 0;
            left: 0;
            background: white;
            border: 1px solid #e9ecef;
            border-radius: 8px;
            margin-top: 5px;
            max-height: 300px;
            overflow-y: auto;
            z-index: 1000;
            display: none;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .search-result-item {
            padding: 10px 15px;
            cursor: pointer;
            border-bottom: 1px solid #f0f0f0;
            transition: all 0.3s;
        }

            .search-result-item:hover {
                background: #f8f9fa;
                transform: translateX(-5px);
            }

        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary {
            background: #4361ee;
            color: white;
        }

            .btn-primary:hover {
                background: #3f37c9;
                transform: translateY(-2px);
            }

        .btn-success {
            background: #28a745;
            color: white;
        }

            .btn-success:hover {
                background: #218838;
                transform: translateY(-2px);
            }

        .btn-warning {
            background: #ffc107;
            color: #333;
        }

            .btn-warning:hover {
                background: #e0a800;
                transform: translateY(-2px);
            }

        .btn-danger {
            background: #dc3545;
            color: white;
        }

            .btn-danger:hover {
                background: #c82333;
                transform: translateY(-2px);
            }

        .btn-info {
            background: #17a2b8;
            color: white;
        }

            .btn-info:hover {
                background: #138496;
                transform: translateY(-2px);
            }

        .btn-secondary {
            background: #6c757d;
            color: white;
        }

            .btn-secondary:hover {
                background: #5a6268;
                transform: translateY(-2px);
            }

        .btn-danger-hard {
            background: #7b1e1e;
            color: white;
        }

            .btn-danger-hard:hover {
                background: #5a1515;
                transform: translateY(-2px);
            }

        .btn-purple {
            background: #6f42c1;
            color: white;
        }

            .btn-purple:hover {
                background: #5e35b1;
                transform: translateY(-2px);
            }

        .btn-pdf {
            background: #d32f2f;
            color: white;
        }

            .btn-pdf:hover {
                background: #b71c1c;
                transform: translateY(-2px);
            }

        .customers-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .customer-card {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 20px;
            border: 1px solid #e9ecef;
            transition: all 0.3s;
            cursor: pointer;
        }

            .customer-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            }

            .customer-card.debt {
                border-right: 4px solid #dc3545;
            }

            .customer-card.normal {
                border-right: 4px solid #28a745;
            }

        .customer-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .customer-name {
            font-size: 16px;
            font-weight: bold;
            color: #4361ee;
        }

        .customer-code {
            font-size: 12px;
            color: #6c757d;
        }

        .customer-phone {
            font-size: 13px;
            color: #666;
            margin: 5px 0;
        }

        .customer-debt {
            font-size: 18px;
            font-weight: bold;
            color: #dc3545;
            margin: 5px 0;
        }

        .customer-actions {
            display: flex;
            gap: 10px;
            margin-top: 15px;
            flex-wrap: wrap;
        }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 1000;
        }

        .modal-content {
            background: white;
            width: 90%;
            max-width: 600px;
            margin: 50px auto;
            border-radius: 16px;
            padding: 25px;
            max-height: 80vh;
            overflow-y: auto;
        }

        .modal-lg {
            max-width: 900px;
        }

        .modal-xl {
            max-width: 1200px;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid #f0f0f0;
        }

            .modal-header h3 {
                margin: 0;
                color: #4361ee;
            }

        .close-btn {
            background: #6c757d;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 8px;
            cursor: pointer;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-label {
            display: block;
            margin-bottom: 5px;
            color: #6c757d;
            font-size: 13px;
        }

        .form-control {
            width: 100%;
            padding: 10px 15px;
            border: 2px solid #e9ecef;
            border-radius: 8px;
            font-size: 14px;
        }

            .form-control:focus {
                outline: none;
                border-color: #4361ee;
            }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .debt-badge {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 500;
            margin-left: 5px;
        }

        .badge-danger {
            background: #dc3545;
            color: white;
        }

        .badge-success {
            background: #28a745;
            color: white;
        }

        .badge-warning {
            background: #ffc107;
            color: #333;
        }

        .badge-info {
            background: #17a2b8;
            color: white;
        }

        .badge-secondary {
            background: #6c757d;
            color: white;
        }

        .badge-purple {
            background: #6f42c1;
            color: white;
        }

        .transactions-list {
            max-height: 400px;
            overflow-y: auto;
            padding: 10px;
        }

        .transaction-item {
            background: #f8f9fa;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 10px;
            border: 1px solid #e9ecef;
        }

        .transaction-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .transaction-type {
            font-weight: bold;
            color: #4361ee;
        }

        .transaction-status {
            font-size: 11px;
            padding: 3px 8px;
            border-radius: 10px;
        }

        .installments-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 10px;
            margin-top: 15px;
        }

        .installment-item {
            background: white;
            border: 1px solid #e9ecef;
            border-radius: 6px;
            padding: 8px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
        }

            .installment-item:hover {
                transform: translateY(-2px);
                box-shadow: 0 3px 10px rgba(0,0,0,0.1);
            }

            .installment-item.paid {
                background: #d4edda;
                border-color: #28a745;
                opacity: 0.8;
                text-decoration: line-through 2px #155724;
            }

            .installment-item.overdue {
                border-color: #dc3545;
                background: #f8d7da;
            }

        .installment-number {
            font-size: 12px;
            color: #6c757d;
        }

        .installment-amount {
            font-size: 13px;
            font-weight: bold;
            color: #4361ee;
        }

        .installment-due {
            font-size: 10px;
            color: #6c757d;
        }

        .progress {
            height: 8px;
            border-radius: 4px;
        }

        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            border-bottom: 2px solid #f0f0f0;
            padding-bottom: 10px;
        }

        .tab {
            padding: 8px 20px;
            border: none;
            background: none;
            border-radius: 8px 8px 0 0;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            color: #6c757d;
        }

            .tab.active {
                color: #4361ee;
                border-bottom: 3px solid #4361ee;
                background: #f0f4ff;
            }

        .tab-content {
            display: none;
        }

            .tab-content.active {
                display: block;
            }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin: 20px 0;
        }

        .stat-card {
            background: white;
            border-radius: 12px;
            padding: 15px;
            border: 1px solid #e9ecef;
            border-right: 4px solid #4361ee;
        }

        .stat-value {
            font-size: 22px;
            font-weight: bold;
            color: #333;
        }

        .stat-label {
            font-size: 12px;
            color: #6c757d;
        }

        .table th {
            background: #f8f9fa;
            color: #4361ee;
        }

        .table td {
            vertical-align: middle;
        }

        .installment-progress {
            width: 100%;
            height: 4px;
            background: #e9ecef;
            border-radius: 2px;
            margin-top: 5px;
        }

        .installment-progress-bar {
            height: 100%;
            background: #4361ee;
            border-radius: 2px;
            transition: width 0.3s;
        }

        .quick-actions {
            display: flex;
            gap: 10px;
            margin: 15px 0;
            flex-wrap: wrap;
        }

        .quick-action-btn {
            flex: 1;
            min-width: 150px;
            padding: 15px;
            border: 1px solid #e9ecef;
            border-radius: 8px;
            background: white;
            cursor: pointer;
            transition: all 0.3s;
            text-align: center;
        }

            .quick-action-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            }

            .quick-action-btn i {
                font-size: 20px;
                color: #4361ee;
            }

            .quick-action-btn span {
                display: block;
                margin-top: 5px;
                font-size: 12px;
                color: #666;
            }

        .summary-box {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 15px;
            margin-bottom: 20px;
            display: flex;
            justify-content: space-around;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .summary-item {
            text-align: center;
        }

        .summary-value {
            font-size: 20px;
            font-weight: bold;
            color: #4361ee;
        }

        .summary-label {
            font-size: 12px;
            color: #6c757d;
        }

        .amount-positive {
            color: #28a745;
            font-weight: bold;
        }

        .amount-negative {
            color: #dc3545;
            font-weight: bold;
        }

        @@media (max-width: 768px) {
            .form-row {
                grid-template-columns: 1fr;
            }

            .customers-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="page-wrapper">
        <div class="header-card">
            <div class="header-title">
                <h1>
                    <i class="fas fa-users"></i> إدارة العملاء
                </h1>
                <p>إدارة حسابات العملاء والديون والأقساط</p>
            </div>
            <div class="user-info">
                <i class="fas fa-user-circle"></i> @username
            </div>
        </div>

        <!-- إحصائيات سريعة -->
        <div class="stats-grid" style="margin-bottom: 25px;">
            <div class="stat-card" id="totalCustomers">
                <div class="stat-label"><i class="fas fa-users"></i> إجمالي العملاء</div>
                <div class="stat-value">-</div>
            </div>
            <div class="stat-card" id="customersWithDebt">
                <div class="stat-label"><i class="fas fa-exclamation-triangle"></i> عملاء عليهم ديون</div>
                <div class="stat-value">-</div>
            </div>
            <div class="stat-card" id="totalDebts">
                <div class="stat-label"><i class="fas fa-money-bill-wave"></i> إجمالي الديون</div>
                <div class="stat-value">-</div>
            </div>
            <div class="stat-card" id="overdueCount">
                <div class="stat-label"><i class="fas fa-clock"></i> معاملات متأخرة</div>
                <div class="stat-value">-</div>
            </div>
        </div>

        <!-- أزرار سريعة -->
        <div class="quick-actions">
            <div class="quick-action-btn" onclick="showAllCustomersReport()">
                <i class="fas fa-file-pdf"></i>
                <span>تقرير شامل PDF</span>
            </div>
            <div class="quick-action-btn" onclick="showAddCustomerModal()">
                <i class="fas fa-user-plus"></i>
                <span>إضافة عميل</span>
            </div>
            <div class="quick-action-btn" onclick="showReportsModal()">
                <i class="fas fa-chart-pie"></i>
                <span>تقارير متقدمة</span>
            </div>
            <div class="quick-action-btn" onclick="exportToExcel()">
                <i class="fas fa-file-excel"></i>
                <span>تصدير Excel</span>
            </div>
        </div>

        <div class="customers-card">
            <div class="card-header">
                <h2><i class="fas fa-list"></i> قائمة العملاء</h2>
                <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                    <button class="btn btn-pdf" onclick="printActiveCustomersPDF()">
                        <i class="fas fa-file-pdf"></i> طباعة العملاء النشطين
                    </button>
                    <button class="btn btn-success" onclick="showAddCustomerModal()">
                        <i class="fas fa-plus"></i> إضافة عميل جديد
                    </button>
                </div>
            </div>

            <div class="search-section">
                <input type="text" class="search-input" id="searchInput" placeholder="ابحث بالاسم أو رقم الهاتف..." autocomplete="off" />
                <button class="btn btn-primary" onclick="loadCustomers()">
                    <i class="fas fa-search"></i> بحث
                </button>
                <button class="btn btn-info" onclick="showReportsModal()">
                    <i class="fas fa-chart-bar"></i> تقارير الديون
                </button>
                <div id="searchResults" class="search-results"></div>
            </div>

            <div class="tabs">
                <button class="tab active" onclick="switchTab('active', true)">العملاء النشطين</button>
                <button class="tab" onclick="switchTab('deleted', false)">العملاء المحذوفين</button>
                <button class="tab" onclick="switchTab('all', 'all')">كل العملاء</button>
            </div>

            <div id="customersList" class="customers-grid">
                <div class="text-center text-muted py-5" style="grid-column: 1/-1;">
                    <i class="fas fa-spinner fa-spin fa-3x mb-3"></i>
                    <h5>جاري التحميل...</h5>
                </div>
            </div>
        </div>

        <!-- العملاء المعرضون للخطر -->
        <div class="customers-card" style="margin-top: 25px;">
            <div class="card-header">
                <h2><i class="fas fa-exclamation-triangle text-danger"></i> عملاء معرضون للخطر</h2>
                <button class="btn btn-warning btn-sm" onclick="printRiskyCustomersPDF()">
                    <i class="fas fa-print"></i> طباعة
                </button>
            </div>
            <div id="riskyCustomersList" class="table-responsive">
                <div class="text-center text-muted py-3">جاري التحميل...</div>
            </div>
        </div>
    </div>

    <!-- مودال إضافة/تعديل عميل -->
    <div id="customerModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="customerModalTitle">إضافة عميل جديد</h3>
                <button class="close-btn" onclick="closeCustomerModal()">إغلاق</button>
            </div>
            <form id="customerForm">
                <input type="hidden" id="customerId" value="0" />

                <div class="form-group">
                    <label class="form-label">الاسم الكامل *</label>
                    <input type="text" class="form-control" id="fullName" required />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">رقم الهاتف *</label>
                        <input type="text" class="form-control" id="phoneNumber" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label">هاتف بديل</label>
                        <input type="text" class="form-control" id="alternativePhone" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">الرقم القومي</label>
                        <input type="text" class="form-control" id="idNumber" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">البريد الإلكتروني</label>
                        <input type="email" class="form-control" id="email" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">العنوان</label>
                    <input type="text" class="form-control" id="address" />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">نوع العميل</label>
                        <select class="form-control" id="customerType">
                            <option value="عادي">عادي</option>
                            <option value="مميز">مميز</option>
                            <option value="شركة">شركة</option>
                            <option value="تاجر">تاجر</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">حد الدين الأقصى</label>
                        <input type="number" class="form-control" id="maxDebtLimit" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">ملاحظات</label>
                    <textarea class="form-control" id="notes" rows="2"></textarea>
                </div>

                <div class="form-group" style="margin-top: 20px;">
                    <button type="button" class="btn btn-success" onclick="saveCustomer()">
                        <i class="fas fa-save"></i> حفظ
                    </button>
                    <button type="button" class="btn btn-secondary" onclick="closeCustomerModal()">
                        <i class="fas fa-times"></i> إلغاء
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- مودال تفاصيل العميل -->
    <div id="customerDetailsModal" class="modal">
        <div class="modal-content modal-xl">
            <div class="modal-header">
                <h3 id="detailsCustomerName">تفاصيل العميل</h3>
                <button class="close-btn" onclick="closeDetailsModal()">إغلاق</button>
            </div>

            <div class="summary-box" id="customerSummary">
                <!-- سيتم تعبئتها ديناميكياً -->
            </div>

            <div class="tabs">
                <button class="tab active" onclick="switchDetailsTab('info', true)">معلومات العميل</button>
                <button class="tab" onclick="switchDetailsTab('transactions', false)">المعاملات</button>
                <button class="tab" onclick="switchDetailsTab('debts', false)">الديون النشطة</button>
                <button class="tab" onclick="switchDetailsTab('installments', false)">الأقساط</button>
                <button class="tab" onclick="switchDetailsTab('analysis', false)">تحليل مالي</button>
            </div>

            <!-- تبويب المعلومات -->
            <div id="infoTab" class="tab-content active">
                <div id="customerInfo"></div>
                <div style="margin-top: 15px; display: flex; gap: 10px; flex-wrap: wrap; justify-content: left;">
                    <button class="btn btn-info" onclick="printCustomerPDF(currentCustomerId)">
                        <i class="fas fa-file-pdf"></i> طباعة بيانات العميل
                    </button>
                    <button class="btn btn-purple" onclick="printCustomerStatement(currentCustomerId)">
                        <i class="fas fa-file-invoice"></i> كشف حساب PDF
                    </button>
                    <button class="btn btn-success" onclick="sendReminder(currentCustomerId)">
                        <i class="fas fa-bell"></i> إرسال تذكير
                    </button>
                </div>
            </div>

            <!-- تبويب المعاملات -->
            <div id="transactionsTab" class="tab-content">
                <div class="stats-grid" id="transactionsStats"></div>
                <div id="transactionsList"></div>
            </div>

            <!-- تبويب الديون النشطة -->
            <div id="debtsTab" class="tab-content">
                <div id="debtsList"></div>
            </div>

            <!-- تبويب الأقساط -->
            <div id="installmentsTab" class="tab-content">
                <div id="installmentsSummary"></div>
                <div id="installmentsList"></div>
            </div>

            <!-- تبويب التحليل المالي -->
            <div id="analysisTab" class="tab-content">
                <div id="financialAnalysis"></div>
            </div>

            <div style="margin-top: 20px; display: flex; gap: 10px; flex-wrap: wrap;">
                <button class="btn btn-primary" onclick="showAddTransactionModal()">
                    <i class="fas fa-plus"></i> إضافة معاملة
                </button>
                <button class="btn btn-warning" onclick="editCurrentCustomer()">
                    <i class="fas fa-edit"></i> تعديل البيانات
                </button>
                <button class="btn btn-danger" onclick="deleteCurrentCustomer()">
                    <i class="fas fa-trash"></i> حذف (ناعم)
                </button>
                <button class="btn btn-danger-hard" onclick="hardDeleteCurrentCustomer()">
                    <i class="fas fa-trash-alt"></i> حذف نهائي
                </button>
            </div>
        </div>
    </div>

    <!-- مودال إضافة معاملة -->
    <div id="transactionModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="transactionModalTitle">إضافة معاملة جديدة</h3>
                <button class="close-btn" onclick="closeTransactionModal()">إغلاق</button>
            </div>
            <form id="transactionForm">
                <input type="hidden" id="transactionCustomerId" value="0" />

                <div class="form-group">
                    <label class="form-label">نوع المعاملة</label>
                    <select class="form-control" id="transactionType" onchange="toggleInstallmentFields()">
                        <option value="دين">دين / قرض</option>
                        <option value="دفعة">دفعة / سداد</option>
                        <option value="تسوية">تسوية</option>
                        <option value="مصروفات">مصروفات إدارية</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">المبلغ</label>
                    <input type="number" class="form-control" id="transactionAmount" required />
                </div>

                <div class="form-group" id="paidAmountGroup">
                    <label class="form-label">المبلغ المدفوع</label>
                    <input type="number" class="form-control" id="paidAmount" value="0" />
                </div>

                <div class="form-group">
                    <label class="form-label">طريقة الدفع</label>
                    <select class="form-control" id="paymentMethod">
                        <option value="نقدي">نقدي</option>
                        <option value="تحويل بنكي">تحويل بنكي</option>
                        <option value="شبكة">شبكة</option>
                        <option value="شيك">شيك</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">تاريخ الاستحقاق</label>
                    <input type="date" class="form-control" id="dueDate" />
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <input type="checkbox" id="isInstallment" onchange="toggleInstallmentFields()" />
                        تقسيط المبلغ
                    </label>
                </div>

                <div id="installmentFields" style="display: none;">
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">عدد الأقساط</label>
                            <input type="number" class="form-control" id="installmentCount" min="1" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">الفترة (بالأيام)</label>
                            <input type="number" class="form-control" id="installmentPeriod" value="30" />
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">ملاحظات</label>
                    <textarea class="form-control" id="transactionNotes" rows="2"></textarea>
                </div>

                <div style="margin-top: 20px;">
                    <button type="button" class="btn btn-success" onclick="saveTransaction()">
                        <i class="fas fa-save"></i> حفظ
                    </button>
                    <button type="button" class="btn btn-secondary" onclick="closeTransactionModal()">
                        <i class="fas fa-times"></i> إلغاء
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- مودال تقارير الديون -->
    <div id="reportsModal" class="modal">
        <div class="modal-content modal-lg">
            <div class="modal-header">
                <h3>تقارير الديون</h3>
                <button class="close-btn" onclick="closeReportsModal()">إغلاق</button>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">من تاريخ</label>
                    <input type="date" class="form-control" id="reportFromDate" value="@DateTime.Now.AddMonths(-1).ToString("yyyy-MM-dd")" />
                </div>
                <div class="form-group">
                    <label class="form-label">إلى تاريخ</label>
                    <input type="date" class="form-control" id="reportToDate" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>
                <div class="form-group">
                    <label class="form-label">عميل</label>
                    <select class="form-control" id="reportCustomerId">
                        <option value="">كل العملاء</option>
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">نوع التقرير</label>
                    <select class="form-control" id="reportType">
                        <option value="summary">ملخص عام</option>
                        <option value="detailed">تقرير مفصل</option>
                        <option value="overdue">الديون المتأخرة</option>
                        <option value="paid">المدفوعات</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">تنسيق التقرير</label>
                    <select class="form-control" id="reportFormat">
                        <option value="html">عرض في الصفحة</option>
                        <option value="pdf">PDF</option>
                        <option value="excel">Excel</option>
                    </select>
                </div>
            </div>

            <div style="display: flex; gap: 10px; margin-bottom: 20px;">
                <button class="btn btn-primary" onclick="loadReports()">
                    <i class="fas fa-chart-line"></i> عرض التقرير
                </button>
                <button class="btn btn-pdf" onclick="printReportsPDF()">
                    <i class="fas fa-file-pdf"></i> طباعة PDF
                </button>
                <button class="btn btn-success" onclick="exportReportsToExcel()">
                    <i class="fas fa-file-excel"></i> تصدير Excel
                </button>
            </div>

            <div id="reportsSummary" class="stats-grid"></div>
            <div id="reportsList"></div>
        </div>
    </div>

    <script>
        let currentCustomerId = 0;
        let currentCustomer = null;
        let showDeleted = false;
        let searchTimeout = null;

        // تحميل العملاء عند فتح الصفحة
        document.addEventListener('DOMContentLoaded', function() {
            loadCustomers();
            loadCustomersForSelect();
            loadDashboardStats();
            loadRiskyCustomers();

            // إضافة حدث البحث الفوري
            document.getElementById('searchInput').addEventListener('input', function(e) {
                clearTimeout(searchTimeout);
                const term = e.target.value.trim();

                if (term.length < 2) {
                    document.getElementById('searchResults').style.display = 'none';
                    return;
                }

                searchTimeout = setTimeout(() => {
                    performLiveSearch(term);
                }, 300);
            });

            // إخفاء نتائج البحث عند النقر خارجها
            document.addEventListener('click', function(e) {
                if (!e.target.closest('.search-section')) {
                    document.getElementById('searchResults').style.display = 'none';
                }
            });

            // تحديث تلقائي كل 30 ثانية
            setInterval(() => {
                loadDashboardStats();
                loadRiskyCustomers();
            }, 30000);
        });

        // البحث الفوري
        function performLiveSearch(term) {
            fetch(`/Customers/SearchCustomers?term=${encodeURIComponent(term)}`)
                .then(res => res.json())
                .then(data => {
                    if (data.success && data.customers.length > 0) {
                        const resultsDiv = document.getElementById('searchResults');
                        let html = '';
                        data.customers.forEach(c => {
                            html += `
                                <div class="search-result-item" onclick="showCustomerDetails(${c.id})">
                                    <div><strong>${c.fullName}</strong></div>
                                    <div style="font-size: 12px; color: #666;">
                                        <span>${c.phoneNumber}</span> |
                                        <span class="${c.currentDebt > 0 ? 'text-danger' : 'text-success'}">
                                            الدين: ${c.currentDebt.toLocaleString()} ج.م
                                        </span>
                                    </div>
                                </div>
                            `;
                        });
                        resultsDiv.innerHTML = html;
                        resultsDiv.style.display = 'block';
                    } else {
                        document.getElementById('searchResults').innerHTML = '<div class="p-3 text-center text-muted">لا توجد نتائج</div>';
                        document.getElementById('searchResults').style.display = 'block';
                    }
                });
        }

        // تحميل إحصائيات لوحة التحكم
        function loadDashboardStats() {
            fetch('/Customers/GetDashboardStats')
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        const stats = data.stats;
                        document.getElementById('totalCustomers').innerHTML = `
                            <div class="stat-label"><i class="fas fa-users"></i> إجمالي العملاء</div>
                            <div class="stat-value">${stats.totalCustomers}</div>
                        `;
                        document.getElementById('customersWithDebt').innerHTML = `
                            <div class="stat-label"><i class="fas fa-exclamation-triangle"></i> عملاء عليهم ديون</div>
                            <div class="stat-value">${stats.customersWithDebt}</div>
                        `;
                        document.getElementById('totalDebts').innerHTML = `
                            <div class="stat-label"><i class="fas fa-money-bill-wave"></i> إجمالي الديون</div>
                            <div class="stat-value">${stats.totalDebts.toLocaleString()} ج.م</div>
                        `;
                        document.getElementById('overdueCount').innerHTML = `
                            <div class="stat-label"><i class="fas fa-clock"></i> معاملات متأخرة</div>
                            <div class="stat-value">${stats.overdueTransactions}</div>
                        `;
                    }
                });
        }

        // تحميل العملاء المعرضين للخطر
        function loadRiskyCustomers() {
            fetch('/Customers/GetRiskyCustomers')
                .then(res => res.json())
                .then(data => {
                    if (data.success && data.customers.length > 0) {
                        let html = '<table class="table table-hover"><thead><tr><th>العميل</th><th>رقم الهاتف</th><th>الدين الحالي</th><th>الحد الأقصى</th><th>النسبة</th><th>الحالة</th><th></th></tr></thead><tbody>';
                        data.customers.forEach(c => {
                            const barColor = c.debtPercentage > 90 ? 'bg-danger' : (c.debtPercentage > 70 ? 'bg-warning' : 'bg-info');
                            html += `
                                <tr onclick="showCustomerDetails(${c.id})" style="cursor: pointer;">
                                    <td>${c.fullName}</td>
                                    <td>${c.phoneNumber}</td>
                                    <td class="text-danger fw-bold">${c.currentDebt.toLocaleString()} ج.م</td>
                                    <td>${c.maxDebtLimit.toLocaleString()} ج.م</td>
                                    <td style="min-width: 150px;">
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar ${barColor}" role="progressbar"
                                                 style="width: ${c.debtPercentage}%;"
                                                 aria-valuenow="${c.debtPercentage}" aria-valuemin="0" aria-valuemax="100">
                                                ${c.debtPercentage.toFixed(1)}%
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="badge ${c.debtPercentage > 90 ? 'bg-danger' : 'bg-warning'}">${c.warningMessage}</span></td>
                                    <td><button class="btn btn-sm btn-primary" onclick="showCustomerDetails(${c.id})"><i class="fas fa-eye"></i></button></td>
                                </tr>
                            `;
                        });
                        html += '</tbody></table>';
                        document.getElementById('riskyCustomersList').innerHTML = html;
                    } else {
                        document.getElementById('riskyCustomersList').innerHTML = '<div class="text-center text-success py-4"><i class="fas fa-check-circle fa-3x mb-3"></i><h5>لا يوجد عملاء معرضون للخطر</h5></div>';
                    }
                });
        }

        // تحميل قائمة العملاء
        function loadCustomers() {
            const search = document.getElementById('searchInput').value;
            let url = '';

            if (showDeleted === 'all') {
                url = `/Customers/GetAllCustomers?search=${encodeURIComponent(search)}&showDeleted=all`;
            } else {
                url = `/Customers/GetAllCustomers?search=${encodeURIComponent(search)}&showDeleted=${showDeleted}`;
            }

            fetch(url)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        displayCustomers(data.customers);
                    } else {
                        alert('خطأ في تحميل العملاء: ' + data.message);
                    }
                });
        }

        // عرض العملاء
        function displayCustomers(customers) {
            const container = document.getElementById('customersList');

            if (customers.length === 0) {
                container.innerHTML = '<div class="text-center text-muted py-5" style="grid-column: 1/-1;"><i class="fas fa-users fa-3x mb-3"></i><h5>لا يوجد عملاء</h5></div>';
                return;
            }

            let html = '';
            customers.forEach(c => {
                const debtClass = c.currentDebt > 0 ? 'debt' : 'normal';

                let actionsHtml = '';
                if (showDeleted === true) {
                    actionsHtml = `
                        <button class="btn btn-sm btn-success" onclick="restoreCustomer(${c.id})">
                            <i class="fas fa-undo"></i> استعادة
                        </button>
                    `;
                } else if (showDeleted === 'all') {
                    actionsHtml = `
                        <button class="btn btn-sm btn-info" onclick="showCustomerDetails(${c.id})">
                            <i class="fas fa-eye"></i> عرض
                        </button>
                        ${c.isDeleted ? `
                            <button class="btn btn-sm btn-success" onclick="restoreCustomer(${c.id})">
                                <i class="fas fa-undo"></i> استعادة
                            </button>
                        ` : `
                            <button class="btn btn-sm btn-warning" onclick="editCustomer(${c.id})">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn btn-sm btn-danger" onclick="deleteCustomer(${c.id})">
                                <i class="fas fa-trash"></i>
                            </button>
                        `}
                    `;
                } else {
                    actionsHtml = `
                        <button class="btn btn-sm btn-warning" onclick="editCustomer(${c.id})">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="btn btn-sm btn-danger" onclick="deleteCustomer(${c.id})">
                            <i class="fas fa-trash"></i>
                        </button>
                        <button class="btn btn-sm btn-info" onclick="printCustomerPDF(${c.id})">
                            <i class="fas fa-print"></i>
                        </button>
                    `;
                }

                html += `
                    <div class="customer-card ${debtClass}" onclick="showCustomerDetails(${c.id})">
                        <div class="customer-header">
                            <span class="customer-name">${c.fullName}</span>
                            <span class="customer-code">${c.customerCode}</span>
                        </div>
                        <div class="customer-phone">
                            <i class="fas fa-phone"></i> ${c.phoneNumber}
                            ${c.alternativePhone ? ` | ${c.alternativePhone}` : ''}
                        </div>
                        <div class="customer-debt">
                            <i class="fas fa-money-bill-wave"></i> الدين: ${c.currentDebt.toLocaleString()} ج.م
                        </div>
                        <div style="font-size: 12px; color: #666; margin-top: 5px;">
                            <span class="debt-badge ${c.customerType === 'مميز' ? 'badge-warning' : (c.customerType === 'تاجر' ? 'badge-purple' : 'badge-success')}">${c.customerType}</span>
                            معاملات: ${c.transactionsCount}
                            ${c.isDeleted ? '<span class="debt-badge badge-secondary">محذوف</span>' : ''}
                            ${c.warningMessage ? `<span class="debt-badge badge-danger">${c.warningMessage}</span>` : ''}
                        </div>
                        <div class="customer-actions" onclick="event.stopPropagation()">
                            ${actionsHtml}
                        </div>
                    </div>
                `;
            });

            container.innerHTML = html;
        }

        // استعادة عميل محذوف
        function restoreCustomer(id) {
            if (confirm('هل أنت متأكد من استعادة هذا العميل؟')) {
                fetch(`/Customers/RestoreCustomer?id=${id}`, { method: 'POST' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            alert(data.message);
                            loadCustomers();
                            loadDashboardStats();
                            loadRiskyCustomers();
                        } else {
                            alert(data.message);
                        }
                    });
            }
        }

        // حذف نهائي لعميل
        function hardDeleteCustomer(id, customerName, currentDebt) {
            const message = `⚠️ تحذير شديد!\n\nأنت على وشك حذف العميل "${customerName}" نهائياً.\nالمبلغ المتبقي عليه: ${currentDebt.toLocaleString()} ج.م\n\nهذا الإجراء لا يمكن التراجع عنه وسيحذف كل معاملاته!`;

            if (confirm(message)) {
                if (confirm('❓❓ تأكيد نهائي: هل أنت متأكد تماماً من الحذف النهائي؟')) {
                    fetch(`/Customers/HardDeleteCustomer?id=${id}`, { method: 'POST' })
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                alert(data.message);
                                closeDetailsModal();
                                loadCustomers();
                                loadDashboardStats();
                                loadRiskyCustomers();
                            } else {
                                alert('❌ ' + data.message);
                            }
                        });
                }
            }
        }

        // حذف العميل الحالي نهائياً
        function hardDeleteCurrentCustomer() {
            if (currentCustomer) {
                hardDeleteCustomer(currentCustomerId, currentCustomer.fullName, currentCustomer.currentDebt);
            }
        }

        // تحميل العملاء للقوائم المنسدلة
        function loadCustomersForSelect() {
            fetch('/Customers/GetAllCustomers?showDeleted=false')
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        const select = document.getElementById('reportCustomerId');
                        data.customers.forEach(c => {
                            select.innerHTML += `<option value="${c.id}">${c.fullName} (${c.phoneNumber})</option>`;
                        });
                    }
                });
        }

        // تبديل التبويب الرئيسي
        function switchTab(tab, value) {
            document.querySelectorAll('.tab').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            showDeleted = value;
            loadCustomers();
        }

        // إظهار مودال إضافة عميل
        function showAddCustomerModal() {
            document.getElementById('customerModalTitle').innerText = 'إضافة عميل جديد';
            document.getElementById('customerId').value = '0';
            document.getElementById('fullName').value = '';
            document.getElementById('phoneNumber').value = '';
            document.getElementById('alternativePhone').value = '';
            document.getElementById('idNumber').value = '';
            document.getElementById('email').value = '';
            document.getElementById('address').value = '';
            document.getElementById('customerType').value = 'عادي';
            document.getElementById('maxDebtLimit').value = '';
            document.getElementById('notes').value = '';
            document.getElementById('customerModal').style.display = 'block';
        }

        // إغلاق مودال العميل
        function closeCustomerModal() {
            document.getElementById('customerModal').style.display = 'none';
        }

        // حفظ العميل
        function saveCustomer() {
            const id = document.getElementById('customerId').value;
            const data = {
                id: id,
                fullName: document.getElementById('fullName').value,
                phoneNumber: document.getElementById('phoneNumber').value,
                alternativePhone: document.getElementById('alternativePhone').value || null,
                idNumber: document.getElementById('idNumber').value || null,
                email: document.getElementById('email').value || null,
                address: document.getElementById('address').value || null,
                customerType: document.getElementById('customerType').value,
                maxDebtLimit: document.getElementById('maxDebtLimit').value ? parseFloat(document.getElementById('maxDebtLimit').value) : null,
                notes: document.getElementById('notes').value || null,
                isActive: true
            };

            const url = id === '0' ? '/Customers/AddCustomer' : '/Customers/UpdateCustomer';

            fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert(data.message);
                    closeCustomerModal();
                    loadCustomers();
                    loadDashboardStats();
                    loadRiskyCustomers();
                } else {
                    alert(data.message);
                }
            });
        }

        // تعديل عميل
        function editCustomer(id) {
            fetch(`/Customers/GetCustomerDetails?id=${id}`)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        const c = data.customer;
                        document.getElementById('customerModalTitle').innerText = 'تعديل بيانات العميل';
                        document.getElementById('customerId').value = id;
                        document.getElementById('fullName').value = c.fullName;
                        document.getElementById('phoneNumber').value = c.phoneNumber;
                        document.getElementById('alternativePhone').value = c.alternativePhone || '';
                        document.getElementById('idNumber').value = c.idNumber || '';
                        document.getElementById('email').value = c.email || '';
                        document.getElementById('address').value = c.address || '';
                        document.getElementById('customerType').value = c.customerType;
                        document.getElementById('maxDebtLimit').value = c.maxDebtLimit || '';
                        document.getElementById('notes').value = c.notes || '';
                        document.getElementById('customerModal').style.display = 'block';
                    }
                });
        }

        // حذف عميل (ناعم)
        function deleteCustomer(id) {
            if (confirm('هل أنت متأكد من حذف هذا العميل؟')) {
                fetch(`/Customers/SoftDeleteCustomer?id=${id}`, { method: 'POST' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            alert(data.message);
                            loadCustomers();
                            loadDashboardStats();
                            loadRiskyCustomers();
                        } else {
                            alert(data.message);
                        }
                    });
            }
        }

        // إظهار تفاصيل العميل
        function showCustomerDetails(id) {
            currentCustomerId = id;
            fetch(`/Customers/GetCustomerDetails?id=${id}`)
