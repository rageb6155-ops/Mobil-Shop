                        <div style="margin-bottom: 10px;">
                            <div style="display: flex; justify-content: space-between;">
                                <span>نسبة السداد</span>
                                <span class="fw-bold ${paidPercentage >= 70 ? 'text-success' : 'text-danger'}">${paidPercentage.toFixed(1)}%</span>
                            </div>
                            <div class="progress" style="height: 10px;">
                                <div class="progress-bar ${paidPercentage >= 70 ? 'bg-success' : 'bg-warning'}"
                                     role="progressbar"
                                     style="width: ${Math.min(paidPercentage, 100)}%;">
                                </div>
                            </div>
                        </div>

                        <div class="row text-center mt-3">
                            <div class="col-4">
                                <div class="p-2">
                                    <span class="badge ${customer.activeTransactions > 0 ? 'bg-warning' : 'bg-success'}">${customer.activeTransactions || 0}</span>
                                    <div class="small">معاملات نشطة</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="p-2">
                                    <span class="badge ${customer.overdueTransactions > 0 ? 'bg-danger' : 'bg-success'}">${customer.overdueTransactions || 0}</span>
                                    <div class="small">معاملات متأخرة</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="p-2">
                                    <span class="badge bg-success">${customer.completedTransactions || 0}</span>
                                    <div class="small">معاملات مكتملة</div>
                                </div>
                            </div>
                        </div>

                        <div class="alert ${paidPercentage >= 80 ? 'alert-success' : (paidPercentage >= 50 ? 'alert-warning' : 'alert-danger')} mt-3">
                            <i class="fas fa-chart-line"></i>
                            ${paidPercentage >= 80 ? '🌟 عميل ممتاز - نسبة سداد عالية' :
                              (paidPercentage >= 50 ? '⚠️ عميل متوسط - يحتاج متابعة' :
                               '❌ عميل高风险 - نسبة سداد منخفضة')}
