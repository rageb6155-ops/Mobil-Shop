        // عرض ملخص الأقساط
        function displayInstallmentsSummary(transactions) {
            const installmentTransactions = transactions.filter(t => t.isInstallment);

            if (installmentTransactions.length === 0) {
                document.getElementById('installmentsSummary').innerHTML = '<p class="text-center text-muted py-3">لا توجد معاملات مقسمة لأقساط</p>';
                document.getElementById('installmentsList').innerHTML = '';
                return;
            }

            let totalInstallments = 0;
            let paidInstallments = 0;
            let totalAmount = 0;
            let paidAmount = 0;

            installmentTransactions.forEach(t => {
                if (t.installments) {
                    totalInstallments += t.installments.length;
                    paidInstallments += t.installments.filter(i => i.isPaid).length;
                    totalAmount += t.amount;
                    paidAmount += t.paidAmount;
                }
            });

            const progress = totalInstallments > 0 ? (paidInstallments * 100 / totalInstallments) : 0;

            const summaryHtml = `
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-value">${installmentTransactions.length}</div>
                        <div class="stat-label">معاملات مقسمة</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">${totalInstallments}</div>
                        <div class="stat-label">إجمالي الأقساط</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">${paidInstallments}</div>
                        <div class="stat-label">أقساط مدفوعة</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">${progress.toFixed(1)}%</div>
                        <div class="stat-label">نسبة التقدم</div>
                    </div>
                </div>
                <div class="progress mb-3" style="height: 20px;">
                    <div class="progress-bar ${progress >= 100 ? 'bg-success' : 'bg-primary'}"
                         role="progressbar"
                         style="width: ${progress}%;">
                        ${progress.toFixed(1)}%
                    </div>
                </div>
            `;

            document.getElementById('installmentsSummary').innerHTML = summaryHtml;

            // عرض تفاصيل الأقساط
            let listHtml = '';
            installmentTransactions.forEach(t => {
                listHtml += `
                    <div class="transaction-item">
                        <div class="transaction-header">
                            <span class="transaction-type">${t.transactionNumber}</span>
                            <span class="badge bg-info">${t.installments ? t.installments.length : 0} أقساط</span>
                        </div>
                        ${displayInstallments(t.installments, t.installmentProgress)}
                    </div>
                `;
            });
            document.getElementById('installmentsList').innerHTML = listHtml;
        }

        // عرض المعاملات
        function displayTransactions(transactions) {
            if (!transactions || transactions.length === 0) {
                document.getElementById('transactionsList').innerHTML = '<p class="text-center text-muted py-3">لا توجد معاملات</p>';
                document.getElementById('transactionsStats').innerHTML = '';
                return;
            }

            // إحصائيات المعاملات
            let totalAdditions = 0, totalDeductions = 0, totalLoans = 0;
            transactions.forEach(t => {
                if (t.transactionType === 'مكافأة') totalAdditions += t.amount;
                else if (t.transactionType === 'خصم') totalDeductions += t.amount;
                else if (t.transactionType === 'سلفة') totalLoans += t.amount;
            });

            document.getElementById('transactionsStats').innerHTML = `
                <div class="stat-card">
                    <div class="stat-value amount-positive">${totalAdditions.toLocaleString()} ج.م</div>
                    <div class="stat-label">إجمالي المكافآت</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value amount-negative">${totalDeductions.toLocaleString()} ج.م</div>
                    <div class="stat-label">إجمالي الخصومات</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value amount-primary">${totalLoans.toLocaleString()} ج.م</div>
                    <div class="stat-label">إجمالي السلف</div>
                </div>
            `;

            let html = '<div class="transactions-list">';
            transactions.forEach(t => {
                const statusClass = t.status === 'مكتمل' ? 'badge-success' : (t.status === 'متأخر' ? 'badge-danger' : 'badge-warning');
                const overdueBadge = t.isOverdue ? '<span class="badge bg-danger me-2">⚠️ متأخر ' + t.overdueDays + ' يوم</span>' : '';

                html += `
                    <div class="transaction-item ${t.isOverdue ? 'border-danger' : ''}">
                        <div class="transaction-header">
                            <span>
                                <span class="transaction-type">${t.transactionType}</span>
                                ${overdueBadge}
                            </span>
                            <span class="transaction-status ${statusClass}">${t.status}</span>
                        </div>
                        <div style="font-size: 13px;">
                            <div class="row">
                                <div class="col-md-6">
                                    <div>💰 المبلغ: ${t.amount.toLocaleString()} ج.م</div>
                                    <div>💵 مدفوع: ${t.paidAmount.toLocaleString()} ج.م</div>
                                    <div>📊 المتبقي: <span class="fw-bold ${t.remainingAmount > 0 ? 'text-danger' : 'text-success'}">${t.remainingAmount.toLocaleString()} ج.م</span></div>
                                </div>
                                <div class="col-md-6">
                                    <div>📅 التاريخ: ${new Date(t.transactionDate).toLocaleString('ar-EG')}</div>
                                    ${t.dueDate ? `<div>⏰ تاريخ الاستحقاق: ${new Date(t.dueDate).toLocaleDateString('ar-EG')}</div>` : ''}
                                    ${t.saleNumber ? `<div>🧾 رقم الفاتورة: ${t.saleNumber}</div>` : ''}
                                    <div>👤 بواسطة: ${t.createdByName}</div>
                                </div>
                            </div>

                            <!-- شريط التقدم لنسبة السداد -->
                            <div class="mt-2">
                                <div class="d-flex justify-content-between">
                                    <small>نسبة السداد</small>
                                    <small class="fw-bold ${t.paidPercentage >= 100 ? 'text-success' : ''}">${t.paidPercentage.toFixed(1)}%</small>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar ${t.paidPercentage >= 100 ? 'bg-success' : 'bg-primary'}"
                                         role="progressbar"
                                         style="width: ${Math.min(t.paidPercentage, 100)}%;"
                                         aria-valuenow="${t.paidPercentage}" aria-valuemin="0" aria-valuemax="100">
                                    </div>
                                </div>
                            </div>
                        </div>
                        ${t.isInstallment ? displayInstallments(t.installments, t.installmentProgress) : ''}
                    </div>
                `;
            });
            html += '</div>';
            document.getElementById('transactionsList').innerHTML = html;
        }

        // عرض الأقساط
        function displayInstallments(installments, progress) {
            if (!installments || installments.length === 0) return '';

            let html = `<div class="mt-2"><small>تقدم الأقساط: ${progress || 0}%</small>`;
            html += '<div class="installments-grid mt-2">';
            installments.forEach(i => {
                const paidClass = i.isPaid ? 'paid' : '';
                const overdueClass = i.isOverdue ? 'overdue' : '';
                html += `
                    <div class="installment-item ${paidClass} ${overdueClass}" onclick="payInstallment(${i.id}, ${i.amount})">
                        <div class="installment-number">القسط ${i.installmentNumber}</div>
                        <div class="installment-amount">${i.amount.toLocaleString()} ج.م</div>
                        <div class="installment-due">${new Date(i.dueDate).toLocaleDateString('ar-EG')}</div>
                        ${i.isOverdue ? '<div class="text-danger"><i class="fas fa-exclamation-circle"></i> متأخر ' + i.overdueDays + ' يوم</div>' : ''}
                        ${i.isPaid ? '<div><i class="fas fa-check-circle text-success"></i> مدفوع</div>' : ''}
                        ${i.paymentMethod ? `<div><small>طريقة الدفع: ${i.paymentMethod}</small></div>` : ''}
                    </div>
                `;
            });
            html += '</div></div>';
            return html;
        }

        // عرض الديون النشطة
        function displayActiveDebts(debts) {
            if (!debts || debts.length === 0) {
                document.getElementById('debtsList').innerHTML = '<p class="text-center text-muted py-3">لا توجد ديون نشطة</p>';
                return;
            }

            let html = '<div class="table-responsive"><table class="table table-bordered"><thead><tr><th>رقم المعاملة</th><th>المبلغ</th><th>المدفوع</th><th>المتبقي</th><th>تاريخ الاستحقاق</th><th>الحالة</th><th>إجراءات</th></tr></thead><tbody>';
            debts.forEach(d => {
                const statusClass = d.isOverdue ? 'bg-danger' : 'bg-warning';
                const statusText = d.isOverdue ? 'متأخر' : 'نشط';
                html += `
                    <tr>
                        <td>${d.transactionNumber}</td>
                        <td>${d.amount.toLocaleString()} ج.م</td>
                        <td>${d.paidAmount.toLocaleString()} ج.م</td>
                        <td class="fw-bold text-danger">${d.remainingAmount.toLocaleString()} ج.م</td>
                        <td>${d.dueDate ? new Date(d.dueDate).toLocaleDateString('ar-EG') : '-'}</td>
                        <td><span class="badge ${statusClass}">${statusText}</span></td>
                        <td>
                            <button class="btn btn-sm btn-success" onclick="quickPayment(${d.id}, ${d.remainingAmount})">
                                <i class="fas fa-money-bill"></i> دفع
                            </button>
                        </td>
                    </tr>
                `;
            });
            html += '</tbody></table></div>';
            document.getElementById('debtsList').innerHTML = html;
        }

        // دفع سريع
        function quickPayment(transactionId, amount) {
            const paidAmount = prompt('المبلغ المدفوع:', amount);
            if (paidAmount === null) return;

            const paidValue = parseFloat(paidAmount);
            if (isNaN(paidValue) || paidValue <= 0) {
                alert('❌ الرجاء إدخال مبلغ صحيح');
                return;
            }

            const data = {
                customerId: currentCustomerId,
                transactionType: 'دفعة',
                amount: paidValue,
                paidAmount: paidValue,
                dueDate: new Date().toISOString().split('T')[0],
                notes: 'دفعة سريعة',
                isInstallment: false
            };

            fetch('/Customers/AddTransaction', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert(data.message);
                    showCustomerDetails(currentCustomerId);
                    loadDashboardStats();
                    loadRiskyCustomers();
                } else {
                    alert('❌ ' + data.message);
                }
            });
        }

        // دفع قسط
        function payInstallment(installmentId, amount) {
            const paidAmount = prompt('المبلغ المدفوع:', amount);
            if (paidAmount === null) return;

            const paidValue = parseFloat(paidAmount);
            if (isNaN(paidValue) || paidValue <= 0) {
                alert('❌ الرجاء إدخال مبلغ صحيح');
                return;
            }

            if (paidValue < amount) {
                if (!confirm(`⚠️ المبلغ المدفوع (${paidValue} ج.م) أقل من قيمة القسط (${amount} ج.م). هل تريد المتابعة؟`)) {
                    return;
                }
            }

            const data = {
                installmentId: installmentId,
                amount: paidValue,
                paymentMethod: document.getElementById('paymentMethod')?.value || 'نقدي'
            };

            fetch('/Customers/PayInstallment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert(data.message);
                    showCustomerDetails(currentCustomerId);
                    loadDashboardStats();
                    loadRiskyCustomers();

                    if (data.invoice) {
                        setTimeout(() => {
                            printCustomerInvoice(data.invoice);
                        }, 500);
                    }
                } else {
                    alert('❌ ' + data.message);
                }
            });
        }

