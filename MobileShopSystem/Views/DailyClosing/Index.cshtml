@{
    ViewBag.Title = "تقفيل الحساب";
    var username = Context.Session.GetString("Username");
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: #ffffff;
            margin: 0;
            padding: 20px;
            color: #333;
        }

        .page-wrapper {
            max-width: 800px;
            margin: 0 auto;
        }

        /* بطاقة العنوان */
        .header-card {
            background: white;
            border-radius: 16px;
            padding: 20px 25px;
            margin-bottom: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .header-title h1 {
            margin: 0;
            font-size: 26px;
            font-weight: 600;
            color: #ff416c;
        }

        .header-title p {
            margin: 5px 0 0;
            color: #6c757d;
            font-size: 14px;
        }

        .user-info {
            background: #f8f9fa;
            color: #ff416c;
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 500;
            border: 1px solid #e9ecef;
        }

            .user-info i {
                margin-left: 8px;
            }

        /* بطاقة المحتوى */
        .content-card {
            background: white;
            border-radius: 16px;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
        }

        .content-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
            color: #ff416c;
            font-weight: 600;
            font-size: 22px;
            padding-bottom: 10px;
            border-bottom: 2px solid #f0f0f0;
        }

            .content-title i {
                font-size: 24px;
            }

        /* التنبيهات */
        .alert {
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .alert-success {
            background: #d4edda;
            color: #155724;
            border-right: 3px solid #28a745;
        }

        .alert-danger {
            background: #f8d7da;
            color: #721c24;
            border-right: 3px solid #dc3545;
        }

        /* النموذج */
        .form-label {
            font-weight: 500;
            color: #ff416c;
            margin-bottom: 5px;
            display: block;
        }

        .form-control {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e9ecef;
            border-radius: 10px;
            font-size: 14px;
            transition: all 0.3s;
            background: #f8f9fa;
        }

            .form-control:focus {
                outline: none;
                border-color: #ff416c;
                background: white;
                box-shadow: 0 5px 20px rgba(255, 65, 108, 0.1);
            }

        /* قسم الماكينات */
        .machines-section {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 20px;
            margin: 20px 0;
        }

        .section-title {
            display: flex;
            align-items: center;
            gap: 10px;
            color: #ff416c;
            font-weight: 600;
            margin-bottom: 15px;
        }

        .machine-row {
            background: white;
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 15px;
            border: 1px solid #e9ecef;
            transition: all 0.3s;
        }

            .machine-row:hover {
                box-shadow: 0 5px 15px rgba(255, 65, 108, 0.1);
            }

        /* الأزرار */
        .btn {
            padding: 10px 20px;
            border-radius: 8px;
            color: #fff;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
            border: none;
            cursor: pointer;
            margin: 3px;
        }

            .btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            }

        .btn-secondary {
            background: #6c757d;
        }

            .btn-secondary:hover {
                background: #5a6268;
            }

        .btn-success {
            background: #28a745;
        }

            .btn-success:hover {
                background: #218838;
            }

        .btn-dark {
            background: #343a40;
        }

            .btn-dark:hover {
                background: #23272b;
            }

        .btn-add {
            background: #ff416c;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 20px;
        }

            .btn-add:hover {
                background: #ff1e4f;
                transform: translateY(-2px);
            }

        .action-buttons {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="page-wrapper">

        <!-- بطاقة العنوان -->
        <div class="header-card">
            <div class="header-title">
                <h1>
                    <i class="fas fa-calculator"></i> تقفيل الحساب اليومي
                </h1>
                <p>إدخال بيانات التقفيل اليومي للماكينات</p>
            </div>
            <div class="user-info">
                <i class="fas fa-user-circle"></i>
                @username
            </div>
        </div>

        <!-- بطاقة المحتوى -->
        <div class="content-card">
            <div class="content-title">
                <i class="fas fa-file-invoice"></i>
                <span>بيانات التقفيل</span>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    <i class="fas fa-check-circle"></i> @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
                </div>
            }

            <form asp-action="Save" method="post">

                <!-- الرصيد المالي -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label">
                            <i class="fas fa-money-bill"></i> الفلوس المتبقية
                        </label>
                        <input type="number" step="0.01" name="CashLeft" class="form-control" placeholder="أدخل المبلغ" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">
                            <i class="fas fa-coins"></i> الفضة
                        </label>
                        <input type="number" step="0.01" name="CoinsAmount" class="form-control" placeholder="أدخل المبلغ" required />
                    </div>
                </div>

                <hr style="border-top: 2px dashed #e9ecef; margin: 25px 0;" />

                <!-- الماكينات -->
                <div class="machines-section">
                    <div class="section-title">
                        <i class="fas fa-cogs"></i>
                        <span>الماكينات</span>
                    </div>

                    <div id="machinesContainer">
                        <div class="machine-row">
                            <div class="row">
                                <div class="col-md-6">
                                    <label class="form-label">اسم الماكينة</label>
                                    <input type="text" name="machineNames" class="form-control" placeholder="أدخل اسم الماكينة" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">الرصيد</label>
                                    <input type="number" step="0.01" name="balances" class="form-control" placeholder="أدخل الرصيد" required />
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="button" class="btn-add" onclick="addMachine()">
                        <i class="fas fa-plus-circle"></i> إضافة ماكينة جديدة
                    </button>
                </div>

                <!-- أزرار الإجراءات -->
                <div class="action-buttons">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> حفظ التقفيل
                    </button>
                    <a asp-action="Reports" class="btn btn-dark">
                        <i class="fas fa-chart-bar"></i> عرض التقارير
                    </a>
                </div>

            </form>
        </div>
    </div>

    <script>
        function addMachine() {
            var container = document.getElementById("machinesContainer");

            var html = `
            <div class="machine-row">
                <div class="row">
                    <div class="col-md-6">
                        <label class="form-label">اسم الماكينة</label>
                        <input type="text" name="machineNames" class="form-control" placeholder="أدخل اسم الماكينة" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">الرصيد</label>
                        <input type="number" step="0.01" name="balances" class="form-control" placeholder="أدخل الرصيد" required />
                    </div>
                </div>
            </div>`;

            container.insertAdjacentHTML('beforeend', html);
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>