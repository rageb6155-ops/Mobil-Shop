@model List<MobileShopSystem.Models.Device>
@{
    ViewData["Title"] = "إدارة الأجهزة";
    var username = Context.Session.GetString("Username");
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <!-- المكتبات المطلوبة للطباعة -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: #f4f6f9;
            margin: 0;
            padding: 20px;
            color: #333;
        }

        .page-wrapper {
            max-width: 1400px;
            margin: 0 auto;
        }

        /* بطاقة العنوان */
        .header-card {
            background: white;
            border-radius: 16px;
            padding: 20px 25px;
            margin-bottom: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .header-title h1 {
            margin: 0;
            font-size: 26px;
            font-weight: 600;
            color: #00c6ff;
        }

        .header-title p {
            margin: 5px 0 0;
            color: #6c757d;
            font-size: 14px;
        }

        .user-info {
            background: #f8f9fa;
            color: #00c6ff;
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 500;
            border: 1px solid #e9ecef;
        }

            .user-info i {
                margin-left: 8px;
            }

        /* بطاقة الإضافة */
        .add-card {
            background: white;
            border-radius: 16px;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
            margin-bottom: 25px;
        }

        .add-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
            color: #00c6ff;
            font-weight: 600;
            font-size: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #f0f0f0;
        }

            .add-title i {
                font-size: 24px;
            }

        /* التنبيهات */
        .alert {
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .alert-success {
            background: #d4edda;
            color: #155724;
            border-right: 3px solid #28a745;
        }

        .alert-danger {
            background: #f8d7da;
            color: #721c24;
            border-right: 3px solid #dc3545;
        }

        /* البحث */
        .search-card {
            background: white;
            border-radius: 16px;
            padding: 20px 25px;
            margin-bottom: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
        }

        .search-label {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 15px;
            color: #333;
            font-weight: 500;
        }

            .search-label i {
                color: #00c6ff;
                font-size: 20px;
            }

        .search-input {
            width: 100%;
            padding: 12px 20px;
            border: 2px solid #e9ecef;
            border-radius: 50px;
            font-size: 15px;
            transition: all 0.3s;
            background: #f8f9fa;
        }

            .search-input:focus {
                outline: none;
                border-color: #00c6ff;
                background: white;
                box-shadow: 0 5px 20px rgba(0, 198, 255, 0.1);
            }

        /* بطاقة الجدول */
        .table-card {
            background: white;
            border-radius: 16px;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
        }

        .table-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
            color: #00c6ff;
            font-weight: 600;
            font-size: 20px;
        }

            .table-title i {
                font-size: 24px;
            }

        /* الجدول */
        .table-responsive {
            overflow-x: auto;
            border-radius: 12px;
        }

        .devices-table {
            width: 100%;
            border-collapse: collapse;
            background: white;
        }

            .devices-table th {
                background: #00c6ff;
                color: white;
                padding: 12px;
                font-weight: 500;
                font-size: 14px;
                text-align: center;
            }

            .devices-table td {
                padding: 12px;
                border-bottom: 1px solid #e9ecef;
                text-align: center;
                color: #333;
                font-size: 13px;
            }

            .devices-table tbody tr {
                transition: all 0.3s;
            }

                .devices-table tbody tr:hover {
                    background: #f0f8ff;
                }

                .devices-table tbody tr.table-warning {
                    background: #fff3cd;
                }

        /* الأزرار */
        .btn {
            padding: 8px 15px;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            margin: 2px;
            color: white;
            text-decoration: none;
        }

            .btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            }

        .btn-primary {
            background: #00c6ff;
        }

            .btn-primary:hover {
                background: #00b0e0;
            }

        .btn-secondary {
            background: #6c757d;
        }

            .btn-secondary:hover {
                background: #5a6268;
            }

        .btn-info {
            background: #17a2b8;
        }

        .btn-success {
            background: #28a745;
        }

        .btn-danger {
            background: #dc3545;
        }

        .btn-warning {
            background: #ffc107;
            color: #333;
        }

        /* شارة الحالة */
        .badge {
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 500;
        }

            .badge.bg-success {
                background: #d4edda;
                color: #155724;
            }

            .badge.bg-warning {
                background: #fff3cd;
                color: #856404;
            }

            .badge.bg-secondary {
                background: #e2e3e5;
                color: #383d41;
            }

        /* قالب الطباعة المخفي */
        #invoiceTemplate {
            display: none;
            width: 80mm;
            background: white;
            padding: 10px;
            font-family: 'Arial', sans-serif;
            direction: rtl;
            text-align: center;
            position: fixed;
            top: -9999px;
            left: -9999px;
        }
    </style>
</head>
<body>
    <div class="page-wrapper">

        <!-- بطاقة العنوان -->
        <div class="header-card">
            <div class="header-title">
                <h1>
                    <i class="fas fa-mobile-alt"></i> إدارة الأجهزة
                </h1>
                <p>إضافة وتعديل ومتابعة الأجهزة</p>
            </div>
            <div class="user-info">
                <i class="fas fa-user-circle"></i>
                @username
            </div>
        </div>

        <!-- رسائل التنبيه -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
            </div>
        }

        <!-- بطاقة إضافة/تعديل جهاز -->
        <div class="add-card">
            <div class="add-title">
                <i class="fas fa-plus-circle"></i>
                <span>إضافة / تعديل جهاز</span>
            </div>
            <form method="post" asp-action="Create" id="deviceForm">
                <input type="hidden" id="Id" name="Id" value="0" />
                <input type="hidden" name="submitType" id="submitType" value="Create" />

                <div class="row mb-3">
                    <div class="col-md-6">
                        <input id="Name" name="Name" class="form-control" placeholder="اسم الجهاز" required />
                    </div>
                    <div class="col-md-6">
                        <input id="Serial" name="Serial" class="form-control" placeholder="السيريال" required />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <input id="Storage" name="Storage" type="number" class="form-control" placeholder="السعة (GB)" required />
                    </div>
                    <div class="col-md-6">
                        <input id="RAM" name="RAM" type="number" class="form-control" placeholder="الرام (GB)" required />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <input id="PurchasePrice" name="PurchasePrice" type="number" step="0.01" class="form-control" placeholder="سعر الشراء" required />
                    </div>
                    <div class="col-md-6">
                        <input id="SalePrice" name="SalePrice" type="number" step="0.01" class="form-control" placeholder="سعر البيع" required />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <input id="OwnerType" name="OwnerType" class="form-control" placeholder="نوع المالك" />
                    </div>
                    <div class="col-md-6">
                        <input id="OwnerName" name="OwnerName" class="form-control" placeholder="اسم المالك" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <input id="OwnerPhone" name="OwnerPhone" class="form-control" placeholder="رقم الهاتف" />
                    </div>
                    <div class="col-md-6">
                        <input id="OwnerID" name="OwnerID" class="form-control" placeholder="رقم الهوية" />
                    </div>
                </div>

                <div style="display: flex; gap: 10px;">
                    <button type="submit" class="btn btn-primary" id="saveBtn">
                        <i class="fas fa-save"></i> حفظ الجهاز
                    </button>
                    <button type="button" class="btn btn-secondary" onclick="resetForm()">
                        <i class="fas fa-eraser"></i> تفريغ
                    </button>
                </div>
            </form>
        </div>

        <!-- بطاقة البحث -->
        <div class="search-card">
            <div class="search-label">
                <i class="fas fa-search"></i>
                <span>ابحث عن جهاز</span>
            </div>
            <input type="text" id="searchInput" class="search-input" placeholder="ابحث بالاسم أو السيريال..." />
        </div>

        <!-- بطاقة الجدول -->
        <div class="table-card">
            <div class="table-title">
                <i class="fas fa-list"></i>
                <span>قائمة الأجهزة</span>
            </div>
            <div class="table-responsive">
                <table class="devices-table" id="devicesTable">
                    <thead>
                        <tr>
                            <th>الاسم</th>
                            <th>السيريال</th>
                            <th>السعة</th>
                            <th>الرام</th>
                            <th>الحالة</th>
                            <th>أضيف بواسطة</th>
                            <th>تاريخ الإضافة</th>
                            <th>آخر تعديل</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model)
                        {
                            string rowClass = d.Status == "تم تعديل" ? "table-warning" : "";
                            <tr class="@rowClass"
                                data-id="@d.Id"
                                data-name="@d.Name"
                                data-serial="@d.Serial"
                                data-storage="@d.Storage"
                                data-ram="@d.RAM"
                                data-purchase="@d.PurchasePrice"
                                data-sale="@d.SalePrice"
                                data-ownertype="@d.OwnerType"
                                data-ownername="@d.OwnerName"
                                data-ownerphone="@d.OwnerPhone"
                                data-ownerid="@d.OwnerID">

                                <td>@d.Name</td>
                                <td>@d.Serial</td>
                                <td>@d.Storage</td>
                                <td>@d.RAM</td>

                                <td>
                                    @if (d.Status == "سليم")
                                    {
                                        <span class="badge bg-success"><i class="fas fa-check"></i> سليم</span>
                                    }
                                    else if (d.Status == "تم تعديل")
                                    {
                                        <span class="badge bg-warning"><i class="fas fa-edit"></i> تم تعديل</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@d.Status</span>
                                    }
                                </td>

                                <td><i class="fas fa-user"></i> @d.CreatedBy</td>
                                <td><i class="far fa-calendar-alt"></i> @d.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>

                                <td>
                                    @if (d.UpdatedAt != null)
                                    {
                                        <div>
                                            <strong>@d.UpdatedBy</strong><br />
                                            <small>@d.UpdatedAt?.ToString("yyyy-MM-dd HH:mm")</small>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">لا يوجد</span>
                                    }
                                </td>

                                <td>
                                    <div style="display: flex; gap: 5px; justify-content: center; flex-wrap: wrap;">
                                        <button type="button" class="btn btn-info btn-sm" onclick="editDevice(this)" title="تعديل">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <a asp-action="Details" asp-route-id="@d.Id" class="btn btn-success btn-sm" title="التفاصيل">
                                            <i class="fas fa-info-circle"></i>
                                        </a>
                                        <button type="button" class="btn btn-primary btn-sm" onclick="printDevice(@d.Id)" title="طباعة">
                                            <i class="fas fa-print"></i>
                                        </button>
                                        <button type="button" class="btn btn-danger btn-sm" onclick="confirmDelete(@d.Id)" title="حذف نهائي">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- إخفاء قالب الفاتورة -->
    <div id="invoiceTemplate" style="display: none; width: 80mm; background: white; padding: 0; margin: 0; font-family: 'Arial', sans-serif; direction: rtl; text-align: center; position: fixed; top: -9999px; left: -9999px;">
        <div id="invoiceContent"></div>
    </div>

    <script>
        function searchDevices() {
            var input = document.getElementById("searchInput").value.toLowerCase();
            var rows = document.querySelectorAll("#devicesTable tbody tr");
            rows.forEach(row => {
                var name = row.cells[0].innerText.toLowerCase();
                var serial = row.cells[1].innerText.toLowerCase();
                row.style.display = (name.includes(input) || serial.includes(input)) ? "" : "none";
            });
        }

        document.getElementById("searchInput").addEventListener("keyup", searchDevices);
        document.getElementById("searchInput").addEventListener("paste", function() {
            setTimeout(searchDevices, 100);
        });

        function editDevice(btn) {
            var tr = btn.closest("tr");
            document.getElementById("Id").value = tr.dataset.id;
            document.getElementById("Name").value = tr.dataset.name;
            document.getElementById("Serial").value = tr.dataset.serial;
            document.getElementById("Storage").value = tr.dataset.storage;
            document.getElementById("RAM").value = tr.dataset.ram;
            document.getElementById("PurchasePrice").value = tr.dataset.purchase;
            document.getElementById("SalePrice").value = tr.dataset.sale;
            document.getElementById("OwnerType").value = tr.dataset.ownertype || '';
            document.getElementById("OwnerName").value = tr.dataset.ownername || '';
            document.getElementById("OwnerPhone").value = tr.dataset.ownerphone || '';
            document.getElementById("OwnerID").value = tr.dataset.ownerid || '';

            document.getElementById("submitType").value = "Update";
            document.getElementById("saveBtn").innerHTML = '<i class="fas fa-edit"></i> تعديل الجهاز';
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function resetForm() {
            document.getElementById("deviceForm").reset();
            document.getElementById("Id").value = 0;
            document.getElementById("submitType").value = "Create";
            document.getElementById("saveBtn").innerHTML = '<i class="fas fa-save"></i> حفظ الجهاز';
        }

        function confirmDelete(id) {
            if (confirm("⚠️ هل أنت متأكد أنك تريد حذف هذا الجهاز؟")) {
                if (confirm("⚠️ سيتم الحذف نهائيًا! هل تريد الاستمرار؟")) {
                    fetch('/Devices/DeletePermanent/' + id, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                        }
                    })
                    .then(res => {
                        if (res.ok) location.reload();
                        else alert("حدث خطأ أثناء حذف الجهاز!");
                    })
                    .catch(err => alert("حدث خطأ: " + err));
                }
            }
        }

        function printDevice(id) {
            var row = document.querySelector(`tr[data-id="${id}"]`);
            if (!row) {
                alert("لم يتم العثور على بيانات الجهاز!");
                return;
            }

            var deviceData = {
                name: row.dataset.name,
                serial: row.dataset.serial,
                storage: row.dataset.storage,
                ram: row.dataset.ram,
                salePrice: row.dataset.sale,
                ownerType: row.dataset.ownertype,
                ownerName: row.dataset.ownername,
                ownerPhone: row.dataset.ownerphone,
                ownerID: row.dataset.ownerid
            };

            var now = new Date();
            var dateStr = now.getDate() + '/' + (now.getMonth() + 1) + '/' + now.getFullYear();
            var timeStr = now.getHours() + ':' + (now.getMinutes() < 10 ? '0' : '') + now.getMinutes();

            // نفس شكل الفاتورة الأولى بالضبط
            var invoiceHTML = `
                <div style="width: 80mm; margin: 0 auto; background: #fff; border-radius: 8px; padding: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); font-size: 10px; line-height: 1.3; box-sizing: border-box; font-family: 'Segoe UI', Tahoma, sans-serif; text-align: center; display: block;">
                    <!-- رأس الفاتورة -->
                    <div style="text-align: center; border-bottom: 1px dashed #00c6ff; padding-bottom: 8px; margin-bottom: 8px; width: 100%;">
                        <h1 style="font-size: 16px; font-weight: bold; color: #00c6ff; margin: 0;">Mobile📱Shop</h1>
                        <div style="color: #7f8c8d; font-size: 8px; margin-top: 3px;">01064211484</div>
                        <div style="background: #00c6ff; color: white; padding: 4px; font-size: 11px; border-radius: 4px; margin-top: 6px; font-weight: bold;">
                            Device Invoice
                        </div>
                    </div>

                    <!-- معلومات الفاتورة -->
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4px; margin-bottom: 8px; width: 100%;">
                        <div style="background: #f8f9fa; padding: 4px; border-radius: 4px; text-align: center;">
                            <span style="font-size: 7px; color: #7f8c8d; display: block;">رقم الجهاز</span>
                            <span style="font-size: 9px; font-weight: bold; color: #2c3e50; display: block;">${deviceData.serial}</span>
                        </div>
                        <div style="background: #f8f9fa; padding: 4px; border-radius: 4px; text-align: center;">
                            <span style="font-size: 7px; color: #7f8c8d; display: block;">التاريخ</span>
                            <span style="font-size: 9px; font-weight: bold; color: #2c3e50; display: block;">${dateStr}</span>
                        </div>
                        <div style="background: #f8f9fa; padding: 4px; border-radius: 4px; text-align: center;">
                            <span style="font-size: 7px; color: #7f8c8d; display: block;">الساعة</span>
                            <span style="font-size: 9px; font-weight: bold; color: #2c3e50; display: block;">${timeStr}</span>
                        </div>
                        <div style="background: #f8f9fa; padding: 4px; border-radius: 4px; text-align: center;">
                            <span style="font-size: 7px; color: #7f8c8d; display: block;">تمت الطباعة بواسطة</span>
                            <span style="font-size: 9px; font-weight: bold; color: #2c3e50; display: block;">@username</span>
                        </div>
                    </div>

                    <!-- خط منقط -->
                    <div style="border-top: 1px dashed #ccc; margin: 6px 0; width: 100%;"></div>

                    <!-- إحصائيات سريعة -->
                    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 4px; margin: 8px 0; width: 100%;">
                        <div style="background: #f8f9fa; padding: 4px; border-radius: 4px; text-align: center; border-right: 2px solid #00c6ff;">
                            <div style="font-size: 6px; color: #7f8c8d;">السعة</div>
                            <div style="font-size: 9px; font-weight: bold; color: #2c3e50;">${deviceData.storage} GB</div>
                        </div>
                        <div style="background: #f8f9fa; padding: 4px; border-radius: 4px; text-align: center; border-right: 2px solid #00c6ff;">
                            <div style="font-size: 6px; color: #7f8c8d;">الرام</div>
                            <div style="font-size: 9px; font-weight: bold; color: #2c3e50;">${deviceData.ram} GB</div>
                        </div>
                        <div style="background: #f8f9fa; padding: 4px; border-radius: 4px; text-align: center; border-right: 2px solid #00c6ff;">
                            <div style="font-size: 6px; color: #7f8c8d;">السعر</div>
                            <div style="font-size: 9px; font-weight: bold; color: #27ae60;">${deviceData.salePrice} LE</div>
                        </div>
                    </div>

                    <!-- اسم الجهاز بشكل بارز -->
                    <div style="background: #00c6ff; color: white; padding: 6px; border-radius: 4px; text-align: center; font-size: 11px; font-weight: bold; margin-bottom: 8px; width: 100%;">
                        ${deviceData.name}
                    </div>

                    <!-- تفاصيل الجهاز -->
                    <div style="margin: 10px 0; width: 100%;">
                        <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px dashed #eee; font-size: 9px; width: 100%;">
                            <span style="color: #00c6ff; font-weight: bold;">🔑 السيريال:</span>
                            <span style="color: #333;">${deviceData.serial}</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px dashed #eee; font-size: 9px; width: 100%;">
                            <span style="color: #00c6ff; font-weight: bold;">💾 السعة:</span>
                            <span style="color: #333;">${deviceData.storage} GB</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px dashed #eee; font-size: 9px; width: 100%;">
                            <span style="color: #00c6ff; font-weight: bold;">⚡ الرام:</span>
                            <span style="color: #333;">${deviceData.ram} GB</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px dashed #eee; font-size: 9px; width: 100%;">
                            <span style="color: #00c6ff; font-weight: bold;">👤 المالك:</span>
                            <span style="color: #333;">${deviceData.ownerName || '---'}</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px dashed #eee; font-size: 9px; width: 100%;">
                            <span style="color: #00c6ff; font-weight: bold;">📞 هاتف المالك:</span>
                            <span style="color: #333;">${deviceData.ownerPhone || '---'}</span>
                        </div>
                    </div>

                    <!-- سعر البيع بشكل بارز -->
                    <div style="background: linear-gradient(135deg, #00c6ff, #0072ff); color: white; border-radius: 6px; padding: 8px; margin: 8px 0; width: 100%;">
                        <div style="display: flex; justify-content: space-between; font-size: 12px; font-weight: bold;">
                            <span>💰 سعر البيع</span>
                            <span>${deviceData.salePrice} LE</span>
                        </div>
                    </div>

                    <!-- خط منقط -->
                    <div style="border-top: 1px dashed #ccc; margin: 6px 0; width: 100%;"></div>

                    <!-- الفوتر -->
                    <div style="margin-top: 8px; font-size: 6px; color: #777; text-align: center; border-top: 1px solid #eee; padding-top: 4px; width: 100%;">
                        <div>Mobile📱Shop - ${dateStr}</div>
                        <div>شكراً لتعاملكم معنا ✨</div>
                    </div>
                </div>
            `;

            document.getElementById('invoiceContent').innerHTML = invoiceHTML;
            var element = document.getElementById('invoiceTemplate');
            element.style.display = 'block';
            element.style.padding = '0';
            element.style.margin = '0';

            html2canvas(element, {
                scale: 2,
                backgroundColor: '#ffffff',
                windowWidth: element.scrollWidth,
                windowHeight: element.scrollHeight
            }).then(canvas => {
                var imgData = canvas.toDataURL('image/png');
                const { jsPDF } = window.jspdf;

                var imgWidth = 80;
                var imgHeight = (canvas.height * imgWidth) / canvas.width;

                var doc = new jsPDF({
                    unit: 'mm',
                    format: [80, imgHeight],
                    orientation: 'portrait'
                });

                doc.addImage(imgData, 'PNG', 0, 0, imgWidth, imgHeight);
                doc.save(`فاتورة_${deviceData.serial}.pdf`);
                element.style.display = 'none';
            }).catch(error => {
                alert('حدث خطأ في الطباعة: ' + error.message);
                element.style.display = 'none';
            });
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>