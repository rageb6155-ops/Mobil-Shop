@model MobileShopSystem.ViewModels.ShopRequestViewModel
@{
    ViewData["Title"] = "طلب جديد";
    var username = Context.Session.GetString("Username");
    var today = DateTime.Now;
    var dayName = today.ToString("dddd", new System.Globalization.CultureInfo("ar-EG"));
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <style>
        :root {
            --primary: #f39c12;
            --primary-dark: #e67e22;
            --secondary: #6c757d;
            --success: #28a745;
            --info: #17a2b8;
            --warning: #ffc107;
            --danger: #dc3545;
            --light: #f8f9fa;
            --dark: #343a40;
            --white: #ffffff;
            --gradient-1: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --gradient-2: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            --gradient-3: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
            --gradient-4: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
            --gradient-5: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.1);
            --shadow-md: 0 5px 15px rgba(0,0,0,0.15);
            --shadow-lg: 0 10px 25px rgba(0,0,0,0.2);
            --border-radius: 16px;
        }

        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            font-family: 'Segoe UI', Tahoma, sans-serif;
            margin: 0;
            padding: 20px;
        }

        .page-wrapper {
            max-width: 800px;
            margin: 0 auto;
        }

        .header-card {
            background: var(--white);
            border-radius: var(--border-radius);
            padding: 20px 25px;
            margin-bottom: 25px;
            box-shadow: var(--shadow-lg);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .header-title h1 {
            margin: 0;
            font-size: 26px;
            font-weight: 600;
            color: var(--primary);
        }

        .header-title p {
            margin: 5px 0 0;
            color: var(--secondary);
            font-size: 14px;
        }

        .user-info {
            background: var(--gradient-5);
            color: white;
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 500;
        }

        .request-card {
            background: var(--white);
            border-radius: var(--border-radius);
            padding: 30px;
            box-shadow: var(--shadow-lg);
        }

        .request-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 25px;
            color: var(--primary);
            font-weight: 600;
            font-size: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid #f0f0f0;
        }

            .request-title i {
                font-size: 24px;
            }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            color: var(--dark);
            font-weight: 500;
            font-size: 14px;
        }

            .form-label i {
                color: var(--primary);
                margin-left: 5px;
            }

        .form-control {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e9ecef;
            border-radius: 12px;
            font-size: 14px;
            transition: all 0.3s ease;
            background: var(--white);
        }

            .form-control:focus {
                outline: none;
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(243, 156, 18, 0.1);
            }

            .form-control::placeholder {
                color: #adb5bd;
                opacity: 1;
            }

        textarea.form-control {
            resize: vertical;
            min-height: 100px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary {
            background: var(--gradient-5);
            color: white;
            box-shadow: var(--shadow-md);
        }

            .btn-primary:hover {
                transform: translateY(-3px);
                box-shadow: var(--shadow-lg);
            }

        .btn-secondary {
            background: var(--secondary);
            color: white;
        }

            .btn-secondary:hover {
                background: #5a6268;
                transform: translateY(-2px);
            }

        .action-buttons {
            display: flex;
            gap: 15px;
            margin-top: 30px;
        }

        .alert {
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .alert-success {
            background: #d4edda;
            color: #155724;
            border-right: 3px solid var(--success);
        }

        .alert-danger {
            background: #f8d7da;
            color: #721c24;
            border-right: 3px solid var(--danger);
        }

        @@media (max-width: 768px) {
            .form-row {
                grid-template-columns: 1fr;
                gap: 0;
            }

            .page-wrapper {
                padding: 0;
            }

            .request-card {
                padding: 20px;
            }

            .action-buttons {
                flex-direction: column;
            }

            .btn {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <div class="page-wrapper">
        <div class="header-card">
            <div class="header-title">
                <h1>
                    <i class="fas fa-plus-circle"></i> طلب جديد
                </h1>
                <p>إضافة طلب للمحل - شواحن، اسكرينات، قطع غيار</p>
            </div>
            <div class="user-info">
                <i class="fas fa-user-circle"></i> @username
                <span class="mx-2">|</span>
                <i class="fas fa-calendar"></i> @today.ToString("yyyy/MM/dd")
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            </div>
        }

        <div class="request-card">
            <div class="request-title">
                <i class="fas fa-edit"></i>
                <span>تفاصيل الطلب</span>
            </div>

            <form asp-action="Create" method="post" id="requestForm">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-tag"></i> اسم القطعة
                    </label>
                    <input type="text"
                           class="form-control"
                           id="itemName"
                           name="ItemName"
                           placeholder="اكتب اسم القطعة (مثال: شاحن سامسونج 25 واط)"
                           value="@Model?.ItemName" />
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-layer-group"></i> النوع
                    </label>
                    <input type="text"
                           class="form-control"
                           id="itemType"
                           name="ItemType"
                           placeholder="اكتب النوع (شاحن، اسكرينة، بطارية، ...)"
                           value="@Model?.ItemType" />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-hashtag"></i> الكمية
                        </label>
                        <input type="number"
                               class="form-control"
                               id="quantity"
                               name="Quantity"
                               placeholder="الكمية المطلوبة"
                               value="@(Model?.Quantity ?? 1)"
                               min="1" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-money-bill-wave"></i> سعر الوحدة (تقديري)
                        </label>
                        <input type="number"
                               class="form-control"
                               id="unitPrice"
                               name="UnitPrice"
                               placeholder="السعر التقريبي"
                               value="@Model?.UnitPrice"
                               step="0.01"
                               min="0" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-truck"></i> المورد
                        </label>
                        <input type="text"
                               class="form-control"
                               id="supplier"
                               name="Supplier"
                               placeholder="اسم المورد (اختياري)"
                               value="@Model?.Supplier" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-phone"></i> رقم المورد
                        </label>
                        <input type="tel"
                               class="form-control"
                               id="phoneNumber"
                               name="PhoneNumber"
                               placeholder="رقم الهاتف (اختياري)"
                               value="@Model?.PhoneNumber" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-exclamation-triangle"></i> الأولوية
                        </label>
                        <select class="form-control" id="priority" name="Priority">
                            <option value="1" selected>🟢 عادي</option>
                            <option value="2">🟠 مهم</option>
                            <option value="3">🔴 عاجل</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-info-circle"></i> الحالة
                        </label>
                        <select class="form-control" id="status" name="Status">
                            <option value="قيد الانتظار" selected>⏳ قيد الانتظار</option>
                            <option value="تم الطلب">📦 تم الطلب</option>
                            <option value="تم الاستلام">✅ تم الاستلام</option>
                            <option value="ملغي">❌ ملغي</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-calendar-alt"></i> تاريخ التسليم المطلوب
                    </label>
                    <input type="date"
                           class="form-control"
                           id="dueDate"
                           name="DueDate"
                           value="@(Model?.DueDate?.ToString("yyyy-MM-dd"))" />
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-sticky-note"></i> ملاحظات إضافية
                    </label>
                    <textarea class="form-control"
                              id="notes"
                              name="Notes"
                              placeholder="أي ملاحظات إضافية (اختياري)">@Model?.Notes</textarea>
                </div>

                <div class="action-buttons">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> حفظ الطلب
                    </button>
                    <a href="/ShopRequest/Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-right"></i> رجوع
                    </a>
                </div>
            </form>
        </div>
    </div>

    <script>
        document.getElementById('requestForm')?.addEventListener('submit', function(e) {
            const itemName = document.getElementById('itemName').value.trim();
            const itemType = document.getElementById('itemType').value.trim();
            const quantity = document.getElementById('quantity').value;

            if (!itemName || !itemType || !quantity) {
                e.preventDefault();
                alert('❌ يفضل ملء الحقول الأساسية (اسم القطعة، النوع، الكمية)');
                return false;
            }

            if (!confirm('هل أنت متأكد من حفظ هذا الطلب؟')) {
                e.preventDefault();
                return false;
            }

            return true;
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>