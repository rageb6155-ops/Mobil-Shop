@{
    ViewData["Title"] = "إدارة الموظفين";
    var username = Context.Session.GetString("Username");
    var today = DateTime.Now;
    var dayName = today.ToString("dddd", new System.Globalization.CultureInfo("ar-EG"));
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <!-- إضافة مكتبات PDF -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: #f4f6f9;
            margin: 0;
            padding: 20px;
        }

        .page-wrapper {
            max-width: 1400px;
            margin: 0 auto;
        }

        .header-card {
            background: white;
            border-radius: 16px;
            padding: 20px 25px;
            margin-bottom: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .header-title h1 {
            margin: 0;
            font-size: 26px;
            font-weight: 600;
            color: #9b59b6;
        }

        .header-title p {
            margin: 5px 0 0;
            color: #6c757d;
            font-size: 14px;
        }

        .user-info {
            background: #f8f9fa;
            color: #9b59b6;
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 500;
            border: 1px solid #e9ecef;
        }

        .employees-card {
            background: white;
            border-radius: 16px;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid #f0f0f0;
            flex-wrap: wrap;
            gap: 15px;
        }

            .card-header h2 {
                margin: 0;
                color: #9b59b6;
                font-weight: 600;
                font-size: 22px;
            }

        .search-section {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 20px;
            position: relative;
        }

        .search-input {
            flex: 1;
            min-width: 250px;
            padding: 10px 15px;
            border: 2px solid #e9ecef;
            border-radius: 8px;
            font-size: 14px;
            transition: all 0.3s;
        }

            .search-input:focus {
                outline: none;
                border-color: #9b59b6;
                box-shadow: 0 0 0 3px rgba(155, 89, 182, 0.1);
            }

        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary {
            background: #9b59b6;
            color: white;
        }

            .btn-primary:hover {
                background: #8e44ad;
                transform: translateY(-2px);
            }

        .btn-success {
            background: #28a745;
            color: white;
        }

            .btn-success:hover {
                background: #218838;
                transform: translateY(-2px);
            }

        .btn-warning {
            background: #ffc107;
            color: #333;
        }

            .btn-warning:hover {
                background: #e0a800;
                transform: translateY(-2px);
            }

        .btn-danger {
            background: #dc3545;
            color: white;
        }

            .btn-danger:hover {
                background: #c82333;
                transform: translateY(-2px);
            }

        .btn-info {
            background: #17a2b8;
            color: white;
        }

            .btn-info:hover {
                background: #138496;
                transform: translateY(-2px);
            }

        .btn-purple {
            background: #9b59b6;
            color: white;
        }

            .btn-purple:hover {
                background: #8e44ad;
                transform: translateY(-2px);
            }

        .btn-pdf {
            background: #d32f2f;
            color: white;
        }

            .btn-pdf:hover {
                background: #b71c1c;
                transform: translateY(-2px);
            }

        .employees-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .employee-card {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 20px;
            border: 1px solid #e9ecef;
            transition: all 0.3s;
            cursor: pointer;
        }

            .employee-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            }

        .employee-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .employee-name {
            font-size: 16px;
            font-weight: bold;
            color: #9b59b6;
        }

        .employee-code {
            font-size: 12px;
            color: #6c757d;
        }

        .employee-phone {
            font-size: 13px;
            color: #666;
            margin: 5px 0;
        }

        .employee-salary {
            font-size: 18px;
            font-weight: bold;
            color: #27ae60;
            margin: 5px 0;
        }

        .employee-actions {
            display: flex;
            gap: 10px;
            margin-top: 15px;
            flex-wrap: wrap;
        }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 1000;
        }

        .modal-content {
            background: white;
            width: 90%;
            max-width: 600px;
            margin: 50px auto;
            border-radius: 16px;
            padding: 25px;
            max-height: 80vh;
            overflow-y: auto;
        }

        .modal-lg {
            max-width: 900px;
        }

        .modal-xl {
            max-width: 1200px;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid #f0f0f0;
        }

            .modal-header h3 {
                margin: 0;
                color: #9b59b6;
            }

        .close-btn {
            background: #6c757d;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 8px;
            cursor: pointer;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-label {
            display: block;
            margin-bottom: 5px;
            color: #6c757d;
            font-size: 13px;
        }

        .form-control {
            width: 100%;
            padding: 10px 15px;
            border: 2px solid #e9ecef;
            border-radius: 8px;
            font-size: 14px;
        }

            .form-control:focus {
                outline: none;
                border-color: #9b59b6;
            }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .badge {
            padding: 3px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 500;
            margin-left: 5px;
        }

        .badge-success {
            background: #28a745;
            color: white;
        }

        .badge-warning {
            background: #ffc107;
            color: #333;
        }

        .badge-danger {
            background: #dc3545;
            color: white;
        }

        .badge-info {
            background: #17a2b8;
            color: white;
        }

        .badge-purple {
            background: #9b59b6;
            color: white;
        }

        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            border-bottom: 2px solid #f0f0f0;
            padding-bottom: 10px;
        }

        .tab {
            padding: 8px 20px;
            border: none;
            background: none;
            border-radius: 8px 8px 0 0;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            color: #6c757d;
        }

            .tab.active {
                color: #9b59b6;
                border-bottom: 3px solid #9b59b6;
                background: #f8f0ff;
            }

        .tab-content {
            display: none;
        }

            .tab-content.active {
                display: block;
            }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin: 20px 0;
        }

        .stat-card {
            background: white;
            border-radius: 12px;
            padding: 15px;
            border: 1px solid #e9ecef;
            border-right: 4px solid #9b59b6;
        }

        .stat-value {
            font-size: 22px;
            font-weight: bold;
            color: #333;
        }

        .stat-label {
            font-size: 12px;
            color: #6c757d;
        }

        .progress {
            height: 8px;
            border-radius: 4px;
        }

        .transactions-list {
            max-height: 400px;
            overflow-y: auto;
            padding: 10px;
        }

        .transaction-item {
            background: #f8f9fa;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 10px;
            border: 1px solid #e9ecef;
        }

        .transaction-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .transaction-type {
            font-weight: bold;
            color: #9b59b6;
        }

        .salary-change-item {
            background: #f8f9fa;
            border-radius: 8px;
            padding: 10px;
            margin-bottom: 10px;
            border-right: 3px solid #9b59b6;
        }

        .amount-positive {
            color: #28a745;
            font-weight: bold;
        }

        .amount-negative {
            color: #dc3545;
            font-weight: bold;
        }

        .amount-primary {
            color: #9b59b6;
            font-weight: bold;
        }

        .summary-box {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 15px;
            margin-bottom: 20px;
            display: flex;
            justify-content: space-around;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .summary-item {
            text-align: center;
        }

        .summary-value {
            font-size: 20px;
            font-weight: bold;
            color: #9b59b6;
        }

        .summary-label {
            font-size: 12px;
            color: #6c757d;
        }

        @@media (max-width: 768px) {
            .form-row {
                grid-template-columns: 1fr;
            }

            .employees-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="page-wrapper">
        <div class="header-card">
            <div class="header-title">
                <h1>
                    <i class="fas fa-users-cog"></i> إدارة الموظفين
                </h1>
                <p>إدارة رواتب ومكافآت وخصومات الموظفين</p>
            </div>
            <div class="user-info">
                <i class="fas fa-user-circle"></i> @username
            </div>
        </div>

        <!-- إحصائيات سريعة -->
        <div class="stats-grid" style="margin-bottom: 25px;">
            <div class="stat-card" id="totalEmployees">
                <div class="stat-label"><i class="fas fa-users"></i> إجمالي الموظفين</div>
                <div class="stat-value">-</div>
            </div>
            <div class="stat-card" id="totalSalaries">
                <div class="stat-label"><i class="fas fa-money-bill-wave"></i> إجمالي الرواتب</div>
                <div class="stat-value">-</div>
            </div>
            <div class="stat-card" id="totalLoans">
                <div class="stat-label"><i class="fas fa-hand-holding-usd"></i> إجمالي السلف</div>
                <div class="stat-value">-</div>
            </div>
            <div class="stat-card" id="activeEmployees">
                <div class="stat-label"><i class="fas fa-user-check"></i> الموظفون النشطون</div>
                <div class="stat-value">-</div>
            </div>
        </div>

        <div class="employees-card">
            <div class="card-header">
                <h2><i class="fas fa-list"></i> قائمة الموظفين</h2>
                <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                    <button class="btn btn-success" onclick="showAddEmployeeModal()">
                        <i class="fas fa-plus"></i> إضافة موظف جديد
                    </button>
                </div>
            </div>

            <div class="search-section">
                <input type="text" class="search-input" id="searchInput" placeholder="ابحث بالاسم أو رقم الهاتف أو الكود..." autocomplete="off" />
                <button class="btn btn-primary" onclick="loadEmployees()">
                    <i class="fas fa-search"></i> بحث
                </button>
            </div>

            <div class="tabs">
                <button class="tab active" onclick="switchTab('active', true)">الموظفون النشطون</button>
                <button class="tab" onclick="switchTab('deleted', false)">الموظفون المحذوفون</button>
            </div>

            <div id="employeesList" class="employees-grid">
                <div class="text-center text-muted py-5" style="grid-column: 1/-1;">
                    <i class="fas fa-spinner fa-spin fa-3x mb-3"></i>
                    <h5>جاري التحميل...</h5>
                </div>
            </div>
        </div>
    </div>

    <!-- مودال إضافة/تعديل موظف -->
    <div id="employeeModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="employeeModalTitle">إضافة موظف جديد</h3>
                <button class="close-btn" onclick="closeEmployeeModal()">إغلاق</button>
            </div>
            <form id="employeeForm">
                <input type="hidden" id="employeeId" value="0" />

                <div class="form-group">
                    <label class="form-label">الاسم الكامل *</label>
                    <input type="text" class="form-control" id="fullName" required />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">رقم الهاتف *</label>
                        <input type="text" class="form-control" id="phoneNumber" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label">البريد الإلكتروني</label>
                        <input type="email" class="form-control" id="email" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">الرقم القومي</label>
                        <input type="text" class="form-control" id="idNumber" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">الراتب الأساسي *</label>
                        <input type="number" class="form-control" id="baseSalary" required min="0" step="0.01" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">العنوان</label>
                    <input type="text" class="form-control" id="address" />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">القسم</label>
                        <input type="text" class="form-control" id="department" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">الوظيفة</label>
                        <input type="text" class="form-control" id="position" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">ملاحظات</label>
                    <textarea class="form-control" id="notes" rows="2"></textarea>
                </div>

                <div class="form-group" style="margin-top: 20px;">
                    <button type="button" class="btn btn-success" onclick="saveEmployee()">
                        <i class="fas fa-save"></i> حفظ
                    </button>
                    <button type="button" class="btn btn-secondary" onclick="closeEmployeeModal()">
                        <i class="fas fa-times"></i> إلغاء
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- مودال تفاصيل الموظف -->
    <div id="employeeDetailsModal" class="modal">
        <div class="modal-content modal-xl">
            <div class="modal-header">
                <h3 id="detailsEmployeeName">تفاصيل الموظف</h3>
                <button class="close-btn" onclick="closeDetailsModal()">إغلاق</button>
            </div>

            <div class="summary-box" id="employeeSummary">
                <!-- سيتم تعبئتها ديناميكياً -->
            </div>

            <div class="tabs">
                <button class="tab active" onclick="switchDetailsTab('info', true)">المعلومات الشخصية</button>
                <button class="tab" onclick="switchDetailsTab('transactions', false)">المعاملات</button>
                <button class="tab" onclick="switchDetailsTab('salaries', false)">الرواتب الشهرية</button>
                <button class="tab" onclick="switchDetailsTab('changes', false)">تغييرات الراتب</button>
            </div>

            <!-- تبويب المعلومات -->
            <div id="infoTab" class="tab-content active">
                <div id="employeeInfo"></div>
                <div style="margin-top: 15px; display: flex; gap: 10px; flex-wrap: wrap; justify-content: left;">
                    <button class="btn btn-purple" onclick="showChangeSalaryModal()">
                        <i class="fas fa-money-bill"></i> تغيير الراتب
                    </button>
                    <button class="btn btn-success" onclick="showAddTransactionModal('مكافأة')">
                        <i class="fas fa-plus-circle"></i> إضافة مكافأة
                    </button>
                    <button class="btn btn-warning" onclick="showAddTransactionModal('خصم')">
                        <i class="fas fa-minus-circle"></i> إضافة خصم
                    </button>
                    <button class="btn btn-info" onclick="showAddTransactionModal('سلفة')">
                        <i class="fas fa-hand-holding-usd"></i> إضافة سلفة
                    </button>
                    <button class="btn btn-pdf" onclick="showReportMonthModal()">
                        <i class="fas fa-file-pdf"></i> تقرير شهري PDF
                    </button>
                </div>
            </div>

            <!-- تبويب المعاملات -->
            <div id="transactionsTab" class="tab-content">
                <div class="stats-grid" id="transactionsStats"></div>
                <div id="transactionsList"></div>
            </div>

            <!-- تبويب الرواتب الشهرية -->
            <div id="salariesTab" class="tab-content">
                <div id="salariesList"></div>
            </div>

            <!-- تبويب تغييرات الراتب -->
            <div id="changesTab" class="tab-content">
                <div id="salaryChangesList"></div>
            </div>

            <div style="margin-top: 20px; display: flex; gap: 10px; flex-wrap: wrap;">
                <button class="btn btn-warning" onclick="editCurrentEmployee()">
                    <i class="fas fa-edit"></i> تعديل البيانات
                </button>
                <button class="btn btn-danger" onclick="deleteCurrentEmployee()">
                    <i class="fas fa-trash"></i> حذف الموظف
                </button>
            </div>
        </div>
    </div>

    <!-- مودال إضافة معاملة (مكافأة/خصم/سلفة) -->
    <div id="transactionModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="transactionModalTitle">إضافة معاملة</h3>
                <button class="close-btn" onclick="closeTransactionModal()">إغلاق</button>
            </div>
            <form id="transactionForm">
                <input type="hidden" id="transactionEmployeeId" value="0" />
                <input type="hidden" id="transactionType" value="" />

                <div class="form-group">
                    <label class="form-label">نوع المعاملة</label>
                    <input type="text" class="form-control" id="transactionTypeDisplay" readonly style="background: #f0f0f0;" />
                </div>

                <div class="form-group">
                    <label class="form-label">المبلغ *</label>
                    <input type="number" class="form-control" id="transactionAmount" required min="0" step="0.01" />
                </div>

                <div class="form-group">
                    <label class="form-label">البيان *</label>
                    <textarea class="form-control" id="transactionDescription" rows="2" required placeholder="أدخل سبب المعاملة"></textarea>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">الشهر</label>
                        <select class="form-control" id="transactionMonth">
                            <option value="1">يناير</option>
                            <option value="2">فبراير</option>
                            <option value="3">مارس</option>
                            <option value="4">إبريل</option>
                            <option value="5">مايو</option>
                            <option value="6">يونيو</option>
                            <option value="7">يوليو</option>
                            <option value="8">أغسطس</option>
                            <option value="9">سبتمبر</option>
                            <option value="10">أكتوبر</option>
                            <option value="11">نوفمبر</option>
                            <option value="12">ديسمبر</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">السنة</label>
                        <input type="number" class="form-control" id="transactionYear" value="@DateTime.Now.Year" min="2020" max="2100" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">ملاحظات إضافية</label>
                    <textarea class="form-control" id="transactionNotes" rows="2"></textarea>
                </div>

                <div style="margin-top: 20px;">
                    <button type="button" class="btn btn-success" onclick="saveTransaction()">
                        <i class="fas fa-save"></i> حفظ
                    </button>
                    <button type="button" class="btn btn-secondary" onclick="closeTransactionModal()">
                        <i class="fas fa-times"></i> إلغاء
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- مودال تغيير الراتب -->
    <div id="changeSalaryModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>تغيير الراتب</h3>
                <button class="close-btn" onclick="closeChangeSalaryModal()">إغلاق</button>
            </div>
            <form id="changeSalaryForm">
                <input type="hidden" id="changeSalaryEmployeeId" value="0" />

                <div class="form-group">
                    <label class="form-label">الراتب الحالي</label>
                    <input type="text" class="form-control" id="currentSalary" readonly style="background: #f0f0f0;" />
                </div>

                <div class="form-group">
                    <label class="form-label">الراتب الجديد *</label>
                    <input type="number" class="form-control" id="newSalary" required min="0" step="0.01" />
                </div>

                <div class="form-group">
                    <label class="form-label">سبب التغيير *</label>
                    <textarea class="form-control" id="salaryChangeReason" rows="2" required placeholder="أدخل سبب تغيير الراتب"></textarea>
                </div>

                <div style="margin-top: 20px;">
                    <button type="button" class="btn btn-success" onclick="saveSalaryChange()">
                        <i class="fas fa-save"></i> حفظ
                    </button>
                    <button type="button" class="btn btn-secondary" onclick="closeChangeSalaryModal()">
                        <i class="fas fa-times"></i> إلغاء
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- مودال تأكيد دفع الراتب -->
    <div id="confirmSalaryModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>تأكيد دفع الراتب</h3>
                <button class="close-btn" onclick="closeConfirmSalaryModal()">إغلاق</button>
            </div>
            <div id="confirmSalaryContent" style="text-align: center; padding: 20px;">
                <h4 id="confirmSalaryMessage"></h4>
                <div style="margin-top: 20px;">
                    <button class="btn btn-success" onclick="executeConfirmSalary()">
                        <i class="fas fa-check"></i> تأكيد
                    </button>
                    <button class="btn btn-secondary" onclick="closeConfirmSalaryModal()">
                        <i class="fas fa-times"></i> إلغاء
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- مودال اختيار الشهر للتقرير -->
    <div id="reportMonthModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>اختر الشهر للتقرير</h3>
                <button class="close-btn" onclick="closeReportMonthModal()">إغلاق</button>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">الشهر</label>
                    <select class="form-control" id="reportMonth">
                        <option value="1">يناير</option>
                        <option value="2">فبراير</option>
                        <option value="3">مارس</option>
                        <option value="4">إبريل</option>
                        <option value="5">مايو</option>
                        <option value="6">يونيو</option>
                        <option value="7">يوليو</option>
                        <option value="8">أغسطس</option>
                        <option value="9">سبتمبر</option>
                        <option value="10">أكتوبر</option>
                        <option value="11">نوفمبر</option>
                        <option value="12">ديسمبر</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">السنة</label>
                    <input type="number" class="form-control" id="reportYear" value="@DateTime.Now.Year" min="2020" max="2100" />
                </div>
            </div>
            <div style="margin-top: 20px;">
                <button class="btn btn-primary" onclick="generateMonthlyReport()">
                    <i class="fas fa-file-pdf"></i> إنشاء التقرير
                </button>
            </div>
        </div>
    </div>

    <script>
        let currentEmployeeId = 0;
        let currentEmployee = null;
        let showDeleted = false;
        let currentTransactionType = '';
        let currentConfirmSalaryData = null;

        // تحميل الموظفين عند فتح الصفحة
        document.addEventListener('DOMContentLoaded', function() {
            loadEmployees();
            loadDashboardStats();
        });

        // تحميل إحصائيات لوحة التحكم
        function loadDashboardStats() {
            fetch('/Employees/GetAllEmployees?showDeleted=false')
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        const employees = data.employees;
                        const totalEmployees = employees.length;
                        const totalSalaries = employees.reduce((sum, e) => sum + e.currentSalary, 0);
                        const totalLoans = employees.reduce((sum, e) => sum + e.totalLoans, 0);
                        const activeEmployees = employees.filter(e => e.status === 'نشط').length;

                        document.getElementById('totalEmployees').innerHTML = `
                            <div class="stat-label"><i class="fas fa-users"></i> إجمالي الموظفين</div>
                            <div class="stat-value">${totalEmployees}</div>
                        `;
                        document.getElementById('totalSalaries').innerHTML = `
                            <div class="stat-label"><i class="fas fa-money-bill-wave"></i> إجمالي الرواتب</div>
                            <div class="stat-value">${totalSalaries.toLocaleString()} ج.م</div>
                        `;
                        document.getElementById('totalLoans').innerHTML = `
                            <div class="stat-label"><i class="fas fa-hand-holding-usd"></i> إجمالي السلف</div>
                            <div class="stat-value">${totalLoans.toLocaleString()} ج.م</div>
                        `;
                        document.getElementById('activeEmployees').innerHTML = `
                            <div class="stat-label"><i class="fas fa-user-check"></i> الموظفون النشطون</div>
                            <div class="stat-value">${activeEmployees}</div>
                        `;
                    }
                });
        }

        // تحميل قائمة الموظفين
        function loadEmployees() {
            const search = document.getElementById('searchInput').value;

            fetch(`/Employees/GetAllEmployees?search=${encodeURIComponent(search)}&showDeleted=${showDeleted}`)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        displayEmployees(data.employees);
                    } else {
                        alert('خطأ في تحميل الموظفين: ' + data.message);
                    }
                });
        }

        // عرض الموظفين
        function displayEmployees(employees) {
            const container = document.getElementById('employeesList');

            if (employees.length === 0) {
                container.innerHTML = '<div class="text-center text-muted py-5" style="grid-column: 1/-1;"><i class="fas fa-users fa-3x mb-3"></i><h5>لا يوجد موظفون</h5></div>';
                return;
            }

            let html = '';
            employees.forEach(e => {
                const statusClass = e.status === 'نشط' ? 'badge-success' : 'badge-warning';

                let actionsHtml = '';
                if (showDeleted) {
                    actionsHtml = `
                        <button class="btn btn-sm btn-success" onclick="restoreEmployee(${e.id})">
                            <i class="fas fa-undo"></i> استعادة
                        </button>
                    `;
                } else {
                    actionsHtml = `
                        <button class="btn btn-sm btn-warning" onclick="editEmployee(${e.id})">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="btn btn-sm btn-danger" onclick="deleteEmployee(${e.id})">
                            <i class="fas fa-trash"></i>
                        </button>
                    `;
                }

                html += `
                    <div class="employee-card" onclick="showEmployeeDetails(${e.id})">
                        <div class="employee-header">
                            <span class="employee-name">${e.fullName}</span>
                            <span class="employee-code">${e.employeeCode}</span>
                        </div>
                        <div class="employee-phone">
                            <i class="fas fa-phone"></i> ${e.phoneNumber}
                            ${e.email ? ` | <i class="fas fa-envelope"></i> ${e.email}` : ''}
                        </div>
                        <div class="employee-salary">
                            <i class="fas fa-money-bill-wave"></i> الراتب: ${e.currentSalary.toLocaleString()} ج.م
                        </div>
                        <div style="font-size: 12px; color: #666; margin-top: 5px;">
                            <span class="badge ${statusClass}">${e.status}</span>
                            <span class="badge badge-info">${e.department || 'بدون قسم'}</span>
                            <span class="badge badge-purple">${e.position || 'بدون وظيفة'}</span>
                        </div>
                        <div style="font-size: 12px; color: #666; margin-top: 5px;">
                            <span class="amount-primary"><i class="fas fa-hand-holding-usd"></i> سلف: ${e.totalLoans.toLocaleString()} ج.م</span>
                            <span class="amount-positive mx-2"><i class="fas fa-plus-circle"></i> مكافآت: ${e.totalAdditions.toLocaleString()} ج.م</span>
                            <span class="amount-negative"><i class="fas fa-minus-circle"></i> خصومات: ${e.totalDeductions.toLocaleString()} ج.م</span>
                        </div>
                        <div class="employee-actions" onclick="event.stopPropagation()">
                            ${actionsHtml}
                        </div>
                    </div>
                `;
            });

            container.innerHTML = html;
        }

        // استعادة موظف محذوف
        function restoreEmployee(id) {
            if (confirm('هل أنت متأكد من استعادة هذا الموظف؟')) {
                fetch(`/Employees/RestoreEmployee?id=${id}`, { method: 'POST' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            alert(data.message);
                            loadEmployees();
                            loadDashboardStats();
                        } else {
                            alert(data.message);
                        }
                    });
            }
        }

        // تبديل التبويب الرئيسي
        function switchTab(tab, isActive) {
            document.querySelectorAll('.tab').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            showDeleted = !isActive;
            loadEmployees();
        }

        // إظهار مودال إضافة موظف
        function showAddEmployeeModal() {
            document.getElementById('employeeModalTitle').innerText = 'إضافة موظف جديد';
            document.getElementById('employeeId').value = '0';
            document.getElementById('fullName').value = '';
            document.getElementById('phoneNumber').value = '';
            document.getElementById('email').value = '';
            document.getElementById('idNumber').value = '';
            document.getElementById('baseSalary').value = '';
            document.getElementById('address').value = '';
            document.getElementById('department').value = '';
            document.getElementById('position').value = '';
            document.getElementById('notes').value = '';
            document.getElementById('employeeModal').style.display = 'block';
        }

        // إغلاق مودال الموظف
        function closeEmployeeModal() {
            document.getElementById('employeeModal').style.display = 'none';
        }

        // حفظ الموظف
        function saveEmployee() {
            const id = document.getElementById('employeeId').value;
            const data = {
                id: id,
                fullName: document.getElementById('fullName').value,
                phoneNumber: document.getElementById('phoneNumber').value,
                email: document.getElementById('email').value || null,
                idNumber: document.getElementById('idNumber').value || null,
                baseSalary: parseFloat(document.getElementById('baseSalary').value),
                address: document.getElementById('address').value || null,
                department: document.getElementById('department').value || null,
                position: document.getElementById('position').value || null,
                notes: document.getElementById('notes').value || null,
                status: 'نشط'
            };

            if (!data.fullName) {
                alert('❌ الرجاء إدخال اسم الموظف');
                return;
            }

            if (!data.phoneNumber) {
                alert('❌ الرجاء إدخال رقم الهاتف');
                return;
            }

            if (!data.baseSalary || data.baseSalary <= 0) {
                alert('❌ الرجاء إدخال راتب صحيح');
                return;
            }

            const url = id === '0' ? '/Employees/AddEmployee' : '/Employees/UpdateEmployee';

            fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert(data.message);
                    closeEmployeeModal();
                    loadEmployees();
                    loadDashboardStats();
                } else {
                    alert(data.message);
                }
            });
        }

        // تعديل موظف
        function editEmployee(id) {
            fetch(`/Employees/GetEmployeeDetails?id=${id}`)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        const e = data.employee;
                        document.getElementById('employeeModalTitle').innerText = 'تعديل بيانات الموظف';
                        document.getElementById('employeeId').value = id;
                        document.getElementById('fullName').value = e.fullName;
                        document.getElementById('phoneNumber').value = e.phoneNumber;
                        document.getElementById('email').value = e.email || '';
                        document.getElementById('idNumber').value = e.idNumber || '';
                        document.getElementById('baseSalary').value = e.baseSalary;
                        document.getElementById('address').value = e.address || '';
                        document.getElementById('department').value = e.department || '';
                        document.getElementById('position').value = e.position || '';
                        document.getElementById('notes').value = e.notes || '';
                        document.getElementById('employeeModal').style.display = 'block';
                    }
                });
        }

        // حذف موظف
        function deleteEmployee(id) {
            if (confirm('هل أنت متأكد من حذف هذا الموظف؟')) {
                fetch(`/Employees/SoftDeleteEmployee?id=${id}`, { method: 'POST' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            alert(data.message);
                            loadEmployees();
                            loadDashboardStats();
                        } else {
                            alert(data.message);
                        }
                    });
            }
        }

        // إظهار تفاصيل الموظف
        function showEmployeeDetails(id) {
            currentEmployeeId = id;
            fetch(`/Employees/GetEmployeeDetails?id=${id}`)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        currentEmployee = data.employee;
                        document.getElementById('detailsEmployeeName').innerText = `تفاصيل الموظف: ${data.employee.fullName}`;

                        // ملخص سريع
                        document.getElementById('employeeSummary').innerHTML = `
                            <div class="summary-item">
                                <div class="summary-value">${data.employee.currentSalary.toLocaleString()} ج.م</div>
                                <div class="summary-label">الراتب الحالي</div>
                            </div>
                            <div class="summary-item">
                                <div class="summary-value amount-positive">+${data.employee.stats.totalAdditions.toLocaleString()} ج.م</div>
                                <div class="summary-label">إجمالي المكافآت</div>
                            </div>
                            <div class="summary-item">
                                <div class="summary-value amount-negative">-${data.employee.stats.totalDeductions.toLocaleString()} ج.م</div>
                                <div class="summary-label">إجمالي الخصومات</div>
                            </div>
                            <div class="summary-item">
                                <div class="summary-value amount-primary">${data.employee.stats.totalLoans.toLocaleString()} ج.م</div>
                                <div class="summary-label">إجمالي السلف</div>
                            </div>
                        `;

                        // معلومات الموظف
                        let infoHtml = `
                            <div class="stats-grid">
                                <div class="stat-card">
                                    <div class="stat-value">${data.employee.currentSalary.toLocaleString()} ج.م</div>
                                    <div class="stat-label">الراتب الحالي</div>
                                </div>
                                <div class="stat-card">
                                    <div class="stat-value">${data.employee.baseSalary.toLocaleString()} ج.م</div>
                                    <div class="stat-label">الراتب الأساسي</div>
                                </div>
                                <div class="stat-card">
                                    <div class="stat-value">${data.employee.recentTransactions ? data.employee.recentTransactions.length : 0}</div>
                                    <div class="stat-label">عدد المعاملات</div>
                                </div>
                                <div class="stat-card">
                                    <div class="stat-value">${data.employee.status}</div>
                                    <div class="stat-label">الحالة</div>
                                </div>
                            </div>
                            <div style="padding: 15px; background: #f8f9fa; border-radius: 8px;">
                                <div class="row">
                                    <div class="col-md-6">
                                        <p><strong>📞 رقم الهاتف:</strong> ${data.employee.phoneNumber}</p>
                                        <p><strong>✉️ البريد الإلكتروني:</strong> ${data.employee.email || 'لا يوجد'}</p>
                                        <p><strong>🆔 الرقم القومي:</strong> ${data.employee.idNumber || 'لا يوجد'}</p>
                                        <p><strong>🏢 القسم:</strong> ${data.employee.department || 'لا يوجد'}</p>
                                    </div>
                                    <div class="col-md-6">
                                        <p><strong>💼 الوظيفة:</strong> ${data.employee.position || 'لا يوجد'}</p>
                                        <p><strong>📅 تاريخ التوظيف:</strong> ${new Date(data.employee.hireDate).toLocaleDateString('ar-EG')}</p>
                                        <p><strong>📝 الملاحظات:</strong> ${data.employee.notes || 'لا يوجد'}</p>
                                    </div>
                                </div>
                                <p class="text-muted"><small>تمت الإضافة بواسطة: ${data.employee.createdByName} في ${new Date(data.employee.createdAt).toLocaleString('ar-EG')}</small></p>
                            </div>
                        `;
                        document.getElementById('employeeInfo').innerHTML = infoHtml;

                        // عرض المعاملات
                        displayTransactions(data.employee.recentTransactions);

                        // عرض الرواتب الشهرية
                        displaySalaries(data.employee.recentSalaries);

                        // عرض تغييرات الراتب
                        displaySalaryChanges(data.employee.salaryChanges);

                        document.getElementById('employeeDetailsModal').style.display = 'block';
                    }
                });
        }

        // عرض المعاملات
        function displayTransactions(transactions) {
            if (!transactions || transactions.length === 0) {
                document.getElementById('transactionsList').innerHTML = '<p class="text-center text-muted py-3">لا توجد معاملات</p>';
                document.getElementById('transactionsStats').innerHTML = '';
                return;
            }

            // إحصائيات المعاملات
            let totalAdditions = 0, totalDeductions = 0, totalLoans = 0;
            transactions.forEach(t => {
                if (t.transactionType === 'مكافأة') totalAdditions += t.amount;
                else if (t.transactionType === 'خصم') totalDeductions += t.amount;
                else if (t.transactionType === 'سلفة') totalLoans += t.amount;
            });

            document.getElementById('transactionsStats').innerHTML = `
                <div class="stat-card">
                    <div class="stat-value amount-positive">${totalAdditions.toLocaleString()} ج.م</div>
                    <div class="stat-label">إجمالي المكافآت</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value amount-negative">${totalDeductions.toLocaleString()} ج.م</div>
                    <div class="stat-label">إجمالي الخصومات</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value amount-primary">${totalLoans.toLocaleString()} ج.م</div>
                    <div class="stat-label">إجمالي السلف</div>
                </div>
            `;

            let html = '<div class="transactions-list">';
            transactions.forEach(t => {
                const amountClass = t.transactionType === 'مكافأة' ? 'amount-positive' :
                                    (t.transactionType === 'خصم' ? 'amount-negative' : 'amount-primary');
                const icon = t.transactionType === 'مكافأة' ? 'fas fa-plus-circle' :
                            (t.transactionType === 'خصم' ? 'fas fa-minus-circle' : 'fas fa-hand-holding-usd');

                html += `
                    <div class="transaction-item">
                        <div class="transaction-header">
                            <span class="transaction-type"><i class="${icon}"></i> ${t.transactionType}</span>
                            <span class="${amountClass}">${t.amount.toLocaleString()} ج.م</span>
                        </div>
                        <div style="font-size: 13px;">
                            <p><strong>البيان:</strong> ${t.description}</p>
                            <div class="row">
                                <div class="col-md-6">
                                    <small>📅 ${new Date(t.transactionDate).toLocaleString('ar-EG')}</small>
                                </div>
                                <div class="col-md-6">
                                    <small>📆 ${t.month}/${t.year}</small>
                                </div>
                            </div>
                            <small>👤 بواسطة: ${t.createdByName}</small>
                        </div>
                    </div>
                `;
            });
            html += '</div>';
            document.getElementById('transactionsList').innerHTML = html;
        }

        // عرض الرواتب الشهرية
        function displaySalaries(salaries) {
            if (!salaries || salaries.length === 0) {
                document.getElementById('salariesList').innerHTML = '<p class="text-center text-muted py-3">لا توجد رواتب شهرية</p>';
                return;
            }

            let html = '<div class="table-responsive"><table class="table table-bordered"><thead><tr><th>الشهر</th><th>الراتب الأساسي</th><th>المكافآت</th><th>الخصومات</th><th>السلف</th><th>الصافي</th><th>الحالة</th><th>الإجراءات</th></tr></thead><tbody>';
            salaries.forEach(s => {
                const statusClass = s.paymentStatus === 'مدفوع' ? 'badge-success' : 'badge-warning';
                html += `
                    <tr>
                        <td>${s.monthName} ${s.year}</td>
                        <td>${s.baseSalary.toLocaleString()} ج.م</td>
                        <td class="amount-positive">${s.totalAdditions.toLocaleString()} ج.م</td>
                        <td class="amount-negative">${s.totalDeductions.toLocaleString()} ج.م</td>
                        <td class="amount-primary">${s.totalLoans.toLocaleString()} ج.م</td>
                        <td class="fw-bold">${s.netSalary.toLocaleString()} ج.م</td>
                        <td><span class="badge ${statusClass}">${s.paymentStatus}</span></td>
                        <td>
                            ${s.paymentStatus !== 'مدفوع' ?
                                `<button class="btn btn-sm btn-success" onclick="showConfirmSalaryModal(${currentEmployeeId}, ${s.month}, ${s.year}, ${s.netSalary})">
                                    <i class="fas fa-check"></i> تأكيد الدفع
                                </button>` :
                                `<span class="text-success"><i class="fas fa-check-circle"></i> تم الدفع</span>`
                            }
                        </td>
                    </tr>
                `;
            });
            html += '</tbody></table></div>';
            document.getElementById('salariesList').innerHTML = html;
        }

        // عرض تغييرات الراتب
        function displaySalaryChanges(changes) {
            if (!changes || changes.length === 0) {
                document.getElementById('salaryChangesList').innerHTML = '<p class="text-center text-muted py-3">لا توجد تغييرات في الراتب</p>';
                return;
            }

            let html = '<div class="transactions-list">';
            changes.forEach(c => {
                const diff = c.newSalary - c.oldSalary;
                const diffClass = diff > 0 ? 'amount-positive' : 'amount-negative';
                const diffText = diff > 0 ? `(+${diff.toLocaleString()} ج.م)` : `(${diff.toLocaleString()} ج.م)`;

                html += `
                    <div class="salary-change-item">
                        <div class="transaction-header">
                            <span class="transaction-type"><i class="fas fa-money-bill"></i> تغيير الراتب</span>
                            <span class="${diffClass}">${diffText}</span>
                        </div>
                        <div style="font-size: 13px;">
                            <p><strong>من:</strong> ${c.oldSalary.toLocaleString()} ج.م → <strong>إلى:</strong> ${c.newSalary.toLocaleString()} ج.م</p>
                            ${c.reason ? `<p><strong>السبب:</strong> ${c.reason}</p>` : ''}
                            <div class="row">
                                <div class="col-md-6">
                                    <small>📅 ${new Date(c.changeDate).toLocaleString('ar-EG')}</small>
                                </div>
                                <div class="col-md-6">
                                    <small>👤 بواسطة: ${c.changedBy}</small>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            });
            html += '</div>';
            document.getElementById('salaryChangesList').innerHTML = html;
        }

        // إظهار مودال تأكيد دفع الراتب
        function showConfirmSalaryModal(employeeId, month, year, amount) {
            currentConfirmSalaryData = { employeeId, month, year };
            document.getElementById('confirmSalaryMessage').innerText = `هل أنت متأكد من تأكيد دفع راتب شهر ${month}/${year} بمبلغ ${amount.toLocaleString()} ج.م؟`;
            document.getElementById('confirmSalaryModal').style.display = 'block';
        }

        // إغلاق مودال تأكيد دفع الراتب
        function closeConfirmSalaryModal() {
            document.getElementById('confirmSalaryModal').style.display = 'none';
        }

        // تنفيذ تأكيد دفع الراتب
        function executeConfirmSalary() {
            if (!currentConfirmSalaryData) return;

            fetch(`/Employees/ConfirmSalaryPayment?employeeId=${currentConfirmSalaryData.employeeId}&month=${currentConfirmSalaryData.month}&year=${currentConfirmSalaryData.year}`, {
                method: 'POST'
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert(data.message);
                    closeConfirmSalaryModal();
                    showEmployeeDetails(currentEmployeeId);
                } else {
                    alert(data.message);
                }
            });
        }

        // إظهار مودال إضافة معاملة
        function showAddTransactionModal(type) {
            currentTransactionType = type;
            document.getElementById('transactionModalTitle').innerText = `إضافة ${type}`;
            document.getElementById('transactionEmployeeId').value = currentEmployeeId;
            document.getElementById('transactionType').value = type;
            document.getElementById('transactionTypeDisplay').value = type;
            document.getElementById('transactionAmount').value = '';
            document.getElementById('transactionDescription').value = '';
            document.getElementById('transactionMonth').value = new Date().getMonth() + 1;
            document.getElementById('transactionYear').value = new Date().getFullYear();
            document.getElementById('transactionNotes').value = '';
            document.getElementById('transactionModal').style.display = 'block';
        }

        // إغلاق مودال المعاملة
        function closeTransactionModal() {
            document.getElementById('transactionModal').style.display = 'none';
        }

        // حفظ المعاملة
        function saveTransaction() {
            const data = {
                employeeId: parseInt(document.getElementById('transactionEmployeeId').value),
                transactionType: document.getElementById('transactionType').value,
                amount: parseFloat(document.getElementById('transactionAmount').value),
                description: document.getElementById('transactionDescription').value,
                month: parseInt(document.getElementById('transactionMonth').value),
                year: parseInt(document.getElementById('transactionYear').value),
                notes: document.getElementById('transactionNotes').value || null
            };

            if (!data.amount || data.amount <= 0) {
                alert('❌ الرجاء إدخال مبلغ صحيح');
                return;
            }

            if (!data.description) {
                alert('❌ الرجاء إدخال بيان المعاملة');
                return;
            }

            fetch('/Employees/AddTransaction', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert(data.message);
                    closeTransactionModal();
                    showEmployeeDetails(currentEmployeeId);
                    loadDashboardStats();
                } else {
                    alert('❌ ' + data.message);
                }
            })
            .catch(error => {
                alert('❌ حدث خطأ في الاتصال بالخادم');
            });
        }

        // إظهار مودال تغيير الراتب
        function showChangeSalaryModal() {
            document.getElementById('changeSalaryEmployeeId').value = currentEmployeeId;
            document.getElementById('currentSalary').value = currentEmployee.currentSalary.toLocaleString() + ' ج.م';
            document.getElementById('newSalary').value = currentEmployee.currentSalary;
            document.getElementById('salaryChangeReason').value = '';
            document.getElementById('changeSalaryModal').style.display = 'block';
        }

        // إغلاق مودال تغيير الراتب
        function closeChangeSalaryModal() {
            document.getElementById('changeSalaryModal').style.display = 'none';
        }

        // حفظ تغيير الراتب
        function saveSalaryChange() {
            const data = {
                employeeId: parseInt(document.getElementById('changeSalaryEmployeeId').value),
                newSalary: parseFloat(document.getElementById('newSalary').value),
                reason: document.getElementById('salaryChangeReason').value
            };

            if (!data.newSalary || data.newSalary <= 0) {
                alert('❌ الرجاء إدخال راتب صحيح');
                return;
            }

            if (!data.reason) {
                alert('❌ الرجاء إدخال سبب تغيير الراتب');
                return;
            }

            fetch('/Employees/ChangeSalary', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert(data.message);
                    closeChangeSalaryModal();
                    showEmployeeDetails(currentEmployeeId);
                } else {
                    alert('❌ ' + data.message);
                }
            });
        }

        // إظهار مودال اختيار الشهر للتقرير
        function showReportMonthModal() {
            document.getElementById('reportMonthModal').style.display = 'block';
        }

        // إغلاق مودال اختيار الشهر
        function closeReportMonthModal() {
            document.getElementById('reportMonthModal').style.display = 'none';
        }

        // إنشاء تقرير شهري PDF
        function generateMonthlyReport() {
            const month = document.getElementById('reportMonth').value;
            const year = document.getElementById('reportYear').value;

            fetch(`/Employees/GetMonthlyReport?employeeId=${currentEmployeeId}&month=${month}&year=${year}`)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        printReportPDF(data.report);
                        closeReportMonthModal();
                    } else {
                        alert('خطأ في تحميل التقرير: ' + data.message);
                    }
                });
        }

        // طباعة التقرير PDF
        function printReportPDF(report) {
            try {
                const printContainer = document.createElement('div');
                printContainer.style.width = '80mm';
                printContainer.style.padding = '3mm';
                printContainer.style.fontFamily = 'Segoe UI, Tahoma, sans-serif';
                printContainer.style.background = 'white';
                printContainer.style.direction = 'rtl';
                printContainer.style.position = 'absolute';
                printContainer.style.top = '-9999px';
                printContainer.style.left = '-9999px';

                // إنشاء HTML التقرير
                let additionsHtml = '';
                report.additions.forEach((item, index) => {
                    additionsHtml += `
                        <tr>
                            <td style="padding: 2px; font-size: 7px;">${index + 1}</td>
                            <td style="padding: 2px; font-size: 7px;">${new Date(item.date).toLocaleDateString('ar-EG')}</td>
                            <td style="padding: 2px; font-size: 7px;">${item.description}</td>
                            <td style="padding: 2px; font-size: 7px; color: #28a745;">${item.amount.toLocaleString()} ج.م</td>
                        </tr>
                    `;
                });

                let deductionsHtml = '';
                report.deductions.forEach((item, index) => {
                    deductionsHtml += `
                        <tr>
                            <td style="padding: 2px; font-size: 7px;">${index + 1}</td>
                            <td style="padding: 2px; font-size: 7px;">${new Date(item.date).toLocaleDateString('ar-EG')}</td>
                            <td style="padding: 2px; font-size: 7px;">${item.description}</td>
                            <td style="padding: 2px; font-size: 7px; color: #dc3545;">${item.amount.toLocaleString()} ج.م</td>
                        </tr>
                    `;
                });

                let loansHtml = '';
                report.loans.forEach((item, index) => {
                    loansHtml += `
                        <tr>
                            <td style="padding: 2px; font-size: 7px;">${index + 1}</td>
                            <td style="padding: 2px; font-size: 7px;">${new Date(item.date).toLocaleDateString('ar-EG')}</td>
                            <td style="padding: 2px; font-size: 7px;">${item.description}</td>
                            <td style="padding: 2px; font-size: 7px; color: #9b59b6;">${item.amount.toLocaleString()} ج.م</td>
                        </tr>
                    `;
                });

                printContainer.innerHTML = `
                    <div style="width: 100%; background: #fff; border-radius: 5px; padding: 3px; border: 1px solid #9b59b6;">
                        <!-- رأس التقرير -->
                        <div style="text-align: center; border-bottom: 1px dashed #9b59b6; padding-bottom: 3px; margin-bottom: 3px;">
                            <h1 style="font-size: 14px; font-weight: bold; color: #9b59b6; margin: 0;">Mobile📱Shop</h1>
                            <div style="color: #7f8c8d; font-size: 7px;">كشف راتب موظف</div>
                        </div>

                        <!-- معلومات الموظف -->
                        <div style="background: #f8f9fa; padding: 3px; border-radius: 3px; margin-bottom: 3px; font-size: 8px;">
                            <div><strong>الموظف:</strong> ${report.employeeName}</div>
                            <div><strong>الكود:</strong> ${report.employeeCode}</div>
                            <div><strong>الشهر:</strong> ${report.monthName} ${report.year}</div>
                            <div><strong>القسم:</strong> ${report.department}</div>
                            <div><strong>الوظيفة:</strong> ${report.position}</div>
                        </div>

                        <!-- ملخص الراتب -->
                        <div style="background: #9b59b6; color: white; padding: 4px; border-radius: 3px; margin: 3px 0; font-size: 8px;">
                            <div style="display: flex; justify-content: space-between;">
                                <span>الراتب الأساسي:</span>
                                <span>${report.baseSalary.toLocaleString()} ج.م</span>
                            </div>
                            <div style="display: flex; justify-content: space-between;">
                                <span>إجمالي المكافآت:</span>
                                <span class="text-warning">+${report.totalAdditions.toLocaleString()} ج.م</span>
                            </div>
                            <div style="display: flex; justify-content: space-between;">
                                <span>إجمالي الخصومات:</span>
                                <span class="text-light">-${report.totalDeductions.toLocaleString()} ج.م</span>
                            </div>
                            <div style="display: flex; justify-content: space-between;">
                                <span>إجمالي السلف:</span>
                                <span class="text-info">-${report.totalLoans.toLocaleString()} ج.م</span>
                            </div>
                            <div style="border-top: 1px solid rgba(255,255,255,0.3); margin-top: 2px; padding-top: 2px; display: flex; justify-content: space-between; font-weight: bold;">
                                <span>الصافي:</span>
                                <span>${report.netSalary.toLocaleString()} ج.م</span>
                            </div>
                        </div>

                        <!-- المكافآت -->
                        ${additionsHtml ? `
                        <div style="margin-top: 3px;">
                            <h3 style="font-size: 9px; color: #28a745; margin: 0 0 2px 0;">➕ المكافآت</h3>
                            <table style="width: 100%; border-collapse: collapse;">
                                <thead>
                                    <tr style="background: #28a745; color: white;">
                                        <th style="padding: 2px; font-size: 7px;">#</th>
                                        <th style="padding: 2px; font-size: 7px;">التاريخ</th>
                                        <th style="padding: 2px; font-size: 7px;">البيان</th>
                                        <th style="padding: 2px; font-size: 7px;">المبلغ</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${additionsHtml}
                                </tbody>
                            </table>
                        </div>
                        ` : ''}

                        <!-- الخصومات -->
                        ${deductionsHtml ? `
                        <div style="margin-top: 3px;">
                            <h3 style="font-size: 9px; color: #dc3545; margin: 0 0 2px 0;">➖ الخصومات</h3>
                            <table style="width: 100%; border-collapse: collapse;">
                                <thead>
                                    <tr style="background: #dc3545; color: white;">
                                        <th style="padding: 2px; font-size: 7px;">#</th>
                                        <th style="padding: 2px; font-size: 7px;">التاريخ</th>
                                        <th style="padding: 2px; font-size: 7px;">البيان</th>
                                        <th style="padding: 2px; font-size: 7px;">المبلغ</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${deductionsHtml}
                                </tbody>
                            </table>
                        </div>
                        ` : ''}

                        <!-- السلف -->
                        ${loansHtml ? `
                        <div style="margin-top: 3px;">
                            <h3 style="font-size: 9px; color: #9b59b6; margin: 0 0 2px 0;">💰 السلف</h3>
                            <table style="width: 100%; border-collapse: collapse;">
                                <thead>
                                    <tr style="background: #9b59b6; color: white;">
                                        <th style="padding: 2px; font-size: 7px;">#</th>
                                        <th style="padding: 2px; font-size: 7px;">التاريخ</th>
                                        <th style="padding: 2px; font-size: 7px;">البيان</th>
                                        <th style="padding: 2px; font-size: 7px;">المبلغ</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${loansHtml}
                                </tbody>
                            </table>
                        </div>
                        ` : ''}

                        <!-- الفوتر -->
                        <div style="margin-top: 5px; font-size: 6px; color: #777; text-align: center; border-top: 1px solid #eee; padding-top: 2px;">
                            <div>تم الإنشاء: ${new Date().toLocaleDateString('ar-EG')} - ${new Date().toLocaleTimeString('ar-EG')}</div>
                            <div>شكراً لتعاملكم معنا ✨</div>
                        </div>
                    </div>
                `;

                document.body.appendChild(printContainer);

                html2canvas(printContainer, {
                    scale: 2,
                    backgroundColor: '#ffffff',
                    logging: false,
                    allowTaint: true,
                    useCORS: true
                }).then(canvas => {
                    try {
                        const { jsPDF } = window.jspdf;

                        const imgWidth = 80;
                        const imgHeight = (canvas.height * imgWidth) / canvas.width;

                        const pdf = new jsPDF({
                            orientation: 'portrait',
                            unit: 'mm',
                            format: [imgWidth, imgHeight]
                        });

                        const imgData = canvas.toDataURL('image/png');
                        pdf.addImage(imgData, 'PNG', 0, 0, imgWidth, imgHeight, undefined, 'FAST');

                        const fileName = `راتب_${report.employeeName}_${report.monthName}_${report.year}.pdf`;
                        pdf.save(fileName);

                    } finally {
                        if (printContainer.parentNode) {
                            document.body.removeChild(printContainer);
                        }
                    }
                }).catch(error => {
                    console.error('خطأ في تحويل التقرير إلى صورة:', error);
                    if (printContainer.parentNode) {
                        document.body.removeChild(printContainer);
                    }
                });
            } catch (error) {
                console.error('خطأ في طباعة التقرير:', error);
            }
        }

        // تبديل تبويب التفاصيل
        function switchDetailsTab(tab, isActive) {
            document.querySelectorAll('#employeeDetailsModal .tab').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');

            document.querySelectorAll('#employeeDetailsModal .tab-content').forEach(content => content.classList.remove('active'));
            document.getElementById(tab + 'Tab').classList.add('active');
        }

        // إغلاق مودال التفاصيل
        function closeDetailsModal() {
            document.getElementById('employeeDetailsModal').style.display = 'none';
        }

        // تعديل الموظف الحالي
        function editCurrentEmployee() {
            closeDetailsModal();
            editEmployee(currentEmployeeId);
        }

        // حذف الموظف الحالي
        function deleteCurrentEmployee() {
            closeDetailsModal();
            deleteEmployee(currentEmployeeId);
        }
    </script>

</body>
</html>