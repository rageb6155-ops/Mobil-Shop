@model List<MobileShopSystem.Models.Product>
@{
    ViewData["Title"] = "إدارة المنتجات";
    var username = Context.Session.GetString("Username");
    var lowStock = ViewBag.LowStock as List<MobileShopSystem.Models.Product>;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: #ffffff;
            margin: 0;
            padding: 20px;
            color: #333;
        }

        .page-wrapper {
            max-width: 1200px;
            margin: 0 auto;
        }

        /* بطاقة العنوان */
        .header-card {
            background: white;
            border-radius: 16px;
            padding: 20px 25px;
            margin-bottom: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .header-title h1 {
            margin: 0;
            font-size: 26px;
            font-weight: 600;
            color: #43cea2;
        }

        .header-title p {
            margin: 5px 0 0;
            color: #6c757d;
            font-size: 14px;
        }

        .user-info {
            background: #f8f9fa;
            color: #43cea2;
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 500;
            border: 1px solid #e9ecef;
        }

            .user-info i {
                margin-left: 8px;
            }

        /* بطاقة الإضافة */
        .add-card {
            background: white;
            border-radius: 16px;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
            margin-bottom: 25px;
        }

        .add-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
            color: #43cea2;
            font-weight: 600;
            font-size: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #f0f0f0;
        }

            .add-title i {
                font-size: 24px;
            }

        /* البحث */
        .search-card {
            background: white;
            border-radius: 16px;
            padding: 20px 25px;
            margin-bottom: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
        }

        .search-label {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 15px;
            color: #333;
            font-weight: 500;
        }

            .search-label i {
                color: #43cea2;
                font-size: 20px;
            }

        .search-input {
            width: 100%;
            padding: 12px 20px;
            border: 2px solid #e9ecef;
            border-radius: 50px;
            font-size: 15px;
            transition: all 0.3s;
            background: #f8f9fa;
        }

            .search-input:focus {
                outline: none;
                border-color: #43cea2;
                background: white;
                box-shadow: 0 5px 20px rgba(67, 206, 162, 0.1);
            }

        /* بطاقة الجدول */
        .table-card {
            background: white;
            border-radius: 16px;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
        }

        .table-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
            color: #43cea2;
            font-weight: 600;
            font-size: 20px;
        }

            .table-title i {
                font-size: 24px;
            }

        /* الجدول */
        .table-responsive {
            overflow-x: auto;
            border-radius: 12px;
        }

        .product-table {
            width: 100%;
            border-collapse: collapse;
            background: white;
        }

            .product-table th {
                background: #43cea2;
                color: white;
                padding: 12px;
                font-weight: 500;
                font-size: 14px;
                text-align: center;
            }

            .product-table td {
                padding: 12px;
                border-bottom: 1px solid #e9ecef;
                text-align: center;
                color: #333;
                font-size: 14px;
            }

            .product-table tbody tr {
                transition: all 0.3s;
            }

                .product-table tbody tr:hover {
                    background: #f0f9f5;
                }

                /* تظليل الصفوف ذات الكمية المنخفضة */
                .product-table tbody tr.low-stock-row {
                    background: #fff3cd;
                    border-right: 3px solid #ffc107;
                }

                    .product-table tbody tr.low-stock-row:hover {
                        background: #ffe69c;
                    }

        /* الأزرار */
        .btn {
            padding: 6px 12px;
            border-radius: 6px;
            color: #fff;
            text-decoration: none;
            font-size: 12px;
            margin: 2px;
            display: inline-block;
            transition: all 0.3s;
            border: none;
            cursor: pointer;
        }

            .btn:hover {
                transform: translateY(-2px);
            }

        .btn-primary {
            background: #43cea2;
        }

            .btn-primary:hover {
                background: #3ab391;
            }

        .btn-info {
            background: #3498db;
        }

        .btn-success {
            background: #27ae60;
        }

        /* تنبيه */
        .alert {
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .alert-success {
            background: #d4edda;
            color: #155724;
            border-right: 3px solid #28a745;
        }

        .alert-danger {
            background: #f8d7da;
            color: #721c24;
            border-right: 3px solid #dc3545;
        }

        .alert-warning {
            background: #fff3cd;
            color: #856404;
            border-right: 3px solid #ffc107;
        }

        /* تحذير المنتجات المنخفضة */
        .low-stock-warning {
            background: #fff3cd;
            color: #856404;
            padding: 20px;
            border-radius: 12px;
            margin-top: 25px;
            border-right: 4px solid #ffc107;
            box-shadow: 0 5px 15px rgba(255, 193, 7, 0.1);
        }

        .low-stock-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 15px;
            font-size: 18px;
            font-weight: 600;
        }

            .low-stock-header i {
                font-size: 28px;
                color: #ffc107;
            }

        .low-stock-items {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .low-stock-badge {
            background: white;
            color: #856404;
            padding: 8px 16px;
            border-radius: 30px;
            font-size: 14px;
            font-weight: 500;
            box-shadow: 0 3px 8px rgba(0,0,0,0.05);
            border: 1px solid #ffe69c;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .low-stock-badge i {
                color: #ffc107;
            }

        .low-stock-count {
            background: #ffc107;
            color: #333;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="page-wrapper">

        <!-- بطاقة العنوان -->
        <div class="header-card">
            <div class="header-title">
                <h1>
                    <i class="fas fa-boxes"></i> إدارة المنتجات
                </h1>
                <p>إضافة وتعديل ومتابعة المنتجات</p>
            </div>
            <div class="user-info">
                <i class="fas fa-user-circle"></i>
                @username
            </div>
        </div>

        <!-- رسائل النجاح والخطأ -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
            </div>
        }
        @if (TempData["ErrorName"] != null)
        {
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i> @TempData["ErrorName"]
            </div>
        }
        @if (TempData["ErrorCode"] != null)
        {
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i> @TempData["ErrorCode"]
            </div>
        }
        @if (TempData["ErrorSerial"] != null)
        {
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i> @TempData["ErrorSerial"]
            </div>
        }

        <!-- بطاقة إضافة/تعديل منتج -->
        <div class="add-card">
            <div class="add-title">
                <i class="fas fa-plus-circle"></i>
                <span>إضافة / تعديل منتج</span>
            </div>
            <form method="post" asp-action="Save" id="productForm" onsubmit="return validateForm()">
                <input type="hidden" name="Id" id="productId" />
                <div class="row mb-3">
                    <div class="col-md-6">
                        <input type="text" name="Name" id="Name" placeholder="اسم المنتج" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <input type="text" name="ShortCode" id="ShortCode" placeholder="الكود المختصر" class="form-control" required />
                    </div>
                </div>
                <div class="mb-3">
                    <input type="text" name="SerialNumber" id="SerialNumber" placeholder="السيريال" class="form-control" required />
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <input type="number" name="FactoryPrice" id="FactoryPrice" placeholder="سعر المصنع" class="form-control" step="0.01" required />
                    </div>
                    <div class="col-md-6">
                        <input type="number" name="SalePrice" id="SalePrice" placeholder="سعر البيع" class="form-control" step="0.01" required />
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <input type="text" name="PurchasePlace" id="PurchasePlace" placeholder="مكان الشراء" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <input type="text" name="StoragePlace" id="StoragePlace" placeholder="مكان التخزين" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <input type="number" name="Quantity" id="Quantity" placeholder="الكمية" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-primary" id="saveBtn">
                    <i class="fas fa-save"></i> حفظ المنتج
                </button>
            </form>
        </div>

        <!-- بطاقة البحث -->
        <div class="search-card">
            <div class="search-label">
                <i class="fas fa-search"></i>
                <span>ابحث عن منتج</span>
            </div>
            <input type="text" id="searchInput" class="search-input" placeholder="ابحث بالاسم أو الكود أو السيريال..." />
        </div>

        <!-- بطاقة الجدول -->
        <div class="table-card">
            <div class="table-title">
                <i class="fas fa-list"></i>
                <span>قائمة المنتجات</span>
            </div>
            <div class="table-responsive">
                <table class="product-table" id="productsTable">
                    <thead>
                        <tr>
                            <th>الاسم</th>
                            <th>الكود المختصر</th>
                            <th>السيريال</th>
                            <th>الكمية</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            var isLowStock = p.Quantity < 3;
                            <tr data-id="@p.Id"
                                data-name="@p.Name"
                                data-code="@p.ShortCode"
                                data-serial="@p.SerialNumber"
                                data-factory="@p.FactoryPrice"
                                data-sale="@p.SalePrice"
                                data-purchase="@p.PurchasePlace"
                                data-storage="@p.StoragePlace"
                                data-quantity="@p.Quantity"
                                class="@(isLowStock ? "low-stock-row" : "")">
                                <td>@p.Name</td>
                                <td>@p.ShortCode</td>
                                <td>@p.SerialNumber</td>
                                <td>
                                    @if (isLowStock)
                                    {
                                        <span style="color: #dc3545; font-weight: bold;">
                                            <i class="fas fa-exclamation-triangle"></i> @p.Quantity
                                        </span>
                                    }
                                    else
                                    {
                                        @p.Quantity
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-info" onclick="editProduct(this)">
                                        <i class="fas fa-edit"></i> تعديل
                                    </button>
                                    <a href="/Products/Details/@p.Id" class="btn btn-success">
                                        <i class="fas fa-info-circle"></i> التفاصيل
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- تنبيه المنتجات على وشك النفاذ -->
        @{
            var lowStockProducts = Model.Where(p => p.Quantity < 3).ToList();
        }
        @if (lowStockProducts.Any())
        {
            <div class="low-stock-warning">
                <div class="low-stock-header">
                    <i class="fas fa-exclamation-triangle"></i>
                    <span>منتجات على وشك النفاذ (أقل من 3 قطع)</span>
                    <span class="low-stock-count">@lowStockProducts.Count</span>
                </div>
                <div class="low-stock-items">
                    @foreach (var p in lowStockProducts)
                    {
                        <span class="low-stock-badge">
                            <i class="fas fa-box"></i> @p.Name
                            <span style="background: #ffc107; color: #333; padding: 2px 6px; border-radius: 12px; font-size: 11px;">@p.Quantity</span>
                        </span>
                    }
                </div>
            </div>
        }
    </div>

    <script>
        // عناصر الصفحة
        const searchInput = document.getElementById("searchInput");
        const table = document.getElementById("productsTable");
        const rows = document.querySelectorAll("#productsTable tbody tr");

        // دالة البحث
        function searchProducts() {
            const filter = searchInput.value.toLowerCase();

            rows.forEach(row => {
                const name = row.cells[0].innerText.toLowerCase();
                const code = row.cells[1].innerText.toLowerCase();
                const serial = row.cells[2].innerText.toLowerCase();

                const match = name.includes(filter) || code.includes(filter) || serial.includes(filter);
                row.style.display = match ? "" : "none";
            });
        }

        // دالة تعديل المنتج
        function editProduct(btn) {
            const tr = btn.closest("tr");

            document.getElementById("productId").value = tr.dataset.id;
            document.getElementById("Name").value = tr.dataset.name;
            document.getElementById("ShortCode").value = tr.dataset.code;
            document.getElementById("SerialNumber").value = tr.dataset.serial;
            document.getElementById("FactoryPrice").value = tr.dataset.factory;
            document.getElementById("SalePrice").value = tr.dataset.sale;
            document.getElementById("PurchasePlace").value = tr.dataset.purchase || '';
            document.getElementById("StoragePlace").value = tr.dataset.storage || '';
            document.getElementById("Quantity").value = tr.dataset.quantity;

            document.getElementById("saveBtn").innerHTML = '<i class="fas fa-edit"></i> تعديل المنتج';

            // تمرير للصفحة لأعلى
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // دالة التحقق من التكرار قبل الإرسال
        function validateForm() {
            const name = document.getElementById("Name").value.trim();
            const code = document.getElementById("ShortCode").value.trim();
            const serial = document.getElementById("SerialNumber").value.trim();
            const currentId = document.getElementById("productId").value;

            // التحقق من تكرار الاسم
            let nameExists = false;
            let codeExists = false;
            let serialExists = false;

            rows.forEach(row => {
                const rowId = row.dataset.id;
                // نتخطى نفس المنتج في حالة التعديل
                if (rowId === currentId) return;

                if (row.dataset.name === name) nameExists = true;
                if (row.dataset.code === code) codeExists = true;
                if (row.dataset.serial === serial) serialExists = true;
            });

            if (nameExists) {
                alert("⚠️ خطأ: اسم المنتج موجود بالفعل");
                return false;
            }

            if (codeExists) {
                alert("⚠️ خطأ: الكود المختصر موجود بالفعل");
                return false;
            }

            if (serialExists) {
                alert("⚠️ خطأ: السيريال موجود بالفعل");
                return false;
            }

            return true;
        }

        // أحداث البحث
        searchInput.addEventListener("keyup", searchProducts);
        searchInput.addEventListener("paste", function() {
            setTimeout(searchProducts, 100);
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>