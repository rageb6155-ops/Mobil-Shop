@model MobileShopSystem.Models.Device
@{
    ViewData["Title"] = "تفاصيل الجهاز";
    var username = Context.Session.GetString("Username");
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: #ffffff;
            margin: 0;
            padding: 20px;
            color: #333;
        }

        .page-wrapper {
            max-width: 900px;
            margin: 0 auto;
        }

        /* بطاقة العنوان */
        .header-card {
            background: white;
            border-radius: 16px;
            padding: 20px 25px;
            margin-bottom: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .header-title h1 {
            margin: 0;
            font-size: 26px;
            font-weight: 600;
            color: #9b59b6;
        }

        .header-title p {
            margin: 5px 0 0;
            color: #6c757d;
            font-size: 14px;
        }

        .user-info {
            background: #f8f9fa;
            color: #9b59b6;
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 500;
            border: 1px solid #e9ecef;
        }

            .user-info i {
                margin-left: 8px;
            }

        /* بطاقة التفاصيل */
        .details-card {
            background: white;
            border-radius: 16px;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
        }

        .details-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
            color: #9b59b6;
            font-weight: 600;
            font-size: 22px;
            padding-bottom: 10px;
            border-bottom: 2px solid #f0f0f0;
        }

            .details-title i {
                font-size: 24px;
            }

        /* صورة الجهاز */
        .device-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #9b59b6, #8e44ad);
            border-radius: 50%;
            margin: 0 auto 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 40px;
            box-shadow: 0 5px 15px rgba(155, 89, 182, 0.3);
        }

        /* أقسام البيانات */
        .section-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 25px 0 15px;
            color: #9b59b6;
            font-weight: 600;
            font-size: 18px;
        }

            .section-title i {
                font-size: 20px;
            }

            .section-title.success {
                color: #27ae60;
            }

            .section-title.warning {
                color: #f39c12;
            }

        /* شبكة المعلومات */
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 15px;
            margin-bottom: 15px;
        }

        .info-item {
            background: #f8f9fa;
            padding: 12px 15px;
            border-radius: 10px;
            border-right: 3px solid #9b59b6;
        }

            .info-item.success {
                border-right-color: #27ae60;
            }

            .info-item.warning {
                border-right-color: #f39c12;
            }

        .info-label {
            font-size: 12px;
            color: #6c757d;
            margin-bottom: 5px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .info-label i {
                width: 20px;
            }

            .info-label.success i {
                color: #27ae60;
            }

            .info-label.warning i {
                color: #f39c12;
            }

        .info-value {
            font-size: 16px;
            font-weight: 600;
            color: #333;
            padding-right: 25px;
        }

        /* حالة الجهاز */
        .status-badge {
            display: inline-block;
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 500;
        }

        .status-safe {
            background: #d4edda;
            color: #155724;
        }

        .status-edited {
            background: #fff3cd;
            color: #856404;
        }

        .status-deleted {
            background: #f8d7da;
            color: #721c24;
        }

        /* خط فاصل */
        .divider {
            height: 1px;
            background: linear-gradient(to right, transparent, #9b59b6, transparent);
            margin: 25px 0;
        }

        /* زر الرجوع */
        .btn-back {
            background: linear-gradient(135deg, #9b59b6, #8e44ad);
            color: white;
            text-decoration: none;
            padding: 12px 25px;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-top: 20px;
            transition: all 0.3s;
            border: none;
            font-size: 14px;
            font-weight: 500;
        }

            .btn-back:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(155, 89, 182, 0.3);
            }
    </style>
</head>
<body>
    <div class="page-wrapper">

        <!-- بطاقة العنوان -->
        <div class="header-card">
            <div class="header-title">
                <h1>
                    <i class="fas fa-mobile-alt"></i> تفاصيل الجهاز
                </h1>
                <p>عرض كامل لبيانات الجهاز والتعديلات</p>
            </div>
            <div class="user-info">
                <i class="fas fa-user-circle"></i>
                @username
            </div>
        </div>

        <!-- بطاقة التفاصيل -->
        <div class="details-card">
            <div class="details-title">
                <i class="fas fa-info-circle"></i>
                <span>معلومات الجهاز</span>
            </div>

            <!-- أيقونة الجهاز -->
            <div class="device-icon">
                <i class="fas fa-mobile-alt"></i>
            </div>

            <!-- البيانات الأصلية -->
            <div class="section-title success">
                <i class="fas fa-history"></i>
                <span>📌 البيانات الأصلية عند الإضافة</span>
            </div>

            <div class="info-grid">
                <div class="info-item success">
                    <div class="info-label success">
                        <i class="fas fa-tag"></i> الاسم
                    </div>
                    <div class="info-value">@Model.OriginalName</div>
                </div>
                <div class="info-item success">
                    <div class="info-label success">
                        <i class="fas fa-barcode"></i> السيريال
                    </div>
                    <div class="info-value">@Model.OriginalSerial</div>
                </div>
                <div class="info-item success">
                    <div class="info-label success">
                        <i class="fas fa-hdd"></i> السعة
                    </div>
                    <div class="info-value">@Model.OriginalStorage GB</div>
                </div>
                <div class="info-item success">
                    <div class="info-label success">
                        <i class="fas fa-microchip"></i> الرام
                    </div>
                    <div class="info-value">@Model.OriginalRAM GB</div>
                </div>
                <div class="info-item success">
                    <div class="info-label success">
                        <i class="fas fa-dollar-sign"></i> سعر الشراء
                    </div>
                    <div class="info-value">@Model.OriginalPurchasePrice?.ToString("N0") ج.م</div>
                </div>
                <div class="info-item success">
                    <div class="info-label success">
                        <i class="fas fa-coins"></i> سعر البيع
                    </div>
                    <div class="info-value">@Model.OriginalSalePrice?.ToString("N0") ج.م</div>
                </div>
                <div class="info-item success">
                    <div class="info-label success">
                        <i class="fas fa-user-tie"></i> نوع المالك
                    </div>
                    <div class="info-value">@Model.OriginalOwnerType</div>
                </div>
                <div class="info-item success">
                    <div class="info-label success">
                        <i class="fas fa-user"></i> اسم المالك
                    </div>
                    <div class="info-value">@Model.OriginalOwnerName</div>
                </div>
                <div class="info-item success">
                    <div class="info-label success">
                        <i class="fas fa-phone"></i> رقم الهاتف
                    </div>
                    <div class="info-value">@Model.OriginalOwnerPhone</div>
                </div>
                <div class="info-item success">
                    <div class="info-label success">
                        <i class="fas fa-id-card"></i> رقم الهوية
                    </div>
                    <div class="info-value">@Model.OriginalOwnerID</div>
                </div>
            </div>

            <div class="info-grid">
                <div class="info-item">
                    <div class="info-label">
                        <i class="fas fa-user-plus"></i> أضيف بواسطة
                    </div>
                    <div class="info-value">@Model.CreatedBy</div>
                </div>
                <div class="info-item">
                    <div class="info-label">
                        <i class="far fa-calendar-alt"></i> تاريخ الإضافة
                    </div>
                    <div class="info-value">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
                </div>
            </div>

            <!-- بيانات التعديل -->
            @if (!string.IsNullOrEmpty(Model.UpdatedBy))
            {
                <div class="divider"></div>

                <div class="section-title warning">
                    <i class="fas fa-edit"></i>
                    <span>📝 البيانات بعد التعديل</span>
                </div>

                <div class="info-grid">
                    <div class="info-item warning">
                        <div class="info-label warning">
                            <i class="fas fa-user-edit"></i> تم التعديل بواسطة
                        </div>
                        <div class="info-value">@Model.UpdatedBy</div>
                    </div>
                    <div class="info-item warning">
                        <div class="info-label warning">
                            <i class="fas fa-clock"></i> تاريخ التعديل
                        </div>
                        <div class="info-value">@Model.UpdatedAt?.ToString("yyyy-MM-dd HH:mm")</div>
                    </div>
                    <div class="info-item warning">
                        <div class="info-label warning">
                            <i class="fas fa-tag"></i> الاسم بعد التعديل
                        </div>
                        <div class="info-value">@Model.Name</div>
                    </div>
                    <div class="info-item warning">
                        <div class="info-label warning">
                            <i class="fas fa-barcode"></i> السيريال بعد التعديل
                        </div>
                        <div class="info-value">@Model.Serial</div>
                    </div>
                    <div class="info-item warning">
                        <div class="info-label warning">
                            <i class="fas fa-hdd"></i> السعة بعد التعديل
                        </div>
                        <div class="info-value">@Model.Storage GB</div>
                    </div>
                    <div class="info-item warning">
                        <div class="info-label warning">
                            <i class="fas fa-microchip"></i> الرام بعد التعديل
                        </div>
                        <div class="info-value">@Model.RAM GB</div>
                    </div>
                    <div class="info-item warning">
                        <div class="info-label warning">
                            <i class="fas fa-dollar-sign"></i> سعر الشراء بعد التعديل
                        </div>
                        <div class="info-value">@Model.PurchasePrice?.ToString("N0") ج.م</div>
                    </div>
                    <div class="info-item warning">
                        <div class="info-label warning">
                            <i class="fas fa-coins"></i> سعر البيع بعد التعديل
                        </div>
                        <div class="info-value">@Model.SalePrice?.ToString("N0") ج.م</div>
                    </div>
                    <div class="info-item warning">
                        <div class="info-label warning">
                            <i class="fas fa-user-tie"></i> نوع المالك بعد التعديل
                        </div>
                        <div class="info-value">@Model.OwnerType</div>
                    </div>
                    <div class="info-item warning">
                        <div class="info-label warning">
                            <i class="fas fa-user"></i> اسم المالك بعد التعديل
                        </div>
                        <div class="info-value">@Model.OwnerName</div>
                    </div>
                    <div class="info-item warning">
                        <div class="info-label warning">
                            <i class="fas fa-phone"></i> رقم الهاتف بعد التعديل
                        </div>
                        <div class="info-value">@Model.OwnerPhone</div>
                    </div>
                    <div class="info-item warning">
                        <div class="info-label warning">
                            <i class="fas fa-id-card"></i> رقم الهوية بعد التعديل
                        </div>
                        <div class="info-value">@Model.OwnerID</div>
                    </div>
                </div>
            }

            <div class="divider"></div>

            <!-- حالة الجهاز -->
            <div style="display: flex; align-items: center; gap: 10px; margin: 20px 0;">
                <span style="font-weight: bold; color: #333;">الحالة:</span>
                @switch (Model.Status)
                {
                    case "سليم":
                        <span class="status-badge status-safe"><i class="fas fa-check"></i> سليم</span>
                        break;
                    case "تم تعديل":
                        <span class="status-badge status-edited"><i class="fas fa-edit"></i> تم التعديل</span>
                        break;
                    case "تم الحذف":
                    case "تم الحذف نهائي":
                        <span class="status-badge status-deleted"><i class="fas fa-trash"></i> محذوف</span>
                        break;
                    default:
                        <span class="status-badge bg-secondary">@Model.Status</span>
                        break;
                }
            </div>

            <!-- زر الرجوع -->
            <div style="margin-top: 30px;">
                <a asp-action="Index" class="btn-back">
                    <i class="fas fa-arrow-right"></i> الرجوع للأجهزة
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>