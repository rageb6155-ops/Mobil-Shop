@{
    ViewData["Title"] = "تسجيل الدخول";
}

<style>
    body {
        background: linear-gradient(135deg, #667eea, #764ba2);
        font-family: 'Segoe UI', Tahoma;
    }

    .card {
        width: 380px;
        margin: 80px auto;
        background: #fff;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0,0,0,.2);
    }

    h2 {
        text-align: center;
        margin-bottom: 25px;
        color: #333;
    }

    input {
        width: 100%;
        padding: 12px;
        margin-bottom: 15px;
        border-radius: 8px;
        border: 1px solid #ccc;
        font-size: 15px;
    }

    button {
        width: 100%;
        padding: 12px;
        border: none;
        background: #667eea;
        color: #fff;
        font-size: 16px;
        border-radius: 8px;
        cursor: pointer;
    }

        button:disabled {
            background: #aaa;
        }

    .loader {
        display: none;
        margin: 15px auto 0;
        width: 40px;
        height: 40px;
        border: 5px solid #eee;
        border-top: 5px solid #667eea;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        100% {
            transform: rotate(360deg);
        }
    }

    .error {
        color: red;
        text-align: center;
        margin-bottom: 10px;
    }

    .link {
        text-align: center;
        margin-top: 15px;
    }
</style>

<div class="card">

       <h2>تسجيل الدخول</h2>

    @if (ViewBag.Error != null)
    {
        <div class="error">@ViewBag.Error</div>
    }

    <form method="post" onsubmit="showLoader()">
        <input type="text"
               name="username"
               placeholder="اسم المستخدم"
               autocomplete="off"
               required />

        <input type="password"
               name="password"
               placeholder="كلمة السر"
               autocomplete="new-password"
               required />

        <button type="submit" id="btn">تسجيل الدخول</button>

        <div class="loader" id="loader"></div>
    </form>

    <div class="link">
    </div>
</div>

<script>
    function showLoader() {
        document.getElementById("loader").style.display = "block";
        document.getElementById("btn").disabled = true;
    }
</script>
