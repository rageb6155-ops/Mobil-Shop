@{
    ViewData["Title"] = "إنشاء حساب";
}

<style>
    body {
        background: linear-gradient(135deg, #43cea2, #185a9d);
        font-family: 'Segoe UI', Tahoma;
    }

    .card {
        width: 420px;
        margin: 60px auto;
        background: #fff;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0,0,0,.2);
        position: relative;
        z-index: 1;
    }

    h2 {
        text-align: center;
        margin-bottom: 25px;
    }

    input {
        width: 100%;
        padding: 12px;
        margin-bottom: 15px;
        border-radius: 8px;
        border: 1px solid #ccc;
        font-size: 14px;
    }

    button {
        width: 100%;
        padding: 12px;
        border: none;
        background: #43cea2;
        color: #fff;
        font-size: 16px;
        border-radius: 8px;
        cursor: pointer;
    }

        button:disabled {
            opacity: .7;
            cursor: not-allowed;
        }

    .loader {
        display: none;
        margin: 15px auto 0;
        width: 40px;
        height: 40px;
        border: 5px solid #eee;
        border-top: 5px solid #43cea2;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        100% {
            transform: rotate(360deg);
        }
    }

    /* ===== رسالة الخطأ الجديدة ===== */
    .error-message {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
        padding: 15px 20px;
        border-radius: 10px;
        margin-bottom: 20px;
        text-align: center;
        font-size: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        box-shadow: 0 5px 15px rgba(245, 87, 108, 0.3);
        animation: slideDown 0.3s ease;
    }

        .error-message i {
            font-size: 18px;
        }

    /* ===== Overlay النجاح الجديد ===== */
    .overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.7);
        backdrop-filter: blur(5px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        animation: fadeIn 0.3s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    .success-box {
        background: white;
        padding: 40px 50px;
        border-radius: 20px;
        text-align: center;
        box-shadow: 0 20px 40px rgba(0,0,0,0.3);
        animation: scaleIn 0.4s ease;
        max-width: 400px;
    }

    @@keyframes scaleIn {
        from {
            opacity: 0;
            transform: scale(0.8);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .success-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        color: white;
        font-size: 40px;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.05);
        }

        100% {
            transform: scale(1);
        }
    }

    .success-box h3 {
        color: #2ecc71;
        font-size: 24px;
        margin: 0 0 15px 0;
    }

    .success-box p {
        color: #666;
        font-size: 16px;
        margin: 10px 0;
        line-height: 1.6;
    }

    .timer-circle {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #43cea2, #185a9d);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 20px auto;
        color: white;
        font-size: 24px;
        font-weight: bold;
        box-shadow: 0 5px 15px rgba(67, 206, 162, 0.3);
    }

    .success-box small {
        color: #999;
        font-size: 13px;
        display: block;
        margin-top: 15px;
    }

    /* ===== تأثيرات الحركة ===== */
    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .fade-out {
        animation: fadeOut 0.3s ease forwards;
    }

    @@keyframes fadeOut {
        from {
            opacity: 1;
        }

        to {
            opacity: 0;
        }
    }
</style>

<div class="card">
    <h2>إنشاء حساب</h2>

    @if (ViewBag.Error != null)
    {
        <div class="error-message" id="errorMessage">
            <i class="fas fa-exclamation-circle"></i>
            @ViewBag.Error
        </div>
    }

    <form method="post" onsubmit="return validateForm();">

        <input type="text"
               name="Username"
               placeholder="اسم المستخدم"
               autocomplete="off"
               autocorrect="off"
               autocapitalize="off"
               spellcheck="false"
               required />

        <input type="password"
               name="Password"
               id="password"
               placeholder="كلمة السر"
               autocomplete="off"
               required />

        <input type="password"
               name="ConfirmPassword"
               id="confirmPassword"
               placeholder="إعادة كلمة السر"
               autocomplete="off"
               required />

        <input type="text"
               name="Phone"
               id="phone"
               placeholder="رقم الهاتف"
               autocomplete="off"
               inputmode="numeric"
               required />

        <button type="submit" id="btn">إنشاء الحساب</button>
        <div class="loader" id="loader"></div>
    </form>
</div>

@if (ViewBag.Success != null)
{
    <div class="overlay" id="successOverlay">
        <div class="success-box">
            <div class="success-icon">
                <i class="fas fa-check"></i>
            </div>
            <h3>تم بنجاح! ✅</h3>
            <p>شكراً لتسجيلك في Mobile Shop</p>
            <p>حسابك قيد مراجعة المشرف</p>
            <p>سيتم تفعيله خلال 24 ساعة</p>
            <div class="timer-circle" id="timer">5</div>
            <small>سيتم تحويلك تلقائياً...</small>
        </div>
    </div>
}

<script>
    window.onload = function () {

        const overlay = document.getElementById("successOverlay");
        const timerElement = document.getElementById("timer");
        const errorMessage = document.getElementById("errorMessage");

        if (overlay) {
            document.body.style.overflow = "hidden";

            let seconds = 5;

            // تحديث العداد كل ثانية
            const countdown = setInterval(function() {
                seconds--;
                if (timerElement) {
                    timerElement.textContent = seconds;
                }

                if (seconds <= 0) {
                    clearInterval(countdown);

                    // إضافة تأثير اختفاء قبل التحويل
                    overlay.classList.add('fade-out');

                    setTimeout(function() {
                        window.location.href = "/Account/Login";
                    }, 300);
                }
            }, 1000);

        } else {
            // تفريغ الحقول
            document.getElementById("password").value = "";
            document.getElementById("confirmPassword").value = "";
            document.getElementById("phone").value = "";

            // إخفاء رسالة الخطأ بعد 3 ثواني
            if (errorMessage) {
                setTimeout(function() {
                    errorMessage.classList.add('fade-out');
                    setTimeout(function() {
                        if (errorMessage.parentNode) {
                            errorMessage.parentNode.removeChild(errorMessage);
                        }
                    }, 300);
                }, 3000);
            }
        }
    };

    function clean(v) {
        return v.trim().replace(/\s+/g, '');
    }

    function validateForm() {

        const pass = clean(document.getElementById("password").value);
        const confirm = clean(document.getElementById("confirmPassword").value);
        const phone = clean(document.getElementById("phone").value);

        if (pass !== confirm) {
            alert("❌ كلمتا السر غير متطابقتين");
            return false;
        }

        if (!/^01\d{9}$/.test(phone)) {
            alert("❌ رقم الهاتف يجب أن يبدأ بـ 01 ويتكون من 11 رقم");
            return false;
        }

        document.getElementById("loader").style.display = "block";
        document.getElementById("btn").disabled = true;
        return true;
    }
</script>