@{
    ViewData["Title"] = "الأكواد السريعة";
    var username = Context.Session.GetString("Username");
    var today = DateTime.Now;
    var dayName = today.ToString("dddd", new System.Globalization.CultureInfo("ar-EG"));
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <style>
        /* ===== متغيرات الألوان ===== */
        :root {
            --primary: #6f42c1;
            --primary-dark: #5e35b1;
            --secondary: #6c757d;
            --success: #28a745;
            --info: #17a2b8;
            --warning: #ffc107;
            --danger: #dc3545;
            --light: #f8f9fa;
            --dark: #343a40;
            --white: #ffffff;
            --gradient-1: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --gradient-2: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            --gradient-3: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
            --gradient-4: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
            --gradient-5: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.1);
            --shadow-md: 0 5px 15px rgba(0,0,0,0.15);
            --shadow-lg: 0 10px 25px rgba(0,0,0,0.2);
            --border-radius: 16px;
        }

        /* ===== الوضع الداكن ===== */
        body.dark-mode {
            --light: #2d2d2d;
            --dark: #f8f9fa;
            --white: #1e1e1e;
            background: #121212;
            color: #e0e0e0;
        }

            body.dark-mode .dashboard,
            body.dark-mode .add-card,
            body.dark-mode .search-card,
            body.dark-mode .table-card,
            body.dark-mode .header-card {
                background: #1e1e1e;
                border: 1px solid #333;
            }

            body.dark-mode .form-control {
                background: #2d2d2d;
                border-color: #404040;
                color: #e0e0e0;
            }

            body.dark-mode .codes-table th {
                background: #2d2d2d;
                color: var(--primary);
                border-color: #404040;
            }

            body.dark-mode .codes-table td {
                border-color: #404040;
            }

            body.dark-mode .codes-table tbody tr:hover {
                background: #2d2d2d;
            }

        /* ===== التنسيقات العامة ===== */
        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 20px;
            min-height: 100vh;
        }

        .page-wrapper {
            max-width: 1200px;
            margin: 0 auto;
            animation: fadeInUp 0.5s ease-out forwards;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ===== بطاقة العنوان ===== */
        .header-card {
            background: var(--white);
            border-radius: var(--border-radius);
            padding: 25px 30px;
            margin-bottom: 25px;
            box-shadow: var(--shadow-lg);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
            border: 1px solid rgba(0,0,0,0.03);
        }

        .header-title h1 {
            margin: 0 0 8px 0;
            font-size: 28px;
            font-weight: 700;
            background: var(--gradient-1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .header-title p {
            margin: 0;
            font-size: 15px;
            color: var(--secondary);
        }

        .user-info {
            background: var(--gradient-2);
            color: white;
            padding: 12px 28px;
            border-radius: 50px;
            font-size: 15px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: var(--shadow-md);
        }

        /* ===== بطاقة الإضافة ===== */
        .add-card {
            background: var(--white);
            border-radius: var(--border-radius);
            padding: 30px;
            box-shadow: var(--shadow-lg);
            margin-bottom: 25px;
            border: 1px solid rgba(0,0,0,0.03);
        }

        .add-title {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 25px;
            font-size: 22px;
            font-weight: 700;
            color: var(--primary);
            padding-bottom: 15px;
            border-bottom: 2px solid rgba(0,0,0,0.05);
        }

            .add-title i {
                font-size: 24px;
            }

        /* ===== النماذج ===== */
        .form-control {
            padding: 14px 18px;
            border: 2px solid rgba(0,0,0,0.05);
            border-radius: 12px;
            font-size: 15px;
            background: var(--white);
            transition: all 0.3s ease;
            width: 100%;
        }

            .form-control:focus {
                outline: none;
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(111, 66, 193, 0.1);
            }

        /* ===== الأزرار ===== */
        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            box-shadow: var(--shadow-md);
        }

            .btn:hover {
                transform: translateY(-3px);
                box-shadow: var(--shadow-lg);
            }

        .btn-primary {
            background: var(--gradient-1);
            color: white;
        }

        .btn-warning {
            background: var(--gradient-5);
            color: #333;
        }

        .btn-danger {
            background: linear-gradient(135deg, #dc3545, #c82333);
            color: white;
        }

        .btn-secondary {
            background: linear-gradient(135deg, #6c757d, #5a6268);
            color: white;
        }

        /* ===== بطاقة البحث ===== */
        .search-card {
            background: var(--white);
            border-radius: var(--border-radius);
            padding: 25px 30px;
            margin-bottom: 25px;
            box-shadow: var(--shadow-lg);
            border: 1px solid rgba(0,0,0,0.03);
        }

        .search-label {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 15px;
            color: var(--dark);
            font-weight: 600;
            font-size: 16px;
        }

            .search-label i {
                color: var(--primary);
                font-size: 20px;
            }

        /* ===== بطاقة الجدول ===== */
        .table-card {
            background: var(--white);
            border-radius: var(--border-radius);
            padding: 30px;
            box-shadow: var(--shadow-lg);
            border: 1px solid rgba(0,0,0,0.03);
        }

        .table-title {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 25px;
            font-size: 22px;
            font-weight: 700;
            color: var(--primary);
        }

        .table-responsive {
            overflow-x: auto;
            border-radius: 12px;
        }

        .codes-table {
            width: 100%;
            border-collapse: collapse;
        }

            .codes-table th {
                background: var(--gradient-1);
                color: white;
                padding: 15px;
                font-weight: 600;
                text-align: center;
                font-size: 14px;
            }

            .codes-table td {
                padding: 15px;
                text-align: center;
                border-bottom: 1px solid rgba(0,0,0,0.05);
                background: var(--white);
            }

            .codes-table tbody tr:hover td {
                background: rgba(111, 66, 193, 0.02);
            }

            .codes-table .badge {
                background: var(--gradient-3);
                color: white;
                padding: 6px 12px;
                border-radius: 30px;
                font-size: 12px;
                font-weight: 600;
                display: inline-block;
            }

        .no-results {
            text-align: center;
            padding: 60px 20px;
            color: var(--secondary);
        }

            .no-results i {
                font-size: 60px;
                margin-bottom: 15px;
                opacity: 0.5;
            }

        /* ===== حالة التعديل ===== */
        .editing {
            background: rgba(255, 193, 7, 0.1) !important;
        }

            .editing td {
                background: rgba(255, 193, 7, 0.1) !important;
            }

        /* ===== التنبيهات ===== */
        .alert {
            padding: 16px 20px;
            border-radius: 12px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: var(--shadow-md);
            animation: slideIn 0.3s ease-out;
        }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .alert-success {
            background: var(--gradient-4);
            color: white;
        }

        .alert-danger {
            background: linear-gradient(135deg, #dc3545, #c82333);
            color: white;
        }

        .alert i {
            font-size: 20px;
        }

        /* ===== تحسينات وضع الهاتف ===== */
        body.mobile-view .header-card {
            padding: 20px;
        }

        body.mobile-view .header-title h1 {
            font-size: 24px;
        }

        body.mobile-view .row.mb-3 {
            flex-direction: column;
            gap: 10px;
        }

            body.mobile-view .row.mb-3 > div {
                width: 100%;
                padding: 0 !important;
            }

        body.mobile-view .btn {
            width: 100%;
            justify-content: center;
        }

        body.mobile-view .codes-table th,
        body.mobile-view .codes-table td {
            padding: 10px;
            font-size: 12px;
        }

        body.mobile-view .codes-table .badge {
            font-size: 10px;
            padding: 4px 8px;
        }

        body.mobile-view .add-card,
        body.mobile-view .search-card,
        body.mobile-view .table-card {
            padding: 20px;
        }
    </style>
</head>
<body>
    <div class="page-wrapper">
        <!-- بطاقة العنوان -->
        <div class="header-card">
            <div class="header-title">
                <h1>
                    <i class="fas fa-bolt"></i> الأكواد السريعة
                </h1>
                <p>إدارة الأكواد المختصرة للعمليات السريعة</p>
            </div>
            <div class="user-info">
                <i class="fas fa-user-circle"></i> @username
            </div>
        </div>

        <!-- رسائل التنبيه -->
        <div id="alertContainer"></div>

        <!-- بطاقة الإضافة -->
        <div class="add-card">
            <div class="add-title">
                <i class="fas fa-plus-circle"></i>
                <span id="formTitle">إضافة كود جديد</span>
            </div>
            <form id="codeForm" onsubmit="return false;">
                <input type="hidden" id="codeId" value="0" />
                <div class="row mb-3">
                    <div class="col-md-6">
                        <input type="text" id="codeName" class="form-control" placeholder="اسم العملية (مثال: رصيد 10 جنيه)" required />
                    </div>
                    <div class="col-md-6">
                        <input type="text" id="codeValue" class="form-control" placeholder="الكود المختصر (مثال: 10)" required />
                    </div>
                </div>
                <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                    <button type="button" class="btn btn-primary" onclick="saveCode()">
                        <i class="fas fa-save"></i> <span id="saveBtnText">حفظ</span>
                    </button>
                    <button type="button" class="btn btn-secondary" onclick="resetForm()">
                        <i class="fas fa-undo"></i> تفريغ
                    </button>
                </div>
            </form>
        </div>

        <!-- بطاقة البحث -->
        <div class="search-card">
            <div class="search-label">
                <i class="fas fa-search"></i>
                <span>ابحث عن كود</span>
            </div>
            <input type="text" id="searchInput" class="form-control" placeholder="ابحث باسم العملية أو الكود..." />
        </div>

        <!-- بطاقة الجدول -->
        <div class="table-card">
            <div class="table-title">
                <i class="fas fa-list"></i>
                <span>قائمة الأكواد السريعة</span>
            </div>
            <div class="table-responsive">
                <table class="codes-table" id="codesTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>اسم العملية</th>
                            <th>الكود المختصر</th>
                            <th>أضيف بواسطة</th>
                            <th>تاريخ الإضافة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody id="codesBody">
                        <tr class="no-results">
                            <td colspan="6">
                                <i class="fas fa-bolt"></i>
                                <p>لا توجد أكواد سريعة</p>
                                <small>أضف كود جديد للبدء</small>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        let allCodes = [];
        let editingId = 0;

        // تحميل الأكواد عند فتح الصفحة
        document.addEventListener('DOMContentLoaded', function() {
            loadCodes();
        });

        // تحميل الأكواد
        function loadCodes(search = '') {
            var url = '/QuickCodes/GetAllCodes';
            if (search) {
                url += '?search=' + encodeURIComponent(search);
            }

            fetch(url)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        allCodes = data.codes;
                        renderCodes(data.codes);
                    }
                });
        }

        // عرض الأكواد في الجدول
        function renderCodes(codes) {
            var tbody = document.getElementById('codesBody');
            if (!codes || codes.length === 0) {
                tbody.innerHTML = `
                    <tr class="no-results">
                        <td colspan="6">
                            <i class="fas fa-bolt"></i>
                            <p>لا توجد أكواد سريعة</p>
                            <small>أضف كود جديد للبدء</small>
                        </td>
                    </tr>
                `;
                return;
            }

            tbody.innerHTML = '';
            codes.forEach((code, index) => {
                tbody.innerHTML += `
                    <tr id="code-${code.id}">
                        <td>${index + 1}</td>
                        <td><strong>${code.codeName}</strong></td>
                        <td><span class="badge">${code.codeValue}</span></td>
                        <td>${code.userName || 'غير معروف'}</td>
                        <td>${new Date(code.createdAt).toLocaleString('ar-EG')}</td>
                        <td>
                            <button class="btn btn-warning" onclick="editCode(${code.id})" style="padding: 8px 16px; font-size: 13px;">
                                <i class="fas fa-edit"></i> تعديل
                            </button>
                            <button class="btn btn-danger" onclick="deleteCode(${code.id})" style="padding: 8px 16px; font-size: 13px;">
                                <i class="fas fa-trash"></i> حذف
                            </button>
                        </td>
                    </tr>
                `;
            });
        }

        // حفظ كود (إضافة أو تعديل)
        function saveCode() {
            var id = document.getElementById('codeId').value;
            var name = document.getElementById('codeName').value.trim();
            var value = document.getElementById('codeValue').value.trim();

            if (!name || !value) {
                showAlert('❌ الرجاء إدخال جميع الحقول', 'danger');
                return;
            }

            var url = id === '0' ? '/QuickCodes/AddCode' : '/QuickCodes/UpdateCode';
            var method = 'POST';

            fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: parseInt(id), codeName: name, codeValue: value })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showAlert('✅ ' + data.message, 'success');
                    resetForm();
                    loadCodes(document.getElementById('searchInput').value);
                } else {
                    showAlert('❌ ' + data.message, 'danger');
                }
            });
        }

        // تعديل كود
        function editCode(id) {
            var code = allCodes.find(c => c.id === id);
            if (!code) return;

            editingId = id;
            document.getElementById('codeId').value = id;
            document.getElementById('codeName').value = code.codeName;
            document.getElementById('codeValue').value = code.codeValue;
            document.getElementById('formTitle').innerText = 'تعديل كود';
            document.getElementById('saveBtnText').innerText = 'تعديل';

            // إزالة التحديد من الصفوف
            document.querySelectorAll('.codes-table tbody tr').forEach(tr => {
                tr.classList.remove('editing');
            });
            document.getElementById(`code-${id}`).classList.add('editing');

            // تمرير للصفحة
            document.querySelector('.add-card').scrollIntoView({ behavior: 'smooth' });
        }

        // حذف كود
        function deleteCode(id) {
            if (confirm('⚠️ هل أنت متأكد من حذف هذا الكود؟')) {
                if (confirm('❓ تأكيد نهائي: سيتم حذف الكود نهائياً، هل تريد المتابعة؟')) {
                    fetch('/QuickCodes/DeleteCode', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id: id })
                    })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            showAlert('✅ ' + data.message, 'success');
                            if (editingId === id) {
                                resetForm();
                            }
                            loadCodes(document.getElementById('searchInput').value);
                        } else {
                            showAlert('❌ ' + data.message, 'danger');
                        }
                    });
                }
            }
        }

        // تفريغ النموذج
        function resetForm() {
            editingId = 0;
            document.getElementById('codeId').value = '0';
            document.getElementById('codeName').value = '';
            document.getElementById('codeValue').value = '';
            document.getElementById('formTitle').innerText = 'إضافة كود جديد';
            document.getElementById('saveBtnText').innerText = 'حفظ';

            document.querySelectorAll('.codes-table tbody tr').forEach(tr => {
                tr.classList.remove('editing');
            });
        }

        // إظهار رسالة
        function showAlert(message, type) {
            var container = document.getElementById('alertContainer');
            var alert = document.createElement('div');
            alert.className = `alert alert-${type}`;
            alert.innerHTML = `<i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'}"></i> ${message}`;
            container.appendChild(alert);

            setTimeout(() => {
                alert.remove();
            }, 3000);
        }

        // البحث
        document.getElementById('searchInput').addEventListener('input', function() {
            var search = this.value.trim().toLowerCase();
            if (search) {
                var filtered = allCodes.filter(c =>
                    c.codeName.toLowerCase().includes(search) ||
                    c.codeValue.toLowerCase().includes(search)
                );
                renderCodes(filtered);
            } else {
                renderCodes(allCodes);
            }
        });

        // إضافة اختصارات لوحة المفاتيح
        document.addEventListener('keydown', function(e) {
            // Ctrl + N لإضافة جديد
            if (e.ctrlKey && e.key === 'n') {
                e.preventDefault();
                resetForm();
                document.getElementById('codeName').focus();
            }
            // Ctrl + F للبحث
            if (e.ctrlKey && e.key === 'f') {
                e.preventDefault();
                document.getElementById('searchInput').focus();
            }
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>