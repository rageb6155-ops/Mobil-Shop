@model IEnumerable<MobileShopSystem.ViewModels.ShopRequestViewModel>
@{
    ViewData["Title"] = "سجل الطلبات";
    var username = Context.Session.GetString("Username") ?? "admin";
    var today = DateTime.Now;
    var dayName = today.ToString("dddd", new System.Globalization.CultureInfo("ar-EG"));
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Mobile Shop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        :root {
            --primary: #f39c12;
            --secondary: #6c757d;
            --success: #28a745;
            --danger: #dc3545;
            --warning: #ffc107;
            --info: #17a2b8;
            --dark: #343a40;
            --light: #f8f9fa;
            --gradient-1: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --gradient-2: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            --gradient-3: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
            --gradient-4: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
            --gradient-5: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.1);
            --shadow-md: 0 5px 15px rgba(0,0,0,0.15);
            --shadow-lg: 0 10px 25px rgba(0,0,0,0.2);
            --border-radius: 16px;
        }

        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            font-family: 'Segoe UI', Tahoma, sans-serif;
            margin: 0;
            padding: 15px;
        }

        .page-wrapper {
            max-width: 1400px;
            margin: 0 auto;
            animation: fadeInUp 0.5s ease-out forwards;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .header-card {
            background: white;
            border-radius: var(--border-radius);
            padding: 15px 20px;
            margin-bottom: 20px;
            box-shadow: var(--shadow-lg);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 10px;
        }

        .header-title h1 {
            margin: 0;
            font-size: 22px;
            font-weight: 600;
            color: var(--primary);
        }

        .header-title p {
            margin: 3px 0 0;
            color: var(--secondary);
            font-size: 12px;
        }

        .user-info {
            background: var(--gradient-5);
            color: white;
            padding: 6px 15px;
            border-radius: 50px;
            font-size: 13px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
        }

        .stat-card {
            background: white;
            border-radius: var(--border-radius);
            padding: 15px;
            box-shadow: var(--shadow-md);
            border-right: 3px solid var(--primary);
            transition: all 0.3s;
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

            .stat-card:hover {
                transform: translateY(-3px);
                box-shadow: var(--shadow-lg);
            }

            .stat-card::before {
                content: '';
                position: absolute;
                top: -50%;
                right: -50%;
                width: 200%;
                height: 200%;
                background: linear-gradient(45deg, transparent, rgba(255,255,255,0.1), transparent);
                transform: rotate(45deg);
                animation: shimmer 3s infinite;
            }

        @@keyframes shimmer {
            0% {
                transform: translateX(-100%) rotate(45deg);
            }

            100% {
                transform: translateX(100%) rotate(45deg);
            }
        }

        .stat-value {
            font-size: 22px;
            font-weight: bold;
            color: #333;
        }

        .stat-label {
            font-size: 11px;
            color: var(--secondary);
            margin-top: 3px;
        }

        .stat-icon {
            position: absolute;
            left: 15px;
            top: 15px;
            font-size: 30px;
            opacity: 0.2;
            color: var(--primary);
        }

        .filter-card {
            background: white;
            border-radius: var(--border-radius);
            padding: 15px;
            margin-bottom: 15px;
            box-shadow: var(--shadow-lg);
        }

        .filter-title {
            color: var(--primary);
            margin-bottom: 12px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 15px;
        }

        .filter-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 10px;
        }

        .filter-group {
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

            .filter-group label {
                font-size: 11px;
                color: var(--secondary);
                font-weight: 500;
            }

        .filter-input {
            padding: 6px 10px;
            border: 2px solid #e9ecef;
            border-radius: 6px;
            font-size: 12px;
            transition: all 0.3s;
        }

            .filter-input:focus {
                outline: none;
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(243, 156, 18, 0.1);
            }

        .filter-actions {
            display: flex;
            gap: 8px;
            align-items: flex-end;
        }

        .btn {
            padding: 8px 15px;
            border: none;
            border-radius: 6px;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
        }

        .btn-sm {
            padding: 5px 10px;
            font-size: 11px;
        }

        .btn-primary {
            background: var(--gradient-5);
            color: white;
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: var(--shadow-md);
            }

        .btn-secondary {
            background: linear-gradient(135deg, #6c757d, #5a6268);
            color: white;
        }

        .btn-info {
            background: var(--gradient-3);
            color: white;
        }

        .btn-whatsapp {
            background: #25D366;
            color: white;
        }

            .btn-whatsapp:hover {
                background: #128C7E;
            }

        .btn-pdf {
            background: #dc3545;
            color: white;
        }

            .btn-pdf:hover {
                background: #b02a37;
            }

        .btn-details {
            background: var(--gradient-1);
            color: white;
        }

        .main-card {
            background: white;
            border-radius: var(--border-radius);
            padding: 15px;
            box-shadow: var(--shadow-lg);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid #f0f0f0;
            flex-wrap: wrap;
        }

            .card-header h2 {
                margin: 0;
                color: var(--primary);
                font-size: 18px;
            }

        .table-responsive {
            overflow-x: auto;
            border-radius: 10px;
        }

        .requests-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
        }

            .requests-table th {
                background: #f8f9fa;
                color: var(--primary);
                padding: 10px 6px;
                font-weight: 600;
                border: 1px solid #e9ecef;
                text-align: center;
                white-space: nowrap;
            }

            .requests-table td {
                padding: 8px 6px;
                border-bottom: 1px solid #e9ecef;
                text-align: center;
                vertical-align: middle;
            }

            .requests-table tbody tr {
                transition: all 0.3s;
            }

                .requests-table tbody tr:hover {
                    background: #f8f9fa;
                }

        .priority-badge {
            padding: 3px 6px;
            border-radius: 20px;
            font-size: 10px;
            font-weight: bold;
            display: inline-block;
        }

        .priority-urgent {
            background: #fee2e2;
            color: #dc2626;
        }

        .priority-important {
            background: #fff3cd;
            color: #856404;
        }

        .priority-normal {
            background: #e6f7e6;
            color: #059669;
        }

        .action-buttons {
            display: flex;
            gap: 3px;
            justify-content: center;
            flex-wrap: wrap;
        }

            .action-buttons .btn-sm {
                padding: 4px 6px;
                font-size: 10px;
            }

        .selection-bar {
            background: linear-gradient(135deg, #e8f4fd, #d1e7ff);
            padding: 12px 15px;
            border-radius: 10px;
            margin-bottom: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
            border-right: 3px solid var(--info);
            animation: slideDown 0.3s ease-out;
            font-size: 13px;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 9999;
            overflow-y: auto;
        }

        .modal-content {
            background: white;
            width: 90%;
            max-width: 500px;
            margin: 40px auto;
            border-radius: var(--border-radius);
            padding: 20px;
            max-height: 85vh;
            overflow-y: auto;
            box-shadow: var(--shadow-lg);
        }

        .modal-lg {
            max-width: 700px;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid #f0f0f0;
        }

            .modal-header h3 {
                margin: 0;
                color: var(--primary);
                font-size: 18px;
            }

        .close-btn {
            background: var(--secondary);
            color: white;
            border: none;
            padding: 6px 15px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 12px;
        }

            .close-btn:hover {
                background: #5a6268;
            }

        .form-group {
            margin-bottom: 12px;
        }

        .form-label {
            display: block;
            margin-bottom: 4px;
            color: var(--secondary);
            font-weight: 500;
            font-size: 12px;
        }

        .form-control {
            width: 100%;
            padding: 8px 12px;
            border: 2px solid #e9ecef;
            border-radius: 6px;
            font-size: 13px;
        }

            .form-control:focus {
                outline: none;
                border-color: var(--primary);
            }

        .alert {
            padding: 10px 12px;
            border-radius: 6px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
        }

        .alert-info {
            background: #d1ecf1;
            color: #0c5460;
            border: 1px solid #bee5eb;
        }

        .badge {
            padding: 4px 8px;
            border-radius: 20px;
            font-size: 10px;
            font-weight: 500;
        }

        .badge-info {
            background: #d1ecf1;
            color: #0c5460;
        }

        .badge-success {
            background: #d4edda;
            color: #155724;
        }

        .badge-warning {
            background: #fff3cd;
            color: #856404;
        }

        .badge-danger {
            background: #f8d7da;
            color: #721c24;
        }

        .export-buttons {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 15px;
            justify-content: flex-start;
        }

            .export-buttons .btn {
                padding: 6px 12px;
                font-size: 12px;
            }

        .details-card {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 15px;
        }

        .details-row {
            display: flex;
            margin-bottom: 10px;
            padding-bottom: 6px;
            border-bottom: 1px solid #e9ecef;
        }

        .details-label {
            width: 100px;
            font-weight: 600;
            color: var(--primary);
            font-size: 12px;
        }

        .details-value {
            flex: 1;
            color: #333;
            font-size: 12px;
        }

        .tooltip {
            position: relative;
            display: inline-block;
        }

            .tooltip .tooltiptext {
                visibility: hidden;
                width: 100px;
                background-color: #555;
                color: #fff;
                text-align: center;
                border-radius: 4px;
                padding: 4px;
                position: absolute;
                z-index: 1;
                bottom: 125%;
                left: 50%;
                margin-left: -50px;
                opacity: 0;
                transition: opacity 0.3s;
                font-size: 10px;
            }

            .tooltip:hover .tooltiptext {
                visibility: visible;
                opacity: 1;
            }

        .loading-spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid #f3f3f3;
            border-top: 3px solid var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @@keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        .phone-badge {
            background: #e8f5e9;
            color: #2e7d32;
            padding: 2px 6px;
            border-radius: 12px;
            font-size: 10px;
            display: inline-flex;
            align-items: center;
            gap: 3px;
            margin: 2px;
        }

        .remove-phone {
            cursor: pointer;
            color: var(--danger);
            font-size: 12px;
            margin-right: 3px;
        }

        .footer {
            text-align: center;
            margin-top: 20px;
            padding: 10px;
            color: var(--secondary);
            font-size: 11px;
        }

        /* تحسين حجم الأزرار في الشريط السفلي */
        .selection-bar .btn-sm {
            padding: 4px 8px;
            font-size: 11px;
        }

        /* تحسين حجم الأزرار في الفلتر */
        .filter-actions .btn {
            padding: 6px 10px;
            font-size: 12px;
        }

        @@media (max-width: 768px) {
            body {
                padding: 10px;
            }

            .filter-grid {
                grid-template-columns: 1fr;
            }

            .filter-actions {
                flex-wrap: wrap;
            }

            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 10px;
            }

            .export-buttons {
                justify-content: center;
            }

            .selection-bar {
                flex-direction: column;
                align-items: flex-start;
            }

                .selection-bar div:last-child {
                    width: 100%;
                    display: flex;
                    gap: 5px;
                }

                .selection-bar .btn-sm {
                    flex: 1;
                }
        }
    </style>
</head>
<body>
    <div class="page-wrapper">
        <div class="header-card">
            <div class="header-title">
                <h1>
                    <i class="fas fa-history"></i> سجل الطلبات
                </h1>
                <p>تاريخ طلبات الشواحن، الاسكرينات، وقطع الغيار</p>
            </div>
            <div class="user-info">
                <i class="fas fa-user-circle"></i> @username
                <span class="mx-2">|</span>
                <i class="fas fa-calendar"></i> @dayName @today.ToString("yyyy/MM/dd")
            </div>
        </div>

        <!-- إحصائيات -->
        <div class="stats-grid">
            <div class="stat-card" onclick="filterByStatus('الكل')">
                <div class="stat-icon"><i class="fas fa-shopping-cart"></i></div>
                <div class="stat-value" id="totalRequests">@ViewBag.TotalRequests</div>
                <div class="stat-label">إجمالي الطلبات</div>
            </div>
            <div class="stat-card" onclick="filterByStatus('مكتمل')">
                <div class="stat-icon"><i class="fas fa-check-circle text-success"></i></div>
                <div class="stat-value" id="completedCount">@Model.Count(r => r.Status == "مكتمل")</div>
                <div class="stat-label">مكتمل</div>
            </div>
            <div class="stat-card" onclick="filterByStatus('معلق')">
                <div class="stat-icon"><i class="fas fa-clock text-warning"></i></div>
                <div class="stat-value" id="pendingCount">@Model.Count(r => r.Status == "معلق")</div>
                <div class="stat-label">معلق</div>
            </div>
            <div class="stat-card" onclick="filterByStatus('قيد التنفيذ')">
                <div class="stat-icon"><i class="fas fa-spinner text-info"></i></div>
                <div class="stat-value" id="inProgressCount">@Model.Count(r => r.Status == "قيد التنفيذ")</div>
                <div class="stat-label">قيد التنفيذ</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-money-bill-wave text-success"></i></div>
                <div class="stat-value">@ViewBag.TotalCost.ToString("N0")</div>
                <div class="stat-label">إجمالي التكلفة (ج.م)</div>
            </div>
            <div class="stat-card" onclick="filterByPriority(3)">
                <div class="stat-icon"><i class="fas fa-exclamation-triangle text-danger"></i></div>
                <div class="stat-value">@Model.Count(r => r.Priority == 3)</div>
                <div class="stat-label">طلبات عاجلة</div>
            </div>
        </div>

        <!-- شريط الإجراءات السريعة - فقط PDF بحجم مناسب -->
        <div class="export-buttons">
            <button class="btn btn-pdf" onclick="exportToPDF()">
                <i class="fas fa-file-pdf"></i> تصدير PDF
            </button>
        </div>

        <!-- فلتر متقدم -->
        <div class="filter-card">
            <div class="filter-title">
                <i class="fas fa-search"></i> بحث متقدم
            </div>
            <form method="get" id="filterForm" onsubmit="return validateDates()">
                <div class="filter-grid">
                    <div class="filter-group">
                        <label>من تاريخ</label>
                        <input type="date" name="fromDate" class="filter-input" value="@ViewBag.Filter?.FromDate?.ToString("yyyy-MM-dd")"
                               onchange="validateDateRange()">
                    </div>
                    <div class="filter-group">
                        <label>إلى تاريخ</label>
                        <input type="date" name="toDate" class="filter-input" value="@ViewBag.Filter?.ToDate?.ToString("yyyy-MM-dd")"
                               onchange="validateDateRange()">
                    </div>
                    <div class="filter-group">
                        <label>النوع</label>
                        <select name="itemType" class="filter-input">
                            <option value="">الكل</option>
                            <option value="شاحن" selected="@(ViewBag.Filter?.ItemType == "شاحن")">شاحن</option>
                            <option value="سكرينة" selected="@(ViewBag.Filter?.ItemType == "سكرينة")">سكرينة</option>
                            <option value="بطارية" selected="@(ViewBag.Filter?.ItemType == "بطارية")">بطارية</option>
                            <option value="وصلة" selected="@(ViewBag.Filter?.ItemType == "وصلة")">وصلة</option>
                            <option value="كابل" selected="@(ViewBag.Filter?.ItemType == "كابل")">كابل</option>
                            <option value="سماعة" selected="@(ViewBag.Filter?.ItemType == "سماعة")">سماعة</option>
                            <option value="قطعة غيار" selected="@(ViewBag.Filter?.ItemType == "قطعة غيار")">قطعة غيار</option>
                            <option value="أخرى" selected="@(ViewBag.Filter?.ItemType == "أخرى")">أخرى</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>الحالة</label>
                        <select name="status" class="filter-input">
                            <option value="">الكل</option>
                            <option value="قيد الانتظار" selected="@(ViewBag.Filter?.Status == "قيد الانتظار")">⏳ قيد الانتظار</option>
                            <option value="قيد التنفيذ" selected="@(ViewBag.Filter?.Status == "قيد التنفيذ")">🔄 قيد التنفيذ</option>
                            <option value="مكتمل" selected="@(ViewBag.Filter?.Status == "مكتمل")">✅ مكتمل</option>
                            <option value="ملغي" selected="@(ViewBag.Filter?.Status == "ملغي")">❌ ملغي</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>الأولوية</label>
                        <select name="priority" class="filter-input">
                            <option value="">الكل</option>
                            <option value="1" selected="@(ViewBag.Filter?.Priority == 1)">🟢 عادي</option>
                            <option value="2" selected="@(ViewBag.Filter?.Priority == 2)">🟠 مهم</option>
                            <option value="3" selected="@(ViewBag.Filter?.Priority == 3)">🔴 عاجل</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>بحث</label>
                        <input type="text" name="searchTerm" class="filter-input" placeholder="اسم القطعة، المورد..." value="@ViewBag.Filter?.SearchTerm">
                    </div>
                    <div class="filter-actions">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-search"></i> بحث
                        </button>
                        <a href="@Url.Action("History")" class="btn btn-secondary">
                            <i class="fas fa-redo-alt"></i> إعادة تعيين
                        </a>
                        <button type="button" class="btn btn-whatsapp" onclick="showBulkWhatsAppModal()">
                            <i class="fab fa-whatsapp"></i> واتساب جماعي
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <!-- شريط التحديد -->
        <div id="selectionBar" class="selection-bar" style="display: none;">
            <div>
                <i class="fas fa-check-circle text-success"></i>
                تم تحديد <span id="selectedCount">0</span> طلب
                <span class="badge badge-info" id="totalSelectedPrice">0 ج.م</span>
            </div>
            <div style="display: flex; gap: 10px;">
                <button class="btn btn-sm btn-whatsapp" onclick="sendSelectedWhatsApp()">
                    <i class="fab fa-whatsapp"></i> إرسال
                </button>
                <button class="btn btn-sm btn-pdf" onclick="exportSelectedToPDF()">
                    <i class="fas fa-file-pdf"></i> PDF
                </button>
                <button class="btn btn-sm btn-secondary" onclick="clearSelection()">
                    <i class="fas fa-times"></i> إلغاء
                </button>
            </div>
        </div>

        <!-- جدول النتائج -->
        <div class="main-card">
            <div class="card-header">
                <h2><i class="fas fa-list"></i> نتائج البحث</h2>
                <div>
                    <span class="badge bg-info" id="resultsCount">@Model.Count() نتيجة</span>
                    <span class="badge bg-success" id="resultsTotalPrice">@Model.Sum(r => r.TotalPrice ?? 0).ToString("N0") ج.م</span>
                </div>
            </div>

            <div class="table-responsive">
                <table class="requests-table" id="requestsTable">
                    <thead>
                        <tr>
                            <th style="width: 25px;">
                                <input type="checkbox" id="selectAll" onchange="toggleAll()">
                            </th>
                            <th>#</th>
                            <th>القطعة</th>
                            <th>النوع</th>
                            <th>الكمية</th>
                            <th>السعر</th>
                            <th>الإجمالي</th>
                            <th>المورد</th>
                            <th>رقم المورد</th>
                            <th>الأولوية</th>
                            <th>الحالة</th>
                            <th>تاريخ الطلب</th>
                            <th>تم بواسطة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int counter = 1;
                            foreach (var item in Model)
                            {
                                <tr id="row-@item.Id" class="request-row" data-id="@item.Id" data-status="@item.Status" data-priority="@item.Priority">
                                    <td>
                                        <input type="checkbox" class="request-checkbox" value="@item.Id"
                                               data-phone="@item.PhoneNumber" data-name="@item.ItemName"
                                               data-price="@(item.TotalPrice ?? 0)" onchange="updateSelection()">
                                    </td>
                                    <td>@counter</td>
                                    <td><strong>@item.ItemName</strong></td>
                                    <td>@item.ItemType</td>
                                    <td>@item.Quantity</td>
                                    <td>@(item.UnitPrice?.ToString("N0") ?? "-")</td>
                                    <td>@(item.TotalPrice?.ToString("N0") ?? "0") ج.م</td>
                                    <td>@(item.Supplier ?? "-")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.PhoneNumber))
                                        {
                                            <a href="javascript:void(0)" onclick="openWhatsApp('@item.PhoneNumber', '@item.ItemName', @item.Quantity)" class="text-success tooltip">
                                                <i class="fab fa-whatsapp"></i> @item.PhoneNumber
                                                <span class="tooltiptext">اضغط للتواصل</span>
                                            </a>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="priority-badge priority-@(item.Priority == 3 ? "urgent" : item.Priority == 2 ? "important" : "normal")">
                                            @(item.Priority == 3 ? "🔴 عاجل" : item.Priority == 2 ? "🟠 مهم" : "🟢 عادي")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @(item.Status == "مكتمل" ? "badge-success" : item.Status == "ملغي" ? "badge-danger" : "badge-warning")">
                                            @item.Status
                                        </span>
                                    </td>
                                    <td>@item.RequestDate.ToString("yyyy/MM/dd")</td>
                                    <td>@item.CreatedByName</td>
                                    <td>
                                        <div class="action-buttons">
                                            <button class="btn btn-sm btn-details" onclick="showDetails(@item.Id)" title="عرض التفاصيل">
                                                <i class="fas fa-eye"></i>
                                            </button>
                                            <a href="/ShopRequest/Edit/@item.Id" class="btn btn-sm btn-warning" title="تعديل">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button class="btn btn-sm btn-danger" onclick="deleteRequest(@item.Id)" title="حذف">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                            @if (!string.IsNullOrEmpty(item.PhoneNumber))
                                            {
                                                <button class="btn btn-sm btn-whatsapp" onclick="openWhatsApp('@item.PhoneNumber', '@item.ItemName', @item.Quantity)" title="واتساب">
                                                    <i class="fab fa-whatsapp"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                                counter++;
                            }
                        }
                    </tbody>
                </table>

                @if (!Model.Any())
                {
                    <div class="text-center py-4">
                        <i class="fas fa-search fa-3x mb-2" style="color: #ccc;"></i>
                        <h5 style="font-size: 16px;">لا توجد نتائج للبحث</h5>
                        <p class="text-muted" style="font-size: 12px;">حاول تغيير معايير البحث</p>
                    </div>
                }
            </div>
        </div>

        <!-- تذييل الصفحة -->
        <div class="footer">
            © @today.Year - Mobile Shop System. جميع الحقوق محفوظة
        </div>
    </div>

    <!-- مودال التفاصيل -->
    <div id="detailsModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-info-circle"></i> تفاصيل الطلب</h3>
                <button class="close-btn" onclick="closeDetailsModal()">✕</button>
            </div>
            <div class="modal-body" id="detailsContent">
                <div class="text-center">
                    <div class="loading-spinner"></div>
                    <p style="font-size: 13px;">جاري تحميل التفاصيل...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- مودال الواتساب الجماعي -->
    <div id="bulkWhatsAppModal" class="modal">
        <div class="modal-content modal-lg">
            <div class="modal-header">
                <h3><i class="fab fa-whatsapp text-success"></i> إرسال واتساب جماعي</h3>
                <button class="close-btn" onclick="closeBulkModal()">✕</button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> سيتم إرسال الرسالة لـ <span id="bulkCount">0</span> مورد
                    <br>
                    <small>إجمالي المبالغ: <span id="bulkTotalPrice">0</span> ج.م</small>
                </div>

                <!-- قائمة الأرقام المختارة -->
                <div id="selectedPhonesList" class="mb-3" style="max-height: 120px; overflow-y: auto; border: 1px solid #e9ecef; border-radius: 6px; padding: 8px; font-size: 12px;">
                </div>

                <!-- إضافة رقم يدوي -->
                <div style="display: flex; gap: 8px; margin-bottom: 12px;">
                    <input type="text" id="customPhone" class="form-control" placeholder="أدخل رقم هاتف إضافي" dir="ltr" style="font-size: 12px;">
                    <button class="btn btn-sm btn-success" onclick="addCustomPhone()">➕ إضافة</button>
                </div>

                <!-- قوالب الرسائل -->
                <div class="form-group">
                    <label class="form-label">قوالب جاهزة</label>
                    <select class="form-control" onchange="applyTemplate(this.value)" style="font-size: 12px;">
                        <option value="">اختر قالب...</option>
                        <option value="reminder">📅 تذكير بالطلب</option>
                        <option value="urgent">🔴 طلب عاجل</option>
                        <option value="followup">📞 متابعة</option>
                        <option value="price">💰 عرض السعر</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">الرسالة</label>
                    <textarea class="form-control" id="bulkMessage" rows="6" oninput="updateCharCount()" style="font-size: 12px;"></textarea>
                    <small class="text-muted" id="charCount" style="font-size: 11px;">0 حرف</small>
                </div>

                <div style="display: flex; gap: 8px; justify-content: center; flex-wrap: wrap;">
                    <button class="btn btn-whatsapp" onclick="sendBulkWhatsApp()" style="padding: 6px 12px; font-size: 12px;">
                        <i class="fab fa-whatsapp"></i> إرسال
                    </button>
                    <button class="btn btn-secondary" onclick="previewMessage()" style="padding: 6px 12px; font-size: 12px;">
                        <i class="fas fa-eye"></i> معاينة
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // ===== متغيرات عامة =====
        let selectedRequests = [];
        let customPhones = [];

        // ===== التحقق من صحة التواريخ =====
        function validateDateRange() {
            const fromDate = document.querySelector('input[name="fromDate"]').value;
            const toDate = document.querySelector('input[name="toDate"]').value;

            if (fromDate && toDate && fromDate > toDate) {
                alert('❌ تاريخ "من" يجب أن يكون قبل تاريخ "إلى"');
                return false;
            }
            return true;
        }

        function validateDates() {
            return validateDateRange();
        }

        // ===== تحديث التحديد =====
        function updateSelection() {
            selectedRequests = [];
            let totalPrice = 0;

            document.querySelectorAll('.request-checkbox:checked').forEach(cb => {
                const row = cb.closest('tr');
                const price = parseFloat(cb.dataset.price || 0);
                totalPrice += price;

                selectedRequests.push({
                    id: parseInt(cb.value),
                    phone: cb.dataset.phone,
                    name: cb.dataset.name,
                    price: price
                });
            });

            const count = selectedRequests.length;
            document.getElementById('selectedCount').innerText = count;
            document.getElementById('totalSelectedPrice').innerHTML = totalPrice.toLocaleString() + ' ج.م';
            document.getElementById('selectionBar').style.display = count > 0 ? 'flex' : 'none';

            const selectAll = document.getElementById('selectAll');
            if (selectAll) {
                selectAll.checked = count === document.querySelectorAll('.request-checkbox').length;
            }
        }

        // ===== تحديد الكل =====
        function toggleAll() {
            const checked = document.getElementById('selectAll').checked;
            document.querySelectorAll('.request-checkbox').forEach(cb => cb.checked = checked);
            updateSelection();
        }

        // ===== إلغاء التحديد =====
        function clearSelection() {
            document.querySelectorAll('.request-checkbox').forEach(cb => cb.checked = false);
            document.getElementById('selectAll').checked = false;
            selectedRequests = [];
            document.getElementById('selectionBar').style.display = 'none';
        }

        // ===== فتح واتساب =====
        function openWhatsApp(phone, itemName, quantity) {
            if (!phone) {
                alert('❌ لا يوجد رقم هاتف');
                return;
            }

            const message = `🛒 *طلب قطعة غيار*\n\n` +
                `📦 *القطعة:* ${itemName}\n` +
                `🔢 *الكمية:* ${quantity}\n` +
                `📅 *التاريخ:* ${new Date().toLocaleDateString('ar-EG')}\n\n` +
                `📍 مركز الصيانة - MobileShop\n` +
                `📞 01064211484`;

            let cleanPhone = phone.replace(/[^0-9]/g, '');
            if (cleanPhone.startsWith('0')) {
                cleanPhone = '20' + cleanPhone.substring(1);
            } else if (!cleanPhone.startsWith('20')) {
                cleanPhone = '20' + cleanPhone;
            }
            const url = `https://api.whatsapp.com/send?phone=${cleanPhone}&text=${encodeURIComponent(message)}`;
            window.open(url, '_blank');
        }

        // ===== إظهار مودال الواتساب الجماعي =====
        function showBulkWhatsAppModal() {
            if (selectedRequests.length === 0) {
                alert('❌ الرجاء تحديد طلب واحد على الأقل');
                return;
            }

            document.getElementById('bulkCount').innerText = selectedRequests.length;

            const totalPrice = selectedRequests.reduce((sum, r) => sum + (r.price || 0), 0);
            document.getElementById('bulkTotalPrice').innerText = totalPrice.toLocaleString();

            // عرض الأرقام المختارة
            const phonesList = document.getElementById('selectedPhonesList');
            phonesList.innerHTML = '';
            selectedRequests.forEach(r => {
                if (r.phone) {
                    phonesList.innerHTML += `<span class="phone-badge"><i class="fab fa-whatsapp"></i> ${r.phone} - ${r.name}</span>`;
                }
            });

            let message = `📋 *تقرير الطلبات المختارة*\n\n`;
            message += `📅 التاريخ: ${new Date().toLocaleDateString('ar-EG')}\n`;
            message += `━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n`;

            selectedRequests.forEach((r, index) => {
                message += `${index + 1}. *${r.name}*\n`;
                if (r.phone) message += `   📞 ${r.phone}\n`;
                if (r.price) message += `   💰 ${r.price.toLocaleString()} ج.م\n`;
                message += `━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n`;
            });

            message += `\n💰 الإجمالي: ${totalPrice.toLocaleString()} ج.م\n`;
            message += `📊 عدد الطلبات: ${selectedRequests.length}\n`;
            message += `━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n`;
            message += `📍 مركز الصيانة - MobileShop\n`;
            message += `📞 01064211484\n`;
            message += `✨ شكراً لتعاملكم معنا ✨`;

            document.getElementById('bulkMessage').value = message;
            updateCharCount();
            document.getElementById('bulkWhatsAppModal').style.display = 'block';
        }

        // ===== إضافة رقم هاتف يدوي =====
        function addCustomPhone() {
            const phone = document.getElementById('customPhone').value.trim();
            if (!phone) {
                alert('❌ الرجاء إدخال رقم الهاتف');
                return;
            }

            let cleanPhone = phone.replace(/[^0-9]/g, '');
            if (!/^01[0-9]{9}$/.test(cleanPhone)) {
                alert('❌ رقم الهاتف غير صحيح (يجب أن يبدأ ب 01 ويتكون من 11 رقم)');
                return;
            }

            customPhones.push(phone);
            document.getElementById('customPhone').value = '';

            const phonesList = document.getElementById('selectedPhonesList');
            phonesList.innerHTML += `<span class="phone-badge"><i class="fab fa-whatsapp"></i> ${phone} (يدوي) <i class="fas fa-times remove-phone" onclick="removeCustomPhone('${phone}')"></i></span>`;

            document.getElementById('bulkCount').innerText = selectedRequests.length + customPhones.length;
        }

        // ===== إزالة رقم يدوي =====
        function removeCustomPhone(phone) {
            customPhones = customPhones.filter(p => p !== phone);
            showBulkWhatsAppModal();
        }

        // ===== تطبيق قالب =====
        function applyTemplate(template) {
            if (!template) return;

            const currentMessage = document.getElementById('bulkMessage').value;
            let newMessage = currentMessage;

            switch(template) {
                case 'reminder':
                    newMessage += `\n\n📅 نود تذكيركم بطلب القطعة المذكورة، نرجو الإفادة عن موعد التوريد.`;
                    break;
                case 'urgent':
                    newMessage += `\n\n🔴 *عاجل جداً*\nنرجو الإسراع في توفير القطعة لأنها ضرورية جداً.`;
                    break;
                case 'followup':
                    newMessage += `\n\n📞 نود متابعة حالة الطلب، هل تم توفير القطعة؟`;
                    break;
                case 'price':
                    newMessage += `\n\n💰 نرجو إفادتنا بأفضل سعر للقطعة المذكورة.`;
                    break;
            }

            document.getElementById('bulkMessage').value = newMessage;
            updateCharCount();
        }

        // ===== تحديث عدد الأحرف =====
        function updateCharCount() {
            const message = document.getElementById('bulkMessage').value;
            document.getElementById('charCount').innerText = message.length + ' حرف';
        }

        // ===== معاينة الرسالة =====
        function previewMessage() {
            alert('📋 معاينة الرسالة:\n\n' + document.getElementById('bulkMessage').value);
        }

        // ===== إرسال واتساب جماعي =====
        function sendBulkWhatsApp() {
            const message = document.getElementById('bulkMessage').value;
            let sentCount = 0;

            // أرقام من الطلبات المختارة
            selectedRequests.forEach(r => {
                if (r.phone) {
                    setTimeout(() => {
                        let cleanPhone = r.phone.replace(/[^0-9]/g, '');
                        if (cleanPhone.startsWith('0')) {
                            cleanPhone = '20' + cleanPhone.substring(1);
                        } else if (!cleanPhone.startsWith('20')) {
                            cleanPhone = '20' + cleanPhone;
                        }
                        const url = `https://api.whatsapp.com/send?phone=${cleanPhone}&text=${encodeURIComponent(message)}`;
                        window.open(url, '_blank');
                    }, sentCount * 1500);
                    sentCount++;
                }
            });

            // الأرقام المضافة يدوياً
            customPhones.forEach(phone => {
                setTimeout(() => {
                    let cleanPhone = phone.replace(/[^0-9]/g, '');
                    if (cleanPhone.startsWith('0')) {
                        cleanPhone = '20' + cleanPhone.substring(1);
                    } else if (!cleanPhone.startsWith('20')) {
                        cleanPhone = '20' + cleanPhone;
                    }
                    const url = `https://api.whatsapp.com/send?phone=${cleanPhone}&text=${encodeURIComponent(message)}`;
                    window.open(url, '_blank');
                }, sentCount * 1500);
                sentCount++;
            });

            alert(`✅ تم فتح ${sentCount} نافذة واتساب`);

            closeBulkModal();
            clearSelection();
        }

        // ===== إرسال للمختارين (اختصار) =====
        function sendSelectedWhatsApp() {
            showBulkWhatsAppModal();
        }

        // ===== إغلاق مودال الواتساب =====
        function closeBulkModal() {
            document.getElementById('bulkWhatsAppModal').style.display = 'none';
            customPhones = [];
        }

        // ===== عرض التفاصيل =====
        function showDetails(id) {
            document.getElementById('detailsModal').style.display = 'block';

            fetch(`/ShopRequest/GetDetails/${id}`)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        const r = data.request;
                        const priorityText = r.priority === 3 ? 'عاجل' : r.priority === 2 ? 'مهم' : 'عادي';
                        const priorityClass = r.priority === 3 ? 'priority-urgent' : r.priority === 2 ? 'priority-important' : 'priority-normal';
                        const statusClass = r.status === 'مكتمل' ? 'badge-success' : r.status === 'ملغي' ? 'badge-danger' : 'badge-warning';

                        let html = `
                            <div class="details-card">
                                <div class="details-row">
                                    <div class="details-label">رقم الطلب:</div>
                                    <div class="details-value">#${r.id}</div>
                                </div>
                                <div class="details-row">
                                    <div class="details-label">القطعة:</div>
                                    <div class="details-value"><strong>${r.itemName || 'غير محدد'}</strong></div>
                                </div>
                                <div class="details-row">
                                    <div class="details-label">النوع:</div>
                                    <div class="details-value">${r.itemType || 'غير محدد'}</div>
                                </div>
                                <div class="details-row">
                                    <div class="details-label">الكمية:</div>
                                    <div class="details-value">${r.quantity || 0}</div>
                                </div>
                                <div class="details-row">
                                    <div class="details-label">السعر:</div>
                                    <div class="details-value">${r.unitPrice ? r.unitPrice.toLocaleString() + ' ج.م' : 'غير محدد'}</div>
                                </div>
                                <div class="details-row">
                                    <div class="details-label">الإجمالي:</div>
                                    <div class="details-value">${r.totalPrice ? r.totalPrice.toLocaleString() + ' ج.م' : 'غير محدد'}</div>
                                </div>
                                <div class="details-row">
                                    <div class="details-label">المورد:</div>
                                    <div class="details-value">${r.supplier || 'غير محدد'}</div>
                                </div>
                                <div class="details-row">
                                    <div class="details-label">رقم المورد:</div>
                                    <div class="details-value">
                                        ${r.phoneNumber ? `
                                            <a href="javascript:void(0)" onclick="openWhatsApp('${r.phoneNumber}', '${r.itemName}', ${r.quantity})" class="text-success">
                                                <i class="fab fa-whatsapp"></i> ${r.phoneNumber}
                                            </a>
                                        ` : 'غير محدد'}
                                    </div>
                                </div>
                                <div class="details-row">
                                    <div class="details-label">الأولوية:</div>
                                    <div class="details-value">
                                        <span class="priority-badge ${priorityClass}">${priorityText}</span>
                                    </div>
                                </div>
                                <div class="details-row">
                                    <div class="details-label">الحالة:</div>
                                    <div class="details-value">
                                        <span class="badge ${statusClass}">${r.status || 'غير محدد'}</span>
                                    </div>
                                </div>
                                <div class="details-row">
                                    <div class="details-label">تاريخ الطلب:</div>
                                    <div class="details-value">${r.requestDate || 'غير محدد'}</div>
                                </div>
                                <div class="details-row">
                                    <div class="details-label">تم بواسطة:</div>
                                    <div class="details-value">${r.createdByName || 'غير معروف'}</div>
                                </div>
                                ${r.notes ? `
                                <div class="details-row">
                                    <div class="details-label">ملاحظات:</div>
                                    <div class="details-value">${r.notes}</div>
                                </div>
                                ` : ''}
                            </div>
                        `;

                        document.getElementById('detailsContent').innerHTML = html;
                    } else {
                        document.getElementById('detailsContent').innerHTML = `
                            <div class="alert alert-danger">
                                <i class="fas fa-exclamation-circle"></i> ${data.message || 'حدث خطأ في تحميل التفاصيل'}
                            </div>
                        `;
                    }
                })
                .catch(err => {
                    console.error('خطأ:', err);
                    document.getElementById('detailsContent').innerHTML = `
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-circle"></i> حدث خطأ في الاتصال
                        </div>
                    `;
                });
        }

        // ===== إغلاق مودال التفاصيل =====
        function closeDetailsModal() {
            document.getElementById('detailsModal').style.display = 'none';
        }

        // ===== تصدير إلى PDF مع التحقق من وجود طلبات =====
        function exportToPDF() {
            const table = document.getElementById('requestsTable');
            const rows = table.querySelectorAll('tbody tr');

            if (rows.length === 0) {
                alert('❌ لا توجد طلبات لتصديرها');
                return;
            }

            // نسخ الجدول لتجنب التأثير على الصفحة الأصلية
            const cloneTable = table.cloneNode(true);

            // إزالة عمود الاختيار وآخر عمود (الإجراءات) من النسخة
            cloneTable.querySelectorAll('th:first-child, td:first-child').forEach(cell => cell.remove());
            cloneTable.querySelectorAll('th:last-child, td:last-child').forEach(cell => cell.remove());

            const opt = {
                margin: [0.3, 0.3, 0.3, 0.3],
                filename: `طلبات_${new Date().toISOString().slice(0,10)}.pdf`,
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 1.5, logging: false },
                jsPDF: { unit: 'in', format: 'a4', orientation: 'landscape' }
            };

            html2pdf().set(opt).from(cloneTable).save();
        }

        // ===== تصدير المختارين إلى PDF مع التحقق من تحديد طلبات =====
        function exportSelectedToPDF() {
            if (selectedRequests.length === 0) {
                alert('❌ الرجاء تحديد طلب واحد على الأقل');
                return;
            }

            // إنشاء جدول جديد بالطلبات المختارة
            const table = document.createElement('table');
            table.className = 'requests-table';

            // نسخ الرأس
            const headerRow = document.querySelector('#requestsTable thead tr').cloneNode(true);
            // إزالة عمود الاختيار وآخر عمود من الرأس
            headerRow.removeChild(headerRow.children[0]);
            headerRow.removeChild(headerRow.children[headerRow.children.length - 1]);
            table.appendChild(headerRow);

            // إضافة الصفوف المختارة
            selectedRequests.forEach(r => {
                const originalRow = document.getElementById(`row-${r.id}`);
                if (originalRow) {
                    const newRow = originalRow.cloneNode(true);
                    // إزالة عمود الاختيار وآخر عمود
                    newRow.removeChild(newRow.children[0]);
                    newRow.removeChild(newRow.children[newRow.children.length - 1]);
                    table.appendChild(newRow);
                }
            });

            const opt = {
                margin: [0.3, 0.3, 0.3, 0.3],
                filename: `طلبات_مختارة_${new Date().toISOString().slice(0,10)}.pdf`,
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 1.5 },
                jsPDF: { unit: 'in', format: 'a4', orientation: 'landscape' }
            };

            html2pdf().set(opt).from(table).save();
        }

        // ===== تصفية حسب الحالة =====
        function filterByStatus(status) {
            const statusSelect = document.querySelector('select[name="status"]');
            if (statusSelect) {
                statusSelect.value = status === 'الكل' ? '' : status;
                document.getElementById('filterForm').submit();
            }
        }

        // ===== تصفية حسب الأولوية =====
        function filterByPriority(priority) {
            const prioritySelect = document.querySelector('select[name="priority"]');
            if (prioritySelect) {
                prioritySelect.value = priority;
                document.getElementById('filterForm').submit();
            }
        }

        // ===== حذف طلب =====
        function deleteRequest(id) {
            if (confirm('⚠️ هل أنت متأكد من حذف هذا الطلب؟')) {
                fetch(`/ShopRequest/Delete/${id}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    }
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById(`row-${id}`).remove();
                        alert('✅ ' + data.message);
                        location.reload();
                    } else {
                        alert('❌ ' + data.message);
                    }
                })
                .catch(err => {
                    console.error('خطأ:', err);
                    alert('❌ حدث خطأ في الاتصال');
                });
            }
        }

        // ===== إغلاق المودالات عند الضغط خارجها =====
        window.onclick = function(event) {
            const detailsModal = document.getElementById('detailsModal');
            const bulkModal = document.getElementById('bulkWhatsAppModal');

            if (event.target === detailsModal) {
                closeDetailsModal();
            }
            if (event.target === bulkModal) {
                closeBulkModal();
            }
        }

        // ===== تهيئة الصفحة =====
        document.addEventListener('DOMContentLoaded', function() {
            console.log('✅ صفحة سجل الطلبات جاهزة');
            validateDateRange();
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
</body>
