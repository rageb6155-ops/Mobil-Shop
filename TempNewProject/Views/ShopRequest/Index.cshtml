                <h3><i class="fab fa-whatsapp text-success"></i> إرسال واتساب</h3>
                <button class="close-btn" onclick="closeBulkModal()">✕ إغلاق</button>
            </div>
            <div class="modal-body">
                <!-- تبويبات -->
                <div class="tabs-container">
                    <button class="tab-btn active" onclick="switchTab('requests')" id="tabRequests">📋 طلبات اليوم</button>
                    <button class="tab-btn" onclick="switchTab('users')" id="tabUsers">👥 المستخدمين</button>
                    <button class="tab-btn" onclick="switchTab('history')" id="tabHistory">📅 طلبات سابقة</button>
                </div>

                <!-- قسم الطلبات (اليوم) -->
                <div id="requestsSection">
                    <div class="selection-actions">
                        <button class="btn btn-sm btn-primary" onclick="selectAllRequests()">
                            <i class="fas fa-check-double"></i> تحديد الكل
                        </button>
                        <button class="btn btn-sm btn-secondary" onclick="deselectAllRequests()">
                            <i class="fas fa-times"></i> إلغاء التحديد
                        </button>
                        <button class="btn btn-sm btn-info" onclick="loadRequests()">
                            <i class="fas fa-sync-alt"></i> تحديث القائمة
                        </button>
                    </div>

                    <div class="selection-grid">
                        <div class="selection-list">
                            <div class="list-header">
                                <span><i class="fas fa-list"></i> طلبات اليوم</span>
                                <span class="selected-count" id="availableRequestsCount">0</span>
                            </div>
                            <div class="list-search">
                                <i class="fas fa-search"></i>
                                <input type="text" id="availableRequestsSearch" placeholder="بحث في الطلبات..." onkeyup="filterAvailableRequests()">
                            </div>
                            <div class="list-items" id="availableRequestsList">
                                <div class="text-center p-3 text-muted">
                                    <i class="fas fa-spinner fa-spin"></i> جاري التحميل...
                                </div>
                            </div>
                        </div>

                        <div class="selection-list">
                            <div class="list-header success">
                                <span><i class="fas fa-check-circle"></i> الطلبات المختارة</span>
                                <span class="selected-count" id="selectedRequestsCount">0</span>
                            </div>
                            <div class="list-search">
                                <i class="fas fa-search"></i>
                                <input type="text" id="selectedRequestsSearch" placeholder="بحث في المختارة..." onkeyup="filterSelectedRequests()">
                            </div>
                            <div class="list-items" id="selectedRequestsList">
                                <div class="text-center p-3 text-muted">
                                    <i class="fas fa-info-circle"></i> لا توجد طلبات مختارة
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- قسم الطلبات السابقة -->
                <div id="historySection" style="display: none;">
                    <div class="date-filter">
                        <input type="date" id="historyFromDate" class="date-input" placeholder="من تاريخ">
                        <input type="date" id="historyToDate" class="date-input" placeholder="إلى تاريخ">
                        <button class="btn btn-sm btn-primary" onclick="loadHistoryRequests()">
                            <i class="fas fa-search"></i> بحث
                        </button>
                        <button class="btn btn-sm btn-secondary" onclick="clearHistoryFilter()">
                            <i class="fas fa-undo"></i> إعادة تعيين
                        </button>
                    </div>

                    <div class="selection-actions">
                        <button class="btn btn-sm btn-primary" onclick="selectAllHistoryRequests()">
                            <i class="fas fa-check-double"></i> تحديد الكل
                        </button>
                        <button class="btn btn-sm btn-secondary" onclick="deselectAllHistoryRequests()">
                            <i class="fas fa-times"></i> إلغاء التحديد
                        </button>
                    </div>

                    <div class="selection-grid">
                        <div class="selection-list">
                            <div class="list-header">
                                <span><i class="fas fa-history"></i> الطلبات السابقة</span>
                                <span class="selected-count" id="availableHistoryCount">0</span>
                            </div>
                            <div class="list-search">
                                <i class="fas fa-search"></i>
                                <input type="text" id="availableHistorySearch" placeholder="بحث في الطلبات..." onkeyup="filterAvailableHistory()">
                            </div>
                            <div class="list-items" id="availableHistoryList">
                                <div class="text-center p-3 text-muted">
                                    <i class="fas fa-info-circle"></i> اختر التاريخ للبحث
                                </div>
                            </div>
                        </div>

                        <div class="selection-list">
                            <div class="list-header success">
                                <span><i class="fas fa-check-circle"></i> الطلبات المختارة</span>
                                <span class="selected-count" id="selectedHistoryCount">0</span>
                            </div>
                            <div class="list-search">
                                <i class="fas fa-search"></i>
                                <input type="text" id="selectedHistorySearch" placeholder="بحث في المختارة..." onkeyup="filterSelectedHistory()">
                            </div>
                            <div class="list-items" id="selectedHistoryList">
                                <div class="text-center p-3 text-muted">
                                    <i class="fas fa-info-circle"></i> لا توجد طلبات مختارة
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- قسم المستخدمين -->
                <div id="usersSection" style="display: none;">
                    <div class="selection-actions">
                        <button class="btn btn-sm btn-primary" onclick="selectAllUsers()">
                            <i class="fas fa-check-double"></i> تحديد الكل
                        </button>
                        <button class="btn btn-sm btn-secondary" onclick="deselectAllUsers()">
                            <i class="fas fa-times"></i> إلغاء التحديد
                        </button>
                        <button class="btn btn-sm btn-info" onclick="loadUsers()">
                            <i class="fas fa-sync-alt"></i> تحديث القائمة
                        </button>
                    </div>

                    <div class="selection-grid">
                        <div class="selection-list">
                            <div class="list-header">
                                <span><i class="fas fa-users"></i> المستخدمين</span>
                                <span class="selected-count" id="availableUsersCount">0</span>
                            </div>
                            <div class="list-search">
                                <i class="fas fa-search"></i>
                                <input type="text" id="availableUsersSearch" placeholder="بحث في المستخدمين..." onkeyup="filterAvailableUsers()">
                            </div>
                            <div class="list-items" id="availableUsersList">
                                <div class="text-center p-3 text-muted">
                                    <i class="fas fa-spinner fa-spin"></i> جاري التحميل...
                                </div>
                            </div>
                        </div>

                        <div class="selection-list">
                            <div class="list-header success">
                                <span><i class="fas fa-check-circle"></i> المستخدمين المختارين</span>
                                <span class="selected-count" id="selectedUsersCount">0</span>
                            </div>
                            <div class="list-search">
                                <i class="fas fa-search"></i>
                                <input type="text" id="selectedUsersSearch" placeholder="بحث في المختارة..." onkeyup="filterSelectedUsers()">
                            </div>
                            <div class="list-items" id="selectedUsersList">
                                <div class="text-center p-3 text-muted">
                                    <i class="fas fa-info-circle"></i> لا يوجد مستخدمين مختارين
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- الأرقام المضافة يدوياً -->
                <div class="custom-phone-input">
                    <input type="text" id="customPhone" placeholder="📱 أدخل رقم هاتف خارجي (مثال: 01000000000)">
                    <button class="btn btn-sm btn-success" onclick="addCustomPhone()">➕ إضافة</button>
                </div>

                <!-- عرض الأرقام المضافة -->
                <div id="customPhonesList" class="phone-list" style="display: none;"></div>

                <!-- رسالة مخصصة -->
                <div class="form-group">
                    <label class="form-label">رسالة إضافية (اختياري)</label>
                    <textarea class="form-control" id="customMessage" rows="3" placeholder="اكتب رسالة إضافية..." onkeyup="updatePreview()"></textarea>
                </div>

                <!-- معاينة التقرير النصي -->
                <div class="message-preview">
                    <h5><i class="fas fa-eye"></i> معاينة الرسالة</h5>
                    <div class="preview-content" id="reportPreviewContent">
                        سيتم عرض محتوى الرسالة هنا...
                    </div>
                </div>

                <!-- أزرار الإرسال مع زر الاختبار -->
                <div style="display: flex; gap: 10px; justify-content: center; margin-top: 20px; flex-wrap: wrap;">
                    <button class="btn btn-whatsapp" onclick="sendWhatsAppMessages()" id="sendTextBtn">
                        <i class="fab fa-whatsapp"></i> إرسال رسالة نصية
                    </button>
                    <button class="btn btn-pdf" onclick="savePDFOnly()" id="savePDFBtn">
                        <i class="fas fa-file-pdf"></i> حفظ PDF فقط
                    </button>
                    <button class="btn btn-success" onclick="sendWhatsAppWithPDF()" id="sendBothBtn">
                        <i class="fas fa-file-pdf"></i> <i class="fab fa-whatsapp"></i> PDF + رسالة
                    </button>
                    <button class="btn btn-info" onclick="testWhatsAppLink()" id="testBtn">
                        <i class="fas fa-vial"></i> اختبار الواتساب
                    </button>
                </div>

                <!-- رسالة التأكيد -->
                <div id="sendResult" class="alert" style="display: none; margin-top: 15px;"></div>
            </div>
        </div>
    </div>

    <script>
        // ===== متغيرات عامة =====
        let allRequests = [];
        let allUsers = [];
        let historyRequests = [];
        let deletedRequests = [];
        let selectedRequests = [];
        let selectedUsers = [];
        let selectedHistory = [];
        let customPhones = [];

        // ===== تبديل التبويبات =====
        function switchTab(tab) {
            document.getElementById('tabRequests').classList.remove('active');
            document.getElementById('tabUsers').classList.remove('active');
            document.getElementById('tabHistory').classList.remove('active');

            document.getElementById('requestsSection').style.display = 'none';
            document.getElementById('usersSection').style.display = 'none';
            document.getElementById('historySection').style.display = 'none';

            if (tab === 'requests') {
                document.getElementById('tabRequests').classList.add('active');
                document.getElementById('requestsSection').style.display = 'block';
                loadRequests();
            } else if (tab === 'users') {
                document.getElementById('tabUsers').classList.add('active');
                document.getElementById('usersSection').style.display = 'block';
                loadUsers();
            } else {
                document.getElementById('tabHistory').classList.add('active');
                document.getElementById('historySection').style.display = 'block';
                if (historyRequests.length === 0) {
                    loadHistoryRequests();
                } else {
                    displayAvailableHistory(historyRequests);
                }
            }
        }

        // ===== تحميل الطلبات =====
        function loadRequests() {
            fetch('/ShopRequest/GetTodayRequests')
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        allRequests = data.requests || [];
                        displayAvailableRequests(allRequests);
                        updateAllCounts();
                        updatePreview();
                    } else {
                        showResult('❌ فشل في تحميل الطلبات', 'danger');
                    }
                })
                .catch(err => {
                    console.error('خطأ:', err);
                    showResult('❌ حدث خطأ في الاتصال', 'danger');
                });
        }

        // ===== تحميل الطلبات المحذوفة =====
        function loadDeletedRequests() {
            fetch('/ShopRequest/GetDeletedRequests')
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        deletedRequests = data.requests || [];
                        displayDeletedRequests(deletedRequests);
                    } else {
                        document.getElementById('deletedRequestsList').innerHTML = `
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">
                                    <i class="fas fa-info-circle fa-2x mb-2"></i>
                                    <div>لا توجد عمليات محذوفة</div>
                                </td>
                            </tr>
                        `;
                    }
                })
                .catch(err => {
                    console.error('خطأ:', err);
                    document.getElementById('deletedRequestsList').innerHTML = `
                        <tr>
                            <td colspan="7" class="text-center py-4 text-danger">
                                <i class="fas fa-exclamation-circle fa-2x mb-2"></i>
                                <div>حدث خطأ في تحميل المحذوفات</div>
                            </td>
                        </tr>
                    `;
                });
        }

        // ===== عرض الطلبات المحذوفة =====
        function displayDeletedRequests(requests) {
            const tbody = document.getElementById('deletedRequestsList');

            if (!requests || requests.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">
                            <i class="fas fa-trash-alt fa-2x mb-2"></i>
                            <div>لا توجد عمليات محذوفة</div>
                        </td>
                    </tr>
                `;
                return;
            }

            let html = '';
            requests.forEach((r, index) => {
                html += `
                    <tr id="deleted-row-${r.id}">
                        <td>${index + 1}</td>
                        <td><strong>${r.itemName || 'بدون اسم'}</strong></td>
                        <td>${r.itemType || 'غير محدد'}</td>
                        <td>${r.quantity || 0}</td>
                        <td>${r.supplier || '-'}</td>
                        <td>${r.deletedAt || 'غير محدد'}</td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn btn-sm btn-details" onclick="showDeletedDetails(${r.id})" title="عرض التفاصيل">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <button class="btn btn-sm btn-restore" onclick="restoreRequest(${r.id})" title="استعادة">
                                    <i class="fas fa-undo-alt"></i>
                                </button>
                                <button class="btn btn-sm btn-danger" onclick="permanentDelete(${r.id})" title="حذف نهائي">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            });

            tbody.innerHTML = html;
        }

        // ===== تصفية المحذوفات =====
        function filterDeletedRequests() {
            const searchTerm = document.getElementById('deletedSearch').value.toLowerCase();
            const rows = document.querySelectorAll('#deletedRequestsList tr');

            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                row.style.display = text.includes(searchTerm) ? '' : 'none';
            });
        }

        // ===== إظهار قسم المحذوفات =====
        function showDeletedRequests() {
            document.getElementById('deletedRequestsSection').style.display = 'block';
            loadDeletedRequests();
            
            setTimeout(() => {
                document.getElementById('deletedRequestsSection').scrollIntoView({ behavior: 'smooth' });
            }, 300);
        }

        // ===== إخفاء قسم المحذوفات =====
        function hideDeletedRequests() {
            document.getElementById('deletedRequestsSection').style.display = 'none';
        }

        // ===== استعادة طلب محذوف =====
        function restoreRequest(id) {
            if (confirm('هل أنت متأكد من استعادة هذا الطلب؟')) {
                fetch(`/ShopRequest/Restore/${id}`, { method: 'POST' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            document.getElementById(`deleted-row-${id}`).remove();
                            showResult('✅ تم استعادة الطلب بنجاح', 'success');
                            refreshSummary();
                            setTimeout(() => {
                                location.reload();
                            }, 1500);
                        } else {
                            showResult('❌ ' + (data.message || 'حدث خطأ'), 'danger');
                        }
                    })
                    .catch(err => {
                        console.error('خطأ:', err);
                        showResult('❌ حدث خطأ في الاتصال', 'danger');
                    });
            }
        }

        // ===== حذف نهائي =====
        function permanentDelete(id) {
            if (confirm('⚠️ هل أنت متأكد؟ هذا الإجراء لا يمكن التراجع عنه!')) {
                fetch(`/ShopRequest/HardDelete/${id}`, { method: 'POST' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            document.getElementById(`deleted-row-${id}`).remove();
                            showResult('✅ تم الحذف النهائي بنجاح', 'success');
                        } else {
                            showResult('❌ ' + (data.message || 'حدث خطأ'), 'danger');
                        }
                    })
                    .catch(err => {
                        console.error('خطأ:', err);
                        showResult('❌ حدث خطأ في الاتصال', 'danger');
                    });
            }
        }

        // ===== تحميل الطلبات السابقة =====
        function loadHistoryRequests() {
            const fromDate = document.getElementById('historyFromDate').value;
            const toDate = document.getElementById('historyToDate').value;

            let url = '/ShopRequest/GetHistoryRequests';
            const params = new URLSearchParams();
            
            if (fromDate) params.append('fromDate', fromDate);
            if (toDate) params.append('toDate', toDate);
            
            if (params.toString()) {
                url += '?' + params.toString();
            }

            const container = document.getElementById('availableHistoryList');
            container.innerHTML = '<div class="text-center p-3 text-muted"><i class="fas fa-spinner fa-spin"></i> جاري البحث...</div>';

            fetch(url)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        historyRequests = data.requests || [];
                        displayAvailableHistory(historyRequests);
                        updateAllCounts();
                        updatePreview();
                    } else {
                        container.innerHTML = '<div class="text-center p-3 text-muted">❌ ' + (data.message || 'لا توجد نتائج') + '</div>';
                    }
                })
                .catch(err => {
                    console.error('خطأ:', err);
                    container.innerHTML = '<div class="text-center p-3 text-muted">❌ حدث خطأ في الاتصال</div>';
                });
        }

        // ===== تحميل المستخدمين =====
        function loadUsers() {
            fetch('/ShopRequest/GetAllUsersForBulk')
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        allUsers = data.users || [];
                        displayAvailableUsers(allUsers);
                        updateAllCounts();
                    } else {
                        showResult('❌ فشل في تحميل المستخدمين', 'danger');
                    }
                })
                .catch(err => {
                    console.error('خطأ:', err);
                    showResult('❌ حدث خطأ في الاتصال', 'danger');
                });
        }

        // ===== عرض الطلبات المتاحة =====
        function displayAvailableRequests(requests) {
            const container = document.getElementById('availableRequestsList');

            if (!requests || requests.length === 0) {
                container.innerHTML = '<div class="text-center p-3 text-muted">لا توجد طلبات اليوم</div>';
                document.getElementById('availableRequestsCount').innerText = '0';
                return;
            }

            let html = '';
            requests.forEach(r => {
                const isSelected = selectedRequests.some(sr => sr.id === r.id);
                const priorityEmoji = r.priority === 3 ? '🔴' : r.priority === 2 ? '🟠' : '🟢';

                html += `
                    <div class="selection-item ${isSelected ? 'selected' : ''}" onclick="toggleRequest(${r.id})">
                        <input type="checkbox" class="item-checkbox" ${isSelected ? 'checked' : ''}
                               onchange="toggleRequest(${r.id})" onclick="event.stopPropagation()">
                        <div class="item-info">
                            <div class="item-name">
                                ${priorityEmoji} ${r.itemName || 'بدون اسم'}
                            </div>
                            <div class="item-details">
                                <span class="item-phone">📞 ${r.phoneNumber || 'لا يوجد'}</span>
                                <span>📦 ${r.quantity || 0} - ${r.itemType || 'غير محدد'}</span>
                                <span>🏢 ${r.supplier || 'بدون مورد'}</span>
                            </div>
                        </div>
                    </div>
                `;
            });

            container.innerHTML = html;
            document.getElementById('availableRequestsCount').innerText = requests.length;
        }

        // ===== عرض الطلبات السابقة =====
        function displayAvailableHistory(requests) {
            const container = document.getElementById('availableHistoryList');

            if (!requests || requests.length === 0) {
                container.innerHTML = '<div class="text-center p-3 text-muted">لا توجد طلبات في هذا التاريخ</div>';
                document.getElementById('availableHistoryCount').innerText = '0';
                return;
            }

            let html = '';
            requests.forEach(r => {
                const isSelected = selectedHistory.some(sr => sr.id === r.id);
                const priorityEmoji = r.priority === 3 ? '🔴' : r.priority === 2 ? '🟠' : '🟢';
                const requestDate = r.requestDate || 'غير محدد';

                html += `
                    <div class="selection-item ${isSelected ? 'selected' : ''}" onclick="toggleHistory(${r.id})">
                        <input type="checkbox" class="item-checkbox" ${isSelected ? 'checked' : ''}
                               onchange="toggleHistory(${r.id})" onclick="event.stopPropagation()">
                        <div class="item-info">
                            <div class="item-name">
                                ${priorityEmoji} ${r.itemName || 'بدون اسم'}
                            </div>
                            <div class="item-details">
                                <span class="item-phone">📞 ${r.phoneNumber || 'لا يوجد'}</span>
                                <span>📅 ${requestDate}</span>
                                <span>📦 ${r.quantity || 0} - ${r.itemType || 'غير محدد'}</span>
                                <span>🏢 ${r.supplier || 'بدون مورد'}</span>
                            </div>
                        </div>
                    </div>
                `;
            });

            container.innerHTML = html;
            document.getElementById('availableHistoryCount').innerText = requests.length;
        }

        // ===== عرض المستخدمين المتاحين =====
        function displayAvailableUsers(users) {
            const container = document.getElementById('availableUsersList');

            if (!users || users.length === 0) {
                container.innerHTML = '<div class="text-center p-3 text-muted">لا يوجد مستخدمين</div>';
                document.getElementById('availableUsersCount').innerText = '0';
                return;
