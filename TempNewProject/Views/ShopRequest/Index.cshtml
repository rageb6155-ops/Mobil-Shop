@model IEnumerable<MobileShopSystem.ViewModels.ShopRequestViewModel>
@{
    ViewData["Title"] = "طلبات المحل";
    var username = Context.Session.GetString("Username") ?? "زائر";
    var today = DateTime.Now;
    var dayName = today.ToString("dddd", new System.Globalization.CultureInfo("ar-EG"));
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

    <style>
        :root {
            --primary: #f39c12;
            --secondary: #6c757d;
            --success: #28a745;
            --danger: #dc3545;
            --warning: #ffc107;
            --info: #17a2b8;
            --dark: #343a40;
            --gradient-1: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --gradient-2: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            --gradient-3: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
            --gradient-4: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
            --gradient-5: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
            --gradient-6: linear-gradient(135deg, #6c757d 0%, #343a40 100%);
            --gradient-7: linear-gradient(135deg, #6c5ce7 0%, #a363d9 100%);
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.1);
            --shadow-md: 0 5px 15px rgba(0,0,0,0.15);
            --shadow-lg: 0 10px 25px rgba(0,0,0,0.2);
            --border-radius: 16px;
        }

        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            font-family: 'Segoe UI', Tahoma, sans-serif;
            margin: 0;
            padding: 20px;
        }

        .page-wrapper {
            max-width: 1400px;
            margin: 0 auto;
            animation: fadeInUp 0.5s ease-out forwards;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .header-card {
            background: white;
            border-radius: var(--border-radius);
            padding: 20px 25px;
            margin-bottom: 25px;
            box-shadow: var(--shadow-lg);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .header-title h1 {
            margin: 0;
            font-size: 26px;
            font-weight: 600;
            color: var(--primary);
        }

        .header-title p {
            margin: 5px 0 0;
            color: var(--secondary);
            font-size: 14px;
        }

        .user-info {
            background: var(--gradient-5);
            color: white;
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 500;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 25px;
        }

        .stat-card {
            background: white;
            border-radius: var(--border-radius);
            padding: 20px;
            box-shadow: var(--shadow-md);
            border-right: 4px solid var(--primary);
        }

        .stat-value {
            font-size: 28px;
            font-weight: bold;
            color: #333;
        }

        .stat-label {
            font-size: 13px;
            color: var(--secondary);
        }

        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

        .btn-primary {
            background: var(--gradient-5);
            color: white;
        }

        .btn-success {
            background: var(--gradient-4);
            color: white;
        }

        .btn-warning {
            background: var(--gradient-5);
            color: #333;
        }

        .btn-danger {
            background: linear-gradient(135deg, #dc3545, #c82333);
            color: white;
        }

        .btn-info {
            background: var(--gradient-3);
            color: white;
        }

        .btn-whatsapp {
            background: #25D366;
            color: white;
        }

        .btn-pdf {
            background: #dc3545;
            color: white;
        }

        .btn-history {
            background: linear-gradient(135deg, #9b59b6, #8e44ad);
            color: white;
        }

        .btn-details {
            background: linear-gradient(135deg, #3498db, #2980b9);
            color: white;
        }

        .btn-archive {
            background: var(--gradient-6);
            color: white;
        }

        .btn-restore {
            background: linear-gradient(135deg, #27ae60, #229954);
            color: white;
        }

        .main-card {
            background: white;
            border-radius: var(--border-radius);
            padding: 25px;
            box-shadow: var(--shadow-lg);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid #f0f0f0;
            flex-wrap: wrap;
        }

        .card-header h2 {
            margin: 0;
            color: var(--primary);
            font-size: 22px;
        }

        .table-responsive {
            overflow-x: auto;
        }

        .requests-table {
            width: 100%;
            border-collapse: collapse;
        }

        .requests-table th {
            background: #f8f9fa;
            color: var(--primary);
            padding: 12px;
            font-size: 13px;
            font-weight: 600;
            border: 1px solid #e9ecef;
            text-align: center;
        }

        .requests-table td {
            padding: 12px;
            border-bottom: 1px solid #e9ecef;
            text-align: center;
            vertical-align: middle;
        }

        .requests-table tbody tr:hover {
            background: #f8f9fa;
        }

        .priority-badge {
            padding: 4px 8px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: bold;
            display: inline-block;
        }

        .priority-urgent {
            background: #fee2e2;
            color: #dc2626;
        }

        .priority-important {
            background: #fff3cd;
            color: #856404;
        }

        .priority-normal {
            background: #e6f7e6;
            color: #059669;
        }

        .action-buttons {
            display: flex;
            gap: 5px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-sm {
            padding: 5px 10px;
            font-size: 11px;
        }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 9999;
            overflow-y: auto;
        }

        .modal-content {
            background: white;
            width: 90%;
            max-width: 1000px;
            margin: 50px auto;
            border-radius: var(--border-radius);
            padding: 25px;
            max-height: 85vh;
            overflow-y: auto;
            box-shadow: var(--shadow-lg);
        }

        .modal-lg {
            max-width: 1200px;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid #f0f0f0;
        }

        .modal-header h3 {
            margin: 0;
            color: var(--primary);
        }

        .close-btn {
            background: var(--secondary);
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
        }

        .close-btn:hover {
            background: #5a6268;
        }

        .tabs-container {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            border-bottom: 2px solid #f0f0f0;
            padding-bottom: 10px;
            flex-wrap: wrap;
        }

        .tab-btn {
            padding: 8px 20px;
            border: none;
            background: none;
            border-radius: 8px 8px 0 0;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            color: #6c757d;
        }

        .tab-btn.active {
            color: var(--primary);
            border-bottom: 3px solid var(--primary);
            background: #fff3e0;
        }

        .date-filter {
            display: flex;
            gap: 10px;
            margin: 15px 0;
            flex-wrap: wrap;
            align-items: center;
        }

        .date-input {
            padding: 8px 12px;
            border: 2px solid #e9ecef;
            border-radius: 8px;
            font-size: 14px;
            flex: 1;
            min-width: 150px;
        }

        .date-input:focus {
            outline: none;
            border-color: var(--primary);
        }

        .selection-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin: 20px 0;
            max-height: 500px;
        }

        .selection-list {
            border: 1px solid #e9ecef;
            border-radius: 12px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .list-header {
            background: var(--primary);
            color: white;
            padding: 12px 15px;
            font-weight: 500;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .list-header.success {
            background: var(--success);
        }

        .list-header.dark {
            background: var(--dark);
        }

        .list-search {
            padding: 10px;
            border-bottom: 1px solid #e9ecef;
            position: relative;
        }

        .list-search input {
            width: 100%;
            padding: 8px 35px 8px 10px;
            border: 1px solid #e9ecef;
            border-radius: 20px;
            font-size: 13px;
        }

        .list-search i {
            position: absolute;
            right: 20px;
            top: 18px;
            color: #adb5bd;
            font-size: 14px;
        }

        .list-items {
            overflow-y: auto;
            flex: 1;
            max-height: 350px;
        }

        .selection-item {
            padding: 10px 15px;
            border-bottom: 1px solid #f0f0f0;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .selection-item:hover {
            background: #fff3e0;
        }

        .selection-item.selected {
            background: #ffe6cc;
            border-right: 3px solid var(--primary);
        }

        .selection-item.deleted {
            background: #f8d7da;
            border-right: 3px solid var(--danger);
        }

        .item-checkbox {
            width: 18px;
            height: 18px;
            cursor: pointer;
        }

        .item-info {
            flex: 1;
        }

        .item-name {
            font-weight: 600;
            color: #333;
            font-size: 14px;
        }

        .item-details {
            font-size: 11px;
            color: #666;
            margin-top: 2px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .item-phone {
            color: #25D366;
            font-weight: bold;
        }

        .selected-count {
            background: white;
            color: var(--primary);
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
        }

        .selection-actions {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
            flex-wrap: wrap;
        }

        .custom-phone-input {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
        }

        .custom-phone-input input {
            flex: 1;
            padding: 10px 15px;
            border: 2px solid #e9ecef;
            border-radius: 8px;
            font-size: 14px;
        }

        .custom-phone-input input:focus {
            outline: none;
            border-color: var(--primary);
        }

        .message-preview {
            background: #fff3e0;
            border-radius: 12px;
            padding: 15px;
            margin: 20px 0;
            border-right: 4px solid #25D366;
        }

        .message-preview h5 {
            margin: 0 0 10px 0;
            color: var(--primary);
            font-size: 14px;
        }

        .preview-content {
            background: white;
            padding: 12px;
            border-radius: 8px;
            font-size: 13px;
            line-height: 1.5;
            white-space: pre-wrap;
            max-height: 200px;
            overflow-y: auto;
            text-align: right;
            font-family: monospace;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            color: #495057;
            font-weight: 500;
        }

        .form-control, .form-select {
            width: 100%;
            padding: 10px 15px;
            border: 2px solid #e9ecef;
            border-radius: 8px;
            font-size: 14px;
        }

        .form-control:focus, .form-select:focus {
            outline: none;
            border-color: var(--primary);
        }

        .alert {
            padding: 12px 15px;
            border-radius: 8px;
            margin-bottom: 20px;
        }

        .alert-success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .alert-info {
            background: #d1ecf1;
            color: #0c5460;
        }

        .alert-warning {
            background: #fff3cd;
            color: #856404;
        }

        .phone-badge {
            background: #e8f5e9;
            color: #2e7d32;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 11px;
            display: inline-flex;
            align-items: center;
            gap: 3px;
            margin-left: 5px;
        }

        .remove-phone {
            cursor: pointer;
            color: var(--danger);
            font-size: 14px;
            margin-right: 5px;
        }

        .phone-list {
            display: flex;
            flex-wrap: wrap;
            gap: 5px;
            margin: 10px 0;
            padding: 10px;
            background: #f8f9fa;
            border-radius: 8px;
        }

        .info-box {
            background: #e7f3ff;
            border-right: 4px solid var(--info);
            padding: 15px;
            border-radius: 8px;
            margin: 15px 0;
        }

        .archive-section {
            margin-top: 20px;
            padding: 15px;
            background: linear-gradient(135deg, #f8f9fa, #e9ecef);
            border-radius: 12px;
            border-right: 4px solid var(--dark);
        }

        .details-card {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 20px;
        }

        .details-row {
            display: flex;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 1px solid #e9ecef;
        }

        .details-label {
            width: 120px;
            font-weight: 600;
            color: var(--primary);
        }

        .details-value {
            flex: 1;
            color: #333;
        }

        .badge-status {
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }

        .badge-completed {
            background: #d4edda;
            color: #155724;
        }

        .badge-pending {
            background: #fff3cd;
            color: #856404;
        }

        .badge-cancelled {
            background: #f8d7da;
            color: #721c24;
        }

        @@media (max-width: 768px) {
            .selection-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="page-wrapper">
        <div class="header-card">
            <div class="header-title">
                <h1>
                    <i class="fas fa-shopping-cart"></i> طلبات المحل
                </h1>
                <p>إدارة طلبات الاكسسوارات ، وقطع الغيار</p>
            </div>
            <div class="user-info">
                <i class="fas fa-user-circle"></i> @username
                <span class="mx-2">|</span>
                <i class="fas fa-calendar"></i> @dayName @today.ToString("yyyy/MM/dd")
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-label">إجمالي الطلبات اليوم</div>
                <div class="stat-value">@ViewBag.TotalRequests</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">التكلفة التقديرية</div>
                <div class="stat-value">@ViewBag.TotalEstimatedCost.ToString("N0") ج.م</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">عالي الأولوية</div>
                <div class="stat-value" id="urgentCount">0</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">متوسط الأولوية</div>
                <div class="stat-value" id="importantCount">0</div>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            </div>
        }

        <div style="display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap;">
            <a href="/ShopRequest/Create" class="btn btn-success">
                <i class="fas fa-plus-circle"></i> طلب جديد
            </a>
            <a href="/ShopRequest/History" class="btn btn-history">
                <i class="fas fa-history"></i> سجل الطلبات
            </a>
            <button class="btn btn-archive" onclick="showDeletedRequests()">
                <i class="fas fa-trash-alt"></i> العمليات المحذوفة
            </button>
            <button class="btn btn-whatsapp" onclick="showBulkWhatsAppModal()">
                <i class="fab fa-whatsapp"></i> إرسال واتساب
            </button>
            <button class="btn btn-pdf" onclick="saveTodayRequestsPDF()">
                <i class="fas fa-file-pdf"></i> حفظ PDF لطلبات اليوم
            </button>
            <button class="btn btn-info" onclick="refreshSummary()">
                <i class="fas fa-sync-alt"></i> تحديث
            </button>
        </div>

        <div style="margin-bottom: 20px;">
            <form method="get" style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                <label style="align-self: center;">📅 تاريخ الطلبات:</label>
                <input type="date" name="date" class="form-control" value="@ViewBag.CurrentDate"
                       onchange="this.form.submit()" style="max-width: 200px;">
                <button type="submit" class="btn btn-primary">عرض</button>
            </form>
        </div>

        <div class="main-card">
            <div class="card-header">
                <h2><i class="fas fa-list"></i> طلبات اليوم</h2>
                <span class="badge bg-warning">@Model.Count() طلب</span>
            </div>

            <div class="table-responsive">
                <table class="requests-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>القطعة</th>
                            <th>النوع</th>
                            <th>الكمية</th>
                            <th>السعر</th>
                            <th>الإجمالي</th>
                            <th>المورد</th>
                            <th>رقم المورد</th>
                            <th>الأولوية</th>
                            <th>الحالة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int counter = 1;
                            foreach (var item in Model)
                            {
                                <tr id="row-@item.Id">
                                    <td>@counter</td>
                                    <td><strong>@item.ItemName</strong></td>
                                    <td>@item.ItemType</td>
                                    <td>@item.Quantity</td>
                                    <td>@(item.UnitPrice?.ToString("N0") ?? "-")</td>
                                    <td>@(item.TotalPrice?.ToString("N0") ?? "-") ج.م</td>
                                    <td>@(item.Supplier ?? "-")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.PhoneNumber))
                                        {
                                            <a href="javascript:void(0)" onclick="openWhatsAppSingle('@item.PhoneNumber', '@item.ItemName', '@item.Quantity', '@item.ItemType')" class="text-success">
                                                <i class="fab fa-whatsapp"></i> @item.PhoneNumber
                                            </a>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="priority-badge priority-@(item.Priority == 3 ? "urgent" : item.Priority == 2 ? "important" : "normal")">
                                            @item.PriorityText
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @item.StatusColor">@item.Status</span>
                                    </td>
                                    <td>
                                        <div class="action-buttons">
                                            <button class="btn btn-sm btn-details" onclick="showDetails(@item.Id)" title="عرض التفاصيل">
                                                <i class="fas fa-eye"></i>
                                            </button>
                                            <a href="/ShopRequest/Edit/@item.Id" class="btn btn-sm btn-warning" title="تعديل">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button class="btn btn-sm btn-danger" onclick="deleteRequest(@item.Id)" title="حذف">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                            @if (!string.IsNullOrEmpty(item.PhoneNumber))
                                            {
                                                <button class="btn btn-sm btn-whatsapp" onclick="openWhatsAppSingle('@item.PhoneNumber', '@item.ItemName', '@item.Quantity', '@item.ItemType')" title="واتساب">
                                                    <i class="fab fa-whatsapp"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                                counter++;
                            }
                        }
                    </tbody>
                </table>

                @if (!Model.Any())
                {
                    <div class="text-center py-5">
                        <i class="fas fa-box-open fa-4x mb-3" style="color: #ccc;"></i>
                        <h5>لا توجد طلبات لهذا اليوم</h5>
                        <p class="text-muted">يمكنك إضافة طلب جديد بالضغط على "طلب جديد"</p>
                    </div>
                }
            </div>
        </div>

        <!-- قسم العمليات المحذوفة -->
        <div class="archive-section" id="deletedRequestsSection" style="display: none;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                <h3 style="color: var(--dark); margin: 0;">
                    <i class="fas fa-trash-alt"></i> العمليات المحذوفة
                </h3>
                <button class="btn btn-sm btn-secondary" onclick="hideDeletedRequests()">
                    <i class="fas fa-times"></i> إخفاء
                </button>
            </div>
            <div style="margin-bottom: 15px;">
                <input type="text" id="deletedSearch" class="form-control" placeholder="بحث في المحذوفات..." onkeyup="filterDeletedRequests()">
            </div>
            <div class="table-responsive">
                <table class="requests-table">
                    <thead>
                        <tr>
                            <th>#</th>
