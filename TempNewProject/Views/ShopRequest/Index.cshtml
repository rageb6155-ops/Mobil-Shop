        // ===== دالة فتح واتساب مباشر (للأزرار الصغيرة) - تم تعديلها =====
        function openWhatsAppSingle(phone, itemName, quantity, itemType) {
            if (!phone) {
                alert('❌ لا يوجد رقم هاتف');
                return;
            }

            // تنظيف الرقم
            let cleanPhone = phone.replace(/[^0-9]/g, '');
            
            // التأكد من صيغة الرقم (تحويل 010... إلى 2010...)
            if (cleanPhone.startsWith('0')) {
                cleanPhone = '20' + cleanPhone.substring(1);
            } else if (!cleanPhone.startsWith('20')) {
                cleanPhone = '20' + cleanPhone;
            }
            
            // إنشاء نص الرسالة
            const message = `🛒 *طلب قطعة غيار*\n\n` +
                `📦 *القطعة:* ${itemName}\n` +
                `📦 *الكمية:* ${quantity}\n` +
                `🏷️ *النوع:* ${itemType}\n` +
                `📅 *التاريخ:* ${new Date().toLocaleDateString('ar-EG')}\n\n` +
                `📍    MobileShop\n` +
                `📞 01064211484`;
            
            // استخدام الرابط الصحيح لفتح الواتساب مع الرسالة
            const url = `https://api.whatsapp.com/send?phone=${cleanPhone}&text=${encodeURIComponent(message)}`;
            
            // فتح في نافذة جديدة
            window.open(url, '_blank');
        }

        // ===== دالة إرسال رسائل واتساب متعددة (فتح تبويبات متعددة) - تم تعديلها =====
        function sendWhatsAppMessages() {
            const allSelected = [...selectedRequests, ...selectedHistory];
            
            if (allSelected.length === 0 && selectedUsers.length === 0 && customPhones.length === 0) {
                showResult('❌ لم يتم اختيار أي طلبات أو مستخدمين', 'warning');
                return;
            }

            // جمع جميع الأرقام
            let phones = [];

            // أرقام من الطلبات
            allSelected.forEach(r => {
                if (r.phoneNumber) {
                    let cleanPhone = r.phoneNumber.replace(/[^0-9]/g, '');
                    if (cleanPhone) {
                        if (cleanPhone.startsWith('0')) {
                            cleanPhone = '20' + cleanPhone.substring(1);
                        } else if (!cleanPhone.startsWith('20')) {
                            cleanPhone = '20' + cleanPhone;
                        }
                        phones.push(cleanPhone);
                    }
                }
            });

            // أرقام المستخدمين
            selectedUsers.forEach(u => {
                if (u.phone) {
                    let cleanPhone = u.phone.replace(/[^0-9]/g, '');
                    if (cleanPhone) {
                        if (cleanPhone.startsWith('0')) {
                            cleanPhone = '20' + cleanPhone.substring(1);
                        } else if (!cleanPhone.startsWith('20')) {
                            cleanPhone = '20' + cleanPhone;
                        }
                        phones.push(cleanPhone);
                    }
                }
            });

            // الأرقام المضافة يدوياً
            customPhones.forEach(phone => {
                let cleanPhone = phone.replace(/[^0-9]/g, '');
                if (cleanPhone) {
                    if (cleanPhone.startsWith('0')) {
                        cleanPhone = '20' + cleanPhone.substring(1);
                    } else if (!cleanPhone.startsWith('20')) {
                        cleanPhone = '20' + cleanPhone;
                    }
                    phones.push(cleanPhone);
                }
            });

            // إزالة التكرارات
            phones = [...new Set(phones)];

            if (phones.length === 0) {
                showResult('❌ لم يتم العثور على أرقام صالحة', 'warning');
                return;
            }

            // محتوى الرسالة
            const previewContent = document.getElementById('reportPreviewContent');
            let message = '';
            
            if (previewContent) {
                message = previewContent.innerText || previewContent.textContent;
            }
            
            if (!message || message === 'سيتم عرض محتوى الرسالة هنا...' || message.includes('⚠️')) {
                message = buildDefaultMessage(allSelected);
            }

            // فتح تبويبات متعددة مع تأخير
            let openedCount = 0;
            
            phones.forEach((phone, index) => {
                setTimeout(() => {
                    try {
                        const url = `https://api.whatsapp.com/send?phone=${phone}&text=${encodeURIComponent(message)}`;
                        const newWindow = window.open(url, '_blank');
                        
                        if (newWindow) {
                            openedCount++;
                        }
                    } catch (err) {
                        console.error('خطأ في فتح واتساب للرقم:', phone, err);
                    }
                }, index * 1500);
            });

            showResult(`✅ تم فتح ${openedCount} من ${phones.length} نافذة واتساب`, 'success');
            
            setTimeout(closeBulkModal, 3000);
        }

        // ===== دالة بناء رسالة افتراضية =====
