                    if (r.unitPrice) message += `   💰 السعر: ${r.unitPrice.toLocaleString()} ج.م\n`;
                    message += `   ⚡ الأولوية: ${priorityText}\n`;
                    message += `━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n`;
                });

                const totalCost = allSelected.reduce((sum, r) => sum + ((r.unitPrice || 0) * (r.quantity || 0)), 0);
                message += `\n💰 إجمالي التكلفة التقديرية: ${totalCost.toLocaleString()} ج.م\n`;
                message += `📊 عدد الطلبات: ${allSelected.length}\n`;
                message += `━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n`;
            }

            message += `📍 مركز الصيانة - MobileShop\n`;
            message += `📞 01064211484\n`;
            message += `✨ شكراً لتعاملكم معنا ✨`;

            const customMsg = document.getElementById('customMessage').value.trim();
            if (customMsg) {
                message += `\n\n📝 *رسالة إضافية:*\n${customMsg}`;
            }

            document.getElementById('reportPreviewContent').innerHTML = message.replace(/\n/g, '<br>');
        }

        // ===== إضافة رقم خارجي =====
        function addCustomPhone() {
            const phone = document.getElementById('customPhone').value.trim();
            if (!phone) {
                showResult('❌ الرجاء إدخال رقم الهاتف', 'warning');
                return;
            }

            let cleanPhone = phone.replace(/[^0-9]/g, '');
            
            if (!/^01[0-9]{9}$/.test(cleanPhone) && !/^201[0-9]{9}$/.test(cleanPhone)) {
                showResult('❌ رقم الهاتف غير صحيح (يجب أن يبدأ ب 01 ويتكون من 11 رقم)', 'warning');
                return;
            }

            customPhones.push(phone);
            document.getElementById('customPhone').value = '';
            displayCustomPhones();
            updateAllCounts();
            showResult('✅ تم إضافة الرقم بنجاح', 'success');
        }

        // ===== إزالة رقم مخصص =====
        function removeCustomPhone(index) {
            customPhones.splice(index, 1);
            displayCustomPhones();
            updateAllCounts();
        }

        // ===== تبديل تحديد طلب =====
        function toggleRequest(requestId) {
            const request = allRequests.find(r => r.id === requestId);
            if (!request) return;

            const index = selectedRequests.findIndex(r => r.id === requestId);
            if (index === -1) {
                selectedRequests.push(request);
            } else {
                selectedRequests.splice(index, 1);
            }

            updateAllLists();
        }

        // ===== تبديل تحديد طلب سابق =====
        function toggleHistory(requestId) {
            const request = historyRequests.find(r => r.id === requestId);
            if (!request) return;

            const index = selectedHistory.findIndex(r => r.id === requestId);
            if (index === -1) {
                selectedHistory.push(request);
            } else {
                selectedHistory.splice(index, 1);
            }

            updateAllLists();
        }

        // ===== تبديل تحديد مستخدم =====
        function toggleUser(userId) {
            const user = allUsers.find(u => u.id === userId);
            if (!user) return;

            const index = selectedUsers.findIndex(u => u.id === userId);
            if (index === -1) {
                selectedUsers.push(user);
            } else {
                selectedUsers.splice(index, 1);
            }

            updateAllLists();
        }

        // ===== إزالة من الطلبات المختارة =====
        function removeFromSelectedRequests(requestId, event) {
            if (event) event.stopPropagation();
            selectedRequests = selectedRequests.filter(r => r.id !== requestId);
            updateAllLists();
        }

        // ===== إزالة من الطلبات السابقة المختارة =====
        function removeFromSelectedHistory(requestId, event) {
            if (event) event.stopPropagation();
            selectedHistory = selectedHistory.filter(r => r.id !== requestId);
            updateAllLists();
        }

        // ===== إزالة من المستخدمين المختارين =====
        function removeFromSelectedUsers(userId, event) {
            if (event) event.stopPropagation();
            selectedUsers = selectedUsers.filter(u => u.id !== userId);
            updateAllLists();
        }

        // ===== تحديد كل الطلبات =====
        function selectAllRequests() {
            allRequests.forEach(request => {
                if (!selectedRequests.some(r => r.id === request.id)) {
                    selectedRequests.push(request);
                }
            });
            updateAllLists();
        }

        // ===== تحديد كل الطلبات السابقة =====
        function selectAllHistoryRequests() {
            historyRequests.forEach(request => {
                if (!selectedHistory.some(r => r.id === request.id)) {
                    selectedHistory.push(request);
                }
            });
            updateAllLists();
        }

        // ===== تحديد كل المستخدمين =====
        function selectAllUsers() {
            allUsers.forEach(user => {
                if (!selectedUsers.some(u => u.id === user.id)) {
                    selectedUsers.push(user);
                }
            });
            updateAllLists();
        }

        // ===== إلغاء تحديد الكل =====
        function deselectAllRequests() {
            selectedRequests = [];
            updateAllLists();
        }

        function deselectAllHistoryRequests() {
            selectedHistory = [];
            updateAllLists();
        }

        function deselectAllUsers() {
            selectedUsers = [];
            updateAllLists();
        }

        // ===== تصفية القوائم =====
        function filterAvailableRequests() {
            const searchTerm = document.getElementById('availableRequestsSearch').value.toLowerCase();
            const items = document.querySelectorAll('#availableRequestsList .selection-item');

            items.forEach(item => {
                const text = item.innerText.toLowerCase();
                item.style.display = text.includes(searchTerm) ? 'flex' : 'none';
            });
        }

        function filterAvailableHistory() {
            const searchTerm = document.getElementById('availableHistorySearch').value.toLowerCase();
            const items = document.querySelectorAll('#availableHistoryList .selection-item');

            items.forEach(item => {
                const text = item.innerText.toLowerCase();
                item.style.display = text.includes(searchTerm) ? 'flex' : 'none';
            });
        }

        function filterSelectedRequests() {
            const searchTerm = document.getElementById('selectedRequestsSearch').value.toLowerCase();
            const items = document.querySelectorAll('#selectedRequestsList .selection-item');

            items.forEach(item => {
                const text = item.innerText.toLowerCase();
                item.style.display = text.includes(searchTerm) ? 'flex' : 'none';
            });
        }

        function filterSelectedHistory() {
            const searchTerm = document.getElementById('selectedHistorySearch').value.toLowerCase();
            const items = document.querySelectorAll('#selectedHistoryList .selection-item');

            items.forEach(item => {
                const text = item.innerText.toLowerCase();
                item.style.display = text.includes(searchTerm) ? 'flex' : 'none';
            });
        }

        function filterAvailableUsers() {
            const searchTerm = document.getElementById('availableUsersSearch').value.toLowerCase();
            const items = document.querySelectorAll('#availableUsersList .selection-item');

            items.forEach(item => {
                const text = item.innerText.toLowerCase();
                item.style.display = text.includes(searchTerm) ? 'flex' : 'none';
            });
        }

        function filterSelectedUsers() {
            const searchTerm = document.getElementById('selectedUsersSearch').value.toLowerCase();
            const items = document.querySelectorAll('#selectedUsersList .selection-item');

            items.forEach(item => {
                const text = item.innerText.toLowerCase();
                item.style.display = text.includes(searchTerm) ? 'flex' : 'none';
            });
        }

        // ===== إعادة تعيين فلتر التاريخ =====
        function clearHistoryFilter() {
            document.getElementById('historyFromDate').value = '';
            document.getElementById('historyToDate').value = '';
            loadHistoryRequests();
        }

        // ===== تحديث كل القوائم =====
        function updateAllLists() {
            displayAvailableRequests(allRequests);
            displaySelectedRequests();
            displayAvailableHistory(historyRequests);
            displaySelectedHistory();
            displayAvailableUsers(allUsers);
            displaySelectedUsers();
            updateAllCounts();
            updatePreview();
        }

        // ===== تحديث كل العدادات =====
        function updateAllCounts() {
            document.getElementById('selectedRequestsCount').innerText = selectedRequests.length;
            document.getElementById('selectedHistoryCount').innerText = selectedHistory.length;
            document.getElementById('selectedUsersCount').innerText = selectedUsers.length;

            const total = selectedRequests.length + selectedHistory.length + selectedUsers.length + customPhones.length;
            document.getElementById('sendTextBtn').innerHTML = `<i class="fab fa-whatsapp"></i> إرسال رسالة نصية (${total})`;
            document.getElementById('savePDFBtn').innerHTML = `<i class="fas fa-file-pdf"></i> حفظ PDF فقط (${total})`;
            document.getElementById('sendBothBtn').innerHTML = `<i class="fas fa-file-pdf"></i> <i class="fab fa-whatsapp"></i> PDF + رسالة (${total})`;
        }

        // ===== حفظ PDF فقط =====
        function savePDFOnly() {
            const allSelected = [...selectedRequests, ...selectedHistory];
            
            if (allSelected.length === 0) {
                showResult('❌ لم يتم اختيار أي طلبات', 'warning');
                return;
            }

            createAndSavePDF(allSelected, 'تقرير_مختار');
            showResult('✅ تم حفظ PDF بنجاح', 'success');
            
            setTimeout(closeBulkModal, 2000);
        }

        // ===== إرسال واتساب مع PDF =====
        function sendWhatsAppWithPDF() {
            const allSelected = [...selectedRequests, ...selectedHistory];
            
            if (allSelected.length === 0) {
                showResult('❌ لم يتم اختيار أي طلبات', 'warning');
                return;
            }
            
            savePDFOnly();
            
            setTimeout(() => {
                sendWhatsAppMessages();
            }, 2000);
        }

        // ===== دالة اختبار للواتساب =====
        function testWhatsAppLink() {
            const testPhone = "201064211484";
            const testMessage = "اختبار رسالة واتساب - MobileShop";
            const testUrl = `https://api.whatsapp.com/send?phone=${testPhone}&text=${encodeURIComponent(testMessage)}`;
            
            const newWindow = window.open(testUrl, '_blank');
            
            if (newWindow) {
                showResult('✅ تم فتح نافذة واتساب بنجاح', 'success');
            } else {
                showResult('❌ فشل فتح نافذة واتساب. يرجى التحقق من إعدادات المتصفح', 'warning');
            }
        }

        // ===== دالة حفظ PDF لطلبات اليوم (الزر الخارجي) =====
        function saveTodayRequestsPDF() {
            const requests = @Html.Raw(Json.Serialize(Model.Select(r => new {
                r.Id,
                r.ItemName,
                r.ItemType,
                r.Quantity,
                UnitPrice = r.UnitPrice ?? 0,
                r.Supplier,
                r.PhoneNumber,
                r.Notes,
                r.Priority,
                r.Status
            })));
            
            if (!requests || requests.length === 0) {
                alert('❌ لا توجد طلبات لليوم');
                return;
            }
            
            createAndSavePDF(requests, 'جميع_طلبات_اليوم');
        }

        // ===== دالة إنشاء وحفظ PDF =====
        function createAndSavePDF(requests, fileName) {
            const pdfContainer = document.createElement('div');
            pdfContainer.style.width = '80mm';
            pdfContainer.style.padding = '2mm';
            pdfContainer.style.fontFamily = 'Segoe UI, Tahoma, sans-serif';
            pdfContainer.style.background = 'white';
            pdfContainer.style.direction = 'rtl';
            pdfContainer.style.boxSizing = 'border-box';
            pdfContainer.style.fontSize = '9px';
            pdfContainer.style.lineHeight = '1.3';
            pdfContainer.style.position = 'absolute';
            pdfContainer.style.top = '-9999px';
            pdfContainer.style.left = '-9999px';

            let itemsHtml = '';
            requests.forEach(r => {
                const priorityText = r.priority === 3 ? 'عاجل' : r.priority === 2 ? 'مهم' : 'عادي';
                const priorityColor = r.priority === 3 ? '#dc3545' : r.priority === 2 ? '#ffc107' : '#28a745';
                
                itemsHtml += `
                    <div style="margin-bottom: 8px; padding: 5px; background: #f8f9fa; border-radius: 4px; border-right: 3px solid ${priorityColor};">
                        <div style="display: flex; justify-content: space-between; font-weight: bold;">
                            <span>${r.ItemName || 'بدون اسم'}</span>
                            <span style="color: ${priorityColor};">${priorityText}</span>
                        </div>
                        <div style="margin-top: 3px; font-size: 8px; color: #666;">
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3px;">
                                <span>📦 الكمية: ${r.Quantity || 0}</span>
                                <span>🏷️ النوع: ${r.ItemType || 'غير محدد'}</span>
                                ${r.Supplier ? `<span>🏢 المورد: ${r.Supplier}</span>` : ''}
                                ${r.PhoneNumber ? `<span>📞 الهاتف: ${r.PhoneNumber}</span>` : ''}
                                ${r.UnitPrice ? `<span>💰 السعر: ${r.UnitPrice.toLocaleString()} ج.م</span>` : ''}
                            </div>
                            ${r.Notes ? `<div style="margin-top: 3px;">📝 ${r.Notes}</div>` : ''}
                        </div>
                    </div>
                `;
            });

            const totalCost = requests.reduce((sum, r) => sum + ((r.UnitPrice || 0) * (r.Quantity || 0)), 0);

            pdfContainer.innerHTML = `
                <div style="width: 100%; background: white; border-radius: 4px; padding: 3px;">
                    <div style="text-align: center; border-bottom: 2px solid #f39c12; padding-bottom: 5px; margin-bottom: 8px;">
                        <div style="font-size: 16px; font-weight: bold; color: #f39c12;">📱 Mobile Shop</div>
                        <div style="font-size: 10px; color: #666;">مركز صيانة معتمد</div>
                        <div style="font-size: 11px; font-weight: bold; background: #f39c12; color: white; padding: 3px; border-radius: 3px; margin-top: 3px;">
                            تقرير طلبات المحل
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3px; margin-bottom: 5px;">
                        <div style="background: #f8f9fa; padding: 3px; border-radius: 3px;">
                            <div style="font-size: 6px; color: #666;">التاريخ</div>
                            <div style="font-size: 9px; font-weight: bold;">${new Date().toLocaleDateString('ar-EG')}</div>
                        </div>
                        <div style="background: #f8f9fa; padding: 3px; border-radius: 3px;">
                            <div style="font-size: 6px; color: #666;">المستخدم</div>
                            <div style="font-size: 9px; font-weight: bold;">@username</div>
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 3px; margin: 5px 0;">
                        <div style="background: #f8f9fa; padding: 3px; text-align: center; border-right: 2px solid #f39c12;">
                            <div style="font-size: 8px; font-weight: bold;">${requests.length}</div>
                            <div style="font-size: 6px;">إجمالي الطلبات</div>
                        </div>
                        <div style="background: #f8f9fa; padding: 3px; text-align: center; border-right: 2px solid #f39c12;">
                            <div style="font-size: 8px; font-weight: bold;">${totalCost.toLocaleString()}</div>
                            <div style="font-size: 6px;">التكلفة</div>
                        </div>
                        <div style="background: #f8f9fa; padding: 3px; text-align: center; border-right: 2px solid #f39c12;">
                            <div style="font-size: 8px; font-weight: bold;">${requests.filter(r => r.priority === 3).length}</div>
                            <div style="font-size: 6px;">عاجل</div>
                        </div>
                    </div>

                    <div style="margin: 8px 0;">
                        <div style="font-size: 9px; font-weight: bold; color: #f39c12; margin-bottom: 3px;">📋 تفاصيل الطلبات</div>
                        ${itemsHtml}
                    </div>

                    <div style="background: linear-gradient(135deg, #f39c12, #e67e22); color: white; border-radius: 3px; padding: 5px; margin: 5px 0;">
                        <div style="display: flex; justify-content: space-between; font-size: 8px;">
                            <span>إجمالي الطلبات:</span>
                            <span>${requests.length}</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; font-size: 8px; margin-top: 2px;">
                            <span>إجمالي التكلفة:</span>
                            <span>${totalCost.toLocaleString()} ج.م</span>
                        </div>
                    </div>

                    <div style="margin-top: 8px; font-size: 7px; color: #666; text-align: center; border-top: 1px solid #eee; padding-top: 3px;">
                        <div>📱 Mobile Shop - ${new Date().toLocaleDateString('ar-EG')}</div>
                        <div>📞 01064211484</div>
                        <div>✨ شكراً لتعاملكم معنا ✨</div>
                    </div>
                </div>
            `;

            document.body.appendChild(pdfContainer);

            html2canvas(pdfContainer, {
                scale: 2,
                backgroundColor: '#ffffff',
                logging: false
            }).then(canvas => {
                try {
                    const { jsPDF } = window.jspdf;

                    const imgWidth = 80;
                    const imgHeight = (canvas.height * imgWidth) / canvas.width;

                    const pdf = new jsPDF({
                        orientation: 'portrait',
                        unit: 'mm',
                        format: [imgWidth, imgHeight]
                    });

                    const imgData = canvas.toDataURL('image/png');
                    pdf.addImage(imgData, 'PNG', 0, 0, imgWidth, imgHeight, undefined, 'FAST');

                    pdf.save(`${fileName}_${new Date().toISOString().slice(0,10)}.pdf`);

                    document.body.removeChild(pdfContainer);
                } catch (error) {
                    console.error('خطأ في إنشاء PDF:', error);
                    document.body.removeChild(pdfContainer);
                }
            });
        }

        // ===== فتح المودال الجماعي =====
        function showBulkWhatsAppModal() {
            document.getElementById('bulkWhatsAppModal').style.display = 'block';
            loadRequests();
            loadUsers();
            updatePreview();
        }

        // ===== إغلاق المودال الجماعي =====
        function closeBulkModal() {
            document.getElementById('bulkWhatsAppModal').style.display = 'none';
            selectedRequests = [];
            selectedHistory = [];
            selectedUsers = [];
            customPhones = [];
            document.getElementById('customMessage').value = '';
            document.getElementById('customPhone').value = '';
            document.getElementById('customPhonesList').style.display = 'none';
        }

        // ===== عرض نتيجة =====
        function showResult(message, type) {
            const resultDiv = document.getElementById('sendResult');
            resultDiv.className = `alert alert-${type}`;
            resultDiv.innerHTML = message;
            resultDiv.style.display = 'block';
            
            setTimeout(() => {
                resultDiv.style.display = 'none';
            }, 3000);
        }

        // ===== تحديث الإحصائيات =====
        function refreshSummary() {
            fetch('/ShopRequest/GetTodaySummary')
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById('urgentCount').innerText = data.data?.byPriority?.urgent || 0;
                        document.getElementById('importantCount').innerText = data.data?.byPriority?.important || 0;
                    }
                })
                .catch(err => console.error('خطأ:', err));
        }

        // ===== حذف طلب (نقل إلى المحذوفات) =====
        function deleteRequest(id) {
            if (confirm('هل أنت متأكد من نقل هذا الطلب إلى المحذوفات؟')) {
                fetch(`/ShopRequest/Delete/${id}`, { method: 'POST' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            document.getElementById(`row-${id}`).remove();
                            refreshSummary();
                            showResult('✅ تم نقل الطلب إلى المحذوفات', 'success');
                        } else {
                            showResult('❌ ' + (data.message || 'حدث خطأ'), 'danger');
                        }
                    })
                    .catch(err => {
                        console.error('خطأ:', err);
                        showResult('❌ حدث خطأ في الاتصال', 'danger');
                    });
            }
        }

        // ===== إغلاق المودال عند الضغط خارج المحتوى =====
        window.onclick = function(event) {
            const detailsModal = document.getElementById('detailsModal');
            const bulkModal = document.getElementById('bulkWhatsAppModal');
            
            if (event.target === detailsModal) {
                closeDetailsModal();
            }
            if (event.target === bulkModal) {
                closeBulkModal();
            }
        }

        // ===== تهيئة الصفحة =====
        document.addEventListener('DOMContentLoaded', function() {
            refreshSummary();
            setInterval(refreshSummary, 30000);
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>