@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Mobile Shop</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            font-family: 'Segoe UI', Tahoma;
            background: #f4f6f9;
            color: #333;
            transition: background .3s, color .3s;
        }

            body.dark {
                background: #1e1f26 !important;
                color: #f1f1f1 !important;
            }

        /* ===== Navbar ===== */
        .navbar {
            background: linear-gradient(135deg, #43cea2, #185a9d);
            box-shadow: 0 4px 12px rgba(0,0,0,.2);
            transition: background .3s;
        }

        body.dark .navbar {
            background: linear-gradient(135deg, #22252f, #2e303b);
        }

        .navbar-brand {
            font-weight: bold;
            font-size: 20px;
        }

        .nav-link {
            color: #fff !important;
            font-size: 15px;
            margin-right: 8px;
            transition: .2s;
        }

            .nav-link:hover {
                opacity: .85;
            }

        .user-badge {
            background: rgba(255,255,255,.2);
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 14px;
            margin-left: 10px;
        }

        body.dark .user-badge {
            background: rgba(255,255,255,.1);
        }

        /* ===== Main Content ===== */
        .main-container {
            margin-top: 35px;
            transition: background .3s, color .3s;
        }

        body.dark .main-container {
            background: #2a2c36;
        }

        /* ===== Footer ===== */
        footer {
            margin-top: 60px;
            padding: 15px;
            text-align: center;
            font-size: 14px;
            color: #777;
            transition: color .3s;
        }

        body.dark footer {
            color: #bbb;
        }

        /* ===== زرار الوضع الداكن ===== */
        .btn-toggle-mode {
            background: #34495e;
            color: #fff;
        }

            .btn-toggle-mode:hover {
                opacity: .85;
            }

        /* ===== زرار العملاء الجديد ===== */
        .btn-customers {
            background: #ffc107;
            color: #333;
            margin-right: 8px;
        }

            .btn-customers:hover {
                background: #e0a800;
                color: #333;
            }
    </style>
</head>

<body>
    <!-- ===== Navbar ===== -->
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">

            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                <i class="bi bi-phone"></i> Mobile Shop
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">

                    @if (Context.Session.GetString("Username") != null)
                    {
                        <li class="nav-item">
                            <span class="nav-link user-badge">
                                <i class="bi bi-person-circle"></i>
                                @Context.Session.GetString("Username")
                            </span>
                        </li>

                        @if (Context.Session.GetString("IsAdmin") == "True")
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Index", "Settings")">
                                    ⚙️ الإعدادات
                                </a>
                            </li>

                        }

                        <li class="nav-item">
                            <a class="nav-link text-warning" href="#" onclick="logoutConfirm()">
                                <i class="bi bi-box-arrow-right"></i> تسجيل الخروج
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Login", "Account")">
                                <i class="bi bi-box-arrow-in-right"></i> تسجيل الدخول
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Register", "Account")">
                                <i class="bi bi-person-plus"></i> إنشاء حساب
                            </a>
                        </li>
                    }

                    <li class="nav-item">
                        <button class="btn btn-sm btn-toggle-mode ms-2" onclick="toggleMode()">
                            🌙 تبديل الوضع
                        </button>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- ===== Page Content ===== -->
    <div class="container main-container">
        @RenderBody()
    </div>

    <!-- ===== Footer ===== -->
    <footer>
        © @DateTime.Now.Year - Mobile Shop System
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // تفعيل الوضع المحفوظ عند تحميل الصفحة
        window.onload = function () {
            if(localStorage.getItem("mode") === "dark"){
                document.body.classList.add("dark");
            }
        }

        function toggleMode() {
            document.body.classList.toggle("dark");
            localStorage.setItem("mode",
                document.body.classList.contains("dark") ? "dark" : "light");
        }

        function logoutConfirm() {
            if (confirm("هل أنت متأكد من تسجيل الخروج؟")) {
                window.location.href = "/Account/Logout";
            }
        }

        setInterval(function () {
            const now = new Date();
            if (now.getHours() === 0 && now.getMinutes() === 0) {
                alert("⚠️ يرجى تحديث بيانات تقفيل الحساب اليومي");
            }
        }, 60000);
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>