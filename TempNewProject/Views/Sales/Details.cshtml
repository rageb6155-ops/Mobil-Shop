@model MobileShopSystem.ViewModels.SaleDetailsViewModel

@{
    ViewData["Title"] = "تفاصيل عملية البيع";
    var username = Context.Session.GetString("Username");
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <!-- إضافة مكتبات PDF -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: #ffffff;
            margin: 0;
            padding: 20px;
            color: #333;
        }

        .page-wrapper {
            max-width: 800px;
            margin: 0 auto;
        }

        /* بطاقة العنوان */
        .header-card {
            background: white;
            border-radius: 16px;
            padding: 20px 25px;
            margin-bottom: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .header-title h1 {
            margin: 0;
            font-size: 26px;
            font-weight: 600;
            color: #17a2b8;
        }

        .header-title p {
            margin: 5px 0 0;
            color: #6c757d;
            font-size: 14px;
        }

        .user-info {
            background: #f8f9fa;
            color: #17a2b8;
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 500;
            border: 1px solid #e9ecef;
        }

        /* بطاقة التفاصيل */
        .details-card {
            background: white;
            border-radius: 16px;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
        }

        .details-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
            color: #17a2b8;
            font-weight: 600;
            font-size: 22px;
            padding-bottom: 10px;
            border-bottom: 2px solid #f0f0f0;
        }

        /* معلومات عامة */
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
        }

        .info-item {
            background: #f8f9fa;
            padding: 12px 15px;
            border-radius: 10px;
            border-right: 3px solid #17a2b8;
        }

        .info-label {
            font-size: 12px;
            color: #6c757d;
            margin-bottom: 5px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .info-label i {
                color: #17a2b8;
                width: 20px;
            }

        .info-value {
            font-size: 16px;
            font-weight: 600;
            color: #333;
        }

        /* حالة السجل */
        .status-badge {
            display: inline-block;
            padding: 5px 15px;
            border-radius: 50px;
            font-size: 13px;
            font-weight: 500;
        }

        .status-normal {
            background: #d4edda;
            color: #155724;
        }

        .status-edited {
            background: #fff3cd;
            color: #856404;
        }

        .status-deleted {
            background: #f8d7da;
            color: #721c24;
        }

        /* الجدول */
        .table-responsive {
            overflow-x: auto;
            border-radius: 12px;
            margin: 20px 0;
        }

        .items-table {
            width: 100%;
            border-collapse: collapse;
        }

            .items-table th {
                background: #17a2b8;
                color: white;
                padding: 12px;
                font-weight: 500;
                font-size: 14px;
                text-align: center;
            }

            .items-table td {
                padding: 12px;
                border: 1px solid #e9ecef;
                text-align: center;
            }

            .items-table tbody tr:hover {
                background: #f0f8ff;
            }

        .badge-rasid {
            background: #28a745;
            color: white;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 12px;
        }

        .badge-product {
            background: #17a2b8;
            color: white;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 12px;
        }

        /* ملخص المبالغ */
        .summary-box {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 20px;
            margin: 20px 0;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            font-size: 16px;
            border-bottom: 1px dashed #dee2e6;
        }

            .summary-row.total {
                font-size: 20px;
                font-weight: bold;
                color: #17a2b8;
                border-top: 2px solid #17a2b8;
                border-bottom: none;
                margin-top: 10px;
                padding-top: 15px;
            }

        /* الأزرار */
        .btn {
            padding: 10px 20px;
            border-radius: 8px;
            color: #fff;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
            border: none;
            cursor: pointer;
        }

            .btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            }

        .btn-secondary {
            background: #6c757d;
        }

            .btn-secondary:hover {
                background: #5a6268;
            }

        .btn-print {
            background: #17a2b8;
        }

            .btn-print:hover {
                background: #138496;
            }

        .action-buttons {
            display: flex;
            gap: 10px;
            margin-top: 25px;
            padding-top: 20px;
            border-top: 2px solid #f0f0f0;
        }

        /* ملاحظات */
        .notes-box {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
            margin: 20px 0;
            border-right: 3px solid #17a2b8;
        }

        .notes-title {
            font-size: 14px;
            color: #17a2b8;
            font-weight: 600;
            margin-bottom: 5px;
        }
    </style>
</head>
<body>
    <div class="page-wrapper">
        <!-- بطاقة العنوان -->
        <div class="header-card">
            <div class="header-title">
                <h1>
                    <i class="fas fa-file-invoice"></i> تفاصيل عملية البيع
                </h1>
                <p>عرض كامل لبيانات العملية</p>
            </div>
            <div class="user-info">
                <i class="fas fa-user-circle"></i> @username
            </div>
        </div>

        <!-- بطاقة التفاصيل -->
        <div class="details-card">
            <div class="details-title">
                <i class="fas fa-info-circle"></i>
                <span>معلومات العملية</span>
            </div>

            <!-- معلومات عامة -->
            <div class="info-grid">
                <div class="info-item">
                    <div class="info-label">
                        <i class="fas fa-hashtag"></i> رقم العملية
                    </div>
                    <div class="info-value">@Model.SaleNumber</div>
                </div>
                <div class="info-item">
                    <div class="info-label">
                        <i class="fas fa-user"></i> المستخدم
                    </div>
                    <div class="info-value">@Model.UserName</div>
                </div>
                <div class="info-item">
                    <div class="info-label">
                        <i class="far fa-calendar-alt"></i> التاريخ
                    </div>
                    <div class="info-value">@Model.SaleDate.ToString("yyyy-MM-dd")</div>
                </div>
                <div class="info-item">
                    <div class="info-label">
                        <i class="far fa-clock"></i> الوقت
                    </div>
                    <div class="info-value">@Model.SaleDate.ToString("HH:mm:ss")</div>
                </div>
            </div>

            <!-- حالة العملية -->
            <div style="margin-bottom: 20px;">
                <span class="info-label">الحالة:</span>
                <div style="margin-top: 5px;">
                    @if (Model.IsDeleted)
                    {
                        <span class="status-badge status-deleted"><i class="fas fa-trash"></i> محذوفة</span>
                    }
                    else if (Model.IsModified)
                    {
                        <span class="status-badge status-edited"><i class="fas fa-edit"></i> معدلة</span>
                    }
                    else
                    {
                        <span class="status-badge status-normal"><i class="fas fa-check"></i> عادية</span>
                    }
                </div>
            </div>

            @if (Model.IsModified && !string.IsNullOrEmpty(Model.ModifiedBy))
            {
                <div class="info-item" style="margin-bottom: 15px;">
                    <div class="info-label">
                        <i class="fas fa-user-edit"></i> آخر تعديل بواسطة
                    </div>
                    <div class="info-value" style="color: #856404;">@Model.ModifiedBy - @Model.ModifiedAt?.ToString("yyyy-MM-dd HH:mm")</div>
                </div>
            }

            <!-- جدول العناصر -->
            <div style="margin: 20px 0;">
                <h5 style="color: #17a2b8; margin-bottom: 15px;">
                    <i class="fas fa-list"></i> العناصر المباعة
                </h5>
                <div class="table-responsive">
                    <table class="items-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>النوع</th>
                                <th>الاسم</th>
                                <th>السعر</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int counter = 1;
                                foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>@counter</td>
                                        <td>
                                            @if (item.SaleTypeName == "رصيد")
                                            {
                                                <span class="badge-rasid"><i class="fas fa-coins"></i> رصيد</span>
                                            }
                                            else
                                            {
                                                <span class="badge-product"><i class="fas fa-box"></i> منتج</span>
                                            }
                                        </td>
                                        <td>@item.ItemName</td>
                                        <td>@item.ItemPrice.ToString("N2") ج.م</td>
                                    </tr>
                                    counter++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ملخص المبالغ -->
            <div class="summary-box">
                <div class="summary-row">
                    <span>المجموع الكلي:</span>
                    <span>@Model.TotalAmount.ToString("N2") ج.م</span>
                </div>
                <div class="summary-row">
                    <span>المبلغ المدفوع:</span>
                    <span>@Model.PaidAmount.ToString("N2") ج.م</span>
                </div>
                <div class="summary-row">
                    <span>المبلغ المتبقي:</span>
                    <span class="@(Model.RemainingAmount > 0 ? "text-success" : "")">@Model.RemainingAmount.ToString("N2") ج.م</span>
                </div>
                <div class="summary-row total">
                    <span>الإجمالي النهائي:</span>
                    <span>@Model.TotalAmount.ToString("N2") ج.م</span>
                </div>
            </div>

            <!-- ملاحظات -->
            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="notes-box">
                    <div class="notes-title">
                        <i class="fas fa-sticky-note"></i> ملاحظات
                    </div>
                    <div>@Model.Notes</div>
                </div>
            }

            <!-- أزرار الإجراءات -->
            <div class="action-buttons">
                <a href="javascript:history.back()" class="btn btn-secondary">
                    <i class="fas fa-arrow-right"></i> العودة
                </a>
                <button class="btn btn-print" onclick="printToPDF()">
                    <i class="fas fa-file-pdf"></i> طباعة PDF
                </button>
            </div>
        </div>
    </div>

    <script>
        function printToPDF() {
            // بيانات الفاتورة
            const invoiceData = {
                saleNumber: '@Model.SaleNumber',
                userName: '@Model.UserName',
                date: '@Model.SaleDate.ToString("yyyy-MM-dd")',
                time: '@Model.SaleDate.ToString("HH:mm:ss")',
                totalAmount: @Model.TotalAmount,
                paidAmount: @Model.PaidAmount,
                remainingAmount: @Model.RemainingAmount,
                items: [
                    @foreach (var item in Model.Items)
                    {
                            <text>{ name: '@item.ItemName', price: @item.ItemPrice, type: '@item.SaleTypeName' },</text>
                    }
                ]
            };

            // إنشاء عنصر مؤقت للفاتورة
            const printContainer = document.createElement('div');
            printContainer.style.width = '80mm';
            printContainer.style.padding = '8px';
            printContainer.style.fontFamily = 'Segoe UI, Tahoma, sans-serif';
            printContainer.style.background = 'white';
            printContainer.style.direction = 'rtl';
            printContainer.style.margin = '0 auto';
            printContainer.style.boxSizing = 'border-box';
            printContainer.style.position = 'absolute';
            printContainer.style.top = '-9999px';
            printContainer.style.left = '-9999px';

            let itemsHtml = '';
            invoiceData.items.forEach((item, index) => {
                itemsHtml += `
                    <tr>
                        <td style="padding: 4px; border-bottom: 1px dashed #eee; font-size: 8px; text-align: center;">${index + 1}</td>
                        <td style="padding: 4px; border-bottom: 1px dashed #eee; font-size: 8px; text-align: right;">${item.name}</td>
                        <td style="padding: 4px; border-bottom: 1px dashed #eee; font-size: 8px; text-align: center;">
                            <span style="background: ${item.type === 'رصيد' ? '#28a745' : '#17a2b8'}; color: white; padding: 2px 6px; border-radius: 10px; font-size: 7px;">${item.type}</span>
                        </td>
                        <td style="padding: 4px; border-bottom: 1px dashed #eee; font-size: 8px; text-align: center; color: #27ae60; font-weight: bold;">${item.price.toLocaleString()} ج.م</td>
                    </tr>
                `;
            });

            printContainer.innerHTML = `
                <div style="width: 100%; background: #fff; border-radius: 8px; padding: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); font-size: 10px; line-height: 1.3; box-sizing: border-box; text-align: center;">
                    <!-- رأس الفاتورة -->
                    <div style="text-align: center; border-bottom: 1px dashed #17a2b8; padding-bottom: 8px; margin-bottom: 8px;">
                        <h1 style="font-size: 16px; font-weight: bold; color: #17a2b8; margin: 0;">Mobile📱Shop</h1>
                        <div style="color: #7f8c8d; font-size: 8px; margin-top: 3px;">01064211484</div>
                        <div style="background: #17a2b8; color: white; padding: 4px; font-size: 11px; border-radius: 4px; margin-top: 6px; font-weight: bold;">
                            Sale Invoice
                        </div>
                    </div>

                    <!-- معلومات الفاتورة -->
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4px; margin-bottom: 8px;">
                        <div style="background: #f8f9fa; padding: 4px; border-radius: 4px;">
                            <span style="font-size: 7px; color: #7f8c8d; display: block;">رقم الفاتورة</span>
                            <span style="font-size: 9px; font-weight: bold; color: #2c3e50; display: block;">${invoiceData.saleNumber}</span>
                        </div>
                        <div style="background: #f8f9fa; padding: 4px; border-radius: 4px;">
                            <span style="font-size: 7px; color: #7f8c8d; display: block;">التاريخ</span>
                            <span style="font-size: 9px; font-weight: bold; color: #2c3e50; display: block;">${invoiceData.date}</span>
                        </div>
                        <div style="background: #f8f9fa; padding: 4px; border-radius: 4px;">
                            <span style="font-size: 7px; color: #7f8c8d; display: block;">الساعة</span>
                            <span style="font-size: 9px; font-weight: bold; color: #2c3e50; display: block;">${invoiceData.time}</span>
                        </div>
                        <div style="background: #f8f9fa; padding: 4px; border-radius: 4px;">
                            <span style="font-size: 7px; color: #7f8c8d; display: block;">البائع</span>
                            <span style="font-size: 9px; font-weight: bold; color: #2c3e50; display: block;">${invoiceData.userName}</span>
                        </div>
                    </div>

                    <!-- خط منقط -->
                    <div style="border-top: 1px dashed #ccc; margin: 6px 0;"></div>

                    <!-- إحصائيات سريعة -->
                    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 4px; margin: 8px 0;">
                        <div style="background: #f8f9fa; padding: 4px; border-radius: 4px; text-align: center; border-right: 2px solid #17a2b8;">
                            <div style="font-size: 6px; color: #7f8c8d;">عدد العناصر</div>
                            <div style="font-size: 9px; font-weight: bold; color: #2c3e50;">${invoiceData.items.length}</div>
                        </div>
                        <div style="background: #f8f9fa; padding: 4px; border-radius: 4px; text-align: center; border-right: 2px solid #17a2b8;">
                            <div style="font-size: 6px; color: #7f8c8d;">المجموع</div>
                            <div style="font-size: 9px; font-weight: bold; color: #27ae60;">${invoiceData.totalAmount.toLocaleString()}</div>
                        </div>
                        <div style="background: #f8f9fa; padding: 4px; border-radius: 4px; text-align: center; border-right: 2px solid #17a2b8;">
                            <div style="font-size: 6px; color: #7f8c8d;">المدفوع</div>
                            <div style="font-size: 9px; font-weight: bold; color: #27ae60;">${invoiceData.paidAmount.toLocaleString()}</div>
                        </div>
                    </div>

                    <!-- جدول العناصر -->
                    <div style="margin: 10px 0;">
                        <h3 style="font-size: 11px; color: #17a2b8; margin-bottom: 5px; text-align: center;">العناصر المباعة</h3>
                        <table style="width: 100%; border-collapse: collapse;">
                            <thead>
                                <tr style="background: #17a2b8; color: white;">
                                    <th style="padding: 4px; font-size: 8px;">#</th>
                                    <th style="padding: 4px; font-size: 8px;">المنتج</th>
                                    <th style="padding: 4px; font-size: 8px;">النوع</th>
                                    <th style="padding: 4px; font-size: 8px;">السعر</th>
                                </tr>
                            </thead>
                            <tbody>
                                ${itemsHtml}
                            </tbody>
                        </table>
                    </div>

                    <!-- ملخص المبالغ -->
                    <div style="background: linear-gradient(135deg, #17a2b8, #138496); color: white; border-radius: 6px; padding: 8px; margin: 8px 0;">
                        <div style="display: flex; justify-content: space-between; font-size: 10px; margin-bottom: 3px;">
                            <span>المجموع الكلي:</span>
                            <span>${invoiceData.totalAmount.toLocaleString()} ج.م</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; font-size: 10px; margin-bottom: 3px;">
                            <span>المبلغ المدفوع:</span>
                            <span>${invoiceData.paidAmount.toLocaleString()} ج.م</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; font-size: 10px;">
                            <span>المبلغ المتبقي:</span>
                            <span>${invoiceData.remainingAmount.toLocaleString()} ج.م</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; font-size: 12px; font-weight: bold; border-top: 1px solid rgba(255,255,255,0.3); margin-top: 5px; padding-top: 5px;">
                            <span>✨ الإجمالي</span>
                            <span>${invoiceData.totalAmount.toLocaleString()} ج.م</span>
                        </div>
                    </div>

                    <!-- خط منقط -->
                    <div style="border-top: 1px dashed #ccc; margin: 6px 0;"></div>

                    <!-- الفوتر -->
                    <div style="margin-top: 8px; font-size: 6px; color: #777; text-align: center; border-top: 1px solid #eee; padding-top: 4px;">
                        <div>Mobile📱Shop - ${invoiceData.date}</div>
                        <div>شكراً لتعاملكم معنا ✨</div>
                    </div>
                </div>
            `;

            document.body.appendChild(printContainer);

            // تحويل إلى PDF
            html2canvas(printContainer, {
                scale: 2,
                backgroundColor: '#ffffff',
                windowWidth: printContainer.scrollWidth,
                windowHeight: printContainer.scrollHeight
            }).then(canvas => {
                const { jsPDF } = window.jspdf;

                const imgWidth = 80; // mm
                const imgHeight = (canvas.height * imgWidth) / canvas.width;

                const pdf = new jsPDF({
                    orientation: 'portrait',
                    unit: 'mm',
                    format: [imgWidth, imgHeight]
                });

                const imgData = canvas.toDataURL('image/png');
                pdf.addImage(imgData, 'PNG', 0, 0, imgWidth, imgHeight, undefined, 'FAST');

                // حفظ PDF مباشرة بدون أي مربعات حوار
                const fileName = `فاتورة_${invoiceData.saleNumber}.pdf`;
                pdf.save(fileName);

                // إزالة العنصر المؤقت
                if (printContainer.parentNode) {
                    document.body.removeChild(printContainer);
                }
            }).catch(error => {
                alert('حدث خطأ في الطباعة: ' + error.message);
                if (printContainer.parentNode) {
                    document.body.removeChild(printContainer);
                }
            });
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>