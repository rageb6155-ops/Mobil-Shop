@model MobileShopSystem.Models.DailyClosing
@{
    ViewBag.Title = "تعديل تقفيل الحساب";
    var username = Context.Session.GetString("Username");
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: #ffffff;
            margin: 0;
            padding: 20px;
            color: #333;
        }

        .page-wrapper {
            max-width: 800px;
            margin: 0 auto;
        }

        /* بطاقة العنوان */
        .header-card {
            background: white;
            border-radius: 16px;
            padding: 20px 25px;
            margin-bottom: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .header-title h1 {
            margin: 0;
            font-size: 26px;
            font-weight: 600;
            color: #ffc107;
        }

        .header-title p {
            margin: 5px 0 0;
            color: #6c757d;
            font-size: 14px;
        }

        .user-info {
            background: #f8f9fa;
            color: #ffc107;
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 500;
            border: 1px solid #e9ecef;
        }

            .user-info i {
                margin-left: 8px;
            }

        /* بطاقة التعديل */
        .edit-card {
            background: white;
            border-radius: 16px;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
        }

        .edit-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
            color: #ffc107;
            font-weight: 600;
            font-size: 22px;
            padding-bottom: 10px;
            border-bottom: 2px solid #f0f0f0;
        }

            .edit-title i {
                font-size: 24px;
            }

        /* التنبيهات */
        .alert {
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .alert-danger {
            background: #f8d7da;
            color: #721c24;
            border-right: 3px solid #dc3545;
        }

        /* النموذج */
        .form-label {
            font-weight: 500;
            color: #ffc107;
            margin-bottom: 5px;
            display: block;
        }

        .form-control {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e9ecef;
            border-radius: 10px;
            font-size: 14px;
            transition: all 0.3s;
            background: #f8f9fa;
        }

            .form-control:focus {
                outline: none;
                border-color: #ffc107;
                background: white;
                box-shadow: 0 5px 20px rgba(255, 193, 7, 0.1);
            }

        /* قسم الماكينات */
        .machines-section {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 20px;
            margin: 20px 0;
        }

        .section-title {
            display: flex;
            align-items: center;
            gap: 10px;
            color: #ffc107;
            font-weight: 600;
            margin-bottom: 15px;
        }

        .machine-row {
            background: white;
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 15px;
            border: 1px solid #e9ecef;
            transition: all 0.3s;
        }

            .machine-row:hover {
                box-shadow: 0 5px 15px rgba(255, 193, 7, 0.1);
            }

        /* الأزرار */
        .btn {
            padding: 10px 20px;
            border-radius: 8px;
            color: #fff;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
            border: none;
            cursor: pointer;
            margin: 3px;
        }

            .btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            }

        .btn-danger {
            background: #dc3545;
        }

            .btn-danger:hover {
                background: #c82333;
            }

        .btn-primary {
            background: #ffc107;
            color: #333;
        }

            .btn-primary:hover {
                background: #e0a800;
            }

        .btn-success {
            background: #28a745;
        }

            .btn-success:hover {
                background: #218838;
            }

        .btn-secondary {
            background: #6c757d;
        }

            .btn-secondary:hover {
                background: #5a6268;
            }

        .btn-add {
            background: #ffc107;
            color: #333;
            border: none;
            padding: 8px 20px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 20px;
        }

            .btn-add:hover {
                background: #e0a800;
                transform: translateY(-2px);
            }

        .action-buttons {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 2px solid #f0f0f0;
        }

        /* معلومات إضافية */
        .info-note {
            background: #fff3cd;
            color: #856404;
            padding: 12px;
            border-radius: 8px;
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
            border-right: 3px solid #ffc107;
        }

            .info-note i {
                font-size: 16px;
            }
    </style>
</head>
<body>
    <div class="page-wrapper">

        <!-- بطاقة العنوان -->
        <div class="header-card">
            <div class="header-title">
                <h1>
                    <i class="fas fa-edit"></i> تعديل تقفيل الحساب
                </h1>
                <p>تعديل بيانات التقفيل اليومي</p>
            </div>
            <div class="user-info">
                <i class="fas fa-user-circle"></i>
                @username
            </div>
        </div>

        <!-- بطاقة التعديل -->
        <div class="edit-card">
            <div class="edit-title">
                <i class="fas fa-pen"></i>
                <span>تعديل البيانات</span>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
                </div>
            }

            <!-- ملاحظة مهمة -->
            <div class="info-note">
                <i class="fas fa-info-circle"></i>
                <span>سيتم حفظ نسخة من البيانات قبل التعديل للمقارنة</span>
            </div>

            <form asp-action="Edit" method="post">

                <input type="hidden" asp-for="Id" />

                <!-- البيانات الرئيسية -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label">
                            <i class="fas fa-money-bill"></i> الفلوس المتبقية
                        </label>
                        <input asp-for="CashLeft" type="number" step="0.01" class="form-control" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">
                            <i class="fas fa-coins"></i> الفضة
                        </label>
                        <input asp-for="CoinsAmount" type="number" step="0.01" class="form-control" required />
                    </div>
                </div>

                <hr style="border-top: 2px dashed #e9ecef; margin: 25px 0;" />

                <!-- الماكينات -->
                <div class="machines-section">
                    <div class="section-title">
                        <i class="fas fa-cogs"></i>
                        <span>تعديل الماكينات</span>
                    </div>

                    <div id="machinesContainer">

                        @for (int i = 0; i < Model.Machines.Count; i++)
                        {
                            var machine = Model.Machines.ElementAt(i);

                            <div class="machine-row" id="machine-@machine.Id">

                                <input type="hidden" name="machineIds" value="@machine.Id" />

                                <div class="row align-items-center">
                                    <div class="col-md-5">
                                        <label class="form-label" style="color: #666;">اسم الماكينة</label>
                                        <input type="text"
                                               name="machineNames"
                                               value="@machine.MachineName"
                                               class="form-control"
                                               required />
                                    </div>

                                    <div class="col-md-5">
                                        <label class="form-label" style="color: #666;">الرصيد</label>
                                        <input type="number"
                                               step="0.01"
                                               name="balances"
                                               value="@machine.Balance"
                                               class="form-control"
                                               required />
                                    </div>

                                    <div class="col-md-2">
                                        <label class="form-label" style="color: #666;">&nbsp;</label>
                                        <button type="button"
                                                class="btn btn-danger w-100"
                                                onclick="removeMachine(this)">
                                            <i class="fas fa-trash"></i> حذف
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }

                    </div>

                    <button type="button"
                            class="btn-add"
                            onclick="addMachine()">
                        <i class="fas fa-plus-circle"></i> إضافة ماكينة جديدة
                    </button>
                </div>

                <!-- أزرار الإجراءات -->
                <div class="action-buttons">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> حفظ التعديلات
                    </button>
                    <a asp-action="Reports" class="btn btn-secondary">
                        <i class="fas fa-arrow-right"></i> رجوع للتقارير
                    </a>
                </div>

            </form>
        </div>
    </div>

    <script>
        function addMachine() {
            var container = document.getElementById("machinesContainer");
            var newId = 'new_' + Date.now();

            var row = document.createElement("div");
            row.className = "machine-row";
            row.id = newId;

            row.innerHTML = `
                <input type="hidden" name="machineIds" value="0" />
                <div class="row align-items-center">
                    <div class="col-md-5">
                        <label class="form-label" style="color: #666;">اسم الماكينة</label>
                        <input type="text"
                               name="machineNames"
                               class="form-control"
                               placeholder="أدخل اسم الماكينة"
                               required />
                    </div>

                    <div class="col-md-5">
                        <label class="form-label" style="color: #666;">الرصيد</label>
                        <input type="number"
                               step="0.01"
                               name="balances"
                               class="form-control"
                               placeholder="أدخل الرصيد"
                               required />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label" style="color: #666;">&nbsp;</label>
                        <button type="button"
                                class="btn btn-danger w-100"
                                onclick="removeMachine(this)">
                            <i class="fas fa-trash"></i> حذف
                        </button>
                    </div>
                </div>
            `;

            container.appendChild(row);
        }

        function removeMachine(button) {
            if (confirm('هل أنت متأكد من حذف هذه الماكينة؟')) {
                var row = button.closest(".machine-row");
                row.remove();
            }
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>