@model MobileShopSystem.Models.DailyClosing

@{
    ViewBag.Title = "تقفيل حساب اليوم";
    var username = Context.Session.GetString("Username");
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <!-- إضافة مكتبات PDF -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: #f4f6f9;
            margin: 0;
            padding: 20px;
            color: #333;
        }

        .page-wrapper {
            max-width: 900px;
            margin: 0 auto;
        }

        /* بطاقة العنوان */
        .header-card {
            background: white;
            border-radius: 16px;
            padding: 20px 25px;
            margin-bottom: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .header-title h1 {
            margin: 0;
            font-size: 26px;
            font-weight: 600;
            color: #0d6efd;
        }

        .header-title p {
            margin: 5px 0 0;
            color: #6c757d;
            font-size: 14px;
        }

        .user-info {
            background: #f8f9fa;
            color: #0d6efd;
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 500;
            border: 1px solid #e9ecef;
        }

            .user-info i {
                margin-left: 8px;
            }

        /* بطاقة المحتوى */
        .content-card {
            background: white;
            border-radius: 16px;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
        }

        .card-header-custom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid #f0f0f0;
        }

            .card-header-custom h4 {
                margin: 0;
                color: #0d6efd;
                font-weight: 600;
            }

        .btn-pdf {
            background: #0d6efd;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .btn-pdf:hover {
                background: #0b5ed7;
                transform: translateY(-2px);
            }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
        }

        .info-item {
            background: #f8f9fa;
            padding: 12px 15px;
            border-radius: 10px;
            border-right: 3px solid #0d6efd;
        }

        .info-label {
            font-size: 12px;
            color: #6c757d;
            margin-bottom: 5px;
        }

        .info-value {
            font-size: 16px;
            font-weight: bold;
            color: #333;
        }

        .alert-custom {
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .alert-warning-custom {
            background: #fff3cd;
            color: #856404;
            border-right: 3px solid #ffc107;
        }

        .table-custom {
            width: 100%;
            border-collapse: collapse;
            margin: 15px 0;
        }

            .table-custom th {
                background: #f8f9fa;
                color: #0d6efd;
                font-weight: 600;
                padding: 12px;
                border: 1px solid #dee2e6;
            }

            .table-custom td {
                padding: 10px;
                border: 1px solid #dee2e6;
            }

            .table-custom tbody tr:hover {
                background: #f8f9fa;
            }

        .section-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 20px 0 15px;
            color: #0d6efd;
            font-weight: 600;
        }

            .section-title i {
                font-size: 20px;
            }

        .alert-danger-custom {
            background: #f8d7da;
            color: #721c24;
            padding: 20px;
            border-radius: 10px;
            text-align: center;
            border-right: 3px solid #dc3545;
        }
    </style>
</head>
<body>
    <div class="page-wrapper">
        <!-- بطاقة العنوان -->
        <div class="header-card">
            <div class="header-title">
                <h1>
                    <i class="fas fa-calculator"></i> تقفيل حساب اليوم
                </h1>
                <p>عرض تفاصيل تقفيل الحساب اليومي</p>
            </div>
            <div class="user-info">
                <i class="fas fa-user-circle"></i>
                @username
            </div>
        </div>

        <!-- بطاقة المحتوى -->
        <div class="content-card">
            <div class="card-header-custom">
                <h4>
                    <i class="fas fa-file-invoice"></i> تفاصيل التقفيل
                </h4>
                @if (Model != null)
                {
                    <button class="btn-pdf" onclick="printToPDF()">
                        <i class="fas fa-file-pdf"></i> تصدير PDF
                    </button>
                }
            </div>

            @if (Model == null)
            {
                <div class="alert-danger-custom">
                    <i class="fas fa-exclamation-triangle" style="font-size: 24px; margin-bottom: 10px;"></i>
                    <h4>لا يوجد تقفيل لليوم</h4>
                    <p class="mb-0">@ViewBag.Message</p>
                </div>
            }
            else
            {
                <!-- معلومات أساسية -->
                <div class="info-grid">
                    <div class="info-item">
                        <div class="info-label">📅 التاريخ</div>
                        <div class="info-value">@Model.ClosingDate.ToString("yyyy-MM-dd HH:mm")</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">👤 أضيف بواسطة</div>
                        <div class="info-value">@Model.CreatedBy</div>
                    </div>
                    @if (Model.IsEdited)
                    {
                        <div class="info-item">
                            <div class="info-label">✏️ آخر تعديل</div>
                            <div class="info-value">@Model.UpdatedBy</div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">⏰ تاريخ التعديل</div>
                            <div class="info-value">@Model.UpdatedAt?.ToString("yyyy-MM-dd HH:mm")</div>
                        </div>
                    }
                </div>

                @if (Model.IsEdited)
                {
                    <div class="alert-custom alert-warning-custom">
                        <i class="fas fa-exclamation-triangle"></i>
                        <span>
                            <strong>تم تعديل هذا التقفيل</strong> - آخر تعديل بواسطة @Model.UpdatedBy في @Model.UpdatedAt?.ToString("yyyy-MM-dd HH:mm")
                        </span>
                    </div>
                }

                <!-- الرصيد المالي -->
                <div class="section-title">
                    <i class="fas fa-coins"></i>
                    <span>الرصيد المالي</span>
                </div>

                <table class="table-custom">
                    <thead>
                        <tr>
                            <th>الفلوس المتبقية</th>
                            <th>الفضة</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>💰 @Model.CashLeft.ToString("N2") ج.م</td>
                            <td>🪙 @Model.CoinsAmount.ToString("N2") ج.م</td>
                        </tr>
                    </tbody>
                </table>

                <!-- الماكينات -->
                <div class="section-title">
                    <i class="fas fa-cogs"></i>
                    <span>الماكينات</span>
                </div>

                <table class="table-custom">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>اسم الماكينة</th>
                            <th>الرصيد</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int counter = 1;
                            foreach (var machine in Model.Machines)
                            {
                                <tr>
                                    <td>@counter</td>
                                    <td>@machine.MachineName</td>
                                    <td>@machine.Balance.ToString("N2") ج.م</td>
                                </tr>
                                counter++;
                            }
                        }
                    </tbody>
                </table>

                <!-- ملخص سريع -->
                <div class="info-grid" style="margin-top: 20px;">
                    <div class="info-item" style="border-right-color: #28a745;">
                        <div class="info-label">💰 إجمالي النقدي</div>
                        <div class="info-value" style="color: #28a745;">@((Model.CashLeft + Model.CoinsAmount).ToString("N2")) ج.م</div>
                    </div>
                    <div class="info-item" style="border-right-color: #17a2b8;">
                        <div class="info-label">⚙️ إجمالي الماكينات</div>
                        <div class="info-value" style="color: #17a2b8;">@Model.Machines.Sum(m => m.Balance).ToString("N2") ج.م</div>
                    </div>
                    <div class="info-item" style="border-right-color: #0d6efd;">
                        <div class="info-label">✨ الإجمالي الكلي</div>
                        <div class="info-value" style="color: #0d6efd;">@((Model.CashLeft + Model.CoinsAmount + Model.Machines.Sum(m => m.Balance)).ToString("N2")) ج.م</div>
                    </div>
                </div>
            }
        </div>
    </div>

    <script>
        function printToPDF() {
            @if (Model != null)
            {
                        <text>
                        // بيانات التقفيل
                        const closingData = {
                            date: '@Model.ClosingDate.ToString("yyyy-MM-dd HH:mm")',
                            createdBy: '@Model.CreatedBy',
                            cashLeft: @Model.CashLeft,
                            coinsAmount: @Model.CoinsAmount,
                            isEdited: @Model.IsEdited.ToString().ToLower(),
                            updatedBy: '@(Model.UpdatedBy ?? "")',
                            updatedAt: '@(Model.UpdatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "")',
                            machines: [
                                @foreach (var machine in Model.Machines)
                                {
                                            <text>{ name: '@machine.MachineName', balance: @machine.Balance },</text>
                                }
                            ]
                        };

                        // إنشاء عنصر مؤقت للفاتورة
                        const printContainer = document.createElement('div');
                        printContainer.style.width = '80mm';
                        printContainer.style.padding = '8px';
                        printContainer.style.fontFamily = 'Segoe UI, Tahoma, sans-serif';
                        printContainer.style.background = 'white';
                        printContainer.style.direction = 'rtl';
                        printContainer.style.margin = '0 auto';
                        printContainer.style.boxSizing = 'border-box';

                        let machinesHtml = '';
                        closingData.machines.forEach((machine, index) => {
                            machinesHtml += `
                                <tr>
                                    <td style="padding: 5px; border: 1px solid #dee2e6; text-align: center;">${index + 1}</td>
                                    <td style="padding: 5px; border: 1px solid #dee2e6; text-align: right;">${machine.name}</td>
                                    <td style="padding: 5px; border: 1px solid #dee2e6; text-align: center; color: #27ae60; font-weight: bold;">${machine.balance.toLocaleString()} ج.م</td>
                                </tr>
                            `;
                        });

                        printContainer.innerHTML = `
                            <div style="width: 100%; background: #fff; border-radius: 8px; padding: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); font-size: 10px; line-height: 1.3; box-sizing: border-box; text-align: center;">
                                <!-- رأس الفاتورة -->
                                <div style="text-align: center; border-bottom: 1px dashed #0d6efd; padding-bottom: 8px; margin-bottom: 8px; width: 100%;">
                                    <h1 style="font-size: 16px; font-weight: bold; color: #0d6efd; margin: 0;">Mobile📱Shop</h1>
                                    <div style="color: #7f8c8d; font-size: 8px; margin-top: 3px;">01064211484</div>
                                    <div style="background: #0d6efd; color: white; padding: 4px; font-size: 11px; border-radius: 4px; margin-top: 6px; font-weight: bold;">
                                        Daily Closing
                                    </div>
                                </div>

                                <!-- معلومات الفاتورة -->
                                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4px; margin-bottom: 8px; width: 100%;">
                                    <div style="background: #f8f9fa; padding: 4px; border-radius: 4px; text-align: center;">
                                        <span style="font-size: 7px; color: #7f8c8d; display: block;">رقم التقفيل</span>
                                        <span style="font-size: 9px; font-weight: bold; color: #2c3e50; display: block;">${closingData.date.replace(/[/: ]/g, '')}</span>
                                    </div>
                                    <div style="background: #f8f9fa; padding: 4px; border-radius: 4px; text-align: center;">
                                        <span style="font-size: 7px; color: #7f8c8d; display: block;">التاريخ</span>
                                        <span style="font-size: 9px; font-weight: bold; color: #2c3e50; display: block;">${new Date().toLocaleDateString('ar-EG')}</span>
                                    </div>
                                    <div style="background: #f8f9fa; padding: 4px; border-radius: 4px; text-align: center;">
                                        <span style="font-size: 7px; color: #7f8c8d; display: block;">الساعة</span>
                                        <span style="font-size: 9px; font-weight: bold; color: #2c3e50; display: block;">${new Date().toLocaleTimeString('ar-EG')}</span>
                                    </div>
                                    <div style="background: #f8f9fa; padding: 4px; border-radius: 4px; text-align: center;">
                                        <span style="font-size: 7px; color: #7f8c8d; display: block;">تمت الطباعة بواسطة</span>
                                        <span style="font-size: 9px; font-weight: bold; color: #2c3e50; display: block;">@username</span>
                                    </div>
                                </div>

                                <!-- خط منقط -->
                                <div style="border-top: 1px dashed #ccc; margin: 6px 0; width: 100%;"></div>

                                <!-- معلومات التقفيل -->
                                <div style="margin-bottom: 10px; width: 100%;">
                                    <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px dashed #eee; font-size: 9px;">
                                        <span style="color: #0d6efd; font-weight: bold;">📅 تاريخ التقفيل:</span>
                                        <span style="color: #333;">${closingData.date}</span>
                                    </div>
                                    <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px dashed #eee; font-size: 9px;">
                                        <span style="color: #0d6efd; font-weight: bold;">👤 تم بواسطة:</span>
                                        <span style="color: #333;">${closingData.createdBy}</span>
                                    </div>
                                    ${closingData.isEdited ? `
                                    <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px dashed #eee; font-size: 9px;">
                                        <span style="color: #0d6efd; font-weight: bold;">✏️ آخر تعديل:</span>
                                        <span style="color: #333;">${closingData.updatedBy} (${closingData.updatedAt})</span>
                                    </div>
                                    ` : ''}
                                </div>

                                <!-- الرصيد المالي -->
                                <div style="margin: 10px 0; width: 100%;">
                                    <h3 style="font-size: 12px; color: #0d6efd; margin-bottom: 8px; text-align: center;">💰 الرصيد المالي</h3>
                                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 5px;">
                                        <div style="background: #f8f9fa; padding: 6px; border-radius: 5px; text-align: center;">
                                            <div style="font-size: 8px; color: #666;">الفلوس</div>
                                            <div style="font-weight: bold; color: #27ae60;">${closingData.cashLeft.toLocaleString()} ج.م</div>
                                        </div>
                                        <div style="background: #f8f9fa; padding: 6px; border-radius: 5px; text-align: center;">
                                            <div style="font-size: 8px; color: #666;">الفضة</div>
                                            <div style="font-weight: bold; color: #f39c12;">${closingData.coinsAmount.toLocaleString()} ج.م</div>
                                        </div>
                                    </div>
                                </div>

                                <!-- الماكينات -->
                                <div style="margin: 10px 0; width: 100%;">
                                    <h3 style="font-size: 12px; color: #0d6efd; margin-bottom: 8px; text-align: center;">⚙️ الماكينات</h3>
                                    <table style="width: 100%; border-collapse: collapse; font-size: 9px;">
                                        <thead>
                                            <tr style="background: #0d6efd; color: white;">
                                                <th style="padding: 4px; border: 1px solid #0d6efd;">#</th>
                                                <th style="padding: 4px; border: 1px solid #0d6efd;">الماكينة</th>
                                                <th style="padding: 4px; border: 1px solid #0d6efd;">الرصيد</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            ${machinesHtml}
                                        </tbody>
                                    </table>
                                </div>

                                <!-- إجمالي المبالغ -->
                                <div style="background: linear-gradient(135deg, #0d6efd, #0b5ed7); color: white; border-radius: 6px; padding: 8px; margin: 10px 0; width: 100%;">
                                    <div style="display: flex; justify-content: space-between; font-size: 11px; margin-bottom: 4px;">
                                        <span>💰 إجمالي النقدي:</span>
                                        <span>${(closingData.cashLeft + closingData.coinsAmount).toLocaleString()} ج.م</span>
                                    </div>
                                    <div style="display: flex; justify-content: space-between; font-size: 11px; margin-bottom: 4px;">
                                        <span>⚙️ إجمالي الماكينات:</span>
                                        <span>${closingData.machines.reduce((sum, m) => sum + m.balance, 0).toLocaleString()} ج.م</span>
                                    </div>
                                    <div style="display: flex; justify-content: space-between; font-size: 13px; font-weight: bold; border-top: 1px solid rgba(255,255,255,0.3); margin-top: 4px; padding-top: 4px;">
                                        <span>✨ الإجمالي الكلي:</span>
                                        <span>${(closingData.cashLeft + closingData.coinsAmount + closingData.machines.reduce((sum, m) => sum + m.balance, 0)).toLocaleString()} ج.م</span>
                                    </div>
                                </div>

                                <!-- خط منقط -->
                                <div style="border-top: 1px dashed #ccc; margin: 6px 0; width: 100%;"></div>

                                <!-- الفوتر -->
                                <div style="margin-top: 8px; font-size: 6px; color: #777; text-align: center; border-top: 1px solid #eee; padding-top: 4px; width: 100%;">
                                    <div>Mobile📱Shop - ${new Date().toLocaleDateString('ar-EG')}</div>
                                    <div>شكراً لتعاملكم معنا ✨</div>
                                </div>
                            </div>
                        `;

                        document.body.appendChild(printContainer);

                        // تحويل إلى PDF
                        html2canvas(printContainer, {
                            scale: 2,
                            backgroundColor: '#ffffff',
                            windowWidth: printContainer.scrollWidth,
                            windowHeight: printContainer.scrollHeight
                        }).then(canvas => {
                            const { jsPDF } = window.jspdf;

                            const imgWidth = 80; // mm
                            const imgHeight = (canvas.height * imgWidth) / canvas.width;

                            const pdf = new jsPDF({
                                orientation: 'portrait',
                                unit: 'mm',
                                format: [imgWidth, imgHeight]
                            });

                            const imgData = canvas.toDataURL('image/png');
                            pdf.addImage(imgData, 'PNG', 0, 0, imgWidth, imgHeight, undefined, 'FAST');

                            pdf.save(`تقفيل_حساب_${closingData.date.replace(/[/: ]/g, '_')}.pdf`);

                            document.body.removeChild(printContainer);
                        }).catch(error => {
                            alert('حدث خطأ في الطباعة: ' + error.message);
                            document.body.removeChild(printContainer);
                        });
                        </text>
            }
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>