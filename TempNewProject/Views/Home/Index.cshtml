@using Microsoft.AspNetCore.Http
@using MobileShopSystem.Data
@using Microsoft.EntityFrameworkCore
@inject AppDbContext _context

@{
    ViewData["Title"] = "الرئيسية";
    var username = Context.Session.GetString("Username");
    var isAdmin = Context.Session.GetString("IsAdmin") == "True";

    // إحصائيات حقيقية من قاعدة البيانات (للإستخدام الداخلي فقط)
    var today = DateTime.Today;
    var todaySales = _context.Sales?
        .Where(s => s.SaleDate.Date == today && !s.IsDeleted)
        .ToList() ?? new List<MobileShopSystem.Models.Sale>();
    var repairDevices = _context.RepairDevices?
        .Where(d => !d.IsDeleted && d.Status != "تم التسليم")
        .ToList() ?? new List<MobileShopSystem.Models.RepairDevice>();
    var activeCustomers = _context.Customers?
        .Where(c => !c.IsDeleted && c.IsActive)
        .ToList() ?? new List<MobileShopSystem.Models.Customer>();
    var todayRequests = _context.ShopRequests?
        .Where(r => !r.IsDeleted && r.RequestDate.Date == today)
        .ToList() ?? new List<MobileShopSystem.Models.ShopRequest>();
}

<style>
    /* ===== متغيرات الألوان ===== */
    :root {
        --primary: #4361ee;
        --primary-dark: #3a56d4;
        --secondary: #6c757d;
        --success: #28a745;
        --info: #17a2b8;
        --warning: #ffc107;
        --danger: #dc3545;
        --light: #f8f9fa;
        --dark: #343a40;
        --white: #ffffff;
        --gradient-1: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --gradient-2: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        --gradient-3: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        --gradient-4: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
        --gradient-5: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
        --shadow-sm: 0 2px 8px rgba(0,0,0,0.1);
        --shadow-md: 0 5px 15px rgba(0,0,0,0.15);
        --shadow-lg: 0 10px 25px rgba(0,0,0,0.2);
        --border-radius: 16px;
    }

    /* ===== الوضع الداكن ===== */
    body.dark-mode {
        --light: #2d2d2d;
        --dark: #f8f9fa;
        --white: #1e1e1e;
        background: #121212;
        color: #e0e0e0;
    }

        body.dark-mode .dashboard {
            background: #1e1e1e;
            border: 1px solid #333;
        }

        body.dark-mode .stat-card {
            background: #2d2d2d;
            border-color: #404040;
        }

        body.dark-mode .card {
            background: #2d2d2d;
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        }

        body.dark-mode .dropdown-menu {
            background: #2d2d2d;
            border: 1px solid #404040;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        body.dark-mode .dropdown-item {
            color: #e0e0e0;
        }

            body.dark-mode .dropdown-item:hover {
                background: #404040;
            }

        body.dark-mode .dropdown-divider {
            border-color: #404040;
        }

    /* ===== التنسيقات العامة ===== */
    body {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        margin: 0;
        padding: 0;
        min-height: 100vh;
    }

    .container-fluid {
        max-width: 1600px;
        margin: 0 auto;
        padding: 20px;
    }

    /* ===== بطاقة الترحيب مع القائمة المنسدلة ===== */
    .welcome-card {
        background: var(--white);
        border-radius: var(--border-radius);
        padding: 25px 30px;
        margin-bottom: 25px;
        box-shadow: var(--shadow-lg);
        position: relative;
        overflow: visible;
        z-index: 100;
    }

    .welcome-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
    }

    .welcome-text h1 {
        font-size: 28px;
        font-weight: 700;
        margin: 0 0 8px 0;
        background: var(--gradient-1);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .welcome-text p {
        font-size: 15px;
        color: var(--secondary);
        margin: 0;
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
    }

    .date-badge {
        background: var(--gradient-2);
        padding: 12px 24px;
        border-radius: 50px;
        color: white;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: var(--shadow-md);
    }

        .date-badge i {
            font-size: 18px;
        }

        .date-badge span {
            font-size: 15px;
        }

    /* ===== القائمة المنسدلة المحترفة (أعلى العناصر) ===== */
    .dropdown-container {
        position: relative;
        z-index: 1000;
    }

    .dropdown-btn {
        background: var(--gradient-3);
        color: white;
        border: none;
        padding: 12px 28px;
        border-radius: 50px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: var(--shadow-lg);
        transition: all 0.3s ease;
        position: relative;
        z-index: 1001;
    }

        .dropdown-btn:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-lg);
            opacity: 0.95;
        }

        .dropdown-btn i:last-child {
            transition: transform 0.3s ease;
        }

        .dropdown-btn.active i:last-child {
            transform: rotate(180deg);
        }

    .dropdown-menu {
        position: absolute;
        top: calc(100% + 15px);
        left: 0;
        min-width: 320px;
        background: var(--white);
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        padding: 12px 0;
        z-index: 9999;
        display: none;
        border: 1px solid rgba(0,0,0,0.08);
        opacity: 0;
        transform: translateY(-10px);
        transition: opacity 0.3s ease, transform 0.3s ease;
    }

        .dropdown-menu.show {
            display: block;
            opacity: 1;
            transform: translateY(0);
        }

    .dropdown-header {
        padding: 12px 20px;
        font-weight: 700;
        color: var(--primary);
        font-size: 14px;
        letter-spacing: 0.5px;
    }

    .dropdown-item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 14px 25px;
        color: var(--dark);
        text-decoration: none;
        transition: all 0.2s ease;
        font-size: 15px;
        border-right: 3px solid transparent;
    }

        .dropdown-item:hover {
            background: rgba(67, 97, 238, 0.08);
            border-right-color: var(--primary);
            padding-right: 30px;
        }

        .dropdown-item i {
            width: 24px;
            font-size: 18px;
            color: var(--primary);
            text-align: center;
        }

    .dropdown-divider {
        height: 1px;
        background: rgba(0,0,0,0.08);
        margin: 8px 15px;
    }

    body.dark-mode .dropdown-divider {
        background: rgba(255,255,255,0.1);
    }

    .dropdown-badge {
        margin-right: auto;
        background: rgba(67, 97, 238, 0.1);
        color: var(--primary);
        padding: 3px 10px;
        border-radius: 30px;
        font-size: 12px;
        font-weight: 600;
    }

    /* ===== بطاقات الإحصائيات (بدون أرقام) ===== */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: var(--white);
        border-radius: 16px;
        padding: 25px;
        box-shadow: var(--shadow-md);
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 20px;
        cursor: pointer;
        border: 1px solid rgba(0,0,0,0.03);
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg);
        }

    .stat-icon {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        color: white;
    }

        .stat-icon.primary {
            background: var(--gradient-1);
        }

        .stat-icon.success {
            background: var(--gradient-4);
        }

        .stat-icon.warning {
            background: var(--gradient-5);
        }

        .stat-icon.info {
            background: var(--gradient-3);
        }

    .stat-content {
        flex: 1;
    }

    .stat-label {
        font-size: 16px;
        font-weight: 600;
        color: var(--dark);
        margin: 0 0 5px 0;
    }

    .stat-desc {
        font-size: 13px;
        color: var(--secondary);
        margin: 0;
    }

    /* ===== شبكة الأزرار ===== */
    .buttons-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .card {
        background: var(--white);
        border-radius: 16px;
        padding: 30px 20px;
        text-decoration: none;
        color: var(--dark);
        box-shadow: var(--shadow-md);
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        border: 1px solid rgba(0,0,0,0.03);
        position: relative;
        overflow: hidden;
    }

        .card:hover {
            transform: translateY(-8px);
            box-shadow: var(--shadow-lg);
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--gradient-1);
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }

        .card:hover::before {
            transform: scaleX(1);
        }

    .card-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 36px;
        color: white;
        margin-bottom: 20px;
        transition: all 0.3s ease;
    }

    .card:hover .card-icon {
        transform: scale(1.1) rotate(5deg);
    }

    .card h3 {
        font-size: 20px;
        font-weight: 600;
        margin: 0 0 10px 0;
        color: var(--dark);
    }

    .card p {
        font-size: 14px;
        color: var(--secondary);
        margin: 0;
        line-height: 1.5;
        opacity: 0.9;
    }

    /* ألوان البطاقات */
    .card:nth-child(1) .card-icon {
        background: var(--gradient-1);
    }

    .card:nth-child(2) .card-icon {
        background: var(--gradient-2);
    }

    .card:nth-child(3) .card-icon {
        background: var(--gradient-3);
    }

    .card:nth-child(4) .card-icon {
        background: var(--gradient-4);
    }

    .card:nth-child(5) .card-icon {
        background: var(--gradient-5);
    }

    .card:nth-child(6) .card-icon {
        background: var(--gradient-1);
    }

    .card:nth-child(7) .card-icon {
        background: var(--gradient-2);
    }

    .card:nth-child(8) .card-icon {
        background: var(--gradient-3);
    }

    .card:nth-child(9) .card-icon {
        background: var(--gradient-4);
    }

    .card:nth-child(10) .card-icon {
        background: var(--gradient-5);
    }

    .card:nth-child(11) .card-icon {
        background: var(--gradient-1);
    }

    .card:nth-child(12) .card-icon {
        background: var(--gradient-2);
    }

    .card:nth-child(13) .card-icon {
        background: var(--gradient-3);
    }

    .card:nth-child(14) .card-icon {
        background: var(--gradient-4);
    }

    .card:nth-child(15) .card-icon {
        background: var(--gradient-5);
    }

    /* ===== زر تسجيل الخروج ===== */
    .logout-section {
        display: flex;
        justify-content: center;
        margin-top: 30px;
    }

    .logout-btn {
        background: linear-gradient(135deg, #dc3545, #c82333);
        color: white;
        border: none;
        padding: 15px 45px;
        border-radius: 50px;
        font-size: 18px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 12px;
        box-shadow: var(--shadow-lg);
    }

        .logout-btn:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg);
            opacity: 0.9;
        }

    /* ===== تحسينات وضع الهاتف ===== */
    body.mobile-view .stats-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
    }

    body.mobile-view .stat-card {
        padding: 20px;
    }

    body.mobile-view .stat-icon {
        width: 50px;
        height: 50px;
        font-size: 24px;
    }

    body.mobile-view .stat-label {
        font-size: 14px;
    }

    body.mobile-view .buttons-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
    }

    body.mobile-view .card {
        padding: 20px 15px;
    }

    body.mobile-view .card-icon {
        width: 60px;
        height: 60px;
        font-size: 28px;
    }

    body.mobile-view .card h3 {
        font-size: 16px;
    }

    body.mobile-view .card p {
        font-size: 12px;
    }

    body.mobile-view .welcome-text h1 {
        font-size: 22px;
    }

    body.mobile-view .header-actions {
        width: 100%;
        justify-content: space-between;
    }

    body.mobile-view .date-badge {
        padding: 8px 16px;
    }

        body.mobile-view .date-badge span {
            font-size: 12px;
        }

    body.mobile-view .dropdown-btn {
        padding: 10px 20px;
        font-size: 14px;
    }

    body.mobile-view .dropdown-menu {
        left: auto;
        right: 0;
        min-width: 280px;
    }

    /* أنيميشن بسيط */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .welcome-card,
    .stat-card,
    .card {
        animation: fadeInUp 0.5s ease-out forwards;
    }

        .stat-card:nth-child(2) {
            animation-delay: 0.1s;
        }

        .stat-card:nth-child(3) {
            animation-delay: 0.15s;
        }

        .stat-card:nth-child(4) {
            animation-delay: 0.2s;
        }
</style>

<div class="container-fluid">
    <!-- بطاقة الترحيب مع القائمة المنسدلة -->
    <div class="welcome-card">
        <div class="welcome-content">
            <div class="welcome-text">
                <h1>👋 مرحباً، @username</h1>
                <p>مركز إدارة Mobile Shop </p>
            </div>
            <div class="header-actions">
                <div class="date-badge">
                    <i class="bi bi-calendar-check"></i>
                    <span>@DateTime.Now.ToString("dd MMMM yyyy")</span>
                    <i class="bi bi-clock"></i>
                    <span>@DateTime.Now.ToString("hh:mm tt")</span>
                </div>

                <!-- القائمة المنسدلة المتطورة -->
                <div class="dropdown-container">
                    <button class="dropdown-btn" onclick="toggleDropdown()" id="dropdownButton">
                        <i class="bi bi-grid-3x3-gap-fill"></i>
                        <span>القائمة السريعة</span>
                        <i class="bi bi-chevron-down"></i>
                    </button>
                    <div class="dropdown-menu" id="quickMenu">
                        <div class="dropdown-header">
                            <i class="bi bi-star-fill" style="color: #ffc107;"></i> الرئيسية
                        </div>
                        <a href="/Sales/Index" class="dropdown-item">
                            <i class="bi bi-cash-register"></i>
                            <span>نقطة البيع</span>
                            <span class="dropdown-badge">@todaySales.Count</span>
                        </a>
                        <a href="/Repair/Index" class="dropdown-item">
                            <i class="bi bi-tools"></i>
                            <span>أجهزة الصيانة</span>
                            <span class="dropdown-badge">@repairDevices.Count</span>
                        </a>
                        <a href="/Customers/Index" class="dropdown-item">
                            <i class="bi bi-people"></i>
                            <span>العملاء والديون</span>
                            <span class="dropdown-badge">@activeCustomers.Count</span>
                        </a>
                        <a href="/ShopRequest/Index" class="dropdown-item">
                            <i class="bi bi-cart"></i>
                            <span>طلبات المحل</span>
                            <span class="dropdown-badge">@todayRequests.Count</span>
                        </a>

                        <div class="dropdown-divider"></div>
                        <div class="dropdown-header">
                            <i class="bi bi-box-seam"></i> المخزون
                        </div>
                        <a href="/Products/ViewAll" class="dropdown-item">
                            <i class="bi bi-boxes"></i>
                            <span>عرض المنتجات</span>
                        </a>
                        <a href="/QuickCodes/Index" class="dropdown-item">
                            <i class="bi bi-qr-code"></i>
                            <span>الأكواد السريعة</span>
                        </a>
                        <a href="/Devices/Inquiry" class="dropdown-item">
                            <i class="bi bi-search"></i>
                            <span>استعلام الأجهزة</span>
                        </a>
                        <a href="/DailyClosing/Today" class="dropdown-item">
                            <i class="bi bi-calendar-check"></i>
                            <span>تقفيل اليوم</span>
                        </a>

                        @if (isAdmin)
                        {
                            <div class="dropdown-divider"></div>
                            <div class="dropdown-header">
                                <i class="bi bi-gear-fill"></i> إدارة النظام
                            </div>
                            <a href="/Employees/Index" class="dropdown-item">
                                <i class="bi bi-people-fill"></i>
                                <span>إدارة الموظفين</span>
                            </a>
                            <a href="/Sales/DailyReports" class="dropdown-item">
                                <i class="bi bi-graph-up"></i>
                                <span>تقارير المبيعات</span>
                            </a>
                            <a href="/Products/Index" class="dropdown-item">
                                <i class="bi bi-pencil-square"></i>
                                <span>إدارة المنتجات</span>
                            </a>
                            <a href="/Settings/Index" class="dropdown-item">
                                <i class="bi bi-gear"></i>
                                <span>الإعدادات</span>
                            </a>
                            <a href="/Devices/Index" class="dropdown-item">
                                <i class="bi bi-phone"></i>
                                <span>إدارة الأجهزة</span>
                            </a>
                            <a href="/DailyClosing/Index" class="dropdown-item">
                                <i class="bi bi-calculator"></i>
                                <span>إدارة التقفيل</span>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- بطاقات الإحصائيات (بدون أرقام) -->
    <div class="stats-grid">
        <div class="stat-card" onclick="window.location.href='/Sales/Index'">
            <div class="stat-icon primary">
                <i class="bi bi-cash-stack"></i>
            </div>
            <div class="stat-content">
                <h3 class="stat-label">مبيعات اليوم</h3>
                <p class="stat-desc">آخر تحديث منذ دقيقة</p>
            </div>
        </div>

        <div class="stat-card" onclick="window.location.href='/Repair/Index'">
            <div class="stat-icon success">
                <i class="bi bi-tools"></i>
            </div>
            <div class="stat-content">
                <h3 class="stat-label">أجهزة الصيانة</h3>
                <p class="stat-desc">قيد العمل والإصلاح</p>
            </div>
        </div>

        <div class="stat-card" onclick="window.location.href='/Customers/Index'">
            <div class="stat-icon warning">
                <i class="bi bi-people"></i>
            </div>
            <div class="stat-content">
                <h3 class="stat-label">العملاء</h3>
                <p class="stat-desc">حسابات ومتابعة</p>
            </div>
        </div>

        <div class="stat-card" onclick="window.location.href='/ShopRequest/Index'">
            <div class="stat-icon info">
                <i class="bi bi-cart"></i>
            </div>
            <div class="stat-content">
                <h3 class="stat-label">طلبات المحل</h3>
                <p class="stat-desc">شواحن واسكرينات</p>
            </div>
        </div>
    </div>

    <!-- شبكة الأزرار الرئيسية (بدون أرقام) -->
    <div class="buttons-grid">
        <!-- نقطة البيع -->
        <a href="/Sales/Index" class="card">
            <div class="card-icon">
                <i class="bi bi-cash-register"></i>
            </div>
            <h3>💰 نقطة البيع</h3>
            <p>إتمام عمليات البيع وإدارة الفواتير</p>
        </a>

        <!-- أجهزة الصيانة -->
        <a href="/Repair/Index" class="card">
            <div class="card-icon">
                <i class="bi bi-tools"></i>
            </div>
            <h3>🔧 الصيانة</h3>
            <p>إدارة أجهزة الصيانة والإصلاح</p>
        </a>

        <!-- العملاء -->
        <a href="/Customers/Index" class="card">
            <div class="card-icon">
                <i class="bi bi-people"></i>
            </div>
            <h3>👥 العملاء</h3>
            <p>إدارة حسابات العملاء والديون</p>
        </a>

        <!-- طلبات المحل -->
        <a href="/ShopRequest/Index" class="card">
            <div class="card-icon">
                <i class="bi bi-cart"></i>
            </div>
            <h3>📦 الطلبات</h3>
            <p>طلبات الشواحن والاسكرينات</p>
        </a>

        <!-- الأكواد السريعة -->
        <a href="/QuickCodes/Index" class="card">
            <div class="card-icon">
                <i class="bi bi-qr-code"></i>
            </div>
            <h3>⚡ الأكواد</h3>
            <p>أكواد البيع السريع</p>
        </a>

        <!-- المنتجات -->
