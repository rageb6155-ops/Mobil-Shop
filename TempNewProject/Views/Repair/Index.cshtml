                function closeInvoiceModal() {
                    document.getElementById('invoiceModal').style.display = 'none';
                }

                // ===== دوال التعديل والحذف =====
                function editDevice(id) {
                    fetch(`/Repair/GetDeviceDetails?id=${id}`).then(res => res.json()).then(data => {
                        if (data.success) {
                            const d = data.device;
                            document.getElementById('deviceModalTitle').innerText = 'تعديل بيانات الجهاز';
                            document.getElementById('deviceId').value = id;
                            document.getElementById('customerName').value = d.customerName;
                            document.getElementById('customerPhone').value = d.customerPhone;
                            document.getElementById('deviceType').value = d.deviceType || '';
                            document.getElementById('deviceBrand').value = d.deviceBrand || '';
                            document.getElementById('deviceModel').value = d.deviceModel || '';
                            document.getElementById('deviceSerial').value = d.deviceSerial || '';
                            document.getElementById('deviceColor').value = d.deviceColor || '';
                            document.getElementById('devicePassword').value = d.devicePassword || '';
                            document.getElementById('deviceAccessories').value = d.deviceAccessories || '';
                            document.getElementById('technicianName').value = d.technicianName || '';
                            document.getElementById('reportedIssue').value = d.reportedIssue;
                            document.getElementById('technicianNotes').value = d.technicianNotes || '';
                            document.getElementById('estimatedCost').value = d.estimatedCost || '';
                            document.getElementById('advancePayment').value = d.advancePayment || 0;
                            document.getElementById('promisedDate').value = d.promisedDate ? new Date(d.promisedDate).toISOString().slice(0, 16) : '';
                            document.getElementById('isWarranty').value = d.isWarranty ? 'true' : 'false';
                            document.getElementById('warrantyDetails').value = d.warrantyDetails || '';
                            document.getElementById('notes').value = d.notes || '';
                            document.getElementById('warrantyDetailsGroup').style.display = d.isWarranty ? 'block' : 'none';
                            document.getElementById('deviceModal').style.display = 'block';
                        }
                    });
                }

                function editCurrentDevice() {
                    closeDetailsModal();
                    editDevice(currentDeviceId);
                }

                function deleteDevice(id) {
                    if (confirm('هل أنت متأكد من حذف هذا الجهاز؟')) {
                        fetch(`/Repair/SoftDeleteDevice?id=${id}`, { method: 'POST' })
                            .then(res => res.json())
                            .then(data => {
                                if (data.success) {
                                    alert('✅ ' + data.message);
                                    loadDevices();
                                    loadDashboardStats();
                                    closeDetailsModal();
                                } else {
                                    alert('❌ ' + data.message);
                                }
                            });
                    }
                }

                function deleteCurrentDevice() {
                    if (currentDevice) {
                        deleteDevice(currentDeviceId);
                    }
                }

                function hardDeleteDevice(id) {
                    if (confirm('⚠️ تحذير شديد! هذا الإجراء لا يمكن التراجع عنه. هل أنت متأكد من الحذف النهائي؟')) {
                        if (confirm('❓❓ تأكيد نهائي: هل أنت متأكد تماماً؟')) {
                            fetch(`/Repair/HardDeleteDevice?id=${id}`, { method: 'POST' })
                                .then(res => res.json())
                                .then(data => {
                                    if (data.success) {
                                        alert('✅ ' + data.message);
                                        loadDevices();
                                        loadDashboardStats();
                                        closeDetailsModal();
                                    } else {
                                        alert('❌ ' + data.message);
