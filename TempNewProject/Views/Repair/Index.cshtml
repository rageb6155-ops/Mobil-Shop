                // ===== دوال الطباعة (PDF) =====
                function printDevicePDF(deviceId) {
                    fetch(`/Repair/GenerateDevicePDF?id=${deviceId}`)
                        .then(res => res.json())
                        .then(data => {
                            if (data.success && data.html) {
                                const printWindow = window.open('', '_blank');
                                printWindow.document.write(data.html);
                                printWindow.document.close();
                                printWindow.focus();
                                printWindow.print();
                            } else {
                                alert('❌ فشل في تحميل بيانات الجهاز');
                            }
                        });
                }

                function printAllDevicesPDF() {
                    const status = currentStatus === 'all' ? 'all' : currentStatus;
                    fetch(`/Repair/GenerateAllDevicesPDF?status=${status}&showDeleted=${showDeleted}`)
                        .then(res => res.json())
                        .then(data => {
                            if (data.success && data.html) {
                                const printWindow = window.open('', '_blank');
                                printWindow.document.write(data.html);
                                printWindow.document.close();
                                printWindow.focus();
                                printWindow.print();
                            } else {
                                alert('❌ فشل في تحميل التقرير');
                            }
                        });
                }

                function printInvoice(deviceId) {
                    fetch(`/Repair/GetDeviceDetails?id=${deviceId}`)
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                const d = data.device;
                                const now = new Date();

                                let invoiceHtml = `
                                    <div class="invoice-row"><span>رقم الفاتورة:</span><span>INV-${d.deviceCode}</span></div>
                                    <div class="invoice-row"><span>التاريخ:</span><span>${now.toLocaleDateString('ar-EG')} ${now.toLocaleTimeString('ar-EG')}</span></div>
                                    <div class="invoice-row"><span>العميل:</span><span>${d.customerName}</span></div>
                                    <div class="invoice-row"><span>رقم الهاتف:</span><span>${d.customerPhone}</span></div>
                                    <div class="invoice-row"><span>الجهاز:</span><span>${d.deviceBrand} ${d.deviceModel}</span></div>
                                    <div class="invoice-row"><span>السيريال:</span><span>${d.deviceSerial || '---'}</span></div>
                                    <div class="invoice-row"><span>المهندس:</span><span>${d.technicianName || 'غير معين'}</span></div>
                                    <div class="invoice-row"><span>العيب:</span><span>${d.reportedIssue}</span></div>
                                    <div class="invoice-row" style="border-top: 2px solid #333; margin-top: 10px; padding-top: 10px;">
                                        <span class="fw-bold">التكلفة التقديرية:</span><span>${d.estimatedCost ? d.estimatedCost.toLocaleString() + ' ج.م' : 'لم تحدد'}</span>
                                    </div>
                                    ${d.finalCost ? `<div class="invoice-row"><span class="fw-bold">التكلفة النهائية:</span><span>${d.finalCost.toLocaleString()} ج.م</span></div>` : ''}
                                    <div class="invoice-row"><span class="fw-bold">المدفوع:</span><span>${d.advancePayment.toLocaleString()} ج.م</span></div>
                                    <div class="invoice-row invoice-total"><span>المتبقي:</span><span>${d.remainingAmount.toLocaleString()} ج.م</span></div>
                                    <div style="text-align: center; margin-top: 20px; font-size: 12px; color: #666;">
                                        <div>شكراً لتعاملكم معنا 🌟</div>
                                    </div>
                                `;

                                document.getElementById('invoiceDetails').innerHTML = invoiceHtml;
                                document.getElementById('invoiceModal').style.display = 'block';

