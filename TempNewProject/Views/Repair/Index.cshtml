                function closeDeviceModal() {
                    document.getElementById('deviceModal').style.display = 'none';
                }

                function saveDevice() {
                    const id = document.getElementById('deviceId').value;
                    const data = {
                        customerName: document.getElementById('customerName').value,
                        customerPhone: document.getElementById('customerPhone').value,
                        deviceType: document.getElementById('deviceType').value,
                        deviceBrand: document.getElementById('deviceBrand').value,
                        deviceModel: document.getElementById('deviceModel').value,
                        deviceSerial: document.getElementById('deviceSerial').value,
                        deviceColor: document.getElementById('deviceColor').value,
                        devicePassword: document.getElementById('devicePassword').value,
                        deviceAccessories: document.getElementById('deviceAccessories').value,
                        technicianName: document.getElementById('technicianName').value,
                        reportedIssue: document.getElementById('reportedIssue').value,
                        technicianNotes: document.getElementById('technicianNotes').value,
                        estimatedCost: document.getElementById('estimatedCost').value ? parseFloat(document.getElementById('estimatedCost').value) : null,
                        advancePayment: parseFloat(document.getElementById('advancePayment').value) || 0,
                        promisedDate: document.getElementById('promisedDate').value || null,
                        isWarranty: document.getElementById('isWarranty').value === 'true',
                        warrantyDetails: document.getElementById('warrantyDetails').value,
                        notes: document.getElementById('notes').value
                    };

                    if (!data.customerName) {
                        alert('❌ الرجاء إدخال اسم العميل');
                        return;
                    }
                    if (!data.customerPhone) {
                        alert('❌ الرجاء إدخال رقم الهاتف');
                        return;
                    }
                    if (!data.reportedIssue) {
                        alert('❌ الرجاء إدخال العيب المشتكى منه');
                        return;
                    }

                    const url = id === '0' ? '/Repair/AddDevice' : '/Repair/UpdateDevice';

                    fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            alert('✅ ' + data.message);
                            closeDeviceModal();
                            loadDevices();
                            loadDashboardStats();
                            if (id === '0' && data.deviceId) {
                                setTimeout(() => printInvoice(data.deviceId), 1000);
                            }
                        } else {
                            alert('❌ ' + data.message);
                        }
                    })
                    .catch(err => {
                        alert('❌ حدث خطأ: ' + err.message);
                    });
                }

                // ===== دوال استعادة الجهاز =====
                function restoreDevice(id) {
                    if (confirm('هل أنت متأكد من استعادة هذا الجهاز؟')) {
                        fetch(`/Repair/RestoreDevice?id=${id}`, { method: 'POST' })
                            .then(res => res.json())
                            .then(data => {
                                if (data.success) {
                                    alert('✅ ' + data.message);
                                    loadDevices();
                                    closeDetailsModal();
                                } else {
                                    alert('❌ ' + data.message);
                                }
                            });
                    }
                }

