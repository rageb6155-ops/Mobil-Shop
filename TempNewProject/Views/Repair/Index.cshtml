                }

                function displayCustomerHistory(history) {
                    const content = document.getElementById('customerHistoryContent');
                    const firstDate = new Date(history.firstRepair).toLocaleDateString('ar-EG');
                    const lastDate = new Date(history.lastRepair).toLocaleDateString('ar-EG');

                    let html = `
                        <div class="summary-box" style="margin-top: 0;">
                            <div class="summary-item">
                                <div class="summary-value">${history.totalDevices}</div>
                                <div class="summary-label">إجمالي الأجهزة</div>
                            </div>
                            <div class="summary-item">
                                <div class="summary-value">${history.totalSpent.toLocaleString()} ج.م</div>
                                <div class="summary-label">إجمالي المنفق</div>
                            </div>
                            <div class="summary-item">
                                <div class="summary-value">${firstDate}</div>
                                <div class="summary-label">أول صيانة</div>
                            </div>
                            <div class="summary-item">
                                <div class="summary-value">${lastDate}</div>
                                <div class="summary-label">آخر صيانة</div>
                            </div>
                        </div>
                        <div class="devices-grid" style="max-height: 500px;">
                    `;

                    history.devices.forEach(d => {
                        html += `
                            <div class="device-card" onclick="showDeviceDetails(${d.id})">
                                <div class="device-header">
                                    <span class="device-name">${d.deviceBrand} ${d.deviceModel}</span>
                                    <span class="device-code">${d.deviceCode}</span>
                                </div>
                                <div class="device-issue">${d.reportedIssue}</div>
                                <div class="device-cost">
                                    <span>💰 ${d.finalCost ? d.finalCost.toLocaleString() : d.estimatedCost ? d.estimatedCost.toLocaleString() : 'لم تحدد'} ج.م</span>
                                </div>
                                <div class="device-footer">
                                    <span class="device-status-badge ${getStatusBadgeClass(d.status)}">${d.status}</span>
                                    <span class="device-date">${new Date(d.receivedDate).toLocaleDateString('ar-EG')}</span>
                                </div>
                            </div>
                        `;
                    });

                    html += '</div>';
                    content.innerHTML = html;
                }

                function closeCustomerHistoryModal() {
                    document.getElementById('customerHistoryModal').style.display = 'none';
                }

                function changeDeviceStatus(status) {
                    let finalCost = null;
                    let advancePayment = null;
                    let notes = prompt('ملاحظات (اختياري):', '');

                    if (status === 'تم الاصلاح') {
                        finalCost = parseFloat(prompt('التكلفة النهائية:', currentDevice?.finalCost || currentDevice?.estimatedCost || ''));
                        if (isNaN(finalCost) || finalCost <= 0) {
                            alert('❌ الرجاء إدخال تكلفة صحيحة');
                            return;
                        }
                    }

                    if (status === 'تم التسليم') {
                        const remaining = currentDevice?.remainingAmount || 0;
                        if (remaining > 0) {
                            advancePayment = parseFloat(prompt(`المبلغ المتبقي: ${remaining.toLocaleString()} ج.م\nالمبلغ المدفوع الآن:`, remaining));
                            if (isNaN(advancePayment) || advancePayment < 0) {
                                alert('❌ الرجاء إدخال مبلغ صحيح');
                                return;
                            }
                        }
                    }

                    const data = {
                        id: currentDeviceId,
                        status: status,
                        finalCost: finalCost,
                        advancePayment: advancePayment,
                        notes: notes,
                        sendWhatsApp: false
                    };

                    fetch('/Repair/ChangeStatus', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            alert('✅ ' + data.message);
                            showDeviceDetails(currentDeviceId);
                            loadDevices();
                            loadDashboardStats();
                            setTimeout(() => printInvoice(currentDeviceId), 1000);
                        } else {
                            alert('❌ ' + data.message);
                        }
                    });
                }

                function getStatusBadgeClass(status) {
                    const classes = {
                        'مستلم': 'badge-info',
                        'قيد الصيانة': 'badge-warning',
                        'بانتظار قطع غيار': 'badge-danger',
                        'تم الاصلاح': 'badge-success',
                        'تم التسليم': 'badge-secondary'
                    };
                    return classes[status] || 'badge-secondary';
                }

                function getStatusIcon(status) {
                    const icons = {
                        'مستلم': 'fa-box-open',
                        'قيد الصيانة': 'fa-tools',
                        'بانتظار قطع غيار': 'fa-clock',
                        'تم الاصلاح': 'fa-check-circle',
                        'تم التسليم': 'fa-check-double'
                    };
                    return icons[status] || 'fa-question';
                }

                function initDropzone() {
                    if (document.getElementById('imageDropzone')) {
                        myDropzone = new Dropzone('#imageDropzone', {
                            url: '/Repair/UploadImage',
                            paramName: 'image',
                            maxFilesize: 5,
                            acceptedFiles: 'image/*',
                            dictDefaultMessage: 'اسحب وأفلت الصور هنا أو انقر للرفع',
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            },
                            init: function() {
                                this.on('sending', function(file, xhr, formData) {
                                    formData.append('deviceId', currentDeviceId);
                                    formData.append('imageType', 'صورة');
                                });
                                this.on('success', function(file, response) {
                                    if (response.success) {
                                        showDeviceDetails(currentDeviceId);
                                    } else {
                                        alert('❌ ' + response.message);
                                    }
                                });
                                this.on('error', function(file, errorMessage) {
                                    alert('❌ ' + errorMessage);
                                });
                            }
                        });
                    }
                }

                // دوال طباعة التقارير
                function printPerformanceReportPDF() {
                    const reportData = document.getElementById('performanceData').innerHTML;
                    if (reportData.includes('لا توجد بيانات')) {
                        alert('لا توجد بيانات للطباعة');
                        return;
                    }

                    const printContainer = document.createElement('div');
                    printContainer.className = 'print-80mm';
                    printContainer.innerHTML = `
                        <div class="header">
                            <div class="title">📱 Mobile Shop</div>
                            <div>تقرير أداء الفنيين</div>
                            <div>${new Date().toLocaleDateString('ar-EG')}</div>
                        </div>
                        ${reportData}
                        <div class="footer">
                            <div>شكراً لتعاملكم معنا 🌟</div>
                        </div>
                    `;

                    document.body.appendChild(printContainer);

                    html2canvas(printContainer, {
                        scale: 2,
                        backgroundColor: '#ffffff',
                        logging: false
                    }).then(canvas => {
                        try {
                            const { jsPDF } = window.jspdf;

                            const imgWidth = 80;
                            const imgHeight = (canvas.height * imgWidth) / canvas.width;

                            const pdf = new jsPDF({
                                orientation: 'portrait',
                                unit: 'mm',
                                format: [imgWidth, imgHeight]
                            });

                            const imgData = canvas.toDataURL('image/png');
                            pdf.addImage(imgData, 'PNG', 0, 0, imgWidth, imgHeight, undefined, 'FAST');

                            pdf.save(`تقرير_اداء_الفنيين.pdf`);
                        } finally {
                            if (printContainer.parentNode) {
                                document.body.removeChild(printContainer);
                            }
                        }
                    });
                }

