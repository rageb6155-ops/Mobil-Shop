                    if (!report || report.length === 0) {
                        document.getElementById('revenueData').innerHTML =
                            '<p class="text-center text-muted">لا توجد بيانات في هذه الفترة</p>';
                        return;
                    }

                    let html = '<table class="report-table"><thead><tr><th>الفترة</th><th>عدد الأجهزة</th><th>الإيرادات</th><th>المصروفات</th><th>الأرباح</th></tr></thead><tbody>';

                    report.forEach(r => {
                        html += `
                            <tr>
                                <td>${new Date(r.date).toLocaleDateString('ar-EG')}</td>
                                <td>${r.devicesCount}</td>
                                <td class="text-primary">${r.revenue.toLocaleString()} ج.م</td>
                                <td class="text-danger">${r.expenses.toLocaleString()} ج.م</td>
