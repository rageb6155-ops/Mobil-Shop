@{
    var username = Context.Session.GetString("Username");
    var today = DateTime.Now;
    var dayName = today.ToString("dddd", new System.Globalization.CultureInfo("ar-EG"));
    ViewData["Title"] = "إدارة أجهزة الصيانة";
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/dropzone/5.9.3/dropzone.min.css" />
    <!-- إضافة مكتبات PDF -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        /* ===== المتغيرات العامة ===== */
        :root {
            --primary-color: #4361ee;
            --success-color: #28a745;
            --warning-color: #ffc107;
            --danger-color: #dc3545;
            --info-color: #17a2b8;
            --dark-color: #343a40;
            --light-color: #f8f9fa;
            --whatsapp-color: #25D366;
            --restore-color: #f39c12;
        }

        /* ===== تنسيقات الصفحة الأساسية ===== */
        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: #f4f6f9;
            margin: 0;
            padding: 20px;
        }

        .page-wrapper {
            max-width: 1400px;
            margin: 0 auto;
        }

        /* ===== تنسيق الهيدر ===== */
        .header-card {
            background: white;
            border-radius: 16px;
            padding: 20px 25px;
            margin-bottom: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .header-title h1 {
            margin: 0;
            font-size: 26px;
            font-weight: 600;
            color: var(--primary-color);
        }

        .header-title p {
            margin: 5px 0 0;
            color: #6c757d;
            font-size: 14px;
        }

        .user-info {
            background: var(--light-color);
            color: var(--primary-color);
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 500;
            border: 1px solid #e9ecef;
        }

        /* ===== تنسيق الإحصائيات ===== */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 15px;
            margin: 20px 0;
        }

        .stat-card {
            background: white;
            border-radius: 12px;
            padding: 15px;
            border: 1px solid #e9ecef;
            border-right: 4px solid var(--primary-color);
            transition: all 0.3s;
        }

            .stat-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            }

        .stat-value {
            font-size: 24px;
            font-weight: bold;
            color: #333;
        }

        .stat-label {
            font-size: 12px;
            color: #6c757d;
        }

        .stat-card.warning {
            border-right-color: var(--warning-color);
        }

        .stat-card.danger {
            border-right-color: var(--danger-color);
        }

        .stat-card.success {
            border-right-color: var(--success-color);
        }

        .stat-card.info {
            border-right-color: var(--info-color);
        }

        /* ===== تنسيق البطاقة الرئيسية ===== */
        .main-card {
            background: white;
            border-radius: 16px;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
            flex: 1;
            margin-bottom: 20px;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid #f0f0f0;
            flex-wrap: wrap;
            gap: 15px;
        }

            .card-header h2 {
                margin: 0;
                color: var(--primary-color);
                font-weight: 600;
                font-size: 22px;
            }

        /* ===== تنسيق البحث الفوري المحسن ===== */
        .search-card {
            background: white;
            border-radius: 16px;
            padding: 20px 25px;
            margin-bottom: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
        }

        .search-label {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 15px;
            color: #333;
            font-weight: 500;
        }

            .search-label i {
                color: var(--primary-color);
                font-size: 20px;
            }

        .search-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .search-icon {
            position: absolute;
            right: 15px;
            color: #adb5bd;
            font-size: 18px;
        }

        .clear-search {
            position: absolute;
            left: 15px;
            color: #adb5bd;
            cursor: pointer;
            font-size: 18px;
            transition: color 0.3s;
            display: none;
        }

            .clear-search:hover {
                color: #dc3545;
            }

        .search-input {
            width: 100%;
            padding: 12px 50px;
            border: 2px solid #e9ecef;
            border-radius: 50px;
            font-size: 15px;
            transition: all 0.3s;
            background: #f8f9fa;
        }

            .search-input:focus {
                outline: none;
                border-color: var(--primary-color);
                background: white;
                box-shadow: 0 5px 20px rgba(67, 97, 238, 0.1);
            }

                .search-input:focus + .clear-search {
                    display: block;
                }

        .search-stats {
            margin-top: 10px;
            font-size: 13px;
            color: #6c757d;
            text-align: left;
        }

        /* ===== تنسيق الأزرار ===== */
        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary {
            background: var(--primary-color);
            color: white;
        }

            .btn-primary:hover {
                background: #3f37c9;
                transform: translateY(-2px);
            }

        .btn-success {
            background: var(--success-color);
            color: white;
        }

            .btn-success:hover {
                background: #218838;
                transform: translateY(-2px);
            }

        .btn-warning {
            background: var(--warning-color);
            color: #333;
        }

            .btn-warning:hover {
                background: #e0a800;
                transform: translateY(-2px);
            }

        .btn-danger {
            background: var(--danger-color);
            color: white;
        }

            .btn-danger:hover {
                background: #c82333;
                transform: translateY(-2px);
            }

        .btn-info {
            background: var(--info-color);
            color: white;
        }

            .btn-info:hover {
                background: #138496;
                transform: translateY(-2px);
            }

        .btn-secondary {
            background: #6c757d;
            color: white;
        }

            .btn-secondary:hover {
                background: #5a6268;
                transform: translateY(-2px);
            }

        .btn-danger-hard {
            background: #7b1e1e;
            color: white;
        }

            .btn-danger-hard:hover {
                background: #5a1515;
                transform: translateY(-2px);
            }

        .btn-purple {
            background: #6f42c1;
            color: white;
        }

            .btn-purple:hover {
                background: #5e35b1;
                transform: translateY(-2px);
            }

        .btn-whatsapp {
            background: var(--whatsapp-color);
            color: white;
        }

            .btn-whatsapp:hover {
                background: #128C7E;
                transform: translateY(-2px);
            }

        .btn-pdf {
            background: #d32f2f;
            color: white;
        }

            .btn-pdf:hover {
                background: #b71c1c;
                transform: translateY(-2px);
            }

        .btn-restore {
            background: var(--restore-color);
            color: white;
        }

            .btn-restore:hover {
                background: #e67e22;
                transform: translateY(-2px);
            }

        /* ===== تنسيق التبويبات الرئيسية ===== */
        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            border-bottom: 2px solid #f0f0f0;
            padding-bottom: 10px;
            flex-wrap: wrap;
        }

        .tab {
            padding: 8px 20px;
            border: none;
            background: none;
            border-radius: 8px 8px 0 0;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            color: #6c757d;
            transition: all 0.3s;
        }

            .tab:hover {
                color: var(--primary-color);
                background: #f0f4ff;
            }

            .tab.active {
                color: var(--primary-color);
                border-bottom: 3px solid var(--primary-color);
                background: #f0f4ff;
            }

        /* ===== تنسيق بطاقات الأجهزة ===== */
        .devices-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 20px;
            margin-top: 20px;
            max-height: 600px;
            overflow-y: auto;
            padding: 10px 5px;
        }

            .devices-grid::-webkit-scrollbar {
                width: 8px;
            }

            .devices-grid::-webkit-scrollbar-track {
                background: #f1f1f1;
                border-radius: 10px;
            }

            .devices-grid::-webkit-scrollbar-thumb {
                background: var(--primary-color);
                border-radius: 10px;
            }

                .devices-grid::-webkit-scrollbar-thumb:hover {
                    background: #3f37c9;
                }

        .device-card {
            background: white;
            border-radius: 12px;
            padding: 20px;
            border: 1px solid #e9ecef;
            transition: all 0.3s;
            cursor: pointer;
            position: relative;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }

            .device-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 8px 20px rgba(0,0,0,0.1);
            }

            .device-card.received {
                border-top: 4px solid var(--info-color);
            }

            .device-card.in-progress {
                border-top: 4px solid var(--warning-color);
            }

            .device-card.waiting-parts {
                border-top: 4px solid var(--danger-color);
            }

            .device-card.completed {
                border-top: 4px solid var(--success-color);
            }

            .device-card.delivered {
                border-top: 4px solid #6c757d;
            }

            .device-card.overdue {
                border-top: 4px solid #dc3545;
                background: #fff5f5;
            }

            .device-card.deleted {
                opacity: 0.7;
                background: #f8f9fa;
                border: 2px dashed #6c757d;
            }

        .device-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }

        .device-code {
            font-size: 12px;
            color: #6c757d;
            background: #e9ecef;
            padding: 4px 10px;
            border-radius: 20px;
            font-family: monospace;
        }

        .device-name {
            font-size: 16px;
            font-weight: bold;
            color: var(--primary-color);
        }

        .device-customer {
            font-size: 15px;
            color: #333;
            margin: 8px 0;
            font-weight: 500;
        }

        .device-phone {
            font-size: 14px;
            color: var(--success-color);
            margin: 5px 0;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .device-issue {
            font-size: 13px;
            color: var(--danger-color);
            margin: 10px 0;
            padding: 8px;
            background: #fff5f5;
            border-radius: 8px;
            border-right: 3px solid var(--danger-color);
        }

        .device-cost {
            font-size: 15px;
            font-weight: bold;
            color: var(--primary-color);
            margin: 10px 0;
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

            .device-cost span {
                background: #f0f4ff;
                padding: 4px 10px;
                border-radius: 20px;
                font-size: 13px;
            }

        .device-status-badge {
            display: inline-block;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }

        .badge-info {
            background: var(--info-color);
            color: white;
        }

        .badge-warning {
            background: var(--warning-color);
            color: #333;
        }

        .badge-danger {
            background: var(--danger-color);
            color: white;
        }

        .badge-success {
            background: var(--success-color);
            color: white;
        }

        .badge-secondary {
            background: #6c757d;
            color: white;
        }

        .badge-restore {
            background: var(--restore-color);
            color: white;
        }

        .device-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 15px;
            padding-top: 10px;
            border-top: 1px solid #e9ecef;
        }

        .device-date {
            font-size: 11px;
            color: #999;
        }

        .overdue-badge {
            background: var(--danger-color);
            color: white;
            padding: 3px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: bold;
            position: absolute;
            top: 10px;
            left: 10px;
        }

        .deleted-badge {
            background: #6c757d;
            color: white;
            padding: 3px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: bold;
            position: absolute;
            top: 10px;
            left: 10px;
        }

        /* ===== تنسيق المودالات ===== */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 9999;
            overflow-y: auto;
        }

        .modal-content {
            background: white;
            width: 90%;
            max-width: 800px;
            margin: 50px auto;
            border-radius: 20px;
            padding: 25px;
            max-height: 85vh;
            overflow-y: auto;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

        .modal-lg {
            max-width: 1100px;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid #f0f0f0;
            position: sticky;
            top: 0;
            background: white;
            z-index: 10;
        }

            .modal-header h3 {
                margin: 0;
                color: var(--primary-color);
                font-weight: 600;
            }

        .close-btn {
            background: #6c757d;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.3s;
        }

            .close-btn:hover {
                background: #5a6268;
            }

        /* ===== تنسيق النماذج ===== */
        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            color: #495057;
            font-size: 14px;
            font-weight: 500;
        }

        .form-control, .form-select {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e9ecef;
            border-radius: 10px;
            font-size: 14px;
            transition: all 0.3s;
        }

            .form-control:focus, .form-select:focus {
                outline: none;
                border-color: var(--primary-color);
                box-shadow: 0 0 0 3px rgba(67, 97, 238, 0.1);
            }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .form-row-3 {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 20px;
        }

        .form-row-4 {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr 1fr;
            gap: 15px;
        }

        /* ===== تنسيق الملخص السريع ===== */
        .summary-box {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 25px;
            display: flex;
            justify-content: space-around;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
            color: white;
        }

        .summary-item {
            text-align: center;
            min-width: 120px;
        }

        .summary-value {
            font-size: 28px;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .summary-label {
            font-size: 13px;
            opacity: 0.9;
        }

        /* ===== تنسيق سجل الحالات ===== */
        .history-list {
            max-height: 400px;
            overflow-y: auto;
            padding: 10px;
        }

        .history-item {
            background: var(--light-color);
            border-radius: 12px;
            padding: 15px;
            margin-bottom: 10px;
            border: 1px solid #e9ecef;
            transition: all 0.3s;
        }

            .history-item:hover {
                transform: translateX(-5px);
                box-shadow: 0 3px 10px rgba(0,0,0,0.1);
            }

        .history-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .history-status {
            font-weight: bold;
            font-size: 14px;
        }

        .history-time {
            font-size: 12px;
            color: #6c757d;
        }

        /* ===== تنسيق الصور ===== */
        .images-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 15px;
            margin-top: 15px;
        }

        .image-item {
            position: relative;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 3px 10px rgba(0,0,0,0.1);
        }

            .image-item img {
                width: 100%;
                height: 150px;
                object-fit: cover;
                transition: all 0.3s;
            }

            .image-item:hover img {
                transform: scale(1.1);
            }

        .image-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(0,0,0,0.7);
            color: white;
            padding: 8px;
            font-size: 11px;
            text-align: center;
        }

        /* ===== تنسيق قطع الغيار ===== */
        .parts-list {
            max-height: 300px;
            overflow-y: auto;
        }

        .part-item {
            background: var(--light-color);
            border-radius: 10px;
            padding: 12px;
            margin-bottom: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid #e9ecef;
        }

        .part-info {
            flex: 1;
        }

        .part-name {
            font-weight: bold;
            color: var(--primary-color);
        }

        .part-details {
            font-size: 12px;
            color: #666;
        }

        .low-stock {
            color: var(--danger-color);
            font-weight: bold;
            font-size: 12px;
        }

        /* ===== تنسيق الأقساط ===== */
        .installments-progress {
            background: var(--light-color);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 20px;
        }

        .progress {
            height: 10px;
            border-radius: 5px;
            margin: 10px 0;
        }

        .progress-bar {
            background: var(--success-color);
            border-radius: 5px;
        }

        .installment-item {
            background: white;
            border: 1px solid #e9ecef;
            border-radius: 10px;
            padding: 12px;
            margin-bottom: 10px;
        }

            .installment-item.paid {
                background: #d4edda;
                border-color: var(--success-color);
            }

            .installment-item.overdue {
                background: #f8d7da;
                border-color: var(--danger-color);
            }

        /* ===== تنسيق رفع الصور ===== */
        .dropzone {
            border: 2px dashed #e9ecef;
            border-radius: 10px;
            padding: 30px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            background: var(--light-color);
        }

            .dropzone:hover {
                border-color: var(--primary-color);
                background: #f0f4ff;
            }

            .dropzone i {
                font-size: 40px;
                color: var(--primary-color);
                margin-bottom: 10px;
            }

        /* ===== تنسيق الفاتورة ===== */
        .invoice-card {
            background: white;
            border-radius: 16px;
            padding: 30px;
            margin: 20px 0;
            border: 2px solid var(--primary-color);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .invoice-header {
            text-align: center;
            border-bottom: 2px dashed #eee;
            padding-bottom: 20px;
            margin-bottom: 20px;
        }

        .invoice-title {
            font-size: 24px;
            font-weight: bold;
            color: var(--primary-color);
        }

        .invoice-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #eee;
        }

        .invoice-total {
            font-size: 18px;
            font-weight: bold;
            color: var(--success-color);
        }

        /* ===== تنسيق سجل الواتساب ===== */
        .whatsapp-log-item {
            background: var(--light-color);
            border-radius: 10px;
            padding: 12px;
            margin-bottom: 8px;
            border: 1px solid #e9ecef;
        }

            .whatsapp-log-item.success {
                border-right: 4px solid var(--success-color);
            }

            .whatsapp-log-item.error {
                border-right: 4px solid var(--danger-color);
            }

        /* ===== تنسيق خاص لمودال الواتساب ===== */
        #whatsappMessageModal .modal-content {
            max-width: 600px;
        }

        #whatsappMessageModal textarea {
            background-color: #f8f9fa;
            border: 2px solid #e9ecef;
            border-radius: 10px;
            padding: 15px;
            font-size: 14px;
            line-height: 1.6;
            font-family: 'Segoe UI', Tahoma, sans-serif;
        }

            #whatsappMessageModal textarea:focus {
                border-color: var(--whatsapp-color);
                box-shadow: 0 0 0 3px rgba(37, 211, 102, 0.1);
                outline: none;
            }

        #customerInfo {
            background-color: #e8f5e9;
            border-right: 4px solid var(--whatsapp-color);
            padding: 10px 15px;
            border-radius: 8px;
            margin-bottom: 20px;
        }

        /* ===== تنسيق مودال الرسائل الجماعية المتقدم ===== */
        #bulkWhatsAppModal .modal-content {
            max-width: 900px;
        }

        .customers-selection {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin: 20px 0;
            max-height: 500px;
        }

        .customers-list {
            border: 1px solid #e9ecef;
            border-radius: 12px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .list-header {
            background: var(--primary-color);
            color: white;
            padding: 12px 15px;
            font-weight: 500;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .list-header i {
                cursor: pointer;
                opacity: 0.8;
                transition: opacity 0.3s;
            }

                .list-header i:hover {
                    opacity: 1;
                }

        .list-search {
            padding: 10px;
            border-bottom: 1px solid #e9ecef;
            position: relative;
        }

            .list-search input {
                width: 100%;
                padding: 8px 35px 8px 10px;
                border: 1px solid #e9ecef;
                border-radius: 20px;
                font-size: 13px;
            }

            .list-search i {
                position: absolute;
                right: 20px;
                top: 18px;
                color: #adb5bd;
                font-size: 14px;
            }

        .list-items {
            overflow-y: auto;
            flex: 1;
            max-height: 350px;
        }

        .customer-item {
            padding: 10px 15px;
            border-bottom: 1px solid #f0f0f0;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            transition: all 0.2s;
        }

            .customer-item:hover {
                background: #f0f4ff;
            }

            .customer-item.selected {
                background: #e3f2fd;
                border-right: 3px solid var(--primary-color);
            }

        .customer-checkbox {
            width: 18px;
            height: 18px;
            cursor: pointer;
        }

        .customer-info {
            flex: 1;
        }

        .customer-name {
            font-weight: 600;
            color: #333;
            font-size: 14px;
        }

        .customer-details {
            font-size: 11px;
            color: #666;
            margin-top: 2px;
            display: flex;
            gap: 10px;
        }

        .customer-phone {
            color: var(--success-color);
        }

        .selected-count {
            background: white;
            color: var(--primary-color);
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
        }

        .selection-actions {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
        }

        .message-preview {
            background: #f0f4ff;
            border-radius: 12px;
            padding: 15px;
            margin: 20px 0;
            border-right: 4px solid var(--whatsapp-color);
        }

            .message-preview h5 {
                margin: 0 0 10px 0;
                color: var(--primary-color);
                font-size: 14px;
            }

        .preview-content {
            background: white;
            padding: 12px;
            border-radius: 8px;
            font-size: 13px;
            line-height: 1.5;
            white-space: pre-wrap;
            max-height: 200px;
            overflow-y: auto;
        }

        /* ===== تنسيق التقارير ===== */
        .report-content {
            display: none;
            margin-top: 20px;
        }

            .report-content.active {
                display: block;
            }

        .report-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }

            .report-table th {
                background: var(--primary-color);
                color: white;
                padding: 10px;
                text-align: center;
            }

            .report-table td {
                padding: 8px 10px;
                border-bottom: 1px solid #e9ecef;
                text-align: center;
            }

            .report-table tr:hover {
                background: var(--light-color);
            }

        /* ===== تنسيق البحث عن العميل ===== */
        .customer-search-section {
            background: white;
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 25px;
            border: 1px solid #f0f0f0;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        }

        .search-filters {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            margin: 20px 0;
        }

        .search-filter-input {
            flex: 1;
            min-width: 250px;
            padding: 12px 15px;
            border: 2px solid #e9ecef;
            border-radius: 8px;
            font-size: 14px;
            transition: all 0.3s;
        }

            .search-filter-input:focus {
                outline: none;
                border-color: var(--primary-color);
                box-shadow: 0 0 0 3px rgba(67, 97, 238, 0.1);
            }

        .search-results-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 20px;
            margin-top: 20px;
            max-height: 600px;
            overflow-y: auto;
            padding: 10px;
        }

        .customer-result-card {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 20px;
            border: 1px solid #e9ecef;
            cursor: pointer;
            transition: all 0.3s;
            border-right: 4px solid var(--success-color);
        }

            .customer-result-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            }

        /* ===== تنسيق المهندس ===== */
        .technician-badge {
            display: inline-block;
            padding: 3px 8px;
            background: #6f42c1;
            color: white;
            border-radius: 12px;
            font-size: 11px;
            margin-right: 5px;
        }

        /* ===== تنسيق 80mm للطباعة ===== */
        .print-80mm {
            width: 80mm;
            padding: 2mm;
            margin: 0 auto;
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: white;
            direction: rtl;
            font-size: 9px;
            line-height: 1.2;
            box-sizing: border-box;
        }

            .print-80mm .header {
                text-align: center;
                border-bottom: 1px dashed var(--primary-color);
                padding-bottom: 2mm;
                margin-bottom: 2mm;
            }

            .print-80mm .title {
                font-size: 14px;
                font-weight: bold;
                color: var(--primary-color);
            }

            .print-80mm .info-row {
                display: flex;
                justify-content: space-between;
                padding: 1mm 0;
                border-bottom: 1px dotted #eee;
            }

            .print-80mm .info-label {
                font-weight: bold;
            }

            .print-80mm .section-title {
                font-weight: bold;
                color: var(--primary-color);
                margin: 2mm 0 1mm 0;
            }

            .print-80mm .footer {
                margin-top: 2mm;
                text-align: center;
                font-size: 7px;
                color: #999;
                border-top: 1px solid #eee;
                padding-top: 1mm;
            }

        /* ===== تنسيق التبويبات الداخلية ===== */
        .details-tabs {
            display: flex;
            gap: 5px;
            margin-bottom: 20px;
            border-bottom: 2px solid var(--primary-color);
            padding-bottom: 5px;
            flex-wrap: wrap;
            overflow-x: auto;
        }

        .details-tab {
            padding: 8px 15px;
            border: none;
            background: none;
            border-radius: 8px 8px 0 0;
            cursor: pointer;
            font-size: 13px;
            font-weight: 500;
            color: #6c757d;
            transition: all 0.3s;
            white-space: nowrap;
        }

            .details-tab:hover {
                color: var(--primary-color);
                background: #f0f4ff;
            }

            .details-tab.active {
                color: var(--primary-color);
                border-bottom: 3px solid var(--primary-color);
                background: #f0f4ff;
            }

        .tab-content {
            display: none;
            padding: 20px;
            background: #f8f9fa;
            border-radius: 12px;
            margin-top: 10px;
        }

            .tab-content.active {
                display: block;
            }

        /* ===== تنسيق المهندسين ===== */
        .technician-input-group {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .technician-input {
            flex: 1;
        }

        /* ===== تنسيق للشاشات الصغيرة ===== */
        @@media (max-width: 768px) {
            .form-row, .form-row-3, .form-row-4 {
                grid-template-columns: 1fr;
            }

            .devices-grid {
                grid-template-columns: 1fr;
            }

            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .search-filters {
                flex-direction: column;
            }

            .customers-selection {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="page-wrapper">
        <!-- ===== الهيدر ===== -->
        <div class="header-card">
            <div class="header-title">
                <h1>
                    <i class="fas fa-tools"></i> إدارة أجهزة الصيانة
                </h1>
                <p>مركز متكامل لإدارة ومتابعة أجهزة الصيانة والإصلاح</p>
            </div>
            <div class="user-info">
                <i class="fas fa-user-circle"></i> @username
                <span class="mx-2">|</span>
                <i class="fas fa-calendar"></i> @dayName @today.ToString("yyyy/MM/dd")
            </div>
        </div>

        <!-- ===== البحث عن العميل (محسن) ===== -->
        <div class="customer-search-section">
            <div class="search-label">
                <i class="fas fa-search"></i>
                <span>بحث عن العميل</span>
            </div>
            <div class="search-wrapper">
                <i class="fas fa-search search-icon"></i>
                <input type="text"
                       id="customerSearchInput"
                       class="search-input"
                       placeholder="ابحث باسم العميل أو رقم الهاتف..."
                       autocomplete="off"
                       oninput="searchCustomerInstant(this.value)">
                <i class="fas fa-times-circle clear-search" id="clearCustomerSearch" onclick="clearCustomerSearch()"></i>
            </div>
            <div class="search-stats" id="customerSearchStats">
                <i class="fas fa-info-circle"></i> اكتب لبدء البحث...
            </div>
            <div id="customerSearchResults" class="search-results-grid"></div>
        </div>

        <!-- ===== الإحصائيات السريعة ===== -->
        <div class="stats-grid">
            <div class="stat-card" id="totalDevices">
                <div class="stat-label"><i class="fas fa-box"></i> إجمالي الأجهزة</div>
                <div class="stat-value">0</div>
            </div>
            <div class="stat-card info" id="receivedToday">
                <div class="stat-label"><i class="fas fa-calendar-day"></i> مستلم اليوم</div>
                <div class="stat-value">0</div>
            </div>
            <div class="stat-card warning" id="inProgress">
                <div class="stat-label"><i class="fas fa-tools"></i> قيد الصيانة</div>
                <div class="stat-value">0</div>
            </div>
            <div class="stat-card danger" id="waitingParts">
                <div class="stat-label"><i class="fas fa-clock"></i> بانتظار قطع غيار</div>
                <div class="stat-value">0</div>
            </div>
            <div class="stat-card success" id="completed">
                <div class="stat-label"><i class="fas fa-check-circle"></i> تم الاصلاح</div>
                <div class="stat-value">0</div>
            </div>
            <div class="stat-card" id="delivered">
                <div class="stat-label"><i class="fas fa-check-double"></i> تم التسليم</div>
                <div class="stat-value">0</div>
            </div>
        </div>

        <!-- ===== أزرار الإجراءات السريعة ===== -->
        <div style="display: flex; gap: 10px; margin-bottom: 25px; flex-wrap: wrap;">
            <button class="btn btn-success" onclick="showAddDeviceModal()">
                <i class="fas fa-plus-circle"></i> استلام جهاز جديد
            </button>
            <button class="btn btn-primary" onclick="loadDevices()">
                <i class="fas fa-sync-alt"></i> تحديث القائمة
            </button>
            <button class="btn btn-info" onclick="showSparePartsModal()">
                <i class="fas fa-microchip"></i> إدارة قطع الغيار
            </button>
            <button class="btn btn-purple" onclick="showReportsModal()">
                <i class="fas fa-chart-bar"></i> التقارير
            </button>
            <button class="btn btn-pdf" onclick="printAllDevicesPDF()">
                <i class="fas fa-file-pdf"></i> تقرير شامل 
            </button>
            <button class="btn btn-whatsapp" onclick="showBulkWhatsAppModal()">
                <i class="fab fa-whatsapp"></i> رسائل جماعية
            </button>
        </div>

        <!-- ===== البطاقة الرئيسية ===== -->
        <div class="main-card">
            <div class="card-header">
                <h2><i class="fas fa-list"></i> قائمة أجهزة الصيانة</h2>
                <span class="badge bg-info" id="totalCount">0</span>
            </div>

            <!-- ===== البحث الفوري المحسن في القائمة ===== -->
            <div class="search-card" style="margin-bottom: 20px;">
                <div class="search-label">
                    <i class="fas fa-filter"></i>
                    <span>تصفية الأجهزة</span>
                </div>
                <div class="search-wrapper">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text"
                           id="liveSearchInput"
                           class="search-input"
                           placeholder="ابحث باسم العميل، رقم الهاتف، كود الجهاز، الموديل..."
                           autocomplete="off"
                           oninput="searchDevicesInstant(this.value)">
                    <i class="fas fa-times-circle clear-search" id="clearLiveSearch" onclick="clearLiveSearch()"></i>
                </div>
                <div class="search-stats" id="liveSearchStats">
                    <i class="fas fa-info-circle"></i> جميع الأجهزة
                </div>
            </div>

            <!-- ===== التبويبات الرئيسية ===== -->
            <div class="tabs">
                <button class="tab active" onclick="filterByStatus('all')">📋 الكل</button>
                <button class="tab" onclick="filterByStatus('مستلم')">📦 مستلم</button>
                <button class="tab" onclick="filterByStatus('قيد الصيانة')">🔧 قيد الصيانة</button>
                <button class="tab" onclick="filterByStatus('بانتظار قطع غيار')">⏳ بانتظار قطع غيار</button>
                <button class="tab" onclick="filterByStatus('تم الاصلاح')">✅ تم الاصلاح</button>
                <button class="tab" onclick="filterByStatus('تم التسليم')">🎉 تم التسليم</button>
                <button class="tab" onclick="filterByStatus('overdue')">⚠️ المتأخرة</button>
                <button class="tab" onclick="filterByStatus('deleted')">🗑️ المحذوفة</button>
            </div>

            <!-- ===== قائمة الأجهزة ===== -->
            <div id="devicesList" class="devices-grid">
                <div class="text-center text-muted py-5" style="grid-column: 1/-1;">
                    <i class="fas fa-spinner fa-spin fa-3x mb-3"></i>
                    <h5>جاري تحميل البيانات...</h5>
                </div>
            </div>

            <!-- ===== رسالة عدم وجود نتائج ===== -->
            <div id="noResults" class="no-results" style="display: none;">
                <i class="fas fa-frown"></i>
                <h4>لا توجد نتائج</h4>
                <p>لم يتم العثور على أجهزة تطابق بحثك</p>
            </div>
        </div>
    </div>

    <!-- ===== مودال إضافة/تعديل جهاز ===== -->
    <div id="deviceModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="deviceModalTitle">استلام جهاز جديد</h3>
                <button class="close-btn" onclick="closeDeviceModal()">✕ إغلاق</button>
            </div>
            <form id="deviceForm">
                <input type="hidden" id="deviceId" value="0" />

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">👤 اسم العميل <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="customerName" required
                               placeholder="أدخل اسم العميل كاملاً" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">📞 رقم الهاتف <span class="text-danger">*</span></label>
                        <input type="tel" class="form-control" id="customerPhone" required
                               placeholder="01xxxxxxxxx" />
                    </div>
                </div>

                <div class="form-row-4">
                    <div class="form-group">
                        <label class="form-label">📱 نوع الجهاز</label>
                        <input type="text" class="form-control" id="deviceType" placeholder="أدخل نوع الجهاز" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">🏷️ الماركة</label>
                        <input type="text" class="form-control" id="deviceBrand" placeholder="أدخل الماركة" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">📌 الموديل</label>
                        <input type="text" class="form-control" id="deviceModel" placeholder="أدخل الموديل" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">🔢 السيريال</label>
                        <input type="text" class="form-control" id="deviceSerial" placeholder="أدخل الرقم التسلسلي" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">🎨 اللون</label>
                        <input type="text" class="form-control" id="deviceColor" placeholder="أدخل اللون" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">🔑 باسورد الجهاز</label>
                        <input type="text" class="form-control" id="devicePassword" placeholder="أدخل الباسورد" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">📦 الاكسسوارات</label>
                        <input type="text" class="form-control" id="deviceAccessories" placeholder="شاحن، سماعة، كفر..." />
                    </div>
                    <div class="form-group">
                        <label class="form-label">👨‍🔧 المهندس</label>
                        <input type="text" class="form-control" id="technicianName" placeholder="أدخل اسم المهندس" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">⚠️ العيب المشتكى منه <span class="text-danger">*</span></label>
                    <textarea class="form-control" id="reportedIssue" rows="3" required
                              placeholder="اكتب وصفاً دقيقاً للعيب"></textarea>
                </div>

                <div class="form-group">
                    <label class="form-label">🔧 ملاحظات الفني</label>
                    <textarea class="form-control" id="technicianNotes" rows="2"
                              placeholder="ملاحظات داخلية للفنيين"></textarea>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">💰 التكلفة التقديرية</label>
                        <input type="number" class="form-control" id="estimatedCost"
                               placeholder="مبلغ بالجنيه" min="0" step="0.01" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">💵 دفعة مقدمة</label>
                        <input type="number" class="form-control" id="advancePayment"
                               value="0" min="0" step="0.01" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">📅 تاريخ الوعد</label>
                        <input type="datetime-local" class="form-control" id="promisedDate" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">🛡️ تحت الضمان</label>
                        <select class="form-select" id="isWarranty">
                            <option value="false">لا</option>
                            <option value="true">نعم</option>
                        </select>
                    </div>
                </div>

                <div class="form-group" id="warrantyDetailsGroup" style="display: none;">
                    <label class="form-label">📝 تفاصيل الضمان</label>
                    <input type="text" class="form-control" id="warrantyDetails"
                           placeholder="مدة الضمان وتفاصيله" />
                </div>

                <div class="form-group">
                    <label class="form-label">📋 ملاحظات إضافية</label>
                    <textarea class="form-control" id="notes" rows="2"
                              placeholder="أي ملاحظات أخرى"></textarea>
                </div>

                <div style="margin-top: 25px; display: flex; gap: 10px; justify-content: flex-start;">
                    <button type="button" class="btn btn-success" onclick="saveDevice()">
                        <i class="fas fa-save"></i> حفظ وطباعة فاتورة
                    </button>
                    <button type="button" class="btn btn-secondary" onclick="closeDeviceModal()">
                        <i class="fas fa-times"></i> إلغاء
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- ===== مودال تفاصيل الجهاز مع التبويبات ===== -->
    <div id="deviceDetailsModal" class="modal">
        <div class="modal-content modal-lg">
            <div class="modal-header">
                <h3 id="detailsDeviceName">تفاصيل الجهاز</h3>
                <button class="close-btn" onclick="closeDetailsModal()">✕ إغلاق</button>
            </div>

            <!-- ملخص سريع -->
            <div class="summary-box" id="deviceSummary">
                <div class="summary-item">
                    <div class="summary-value">0</div>
                    <div class="summary-label">أيام في الصيانة</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">0 ج.م</div>
                    <div class="summary-label">التكلفة التقديرية</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">0 ج.م</div>
                    <div class="summary-label">المدفوع</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">0 ج.م</div>
                    <div class="summary-label">المتبقي</div>
                </div>
            </div>

            <!-- أزرار تغيير الحالة -->
            <div style="display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; justify-content: center;">
                <button class="btn btn-info" onclick="changeDeviceStatus('قيد الصيانة')">
