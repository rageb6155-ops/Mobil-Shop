                function copyWhatsAppMessage() {
                    const message = document.getElementById('whatsappMessageText').value;

                    navigator.clipboard.writeText(message).then(() => {
                        alert('✅ تم نسخ الرسالة! يمكنك لصقها في واتساب الآن');
                    }).catch(err => {
                        alert('❌ فشل في النسخ: ' + err.message);
                    });
                }

                function openWhatsAppChat() {
                    const message = document.getElementById('whatsappMessageText').value;
                    let phone = currentWhatsAppPhone;

                    phone = phone.replace(/[^0-9]/g, '');
                    if (phone.startsWith('0')) {
                        phone = '20' + phone.substring(1);
                    }

                    const url = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
                    window.open(url, '_blank');
                }

                // ===== دوال إدارة قطع الغيار =====
                function showSparePartsModal() {
                    document.getElementById('sparePartsModal').style.display = 'block';
                    loadSparePartsList();
                }

                function closeSparePartsModal() {
                    document.getElementById('sparePartsModal').style.display = 'none';
                }

                function loadSparePartsList() {
                    const search = document.getElementById('searchParts')?.value || '';
                    const lowStockOnly = document.getElementById('showLowStockOnly')?.checked || false;

                    fetch(`/Repair/GetSpareParts?search=${encodeURIComponent(search)}&lowStockOnly=${lowStockOnly}`)
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                displaySparePartsGrid(data.parts);
                                updateSparePartsStats(data.parts);
                            }
                        });
                }

                function displaySparePartsGrid(parts) {
                    const container = document.getElementById('sparePartsGrid');

                    if (!parts || parts.length === 0) {
                        container.innerHTML = '<p class="text-center text-muted py-3">لا توجد قطع غيار</p>';
                        return;
                    }

                    let html = '';
                    parts.forEach(p => {
                        const lowStockClass = p.quantity <= p.minQuantity ? 'low-stock' : '';
                        html += `
                            <div class="part-item">
                                <div class="part-info">
                                    <div class="part-name">${p.partName} (${p.partCode})</div>
                                    <div class="part-details">
                                        <span>📦 الكمية: <span class="${lowStockClass}">${p.quantity}</span> / حد: ${p.minQuantity}</span> |
                                        <span>💰 الشراء: ${p.cost.toLocaleString()} ج.م</span> |
                                        <span>💵 البيع: ${p.sellingPrice.toLocaleString()} ج.م</span>
                                    </div>
                                </div>
                                <button class="btn btn-sm btn-primary" onclick="selectPartForRepair(${p.id}, '${p.partName}', ${p.sellingPrice})">
                                    <i class="fas fa-plus"></i> إضافة
                                </button>
                            </div>
                        `;
                    });

                    container.innerHTML = html;
                }

                function updateSparePartsStats(parts) {
                    const total = parts.length;
                    const lowStock = parts.filter(p => p.quantity <= p.minQuantity).length;
                    const totalValue = parts.reduce((sum, p) => sum + (p.cost * p.quantity), 0);

                    document.getElementById('totalParts').innerHTML = `
                        <div class="stat-label">إجمالي القطع</div>
                        <div class="stat-value">${total}</div>
                    `;
                    document.getElementById('lowStockCount').innerHTML = `
                        <div class="stat-label">قطع منخفضة المخزون</div>
                        <div class="stat-value">${lowStock}</div>
                    `;
                    document.getElementById('totalPartsValue').innerHTML = `
                        <div class="stat-label">قيمة المخزون</div>
                        <div class="stat-value">${totalValue.toLocaleString()} ج.م</div>
                    `;
                }

                function showAddPartModal() {
                    document.getElementById('partDeviceId').value = currentDeviceId;
                    loadPartsDropdown();
                    document.getElementById('addPartModal').style.display = 'block';
                }

                function closeAddPartModal() {
                    document.getElementById('addPartModal').style.display = 'none';
                }

                function loadPartsDropdown() {
                    fetch('/Repair/GetSpareParts')
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                const select = document.getElementById('partId');
                                select.innerHTML = '<option value="">اختر قطعة الغيار</option>';
                                data.parts.forEach(p => {
                                    select.innerHTML += `<option value="${p.id}" data-price="${p.sellingPrice}">${p.partName} (${p.partCode}) - متوفر: ${p.quantity}</option>`;
                                });
                            }
                        });
                }

                function savePart() {
                    const data = {
                        repairId: document.getElementById('partDeviceId').value,
                        partId: document.getElementById('partId').value,
                        quantity: parseInt(document.getElementById('partQuantity').value),
                        notes: document.getElementById('partNotes').value
                    };

                    if (!data.partId) {
                        alert('❌ الرجاء اختيار قطعة الغيار');
                        return;
                    }

                    fetch('/Repair/AddSparePart', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            alert('✅ ' + data.message);
                            closeAddPartModal();
                            showDeviceDetails(currentDeviceId);
                            loadSparePartsList();
                        } else {
                            alert('❌ ' + data.message);
                        }
                    });
                }

                function selectPartForRepair(partId, partName, price) {
                    if (currentDeviceId) {
                        document.getElementById('partId').value = partId;
                        document.getElementById('partQuantity').value = 1;
                        document.getElementById('partNotes').value = '';
                        closeSparePartsModal();
                        showAddPartModal();
                    } else {
                        alert('الرجاء فتح جهاز أولاً');
                    }
                }

                // ===== دوال التقارير =====
                function showReportsModal() {
                    document.getElementById('reportsModal').style.display = 'block';
                    loadPerformanceReport();
                }

                function closeReportsModal() {
                    document.getElementById('reportsModal').style.display = 'none';
                }

                function switchReportTab(tab) {
                    document.querySelectorAll('#reportsModal .tabs .tab').forEach(btn => btn.classList.remove('active'));
                    event.target.classList.add('active');

                    document.querySelectorAll('#reportsModal .report-content').forEach(content => {
                        content.classList.remove('active');
                    });

                    if (tab === 'performance') {
                        document.getElementById('performanceReport').classList.add('active');
                        loadPerformanceReport();
                    } else if (tab === 'revenue') {
                        document.getElementById('revenueReport').classList.add('active');
                        loadRevenueReport();
                    } else if (tab === 'customers') {
                        document.getElementById('customerReport').classList.add('active');
                    } else if (tab === 'devices') {
                        document.getElementById('devicesReport').classList.add('active');
                        loadDevicesReport();
                    }
                }

                // البحث الفوري في تقرير العملاء
                function searchCustomerReportInstant(term) {
                    clearTimeout(reportSearchTimeout);

                    term = term.trim();

                    if (term.length < 1) {
                        document.getElementById('customerReportData').innerHTML =
                            '<p class="text-center text-muted">أدخل اسم العميل أو رقم الهاتف للبحث</p>';
                        return;
                    }

                    reportSearchTimeout = setTimeout(() => {
                        searchCustomerReport();
                    }, 300);
                }

                function searchCustomerReport() {
                    const searchTerm = document.getElementById('customerReportSearch').value.trim();

                    if (!searchTerm) {
                        alert('❌ الرجاء إدخال اسم العميل أو رقم الهاتف');
                        return;
                    }

                    fetch(`/Repair/CustomerReport?searchTerm=${encodeURIComponent(searchTerm)}`)
                        .then(res => res.json())
                        .then(data => {
                            if (data.success && data.report.length > 0) {
                                displayCustomerReportData(data.report);
                            } else {
                                document.getElementById('customerReportData').innerHTML =
                                    '<p class="text-center text-muted">لا توجد بيانات لهذا العميل</p>';
                            }
                        });
                }

                function displayCustomerReportData(report) {
                    if (!report || report.length === 0) {
                        document.getElementById('customerReportData').innerHTML =
                            '<p class="text-center text-muted">لا توجد بيانات</p>';
                        return;
                    }

                    let html = '';
                    report.forEach(customer => {
                        html += `
                            <div class="alert alert-info">
                                <h5>معلومات العميل</h5>
                                <p><strong>الاسم:</strong> ${customer.customerName}</p>
                                <p><strong>رقم الهاتف:</strong> ${customer.customerPhone}</p>
                                <p><strong>إجمالي الأجهزة:</strong> ${customer.totalDevices}</p>
                                <p><strong>إجمالي المنفق:</strong> ${customer.totalSpent.toLocaleString()} ج.م</p>
                                <p><strong>آخر صيانة:</strong> ${new Date(customer.lastRepairDate).toLocaleDateString('ar-EG')}</p>
                            </div>
                            <h6>آخر الأجهزة</h6>
                            <table class="report-table">
                                <thead>
                                    <tr>
                                        <th>كود الجهاز</th>
                                        <th>الجهاز</th>
                                        <th>الحالة</th>
                                        <th>تاريخ الاستلام</th>
                                        <th>التكلفة</th>
                                    </tr>
                                </thead>
                                <tbody>
                        `;

                        customer.devices.slice(0, 5).forEach(d => {
                            html += `
                                <tr onclick="showDeviceDetails(${d.id})" style="cursor: pointer;">
                                    <td>${d.deviceCode}</td>
                                    <td>${d.deviceModel}</td>
                                    <td><span class="badge ${d.statusColor || 'badge-secondary'}">${d.status || 'غير معروف'}</span></td>
                                    <td>${d.receivedDate ? new Date(d.receivedDate).toLocaleDateString('ar-EG') : '---'}</td>
                                    <td>${d.finalCost ? d.finalCost.toLocaleString() + ' ج.م' : (d.estimatedCost ? d.estimatedCost.toLocaleString() + ' ج.م' : 'لم يحدد')}</td>
                                </tr>
                            `;
                        });

                        html += '</tbody></table>';
                    });

                    document.getElementById('customerReportData').innerHTML = html;
                }

                // البحث الفوري في تقرير الأجهزة
                function searchDevicesReportInstant(term) {
                    clearTimeout(devicesReportSearchTimeout);

                    term = term.trim();

                    devicesReportSearchTimeout = setTimeout(() => {
                        loadDevicesReport();
                    }, 300);
                }

                function loadDevicesReport() {
                    const fromDate = document.getElementById('devFromDate').value;
                    const toDate = document.getElementById('devToDate').value;
                    const searchTerm = document.getElementById('deviceSearchInput').value.trim();
                    const status = document.getElementById('devStatus').value;

                    fetch(`/Repair/DevicesReport?fromDate=${fromDate}&toDate=${toDate}&status=${status}&searchTerm=${encodeURIComponent(searchTerm)}`)
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                displayDevicesReportData(data.devices);
                            }
                        });
                }

                function displayDevicesReportData(devices) {
                    if (!devices || devices.length === 0) {
                        document.getElementById('devicesReportData').innerHTML =
                            '<p class="text-center text-muted">لا توجد أجهزة في هذه الفترة</p>';
                        return;
                    }

                    let html = '<table class="report-table"><thead><tr><th>كود الجهاز</th><th>العميل</th><th>الجهاز</th><th>الحالة</th><th>التكلفة</th><th>المدفوع</th><th>تاريخ الاستلام</th></tr></thead><tbody>';

                    devices.slice(0, 20).forEach(d => {
                        html += `
                            <tr onclick="showDeviceDetails(${d.id})" style="cursor: pointer;">
                                <td>${d.deviceCode}</td>
                                <td>${d.customerName}</td>
                                <td>${d.deviceBrand} ${d.deviceModel}</td>
                                <td><span class="badge ${d.statusColor || 'badge-secondary'}">${d.status || 'غير معروف'}</span></td>
                                <td>${d.estimatedCost ? d.estimatedCost.toLocaleString() : '0'} ج.م</td>
                                <td>${d.advancePayment.toLocaleString()} ج.م</td>
                                <td>${d.receivedDate ? new Date(d.receivedDate).toLocaleDateString('ar-EG') : '---'}</td>
                            </tr>
                        `;
                    });

                    html += '</tbody></table>';
                    if (devices.length > 20) {
                        html += `<p class="text-center text-muted">... و ${devices.length - 20} أجهزة أخرى</p>`;
                    }

                    document.getElementById('devicesReportData').innerHTML = html;
                }

                function loadPerformanceReport() {
                    const fromDate = document.getElementById('perfFromDate').value;
                    const toDate = document.getElementById('perfToDate').value;

                    fetch(`/Repair/TechnicianPerformanceReport?fromDate=${fromDate}&toDate=${toDate}`)
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                displayPerformanceReport(data.report);
                            }
                        });
                }

                function displayPerformanceReport(report) {
                    if (!report || report.length === 0) {
                        document.getElementById('performanceData').innerHTML =
                            '<p class="text-center text-muted">لا توجد بيانات في هذه الفترة</p>';
                        return;
                    }

                    let html = '<table class="report-table"><thead><tr><th>الفني</th><th>إجمالي الأجهزة</th><th>المكتملة</th><th>قيد العمل</th><th>متوسط الأيام</th><th>الإيرادات</th><th>تقييم العملاء</th></tr></thead><tbody>';

                    report.forEach(r => {
                        html += `
                            <tr>
                                <td>${r.technicianName}</td>
                                <td>${r.totalDevices}</td>
                                <td class="text-success">${r.completedDevices}</td>
                                <td class="text-warning">${r.devicesInProgress}</td>
                                <td>${r.averageDays.toFixed(1)} يوم</td>
                                <td class="text-primary">${r.totalRevenue.toLocaleString()} ج.م</td>
                                <td>${r.customerRating.toFixed(1)} ★</td>
                            </tr>
                        `;
                    });

                    html += '</tbody></table>';
                    document.getElementById('performanceData').innerHTML = html;
                }

                function loadRevenueReport() {
                    const fromDate = document.getElementById('revFromDate').value;
                    const toDate = document.getElementById('revToDate').value;
                    const period = document.getElementById('revPeriod').value;

