                let allCustomers = [];
                let selectedCustomers = [];

                // متغيرات الواتساب
                let currentWhatsAppDevice = null;
                let currentWhatsAppPhone = '';

                // ===== التحميل الأولي =====
                document.addEventListener('DOMContentLoaded', function() {
                    loadDevices();
                    loadDashboardStats();
                    loadSparePartsList();
                    initDropzone();

                    // تحديث الإحصائيات كل 30 ثانية
                    setInterval(() => loadDashboardStats(), 30000);

                    document.getElementById('isWarranty')?.addEventListener('change', function() {
                        document.getElementById('warrantyDetailsGroup').style.display =
                            this.value === 'true' ? 'block' : 'none';
                    });

                    document.getElementById('searchParts')?.addEventListener('input', function() {
                        loadSparePartsList();
                    });
                    document.getElementById('showLowStockOnly')?.addEventListener('change', function() {
                        loadSparePartsList();
                    });
                });

                // ===== دوال البحث الفوري =====

                // البحث الفوري عن العميل
                function searchCustomerInstant(term) {
                    clearTimeout(customerSearchTimeout);

                    term = term.trim();

                    // إظهار/إخفاء زر المسح
                    document.getElementById('clearCustomerSearch').style.display = term ? 'block' : 'none';

                    if (term.length < 1) {
                        document.getElementById('customerSearchResults').innerHTML = '';
                        document.getElementById('customerSearchStats').innerHTML = '<i class="fas fa-info-circle"></i> اكتب لبدء البحث...';
                        return;
                    }

                    // تحديث حالة البحث
                    document.getElementById('customerSearchStats').innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري البحث...';

                    customerSearchTimeout = setTimeout(() => {
                        fetch(`/Repair/SearchCustomerByPhone?term=${encodeURIComponent(term)}`)
                            .then(res => res.json())
                            .then(data => {
                                if (data.success && data.customers && data.customers.length > 0) {
                                    displayCustomerSearchResults(data.customers);
                                    document.getElementById('customerSearchStats').innerHTML =
                                        `<i class="fas fa-check-circle"></i> تم العثور على ${data.customers.length} عميل`;
                                } else {
                                    document.getElementById('customerSearchResults').innerHTML = `
                                        <div class="text-center text-muted py-5" style="grid-column: 1/-1;">
                                            <i class="fas fa-search fa-3x mb-3" style="color: #ccc;"></i>
                                            <h5>لا توجد نتائج للبحث</h5>
                                            <p class="text-muted">لم نتمكن من العثور على أي عميل يطابق "${term}"</p>
                                        </div>
                                    `;
                                    document.getElementById('customerSearchStats').innerHTML =
                                        '<i class="fas fa-exclamation-circle"></i> لا توجد نتائج';
                                }
                            })
                            .catch(err => {
                                console.error('خطأ في البحث:', err);
                                document.getElementById('customerSearchStats').innerHTML =
                                    '<i class="fas fa-exclamation-triangle"></i> حدث خطأ في البحث';
                            });
                    }, 300);
                }

                // عرض نتائج بحث العميل
                function displayCustomerSearchResults(customers) {
                    const container = document.getElementById('customerSearchResults');

                    let html = '';
                    customers.forEach(c => {
                        // تجهيز الأجهزة الخاصة بالعميل
                        let devicesHtml = '';
                        if (c.devices && c.devices.length > 0) {
                            devicesHtml = '<div style="margin-top: 10px; border-top: 1px solid #eee; padding-top: 10px;">';
                            devicesHtml += '<small style="color: #666;">آخر الأجهزة:</small>';
                            c.devices.forEach(d => {
                                devicesHtml += `
                                    <div style="font-size: 11px; margin: 5px 0; padding: 3px; background: #f8f9fa; border-radius: 4px;">
                                        <span class="badge ${d.statusColor}" style="font-size: 8px;">${d.status}</span>
                                        ${d.deviceBrand} ${d.deviceModel} - ${d.deviceCode}
                                    </div>
                                `;
                            });
                            if (c.deviceCount > 5) {
                                devicesHtml += `<small style="color: #999;">... و ${c.deviceCount - 5} أجهزة أخرى</small>`;
                            }
                            devicesHtml += '</div>';
                        }

                        html += `
                            <div class="customer-result-card" onclick="showCustomerHistory('${c.customerPhone}')">
                                <div style="display: flex; justify-content: space-between; align-items: start;">
                                    <h5 style="margin: 0; color: var(--primary-color);">
                                        <i class="fas fa-user"></i> ${c.customerName}
                                    </h5>
                                    <span class="badge bg-info">${c.deviceCount} جهاز</span>
                                </div>
                                <p style="margin: 8px 0; color: var(--success-color);">
                                    <i class="fas fa-phone"></i> ${c.customerPhone}
                                </p>
                                <div style="display: flex; gap: 15px; font-size: 12px; color: #666; margin-bottom: 8px;">
                                    <span><i class="fas fa-calendar"></i> آخر صيانة: ${new Date(c.lastRepair).toLocaleDateString('ar-EG')}</span>
                                    <span><i class="fas fa-money-bill"></i> ${c.totalSpent.toLocaleString()} ج.م</span>
                                </div>
                                ${devicesHtml}
                            </div>
                        `;
                    });

                    container.innerHTML = html;
                }

                // مسح بحث العميل
                function clearCustomerSearch() {
                    document.getElementById('customerSearchInput').value = '';
                    document.getElementById('clearCustomerSearch').style.display = 'none';
                    document.getElementById('customerSearchResults').innerHTML = '';
                    document.getElementById('customerSearchStats').innerHTML = '<i class="fas fa-info-circle"></i> اكتب لبدء البحث...';
                    document.getElementById('customerSearchInput').focus();
                }

                // البحث الفوري في قائمة الأجهزة
                function searchDevicesInstant(term) {
                    clearTimeout(deviceSearchTimeout);

                    term = term.trim();

                    // إظهار/إخفاء زر المسح
                    document.getElementById('clearLiveSearch').style.display = term ? 'block' : 'none';

                    if (term.length < 1) {
                        loadDevices();
                        return;
                    }

                    // تحديث حالة البحث
                    document.getElementById('liveSearchStats').innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري البحث...';

                    deviceSearchTimeout = setTimeout(() => {
                        loadDevicesWithSearch(term);
                    }, 300);
                }

                // تحميل الأجهزة مع تطبيق البحث
                function loadDevicesWithSearch(searchTerm) {
                    let url = `/Repair/GetAllDevices?status=${currentStatus}&showDeleted=${showDeleted}`;
                    if (searchTerm) {
                        url += `&search=${encodeURIComponent(searchTerm)}`;
                    }

                    fetch(url)
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                displayDevices(data.devices);
                                document.getElementById('totalCount').innerText = data.devices.length;
                                document.getElementById('liveSearchStats').innerHTML =
                                    `<i class="fas fa-info-circle"></i> عرض ${data.devices.length} جهاز`;

                                // تجميع كل العملاء للرسائل الجماعية
                                allCustomers = data.devices.map(d => ({
                                    id: d.id,
                                    name: d.customerName,
                                    phone: d.customerPhone,
                                    device: `${d.deviceBrand} ${d.deviceModel}`,
                                    code: d.deviceCode,
                                    status: d.status
                                }));
                            } else {
                                console.error('خطأ:', data.message);
                            }
                        });
                }

                // مسح البحث في القائمة
                function clearLiveSearch() {
                    document.getElementById('liveSearchInput').value = '';
                    document.getElementById('clearLiveSearch').style.display = 'none';
                    loadDevices();
                    document.getElementById('liveSearchInput').focus();
                }

                // ===== دوال الإحصائيات =====
                function loadDashboardStats() {
                    fetch('/Repair/GetDashboardStats')
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                const stats = data.stats;
                                document.getElementById('totalDevices').innerHTML = `
                                    <div class="stat-label"><i class="fas fa-box"></i> إجمالي الأجهزة</div>
                                    <div class="stat-value">${stats.totalDevices}</div>
                                `;
                                document.getElementById('receivedToday').innerHTML = `
                                    <div class="stat-label"><i class="fas fa-calendar-day"></i> مستلم اليوم</div>
                                    <div class="stat-value">${stats.receivedToday}</div>
                                `;
                                document.getElementById('inProgress').innerHTML = `
                                    <div class="stat-label"><i class="fas fa-tools"></i> قيد الصيانة</div>
                                    <div class="stat-value">${stats.inProgress}</div>
                                `;
                                document.getElementById('waitingParts').innerHTML = `
                                    <div class="stat-label"><i class="fas fa-clock"></i> بانتظار قطع غيار</div>
                                    <div class="stat-value">${stats.waitingParts}</div>
                                `;
                                document.getElementById('completed').innerHTML = `
                                    <div class="stat-label"><i class="fas fa-check-circle"></i> تم الاصلاح</div>
                                    <div class="stat-value">${stats.completed}</div>
                                `;
                                document.getElementById('delivered').innerHTML = `
                                    <div class="stat-label"><i class="fas fa-check-double"></i> تم التسليم</div>
                                    <div class="stat-value">${stats.delivered}</div>
                                `;
                            }
                        });
                }

                // ===== دوال تحميل الأجهزة =====
                function loadDevices() {
                    loadDevicesWithSearch('');
                }

                function displayDevices(devices) {
                    const container = document.getElementById('devicesList');

                    if (devices.length === 0) {
                        container.innerHTML = `
                            <div class="text-center text-muted py-5" style="grid-column: 1/-1;">
                                <i class="fas fa-box-open fa-4x mb-3" style="color: #ccc;"></i>
                                <h5>لا توجد أجهزة في هذه القائمة</h5>
                                <p class="text-muted">يمكنك إضافة جهاز جديد بالضغط على زر "استلام جهاز جديد"</p>
                            </div>
                        `;
                        document.getElementById('noResults').style.display = 'none';
                        return;
                    }

                    let html = '';
                    devices.forEach(d => {
                        let cardClass = 'device-card';
                        if (d.status === 'مستلم') cardClass += ' received';
                        else if (d.status === 'قيد الصيانة') cardClass += ' in-progress';
                        else if (d.status === 'بانتظار قطع غيار') cardClass += ' waiting-parts';
                        else if (d.status === 'تم الاصلاح') cardClass += ' completed';
                        else if (d.status === 'تم التسليم') cardClass += ' delivered';

                        if (d.isOverdue) cardClass += ' overdue';
                        if (d.isDeleted) cardClass += ' deleted';

                        html += `
                            <div class="${cardClass}" onclick="showDeviceDetails(${d.id})"
                                 data-customer-name="${d.customerName}"
                                 data-customer-phone="${d.customerPhone}"
                                 data-device-brand="${d.deviceBrand}"
                                 data-device-model="${d.deviceModel}"
                                 data-device-code="${d.deviceCode}"
                                 data-status="${d.status}">
                                ${d.isOverdue ? '<span class="overdue-badge"><i class="fas fa-exclamation-triangle"></i> متأخر ' + d.overdueDays + ' يوم</span>' : ''}
                                ${d.isDeleted ? '<span class="deleted-badge"><i class="fas fa-trash"></i> محذوف</span>' : ''}

                                <div class="device-header">
                                    <span class="device-name">${d.customerName}</span>
                                    <span class="device-code">${d.deviceCode}</span>
                                </div>

                                <div class="device-customer">
                                    <i class="fas fa-mobile-alt"></i> ${d.deviceBrand} ${d.deviceModel}
                                    ${d.technicianName && d.technicianName !== 'غير معين' ?
                                        `<span class="technician-badge"><i class="fas fa-user-cog"></i> ${d.technicianName}</span>` : ''}
                                </div>

                                <div class="device-phone">
                                    <i class="fas fa-phone"></i> ${d.customerPhone}
                                </div>

                                <div class="device-issue">
                                    <i class="fas fa-exclamation-triangle"></i>
                                    ${d.reportedIssue.length > 60 ? d.reportedIssue.substring(0, 60) + '...' : d.reportedIssue}
                                </div>

                                <div class="device-cost">
                                    <span><i class="fas fa-money-bill-wave"></i> ${d.estimatedCost ? d.estimatedCost.toLocaleString() + ' ج.م' : 'لم يحدد'}</span>
                                    ${d.advancePayment > 0 ?
                                        `<span class="text-success"><i class="fas fa-check-circle"></i> مدفوع: ${d.advancePayment.toLocaleString()} ج.م</span>` : ''}
                                </div>

                                <div class="device-footer">
                                    <span class="device-status-badge ${d.statusColor}">
                                        <i class="fas ${d.statusIcon}"></i> ${d.status}
                                    </span>
                                    <span class="device-date">
                                        <i class="far fa-clock"></i> ${d.daysInRepair} يوم
                                    </span>
                                </div>

                                ${d.requiresSpareParts ?
                                    '<div class="mt-2"><span class="badge bg-warning"><i class="fas fa-microchip"></i> يحتاج قطع غيار</span></div>' : ''}

                                ${d.isDeleted ? `
                                    <div class="mt-2">
                                        <button class="btn btn-restore btn-sm" onclick="restoreDevice(${d.id}); event.stopPropagation();">
                                            <i class="fas fa-undo"></i> استعادة
                                        </button>
                                    </div>
                                ` : ''}
                            </div>
                        `;
                    });

                    container.innerHTML = html;

                    // إعادة تطبيق البحث إذا كان هناك مصطلح بحث
                    const searchTerm = document.getElementById('liveSearchInput').value.trim();
                    document.getElementById('noResults').style.display = devices.length === 0 && searchTerm ? 'block' : 'none';
                }

                // ===== دوال التصفية =====
                function filterByStatus(status) {
                    document.querySelectorAll('.tabs .tab').forEach(btn => btn.classList.remove('active'));
                    event.target.classList.add('active');

                    if (status === 'deleted') {
                        showDeleted = true;
                        currentStatus = 'all';
                    } else if (status === 'overdue') {
                        showDeleted = false;
                        currentStatus = 'all';
                    } else {
                        showDeleted = false;
                        currentStatus = status;
                    }

                    loadDevices();
                }

                // ===== دوال الرسائل الجماعية المتقدمة =====
                function showBulkWhatsAppModal() {
                    document.getElementById('bulkWhatsAppModal').style.display = 'block';
                    loadCustomersForBulk();
                }

                function closeBulkWhatsAppModal() {
                    document.getElementById('bulkWhatsAppModal').style.display = 'none';
                    selectedCustomers = [];
                }

                function loadCustomersForBulk() {
                    fetch('/Repair/GetAllPhonesForBulk')
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                allCustomers = data.phones;
                                displayAvailableCustomers(allCustomers);
                                updateSelectedCounts();
                            } else {
                                alert('❌ فشل في تحميل قائمة العملاء');
                            }
                        })
                        .catch(err => {
                            console.error('خطأ:', err);
                            alert('❌ حدث خطأ في تحميل العملاء');
                        });
                }

                function displayAvailableCustomers(customers) {
                    const container = document.getElementById('availableCustomersList');

                    if (!customers || customers.length === 0) {
                        container.innerHTML = '<div class="text-center p-3 text-muted">لا يوجد عملاء</div>';
                        return;
                    }

                    let html = '';
                    customers.forEach(c => {
                        const isSelected = selectedCustomers.some(sc => sc.phone === c.customerPhone);
                        html += `
                            <div class="customer-item ${isSelected ? 'selected' : ''}" onclick="toggleCustomer(this, '${c.customerPhone}')">
                                <input type="checkbox" class="customer-checkbox" ${isSelected ? 'checked' : ''}
                                       onchange="toggleCustomer(this, '${c.customerPhone}')" onclick="event.stopPropagation()">
                                <div class="customer-info">
                                    <div class="customer-name">${c.customerName}</div>
                                    <div class="customer-details">
                                        <span class="customer-phone">📞 ${c.customerPhone}</span>
                                        <span>📱 ${c.deviceBrand} ${c.deviceModel}</span>
                                        <span>🔢 ${c.deviceCode}</span>
                                    </div>
                                </div>
                            </div>
                        `;
                    });

                    container.innerHTML = html;
                    document.getElementById('availableCount').innerText = customers.length;
                }

                function displaySelectedCustomers(customers) {
                    const container = document.getElementById('selectedCustomersList');

                    if (!customers || customers.length === 0) {
                        container.innerHTML = '<div class="text-center p-3 text-muted">لا يوجد عملاء مختارين</div>';
                        return;
                    }

                    let html = '';
                    customers.forEach(c => {
                        html += `
                            <div class="customer-item selected" onclick="removeFromSelected('${c.phone}')">
                                <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                                <div class="customer-info">
                                    <div class="customer-name">${c.name}</div>
                                    <div class="customer-details">
                                        <span class="customer-phone">📞 ${c.phone}</span>
                                        <span>📱 ${c.device}</span>
                                        <span>🔢 ${c.code}</span>
                                    </div>
                                </div>
                                <i class="fas fa-times" style="color: #dc3545; margin-right: auto;" onclick="removeFromSelected('${c.phone}', event)"></i>
                            </div>
                        `;
                    });

                    container.innerHTML = html;
                }

                function toggleCustomer(element, phone) {
                    const checkbox = element.classList.contains('customer-item') ?
                        element.querySelector('.customer-checkbox') : element;

                    const customer = allCustomers.find(c => c.customerPhone === phone);
                    if (!customer) return;

                    if (checkbox.checked) {
                        // إضافة إلى المختارين
                        if (!selectedCustomers.some(c => c.phone === phone)) {
                            selectedCustomers.push({
                                phone: phone,
                                name: customer.customerName,
                                device: `${customer.deviceBrand} ${customer.deviceModel}`,
                                code: customer.deviceCode
                            });
                        }
                    } else {
                        // إزالة من المختارين
                        selectedCustomers = selectedCustomers.filter(c => c.phone !== phone);
                    }

                    // تحديث واجهة المستخدم
                    updateSelectedCounts();
                    filterAvailableCustomers();
                    filterSelectedCustomers();

                    // تحديث حالة زر الإرسال
                    updateSendButtonState();
                }

                function removeFromSelected(phone, event) {
                    if (event) event.stopPropagation();

                    selectedCustomers = selectedCustomers.filter(c => c.phone !== phone);

                    // تحديث المربعات في القائمة المتاحة
                    const checkboxes = document.querySelectorAll('#availableCustomersList .customer-checkbox');
                    checkboxes.forEach(cb => {
                        const item = cb.closest('.customer-item');
                        const itemPhone = item.querySelector('.customer-phone')?.innerText?.replace('📞 ', '');
                        if (itemPhone === phone) {
                            cb.checked = false;
                            item.classList.remove('selected');
                        }
                    });

                    updateSelectedCounts();
                    filterSelectedCustomers();
                    updateSendButtonState();
                }

                function selectAllCustomers() {
                    const visibleCheckboxes = document.querySelectorAll('#availableCustomersList .customer-checkbox:not([style*="display: none"])');
                    visibleCheckboxes.forEach(cb => {
                        if (!cb.checked) {
                            cb.checked = true;
                            const item = cb.closest('.customer-item');
                            const phone = item.querySelector('.customer-phone')?.innerText?.replace('📞 ', '');
                            const customer = allCustomers.find(c => c.customerPhone === phone);

                            if (customer && !selectedCustomers.some(c => c.phone === phone)) {
                                selectedCustomers.push({
                                    phone: phone,
                                    name: customer.customerName,
                                    device: `${customer.deviceBrand} ${customer.deviceModel}`,
                                    code: customer.deviceCode
                                });
                            }
                            item.classList.add('selected');
                        }
                    });

                    updateSelectedCounts();
                    filterSelectedCustomers();
                    updateSendButtonState();
                }

                function deselectAllCustomers() {
                    selectedCustomers = [];

                    document.querySelectorAll('#availableCustomersList .customer-checkbox').forEach(cb => {
                        cb.checked = false;
                        cb.closest('.customer-item').classList.remove('selected');
                    });

                    updateSelectedCounts();
                    filterSelectedCustomers();
                    updateSendButtonState();
                }

                function refreshCustomersList() {
                    loadCustomersForBulk();
                }

                function filterAvailableCustomers() {
                    const searchTerm = document.getElementById('availableSearch').value.toLowerCase();
                    const items = document.querySelectorAll('#availableCustomersList .customer-item');

                    items.forEach(item => {
                        const text = item.innerText.toLowerCase();
                        if (text.includes(searchTerm)) {
                            item.style.display = 'flex';
                        } else {
                            item.style.display = 'none';
                        }
                    });
                }

                function filterSelectedCustomers() {
                    const searchTerm = document.getElementById('selectedSearch').value.toLowerCase();
                    const items = document.querySelectorAll('#selectedCustomersList .customer-item');

                    items.forEach(item => {
                        const text = item.innerText.toLowerCase();
                        if (text.includes(searchTerm)) {
                            item.style.display = 'flex';
                        } else {
                            item.style.display = 'none';
                        }
                    });

                    displaySelectedCustomers(selectedCustomers);
                }

                function updateSelectedCounts() {
                    document.getElementById('selectedCount').innerText = selectedCustomers.length;
                    document.getElementById('sendCount').innerText = selectedCustomers.length;
                }

                function updateSendButtonState() {
                    const sendBtn = document.getElementById('sendBulkBtn');
                    const singleBtn = document.getElementById('sendSingleBtn');

                    if (selectedCustomers.length === 1) {
                        sendBtn.style.display = 'inline-flex';
                        singleBtn.style.display = 'inline-flex';
                    } else if (selectedCustomers.length > 1) {
                        sendBtn.style.display = 'inline-flex';
                        singleBtn.style.display = 'none';
                    } else {
                        sendBtn.style.display = 'inline-flex';
                        singleBtn.style.display = 'none';
                    }
                }

                function updateBulkMessageTemplate() {
                    const type = document.getElementById('bulkMessageType').value;
                    let message = '';

                    switch(type) {
                        case 'received':
                            message = `📦 *تم استلام جهازك في الصيانة*

        مرحباً {اسم العميل}،

        تم استلام جهازك {الجهاز} بنجاح.
        كود المتابعة: {الكود}

        سنقوم بإعلامك بأي تحديثات.

        📞 01064211484
        📍 مركز الصيانة - Mobile Shop`;
                            break;

                        case 'inprogress':
                            message = `🔧 *تحديث حالة جهازك*

        مرحباً {اسم العميل}،

        جهازك {الجهاز} قيد الصيانة حالياً.

        سنخبرك فور الانتهاء.

        📞 01064211484`;
                            break;

                        case 'waiting':
                            message = `⏳ *تحديث حالة جهازك*

        مرحباً {اسم العميل}،

        جهازك {الجهاز} بانتظار قطع غيار.

        سيتم إعلامك فور توفرها.

        📞 01064211484`;
                            break;

                        case 'completed':
                            message = `✅ *تم اكتمال صيانة جهازك*

        مرحباً {اسم العميل}،

        تم الانتهاء من صيانة جهازك {الجهاز}.

        يمكنك القدوم لاستلامه.

        📞 01064211484`;
                            break;

                        case 'delivered':
                            message = `🎉 *تم تسليم الجهاز*

        مرحباً {اسم العميل}،

        تم تسليم جهازك {الجهاز}.

        نتمنى أن يكون بحالة جيدة.

        📞 01064211484`;
                            break;

                        case 'reminder':
                            message = `⏰ *تذكير*

        مرحباً {اسم العميل}،

        نذكرك بمتابعة جهازك {الجهاز}.
        كود المتابعة: {الكود}

        للاستفسار: 01064211484`;
                            break;

                        case 'promo':
                            message = `🎁 *عرض خاص*

        مرحباً {اسم العميل}،

        نقدم لكم أقوى العروض على الصيانة
        خصومات تصل إلى 20%

        📞 01064211484`;
                            break;

                        default:
                            message = document.getElementById('bulkMessageText').value;
                            break;
                    }

                    document.getElementById('bulkMessageText').value = message;
                }

                function previewBulkMessage() {
                    const message = document.getElementById('bulkMessageText').value;
                    const previewDiv = document.getElementById('messagePreview');
                    const previewContent = document.getElementById('previewContent');

                    if (selectedCustomers.length > 0) {
                        // تجربة مع أول عميل
                        const sampleCustomer = selectedCustomers[0];
                        let sampleMessage = message
                            .replace('{اسم العميل}', sampleCustomer.name)
                            .replace('{الجهاز}', sampleCustomer.device)
                            .replace('{الكود}', sampleCustomer.code);

                        previewContent.innerText = sampleMessage;
                    } else {
                        previewContent.innerText = message;
                    }

                    previewDiv.style.display = 'block';
                }

                function sendToSelectedCustomers() {
                    if (selectedCustomers.length === 0) {
                        alert('❌ الرجاء اختيار عميل واحد على الأقل');
                        return;
                    }

                    const message = document.getElementById('bulkMessageText').value;
                    if (!message.trim()) {
                        alert('❌ الرجاء كتابة الرسالة');
                        return;
                    }

                    const resultDiv = document.getElementById('bulkSendResult');
                    resultDiv.style.display = 'block';
                    resultDiv.className = 'alert alert-info';
                    resultDiv.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري فتح واتساب...';

                    // فتح واتساب لكل عميل في تبويب جديد
                    let successCount = 0;
                    let failCount = 0;

                    selectedCustomers.forEach((customer, index) => {
                        setTimeout(() => {
                            try {
                                let personalizedMessage = message
                                    .replace('{اسم العميل}', customer.name)
                                    .replace('{الجهاز}', customer.device)
                                    .replace('{الكود}', customer.code);

                                let phone = customer.phone.replace(/[^0-9]/g, '');
                                if (phone.startsWith('0')) {
                                    phone = '20' + phone.substring(1);
                                }

                                const url = `https://wa.me/${phone}?text=${encodeURIComponent(personalizedMessage)}`;
                                window.open(url, '_blank');
                                successCount++;
                            } catch (err) {
                                console.error('خطأ في فتح واتساب:', err);
                                failCount++;
                            }
                        }, index * 1000); // تأخير ثانية بين كل عملية فتح
                    });

                    resultDiv.className = 'alert alert-success';
                    resultDiv.innerHTML = `
                        <i class="fas fa-check-circle"></i>
                        تم فتح ${successCount} محادثة واتساب بنجاح
                        ${failCount > 0 ? `، فشل فتح ${failCount} محادثة` : ''}
                    `;
                }

                function sendToSingleCustomer() {
                    if (selectedCustomers.length !== 1) {
                        alert('❌ الرجاء اختيار عميل واحد فقط');
                        return;
                    }

                    const customer = selectedCustomers[0];
                    const message = document.getElementById('bulkMessageText').value;

                    if (!message.trim()) {
                        alert('❌ الرجاء كتابة الرسالة');
                        return;
                    }

                    let personalizedMessage = message
                        .replace('{اسم العميل}', customer.name)
                        .replace('{الجهاز}', customer.device)
                        .replace('{الكود}', customer.code);

                    let phone = customer.phone.replace(/[^0-9]/g, '');
                    if (phone.startsWith('0')) {
                        phone = '20' + phone.substring(1);
                    }

                    const url = `https://wa.me/${phone}?text=${encodeURIComponent(personalizedMessage)}`;
                    window.open(url, '_blank');

                    const resultDiv = document.getElementById('bulkSendResult');
                    resultDiv.style.display = 'block';
                    resultDiv.className = 'alert alert-success';
                    resultDiv.innerHTML = '<i class="fas fa-check-circle"></i> تم فتح محادثة واتساب';
                }

